---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/programs', label: 'Programs' },
  { href: '/donate', label: 'Donate' },
  { href: '/volunteer', label: 'Volunteer' },
  { href: '/contact', label: 'Contact' },
];
---

<!-- Mobile drawer backdrop -->
<div id="mobile-backdrop" class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm opacity-0 invisible pointer-events-none"></div>

<!-- Mobile drawer panel -->
<div id="mobile-drawer" class="fixed top-0 right-0 z-50 h-full w-72 sm:w-80 bg-canvas border-l border-hairline shadow-xl translate-x-full invisible overflow-y-auto">
  <div class="flex justify-end p-4">
    <button
      id="mobile-close-btn"
      type="button"
      class="p-2 text-steel hover:text-ink hover:bg-surface rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
      aria-label="Close menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <nav class="px-4 pb-8" aria-label="Mobile navigation">
    <div class="flex flex-col gap-1">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          style={`--delay: ${i * 50}ms`}
          class={`nav-link-stagger px-3 py-3 text-sm transition-colors rounded-full ${
            currentPath === link.href
              ? 'text-ink bg-surface font-medium'
              : 'text-steel hover:text-ink hover:bg-surface'
          }`}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="mt-6 pt-6 border-t border-hairline">
      <a
        href="/donate"
        class="flex items-center justify-center w-full px-5 py-3 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors"
      >
        Donate
      </a>
    </div>
  </nav>
</div>

<!-- Site header (scroll-aware) -->
<header id="site-header" class="sticky top-0 z-30 nav-visible border-b border-hairline">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-baseline gap-2" aria-label="Peace League Africa Home">
        <span class="text-lg font-semibold tracking-tight text-ink">Peace League</span>
        <span class="text-sm text-steel font-medium">Africa</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm transition-colors ${
              currentPath === link.href
                ? 'text-ink bg-surface font-medium rounded-full'
                : 'text-steel hover:text-ink hover:bg-surface rounded-full'
            }`}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop Right Side -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Dark Mode Toggle -->
        <button
          id="theme-toggle"
          type="button"
          class="w-8 h-8 flex items-center justify-center text-steel hover:text-ink hover:bg-surface rounded-full border border-hairline transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
          aria-label="Switch to dark mode"
        >
          <svg id="theme-sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg id="theme-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <a
          href="/donate"
          class="inline-flex items-center px-5 py-2 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
        >
          Donate
        </a>
      </div>

      <!-- Mobile buttons -->
      <div class="flex items-center gap-2 lg:hidden">
        <button
          id="theme-toggle-mobile"
          type="button"
          class="w-8 h-8 flex items-center justify-center text-steel hover:text-ink hover:bg-surface rounded-full border border-hairline transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
          aria-label="Switch to dark mode"
        >
          <svg id="theme-sun-mobile" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg id="theme-moon-mobile" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        <button
          type="button"
          id="mobile-menu-btn"
          class="p-2 text-steel hover:text-ink hover:bg-surface rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
          aria-expanded="false"
          aria-controls="mobile-drawer"
          aria-label="Open menu"
        >
          <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<script>
  // ── Mobile Drawer ──

  const menuBtn = document.getElementById('mobile-menu-btn');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('mobile-backdrop');
  const closeBtn = document.getElementById('mobile-close-btn');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  const staggerLinks = document.querySelectorAll('.nav-link-stagger');

  function openDrawer() {
    menuBtn.setAttribute('aria-expanded', 'true');
    menuBtn.setAttribute('aria-label', 'Close menu');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    backdrop?.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
    backdrop?.classList.add('opacity-100', 'visible', 'pointer-events-auto');
    drawer?.classList.add('open');
    document.body.classList.add('overflow-hidden');
    staggerLinks.forEach(el => {
      el.style.animation = 'none';
      el.classList.remove('animate');
      void el.offsetWidth;
      el.style.animation = '';
      el.classList.add('animate');
    });
  }

  function closeDrawer() {
    menuBtn.setAttribute('aria-expanded', 'false');
    menuBtn.setAttribute('aria-label', 'Open menu');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    backdrop?.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
    backdrop?.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    drawer?.classList.remove('open');
    document.body.classList.remove('overflow-hidden');
  }

  menuBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('open')) {
      closeDrawer();
    }
  });

  // ── Scroll-Aware Header ──

  let lastScrollY = 0;
  const header = document.getElementById('site-header');
  const scrollThreshold = 80;

  function onScroll() {
    const currentScrollY = window.scrollY;

    if (currentScrollY > scrollThreshold) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    if (currentScrollY > lastScrollY && currentScrollY > 120) {
      header?.classList.remove('nav-visible');
      header?.classList.add('nav-hidden');
    } else {
      header?.classList.remove('nav-hidden');
      header?.classList.add('nav-visible');
    }

    lastScrollY = currentScrollY;
  }

  window.addEventListener('scroll', onScroll, { passive: true });

  // ── Dark Mode Toggle ──

  function setupThemeToggle(btnId, sunId, moonId) {
    const btn = document.getElementById(btnId);
    const sun = document.getElementById(sunId);
    const moon = document.getElementById(moonId);

    if (!btn) return;

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      if (sun) sun.classList.toggle('hidden', !isDark);
      if (moon) moon.classList.toggle('hidden', isDark);
      btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }

    updateIcons();

    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();

      const icon = isDark ? sun : moon;
      if (icon) {
        icon.classList.remove('theme-icon-rotate');
        void icon.offsetWidth;
        icon.classList.add('theme-icon-rotate');
        setTimeout(() => icon.classList.remove('theme-icon-rotate'), 500);
      }
    });
  }

  setupThemeToggle('theme-toggle', 'theme-sun', 'theme-moon');
  setupThemeToggle('theme-toggle-mobile', 'theme-sun-mobile', 'theme-moon-mobile');
</script>
