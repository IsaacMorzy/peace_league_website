---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/programs', label: 'Programs' },
  { href: '/donate', label: 'Donate' },
  { href: '/volunteer', label: 'Volunteer' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-white border-b border-[#e5e5e5] sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-baseline gap-2" aria-label="Peace League Africa Home">
        <span class="text-lg font-semibold tracking-tight text-[#0a0a0a]">Peace League</span>
        <span class="text-sm text-[#5a5a5c] font-medium">Africa</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm transition-colors ${
              currentPath === link.href
                ? 'text-[#0a0a0a] bg-[#f7f7f7] font-medium rounded-full'
                : 'text-[#5a5a5c] hover:text-[#0a0a0a] hover:bg-[#f7f7f7] rounded-full'
            }`}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href="/donate"
          class="inline-flex items-center px-5 py-2 bg-[#0a0a0a] text-white text-sm font-medium rounded-full hover:bg-[#1c1c1e] transition-colors focus:outline-none focus:ring-2 focus:ring-[#00d4a4] focus:ring-offset-2"
        >
          Donate
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-[#5a5a5c] hover:text-[#0a0a0a] hover:bg-[#f7f7f7] rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-[#00d4a4]"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4" aria-label="Mobile navigation">
      <div class="flex flex-col gap-1 pt-2 border-t border-[#e5e5e5]">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-3 text-sm transition-colors ${
              currentPath === link.href
                ? 'text-[#0a0a0a] bg-[#f7f7f7] font-medium rounded-full'
                : 'text-[#5a5a5c] hover:text-[#0a0a0a] hover:bg-[#f7f7f7] rounded-full'
            }`}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <div class="mt-4 pt-4 border-t border-[#e5e5e5]">
          <a
            href="/donate"
            class="flex items-center justify-center w-full px-5 py-3 bg-[#0a0a0a] text-white text-sm font-medium rounded-full hover:bg-[#1c1c1e] transition-colors"
          >
            Donate
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';

    menuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenu?.classList.toggle('hidden');
    menuIconOpen?.classList.toggle('hidden');
    menuIconClose?.classList.toggle('hidden');

    document.body.classList.toggle('overflow-hidden');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      menuBtn?.click();
    }
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('header') && !mobileMenu?.classList.contains('hidden')) {
      menuBtn?.click();
    }
  });
</script>
