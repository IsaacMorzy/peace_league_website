    var shouldHandoff = false;
    var department = 'general';

    // Check handoff triggers
    for (var i = 0; i < handoffTriggers.length; i++) {
      if (text.includes(handoffTriggers[i])) {
        shouldHandoff = true;
        break;
      }
    }

    // Try Gemini first
    if (CONFIG.geminiApiKey) {
      var aiResponse = await callGemini(message);
      if (aiResponse) {
        response = aiResponse;
        if (text.match(/donate|donation|give|money/)) department = 'fundraising';
        else if (text.match(/volunteer|help|join/)) department = 'volunteer-coordination';
        else if (text.match(/partner|partnership/)) department = 'partnerships';
        else if (text.match(/event|workshop|summit/)) department = 'events';
      }
    }

    // Fallback to keyword matching
    if (!response) {
      for (var key in keywords) {
        if (new RegExp(keywords[key], 'i').test(text)) {
          response = responses[key];
          if (key === 'donate') department = 'fundraising';
          else if (key === 'volunteer') department = 'volunteer-coordination';
          else if (key === 'partner') department = 'partnerships';
          else if (key === 'events') department = 'events';
          break;
        }
      }
    }

    if (!response) {
      response = shouldHandoff ? "I understand you need specialized assistance. Let me connect you with the right team member who can help you better." : "I can help with donations, volunteering, events, partnerships, and general information about Peace League Africa. What would you like to know?";
    }

    return { response: response, shouldHandoff: shouldHandoff, department: department };
  }

  // ══════════════════════════════════════════
  // AGENT ROUTING
  // ══════════════════════════════════════════
  var agentRoutes = {
    '/donate': { dept: 'fundraising', msg: "Hi! 👋 I see you're interested in supporting our mission. I can help you find the perfect way to make a difference — whether it's a one-time gift, monthly sponsorship, or corporate giving. What would you like to know?" },
    '/volunteer': { dept: 'volunteer-coordination', msg: "Welcome, future peacebuilder! 🌍 I can help you find the perfect volunteer opportunity based on your skills and interests. We have roles in teaching, healthcare, communications, and more. What skills do you have?" },
    '/events': { dept: 'events', msg: "Looking for an event to attend? 📅 I can tell you about our upcoming summits, workshops, and community gatherings. Most are free or low-cost. Would you like me to recommend an event based on your interests?" },
    '/events/': { dept: 'events', msg: "I see you're checking out this event! 🎉 I can help with registration, answer questions about the schedule, or tell you what to expect. What would you like to know?" },
    '/contact': { dept: 'general', msg: "How can we help you today? 📞 Our team is ready to assist with donations, volunteering, partnerships, or any questions about our work across Africa." },
    '/partner': { dept: 'partnerships', msg: "Interested in partnering with Peace League Africa? 🤝 I can help you explore collaboration opportunities. We work with NGOs, governments, corporations, and community organizations. What type of partnership are you considering?" },
    '/causes': { dept: 'programs', msg: "Our programs are making a real difference! 🌟 From peace education in 45+ schools to clean water projects serving 30,000+ people, there are many ways to support. Which cause speaks to you?" },
    '/careers': { dept: 'hr', msg: "Looking to join our team? 💼 I can answer questions about open positions, our culture, and what it's like to work at Peace League Africa. What role interests you?" },
    '/blog': { dept: 'communications', msg: "Enjoying our stories? 📝 I can help you subscribe to our newsletter, share articles, or find specific topics. What caught your interest?" },
    '/about': { dept: 'general', msg: "Want to learn more about Peace League Africa? 🌍 I can share our story, mission, impact, and how you can be part of our journey. What would you like to know?" },
    '/team': { dept: 'general', msg: "Our team is passionate about peace! 👥 I can help you connect with the right person for your inquiry. Who would you like to reach?" },
    '/gallery': { dept: 'communications', msg: "Beautiful moments of peace! 📸 Want to see more, share your own photos, or use our images for a project? I can help with that." }
  };

  // ══════════════════════════════════════════
  // ANALYTICS TRACKER
  // ══════════════════════════════════════════
  var analytics = {
    events: [],
    track: function(event, data) {
      this.events.push({ event: event, data: data, timestamp: Date.now() });
      if (CONFIG.analytics && window.Libredesk && window.Libredesk.sendMessage) {
        window.Libredesk.sendMessage({ type: 'event', event: event, data: data });
      }
      localStorage.setItem('pleague-analytics', JSON.stringify(this.events.slice(-50)));
    },
    getMetrics: function() {
      return {
        totalMessages: state.messagesSent,
        conversationDuration: Math.round((Date.now() - state.startTime) / 1000),
        leadCaptured: state.leadCaptured,
        appointmentRequested: state.appointmentRequested,
        department: state.department,
        events: this.events.length,
        topicsDiscussed: [...new Set(state.conversationHistory.map(m => m.content.substring(0, 50)))]
      };
    }
  };

  try {
    var savedAnalytics = localStorage.getItem('pleague-analytics');
    if (savedAnalytics) analytics.events = JSON.parse(savedAnalytics);
  } catch(e) {}

  // ══════════════════════════════════════════
  // MULTI-LANGUAGE SUPPORT
  // ══════════════════════════════════════════
  var translations = {
    en: { greeting: "Hello! I'm Peace Bot. How can I help you today?", fallback: "I can help with donations, volunteering, events, and more." },
    fr: { greeting: "Bonjour! Je suis Peace Bot. Comment puis-je vous aider aujourd'hui?", fallback: "Je peux aider avec les dons, le bénévolat, les événements et plus encore." },
    es: { greeting: "¡Hola! Soy Peace Bot. ¿Cómo puedo ayudarte hoy?", fallback: "Puedo ayudar con donaciones, voluntariado, eventos y más." },
    pt: { greeting: "Olá! Sou o Peace Bot. Como posso ajudá-lo hoje?", fallback: "Posso ajudar com doações, voluntariado, eventos e mais." },
    de: { greeting: "Hallo! Ich bin Peace Bot. Wie kann ich Ihnen heute helfen?", fallback: "Ich kann bei Spenden, Freiwilligenarbeit, Veranstaltungen und mehr helfen." },
    it: { greeting: "Ciao! Sono Peace Bot. Come posso aiutarti oggi?", fallback: "Posso aiutare con donazioni, volontariato, eventi e altro." },
    ar: { greeting: "مرحباً! أنا Peace Bot. كيف يمكنني مساعدتك اليوم؟", fallback: "يمكنني المساعدة في التبرعات والتطوع والفعاليات والمزيد." },
    zh: { greeting: "你好！我是 Peace Bot。今天我能帮你什么？", fallback: "我可以帮助您了解捐赠、志愿服务、活动等信息。" },
    ja: { greeting: "こんにちは！Peace Botです。今日はどのようにお手伝いできますか？", fallback: "寄付、ボランティア、イベントなどについてお手伝いできます。" },
    ko: { greeting: "안녕하세요! Peace Bot입니다. 오늘 무엇을 도와드릴까요?", fallback: "기부, 봉사활동, 이벤트 등에 대해 도움을 드릴 수 있습니다." },
    hi: { greeting: "नमस्ते! मैं Peace Bot हूँ। आज मैं आपकी कैसे मदद कर सकता हूँ?", fallback: "मैं दान, स्वयंसेवा, कार्यक्रमों और बहुत कुछ में मदद कर सकता हूँ।" },
    ru: { greeting: "Здравствуйте! Я Peace Bot. Чем я могу помочь вам сегодня?", fallback: "Я могу помочь с пожертвованиями, волонтерством, мероприятиями и многим другим." },
    sw: { greeting: "Habari! Mimi ni Peace Bot. Nikisaidiaje leo?", fallback: "Ninaweza kusaidia na michango, kujitolea, matukio, na mengi zaidi." },
    am: { greeting: "ሰላም! እኔ ፒስ ቦት ነኝ. ዛሬ እንዴት ልረዳዎ?", fallback: "በ捐助፣ በ voluntarism፣ በክስተቶች እና በተጨማሪ ነገሮች ልረዳዎ ይችላል።" },
    rw: { greeting: "Amakuru! Ndi Peace Bot. Nshobora kukugira iki uyu munsi?", fallback: "Nshobora gufasha mu buryo bwo gutanga, gukorerabushake, nibindi." },
    lg: { greeting: "Nkulamisa! Nze Peace Bot. Njogera n'akiiki lero?", fallback: "Njogera okuyamba ku mpano, okuwumulira, n'ebintu ebirala." },
    ha: { greeting: "Sannu! Ni Peace Bot. Yaya zan taimaka a yau?", fallback: "Zan iya taimaka da bayar da gudummawa, aikin yi, tarurruwa, da ƙari." },
    yo: { greeting: "Bawo ni! Mi ni Peace Bot. Bawo ni le mo le ran se?", fallback: "Mo le ran se pẹlu awọn奉献, iṣura, iṣẹlẹ, ati bii bee loke." },
    ig: { greeting: "Ndewo! Abụ m Peace Bot. Kedu ka m nyere gị aka taa?", fallback: "Enwere m ike inyere gị aka n'ntụgo, ochikwa, mbibi, na ọzọ." }
  };

  function detectLanguage(text) {
    if (text.match(/[ሀ-፿]/)) return 'am'; // Amharic
    if (text.match(/[Ѐ-ӿ]/)) return 'ru'; // Russian
    if (text.match(/[؀-ۿ]/)) return 'ar'; // Arabic
    if (text.match(/[一-鿿]/)) return 'zh'; // Chinese
    if (text.match(/[぀-ゟ゠-ヿ]/)) return 'ja'; // Japanese
    if (text.match(/[가-힯]/)) return 'ko'; // Korean
    if (text.match(/[ऀ-ॿ]/)) return 'hi'; // Hindi
    if (text.match(/[ñáéíóúü]/i)) return 'es';
    if (text.match(/[àâçéèêëîïôùûüÿœæ]/i)) return 'fr';
    if (text.match(/[äöüß]/i)) return 'de';
    if (text.match(/\b(ndi|nshobora|amakuru)\b/i)) return 'rw'; // Kinyarwanda
    if (text.match(/\b(nkulamisa|njogera|kiiki)\b/i)) return 'lg'; // Luganda
    if (text.match(/\b(habari|nikisaidia|pole)\b/i)) return 'sw'; // Swahili
    if (text.match(/\b(sannu|yaya|taimaka)\b/i)) return 'ha'; // Hausa
    if (text.match(/\b(bawo|ranse|isele)\b/i)) return 'yo'; // Yoruba
    if (text.match(/\b(ndewo|ochikwa|mbibi)\b/i)) return 'ig'; // Igbo
    return 'en';
  }

  // ══════════════════════════════════════════
  // MAIN INITIALIZATION
  // ══════════════════════════════════════════
  function waitForLibredesk(callback, maxWait) {
    maxWait = maxWait || 10000;
    var start = Date.now();
    function check() {
      if (window.Libredesk && window.Libredesk.show) {
        callback();
      } else if (Date.now() - start < maxWait) {
        setTimeout(check, 200);
      }
    }
    check();
  }

  waitForLibredesk(function() {
    var page = window.location.pathname;

    // 1. Agent routing
    for (var route in agentRoutes) {
      if (page === route || page.startsWith(route)) {
        state.department = agentRoutes[route].dept;
        sessionStorage.setItem('libredesk-department', state.department);
        setTimeout(function() {
          window.Libredesk.sendMessage && window.Libredesk.sendMessage({ type: 'proactive', message: agentRoutes[route].msg });
        }, CONFIG.proactiveDelay);
        break;
      }
    }

    // 2. Auto-open after delay
    setTimeout(function() {
      if (!sessionStorage.getItem('libredesk-dismissed')) {
        window.Libredesk.show();
      }
    }, CONFIG.autoOpenDelay);

    window.Libredesk.onHide(function() {
      sessionStorage.setItem('libredesk-dismissed', '1');
      analytics.track('conversation_end', analytics.getMetrics());
    });

    // 3. User data from forms
    document.querySelectorAll('form[id*="booking"], form[id*="reg-"], form[id*="partner"], form[id*="volunteer"], form[id*="contact"]').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        var formData = new FormData(form);
        var userData = {
          name: formData.get('name') || '',
          email: formData.get('email') || '',
          phone: formData.get('phone') || '',
          company: formData.get('organization') || '',
          department: state.department
        };
        if (userData.name || userData.email) {
          window.Libredesk.setUser && window.Libredesk.setUser(userData);
          localStorage.setItem('pleague-user', JSON.stringify(userData));
          state.user = userData;
          state.leadCaptured = true;
          analytics.track('user_data_captured', { source: form.id });
        }
      });
    });

    if (state.user) {
      window.Libredesk.setUser && window.Libredesk.setUser(state.user);
    }

    // 4. Event tracking
    document.querySelectorAll('form[id*="volunteer"]').forEach(function(f) {
      f.addEventListener('submit', function() { setTimeout(function() { analytics.track('volunteer_signup'); }, 500); });
    });
    document.querySelectorAll('form[id*="contact"]').forEach(function(f) {
      f.addEventListener('submit', function() { setTimeout(function() { analytics.track('contact_form_submit'); }, 500); });
    });
    document.querySelectorAll('form[id*="booking"], form[id*="reg-"]').forEach(function(f) {
      f.addEventListener('submit', function() { setTimeout(function() { analytics.track('event_registration'); }, 500); });
    });
    if (page === '/donate') {
      setTimeout(function() { analytics.track('donate_page_view'); }, 3000);
    }

    // 5. Smart agent responses
    window.Libredesk.onMessage && window.Libredesk.onMessage(async function(msg) {
      if (msg.sender === 'user') {
        state.messagesSent++;
        state.conversationHistory.push({ role: 'user', content: msg.text });
        analytics.track('user_message', { text: msg.text.substring(0, 100) });

        var result = await getResponse(msg.text);

        if (result.shouldHandoff) {
          window.Libredesk.sendMessage && window.Libredesk.sendMessage({
            type: 'handoff',
            department: result.department,
            reason: 'User needs human assistance'
          });
          analytics.track('handoff_triggered', { department: result.department });
        }
      }
    });

    // 6. Unread count badge
    window.Libredesk.onUnreadCountChange && window.Libredesk.onUnreadCountChange(function(count) {
      var badge = document.getElementById('chat-unread-badge');
      if (badge) {
        badge.textContent = count;
        badge.classList.toggle('hidden', count === 0);
      }
    });

    // 7. Page context
    if (page === '/donate') sessionStorage.setItem('libredesk-context', 'donor');
    if (page === '/volunteer') sessionStorage.setItem('libredesk-context', 'volunteer');
    if (page.startsWith('/events/')) sessionStorage.setItem('libredesk-context', 'attendee');

    // Save state
    localStorage.setItem('pleague-chat-state', JSON.stringify(state));

    // Expose API
    window.PLAChat = {
      getState: function() { return state; },
      getAnalytics: function() { return analytics.getMetrics(); },
      trackEvent: function(event, data) { analytics.track(event, data); },
      captureLead: function(data) { state.leadCaptured = true; state.user = data; localStorage.setItem('pleague-user', JSON.stringify(data)); },
      requestAppointment: function(data) { state.appointmentRequested = true; analytics.track('appointment_requested', data); },
      detectLanguage: detectLanguage,
      translate: function(text, lang) { return translations[lang]?.greeting || text; },
      getPrograms: function() { return KB.programs; },
      getCountries: function() { return KB.countries; },
      getDonationImpact: function() { return KB.donations.impact; }
    };

    console.log('Peace Bot initialized with Gemini AI. Use PLAChat to interact.');
  });
})();
</script>
