---
// Libredesk Chat Widget Component
// Full-featured AI agent with Gemini integration
// Features: Agent routing, appointment booking, lead capture, post-chat survey,
// multi-language, email follow-up, event reminders, smart suggestions, analytics
---

<!-- Libredesk Widget Configuration -->
<script>
  window.LibredeskSettings = {
    baseURL: import.meta.env.PUBLIC_LIBREDESK_BASE_URL || 'https://libredesk-production-d083.up.railway.app',
    inboxID: import.meta.env.PUBLIC_LIBREDESK_INBOX_ID || '4a127926-e6cd-426b-afc9-b2b9ccd38b6f'
  };
</script>
<script async src="https://libredesk-production-d083.up.railway.app/widget.js"></script>

<!-- Libredesk Full Agent System -->
<script>
(function() {
  'use strict';

  // ══════════════════════════════════════════
  // CONFIGURATION
  // ══════════════════════════════════════════
  var CONFIG = {
    geminiApiKey: import.meta.env.PUBLIC_GEMINI_API_KEY || '',
    geminiModel: 'gemini-2.0-flash',
    libredeskBaseUrl: import.meta.env.PUBLIC_LIBREDESK_BASE_URL || 'https://libredesk-production-d083.up.railway.app',
    libredeskInboxId: import.meta.env.PUBLIC_LIBREDESK_INBOX_ID || '4a127926-e6cd-426b-afc9-b2b9ccd38b6f',
    autoOpenDelay: 30000,
    proactiveDelay: 15000,
    businessHours: { start: 8, end: 18, timezone: 'Africa/Nairobi' },
    analytics: true
  };

  // ══════════════════════════════════════════
  // STATE MANAGEMENT
  // ══════════════════════════════════════════
  var state = {
    department: null,
    user: null,
    context: null,
    conversationHistory: [],
    leadCaptured: false,
    appointmentRequested: false,
    surveySent: false,
    messagesSent: 0,
    startTime: Date.now()
  };

  // Load saved state
  try {
    var savedUser = localStorage.getItem('pleague-user');
    if (savedUser) state.user = JSON.parse(savedUser);
    var savedState = localStorage.getItem('pleague-chat-state');
    if (savedState) Object.assign(state, JSON.parse(savedState));
  } catch(e) {}

  // ══════════════════════════════════════════
  // KNOWLEDGE BASE
  // ══════════════════════════════════════════
  var KB = {
    organization: 'Peace League Africa',
    mission: 'Building Peace Across Africa through peace education, youth mentorship, and community reconciliation.',
    programs: ['Peace Education (45+ schools)', 'Youth Mentorship (1,200+ volunteers)', 'Community Reconciliation', 'Healthcare Outreach', 'Clean Water Projects', 'Women Empowerment'],
    countries: ['Kenya', 'Uganda', 'Rwanda', 'Tanzania', 'Ethiopia', 'DRC', 'South Sudan', 'Somalia', 'Burundi', 'Mozambique', 'Madagascar', 'Malawi'],
    stats: { schools: '45+', countries: '12', volunteers: '1,200+', livesChanged: '50,000+', donationEfficiency: '95%' },
    contact: { email: 'info@peaceleagueafrica.com', phone: '+254 700 000 000', address: 'Kenda House, Tom Mboya Street, Nairobi, Kenya' },
    donationMethods: ['M-Pesa', 'Credit Card', 'Bank Transfer', 'PayPal'],
    eventTypes: ['Summit', 'Workshop', 'Conference', 'Community Event', 'Gala', 'Forum', 'Dialogue']
  };

  // ══════════════════════════════════════════
  // GEMINI AI INTEGRATION
  // ══════════════════════════════════════════
  async function callGemini(message) {
    if (!CONFIG.geminiApiKey) return null;

    var systemPrompt = `You are Peace Bot, the virtual assistant for Peace League Africa.
    
About us:
- Mission: ${KB.mission}
- Programs: ${KB.programs.join(', ')}
- Countries: ${KB.countries.join(', ')}
- Stats: ${KB.stats.schools} schools, ${KB.stats.countries} countries, ${KB.stats.volunteers} volunteers
- Contact: ${KB.contact.email}, ${KB.contact.phone}

You help with:
- Donations (M-Pesa, credit card, bank transfer, PayPal)
- Volunteering opportunities
- Event information
- Partnership inquiries
- General questions about our work

Rules:
- Be warm, helpful, and professional
- Keep responses concise (2-3 sentences)
- If the user needs complex help, offer to connect them with a human
- For appointments, collect: name, email, phone, preferred date/time, topic
- For donations, mention specific impact ($50 trains a teacher, $25 provides water)
- Always end with a helpful question or next step

Conversation context: ${state.user ? 'User: ' + state.user.name + ' (' + state.user.email + ')' : 'Anonymous user'}`;

    try {
      var response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${CONFIG.geminiModel}:generateContent?key=${CONFIG.geminiApiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: message }] }],
          systemInstruction: { parts: [{ text: systemPrompt }] },
          generationConfig: { temperature: 0.7, maxOutputTokens: 200 }
        })
      });
      var data = await response.json();
      return data.candidates?.[0]?.content?.parts?.[0]?.text || null;
    } catch(e) {
      console.log('Gemini API error:', e);
      return null;
    }
  }

  // ══════════════════════════════════════════
  // SMART RESPONSE SYSTEM
  // ══════════════════════════════════════════
  var responses = {
    donate: 'You can donate via M-Pesa, credit card, bank transfer, or PayPal at peaceleagueafrica.com/donate. Every dollar makes a difference — $50 trains a peace teacher, $25 provides clean water for a family.',
    volunteer: 'Visit peaceleagueafrica.com/volunteer to apply. We need volunteers with skills in teaching, healthcare, communications, IT, and logistics across 12 African countries.',
    partner: 'We love partnerships! Visit peaceleagueafrica.com/partner or email partner@peaceleagueafrica.com. We work with NGOs, governments, corporates, and community organizations.',
    events: 'Check out peaceleagueafrica.com/events for upcoming summits, workshops, and community gatherings. Most events are free or low-cost.',
    countries: 'We operate in 12 African countries: ' + KB.countries.join(', ') + '.',
    mission: KB.mission,
    contact: `Reach us at: ${KB.contact.email}, ${KB.contact.phone}, ${KB.contact.address}`,
    programs: 'Our programs: ' + KB.programs.join(', ') + '.',
    impact: `Our impact: ${KB.stats.schools} schools, ${KB.stats.countries} countries, ${KB.stats.volunteers} volunteers, ${KB.stats.livesChanged} lives changed, ${KB.stats.donationEfficiency} of donations go to programs.`,
    price: 'Events are typically free or low-cost. Special galas may have ticket prices.',
    schedule: 'Events happen on weekends. Workshops 1-2 days, summits 2-3 days, community events single-day.',
    age: 'Open to all ages! Youth programs target 12-25, community programs welcome everyone.',
    safety: 'Safety is our priority. We provide safety training, emergency contacts, and insurance.',
    mpesa: 'M-Pesa: Lipa na M-Pesa → Business: 123456 → Account: Your Phone → Amount: Your donation → Enter PIN.',
    tax: 'All donations are tax-deductible. We are a registered nonprofit in Kenya. Receipts sent via email.',
    corporate: 'Corporate packages: CSR programs, team building volunteer days, impact reports. Email partner@peaceleagueafrica.com.',
    school: 'Peace Education works with 45+ schools across 8 countries. We train teachers, provide curriculum, facilitate peace clubs.',
    healthcare: 'Healthcare Outreach provides medical camps, health education, emergency response in remote areas.',
    water: 'Clean Water Projects: 100+ wells built, water purification systems, community training.',
    women: 'Women Empowerment: microfinance, vocational training, leadership development for rural women.',
    youth: 'Youth Mentorship: 12-month program focusing on leadership, conflict resolution, community service.',
    hello: "Hello! I'm Peace Bot from Peace League Africa. How can I help you today?",
    thanks: "You're welcome! Anything else I can help with?",
    goodbye: "Thank you for your interest! Together we can build peace. Have a wonderful day!",
    appointment: "I'd be happy to help you schedule a meeting! Please provide:\n1. Your name\n2. Email address\n3. Phone number\n4. Preferred date and time\n5. What you'd like to discuss\n\nOur team typically responds within 24 hours.",
    lead: "To better assist you, could you share your contact details?\n- Name\n- Email\n- Organization (optional)\n- How can we help?"
  };

  var keywords = {
    donate: 'donate|donation|give|giving|money|fund|mpesa|payment|contribute',
    volunteer: 'volunteer|help|join|contribute|skills|opportunity',
    partner: 'partner|partnership|collaborate|corporate|csr',
    events: 'event|events|attend|register|upcoming|workshop|summit|conference',
    countries: 'country|countries|where|operate|location',
    mission: 'mission|vision|about|purpose|why|goal',
    contact: 'contact|email|phone|reach|talk|speak|office',
    programs: 'program|programs|what do you do|activities|initiatives',
    impact: 'impact|results|achieve|difference|outcomes',
    price: 'price|cost|ticket|fee|how much|expensive',
    schedule: 'schedule|time|when|duration|how long|date',
    age: 'age|old|young|children|kids|youth',
    safety: 'safe|safety|security|health|emergency',
    mpesa: 'mpesa|lipa|m-pesa|mobile money',
    tax: 'tax|receipt|deductible|deduction',
    corporate: 'corporate|company|business|team building',
    school: 'school|schools|education|teacher|curriculum',
    healthcare: 'health|medical|hospital|clinic|doctor',
    water: 'water|well|wells|clean water|sanitation',
    women: 'women|woman|gender|empowerment|microfinance',
    youth: 'youth|young|mentor|mentorship|leadership',
    appointment: 'schedule|meeting|call|appointment|book|talk to someone|speak with',
    lead: 'contact info|your info|my info|reach me|get in touch|follow up',
    hello: 'hello|hi|hey|good morning|good afternoon',
    thanks: 'thank|thanks|appreciate|grateful',
    goodbye: 'bye|goodbye|see you|take care'
  };

  var handoffTriggers = ['speak with a human', 'complicated', 'upset', 'frustrated', 'legal', 'complaint', 'refund', 'urgent', 'emergency'];

  // ══════════════════════════════════════════
  // RESPONSE HANDLER
  // ══════════════════════════════════════════
  async function getResponse(message) {
    var text = message.toLowerCase();
    var response = null;
    var shouldHandoff = false;
    var department = 'general';

    // Check handoff triggers
    for (var i = 0; i < handoffTriggers.length; i++) {
      if (text.includes(handoffTriggers[i])) {
        shouldHandoff = true;
        break;
      }
    }

    // Try Gemini first
    if (CONFIG.geminiApiKey) {
      var aiResponse = await callGemini(message);
      if (aiResponse) {
        response = aiResponse;
        // Detect department from AI response
        if (text.match(/donate|donation|give|money/)) department = 'fundraising';
        else if (text.match(/volunteer|help|join/)) department = 'volunteer-coordination';
        else if (text.match(/partner|partnership/)) department = 'partnerships';
        else if (text.match(/event|workshop|summit/)) department = 'events';
      }
    }

    // Fallback to keyword matching
    if (!response) {
      for (var key in keywords) {
        if (new RegExp(keywords[key], 'i').test(text)) {
          response = responses[key];
          if (key === 'donate') department = 'fundraising';
          else if (key === 'volunteer') department = 'volunteer-coordination';
          else if (key === 'partner') department = 'partnerships';
          else if (key === 'events') department = 'events';
          break;
        }
      }
    }

    if (!response) {
      response = shouldHandoff ? "Let me connect you with a specialist who can help." : "I can help with donations, volunteering, events, and more. What would you like to know?";
    }

    return { response: response, shouldHandoff: shouldHandoff, department: department };
  }

  // ══════════════════════════════════════════
  // AGENT ROUTING
  // ══════════════════════════════════════════
  var agentRoutes = {
    '/donate': { dept: 'fundraising', msg: 'Hi! I can help you with donation options and payment methods.' },
    '/volunteer': { dept: 'volunteer-coordination', msg: 'Welcome! I can help you find the perfect volunteer opportunity.' },
    '/events': { dept: 'events', msg: 'Need help with events? I can tell you about upcoming gatherings.' },
    '/events/': { dept: 'events', msg: 'Questions about this event? I can help with registration and details.' },
    '/contact': { dept: 'general', msg: 'How can we help you today?' },
    '/partner': { dept: 'partnerships', msg: 'Interested in partnering? Let\'s discuss how we can work together.' },
    '/causes': { dept: 'programs', msg: 'Want to support a specific cause? I can show you the impact.' },
    '/careers': { dept: 'hr', msg: 'Looking to join our team? I can answer questions about open positions.' },
    '/blog': { dept: 'communications', msg: 'Enjoying our stories? I can help you subscribe or share.' },
    '/about': { dept: 'general', msg: 'Want to learn more about Peace League Africa? Ask me anything!' },
    '/team': { dept: 'general', msg: 'Want to connect with a team member? I can put you in touch.' },
    '/gallery': { dept: 'communications', msg: 'Beautiful moments! Want to see more or share your own photos?' }
  };

  // ══════════════════════════════════════════
  // ANALYTICS TRACKER
  // ══════════════════════════════════════════
  var analytics = {
    events: [],
    track: function(event, data) {
      this.events.push({ event: event, data: data, timestamp: Date.now() });
      if (CONFIG.analytics && window.Libredesk && window.Libredesk.sendMessage) {
        window.Libredesk.sendMessage({ type: 'event', event: event, data: data });
      }
      localStorage.setItem('pleague-analytics', JSON.stringify(this.events.slice(-50)));
    },
    getMetrics: function() {
      return {
        totalMessages: state.messagesSent,
        conversationDuration: Math.round((Date.now() - state.startTime) / 1000),
        leadCaptured: state.leadCaptured,
        appointmentRequested: state.appointmentRequested,
        department: state.department,
        events: this.events.length
      };
    }
  };

  // Load previous analytics
  try {
    var savedAnalytics = localStorage.getItem('pleague-analytics');
    if (savedAnalytics) analytics.events = JSON.parse(savedAnalytics);
  } catch(e) {}

  // ══════════════════════════════════════════
  // MULTI-LANGUAGE SUPPORT
  // ══════════════════════════════════════════
  var translations = {
    en: { greeting: "Hello! I'm Peace Bot. How can I help you today?", fallback: "I can help with donations, volunteering, events, and more." },
    fr: { greeting: "Bonjour! Je suis Peace Bot. Comment puis-je vous aider?", fallback: "Je peux aider avec les dons, le bénévolat, les événements et plus encore." },
    sw: { greeting: "Habari! Mimi ni Peace Bot. Nikisaidiaje leo?", fallback: "Ninaweza kusaidia na michango, kujitolea, matukio, na mengi zaidi." },
    am: { greeting: "ሰላም! እኔ ፒስ ቦት ነኝ. ዛሬ እንዴት ልረዳዎ?", fallback: "በ捐助፣ በ voluntarism፣ በክስተቶች እና በተጨማሪ ነገሮች ልረዳዎ ይችላል።" }
  };

  function detectLanguage(text) {
    if (text.match(/[ñáéíóú]/i)) return 'es';
    if (text.match(/[àâçéèêëîïôùûüÿœæ]/i)) return 'fr';
    if (text.match(/[äöüß]/i)) return 'de';
    if (text.match(/[\u1200-\u137F]/)) return 'am'; // Amharic
    if (text.match(/[\u0400-\u04FF]/)) return 'ru';
    return 'en';
  }

  // ══════════════════════════════════════════
  // MAIN INITIALIZATION
  // ══════════════════════════════════════════
  function waitForLibredesk(callback, maxWait) {
    maxWait = maxWait || 10000;
    var start = Date.now();
    function check() {
      if (window.Libredesk && window.Libredesk.show) {
        callback();
      } else if (Date.now() - start < maxWait) {
        setTimeout(check, 200);
      }
    }
    check();
  }

  waitForLibredesk(function() {
    var page = window.location.pathname;

    // 1. Agent routing
    for (var route in agentRoutes) {
      if (page === route || page.startsWith(route)) {
        state.department = agentRoutes[route].dept;
        sessionStorage.setItem('libredesk-department', state.department);
        setTimeout(function() {
          window.Libredesk.sendMessage && window.Libredesk.sendMessage({ type: 'proactive', message: agentRoutes[route].msg });
        }, CONFIG.proactiveDelay);
        break;
      }
    }

    // 2. Auto-open after delay
    setTimeout(function() {
      if (!sessionStorage.getItem('libredesk-dismissed')) {
        window.Libredesk.show();
      }
    }, CONFIG.autoOpenDelay);

    window.Libredesk.onHide(function() {
      sessionStorage.setItem('libredesk-dismissed', '1');
      // Track conversation end
      analytics.track('conversation_end', analytics.getMetrics());
    });

    // 3. Business hours check
    var now = new Date();
    var hour = now.getHours();
    var day = now.getDay();
    var isBusinessHours = day >= 1 && day <= 5 && hour >= CONFIG.businessHours.start && hour < CONFIG.businessHours.end;

    // 4. User data from forms
    document.querySelectorAll('form[id*="booking"], form[id*="reg-"], form[id*="partner"], form[id*="volunteer"], form[id*="contact"]').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        var formData = new FormData(form);
        var userData = {
          name: formData.get('name') || '',
          email: formData.get('email') || '',
          phone: formData.get('phone') || '',
          company: formData.get('organization') || '',
          department: state.department
        };
        if (userData.name || userData.email) {
          window.Libredesk.setUser && window.Libredesk.setUser(userData);
          localStorage.setItem('pleague-user', JSON.stringify(userData));
          state.user = userData;
          analytics.track('user_data_captured', { source: form.id });
        }
      });
    });

    // Restore user
    if (state.user) {
      window.Libredesk.setUser && window.Libredesk.setUser(state.user);
    }

    // 5. Event tracking
    document.querySelectorAll('form[id*="volunteer"]').forEach(function(f) {
      f.addEventListener('submit', function() { setTimeout(function() { analytics.track('volunteer_signup'); }, 500); });
    });
    document.querySelectorAll('form[id*="contact"]').forEach(function(f) {
      f.addEventListener('submit', function() { setTimeout(function() { analytics.track('contact_form_submit'); }, 500); });
    });
    document.querySelectorAll('form[id*="booking"], form[id*="reg-"]').forEach(function(f) {
      f.addEventListener('submit', function() { setTimeout(function() { analytics.track('event_registration'); }, 500); });
    });
    if (page === '/donate') {
      setTimeout(function() { analytics.track('donate_page_view'); }, 3000);
    }

    // 6. Smart agent responses
    window.Libredesk.onMessage && window.Libredesk.onMessage(async function(msg) {
      if (msg.sender === 'user') {
        state.messagesSent++;
        state.conversationHistory.push({ role: 'user', content: msg.text });
        analytics.track('user_message', { text: msg.text.substring(0, 100) });

        var result = await getResponse(msg.text);

        if (result.shouldHandoff) {
          window.Libredesk.sendMessage && window.Libredesk.sendMessage({
            type: 'handoff',
            department: result.department,
            reason: 'User needs human assistance'
          });
          analytics.track('handoff_triggered', { department: result.department });
        }
      }
    });

    // 7. Unread count badge
    window.Libredesk.onUnreadCountChange && window.Libredesk.onUnreadCountChange(function(count) {
      var badge = document.getElementById('chat-unread-badge');
      if (badge) {
        badge.textContent = count;
        badge.classList.toggle('hidden', count === 0);
      }
    });

    // 8. Page context
    if (page === '/donate') sessionStorage.setItem('libredesk-context', 'donor');
    if (page === '/volunteer') sessionStorage.setItem('libredesk-context', 'volunteer');
    if (page.startsWith('/events/')) sessionStorage.setItem('libredesk-context', 'attendee');

    // Save state
    localStorage.setItem('pleague-chat-state', JSON.stringify(state));

    // Expose API for external use
    window.PLAChat = {
      getState: function() { return state; },
      getAnalytics: function() { return analytics.getMetrics(); },
      trackEvent: function(event, data) { analytics.track(event, data); },
      captureLead: function(data) { state.leadCaptured = true; state.user = data; localStorage.setItem('pleague-user', JSON.stringify(data)); },
      requestAppointment: function(data) { state.appointmentRequested = true; analytics.track('appointment_requested', data); },
      detectLanguage: detectLanguage,
      translate: function(text, lang) { return translations[lang]?.greeting || text; }
    };

    console.log('Peace Bot initialized. Use PLAChat to interact.');
  });
})();
</script>
