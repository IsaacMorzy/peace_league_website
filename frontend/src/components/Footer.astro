---
const currentYear = new Date().getFullYear();

const footerLinks = {
  explore: [
    { label: 'About Us', href: '/about' },
    { label: 'Our Programs', href: '/programs' },
    { label: 'Success Stories', href: '/stories' },
    { label: 'Annual Reports', href: '/reports' },
  ],
  getInvolved: [
    { label: 'Donate', href: '/donate' },
    { label: 'Volunteer', href: '/volunteer' },
    { label: 'Partner With Us', href: '/partner' },
    { label: 'Careers', href: '/careers' },
  ],
  support: [
    { label: 'Contact Us', href: '/contact' },
    { label: 'FAQ', href: '/faq' },
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
  ],
};
---

<footer class="bg-canvas mt-auto relative">
  <!-- Gradient border-top -->
  <div class="h-px bg-gradient-to-r from-accent via-accent/30 to-transparent"></div>

  <!-- Footer back-to-top (appears on scroll) -->
  <button
    id="footer-back-to-top"
    type="button"
    class="w-full text-center py-3 text-xs text-steel hover:text-ink tracking-[1px] uppercase transition-all duration-300 opacity-0 hidden cursor-pointer"
    aria-label="Back to top"
  >
    &uarr; Back to top
  </button>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Brand column -->
      <div class="lg:col-span-4">
        <a href="/" class="inline-flex items-baseline gap-2 mb-6" aria-label="Peace League Africa Home">
          <span class="text-lg font-semibold tracking-tight text-ink">Peace League</span>
          <span class="text-sm text-steel font-medium">Africa</span>
        </a>

        <p class="text-steel mb-6 max-w-sm leading-relaxed text-sm">
          Building peace and empowering communities across Africa through education, healthcare, and sustainable development.
        </p>

        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="#" aria-label="Twitter" class="social-link text-steel hover:text-ink transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" aria-label="Facebook" class="social-link text-steel hover:text-ink transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="social-link text-steel hover:text-ink transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="social-link text-steel hover:text-ink transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 4.948C.014 8.316 0 8.754 0 12c0 3.259.014 3.668.072 4.948.2 2.248 2.628 4.676 4.98 4.676 1.266.057 1.645.069 4.85.069 3.259 0 3.668-.014 4.848-.072 2.248-.2 4.676-2.628 4.676-4.98-.072-3.259-.072-3.668-.072-4.948 0-3.246-.2-4.678-4.676-4.978C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" class="social-link text-steel hover:text-ink transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links columns -->
      <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div>
          <h4 class="text-[11px] font-semibold text-steel uppercase tracking-[0.5px] mb-4">Explore</h4>
          <ul class="flex flex-col gap-1">
            {footerLinks.explore.map(link => (
              <li>
                <a href={link.href} class="footer-link-underline text-sm text-steel hover:text-ink transition-colors py-1 inline-block">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-[11px] font-semibold text-steel uppercase tracking-[0.5px] mb-4">Get Involved</h4>
          <ul class="flex flex-col gap-1">
            {footerLinks.getInvolved.map(link => (
              <li>
                <a href={link.href} class="footer-link-underline text-sm text-steel hover:text-ink transition-colors py-1 inline-block">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-[11px] font-semibold text-steel uppercase tracking-[0.5px] mb-4">Support</h4>
          <ul class="flex flex-col gap-1">
            {footerLinks.support.map(link => (
              <li>
                <a href={link.href} class="footer-link-underline text-sm text-steel hover:text-ink transition-colors py-1 inline-block">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-hairline">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-steel">
        <p>&copy; {currentYear} Peace League Africa. All rights reserved.</p>
        <p>Making a difference across Africa</p>
      </div>
    </div>
  </div>
</footer>

<script>
  const backToTopBtn = document.getElementById('footer-back-to-top');

  function toggleFooterBackToTop() {
    const scrollHeight = document.documentElement.scrollHeight;
    const viewportHeight = window.innerHeight;
    const scrollBottom = window.scrollY + viewportHeight;
    if (scrollBottom > scrollHeight - viewportHeight * 1.5) {
      backToTopBtn?.classList.remove('opacity-0', 'hidden');
      backToTopBtn?.classList.add('opacity-100');
    } else {
      backToTopBtn?.classList.add('opacity-0', 'hidden');
      backToTopBtn?.classList.remove('opacity-100');
    }
  }

  window.addEventListener('scroll', toggleFooterBackToTop, { passive: true });
  toggleFooterBackToTop();

  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
