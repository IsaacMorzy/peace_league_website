---
export interface Props {
  heading?: string;
  description?: string;
  id?: string;
  variant?: keyof typeof variantClasses;
  size?: keyof typeof sizeClasses;
  class?: string;
  animate?: boolean;
}

const {
  heading,
  description,
  id,
  variant = "default" as keyof typeof variantClasses,
  size = "md" as keyof typeof sizeClasses,
  class: className = "",
  animate = true,
} = Astro.props;

const variantClasses: Record<string, string> = {
  default: "bg-canvas",
  surface: "bg-surface",
  accent: "bg-accent/10",
  dark: "bg-ink text-on-dark",
};

const sizeClasses: Record<string, string> = {
  sm: "py-12 md:py-16",
  md: "py-16 md:py-24",
  lg: "py-20 md:py-32",
};
---

<section
  id={id}
  class={`section-padding ${variantClasses[variant]} ${sizeClasses[size]} ${className}`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      heading && (
        <div class={`max-w-3xl mx-auto text-center mb-12 md:mb-16 ${animate ? 'scroll-reveal' : ''}`}>
          <h2 class="heading-xl text-ink mb-4">{heading}</h2>
          {description && (
            <p class="text-lg text-steel leading-relaxed max-w-2xl mx-auto">
              {description}
            </p>
          )}
        </div>
      )
    }
    <slot />
  </div>
</section>
