---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Peace League Africa transforms conflict into hope across East Africa and the Great Lakes region. Through peace education in 45+ schools, youth mentorship across 12 countries, and community reconciliation programs, we are building lasting peace in communities divided by war and poverty. Donate, volunteer, or partner with us.',
  image = '/og-image.png',
  noIndex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://peaceleagueafrica.org');
const pageTitle = `${title} | Peace League Africa`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Anti-FOUC: apply dark class before render -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />

    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || 'https://peaceleagueafrica.org')} />
    <meta property="og:site_name" content="Peace League Africa" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site || 'https://peaceleagueafrica.org')} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Peace League Africa",
      "description": description,
      "url": "https://peaceleagueafrica.org",
      "logo": "https://peaceleagueafrica.org/favicon.svg",
      "sameAs": [
        "https://twitter.com/peaceleagueafrica",
        "https://facebook.com/peaceleagueafrica",
        "https://linkedin.com/company/peaceleagueafrica"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@peaceleagueafrica.org",
        "telephone": "+1-555-123-4567",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Nairobi",
          "addressCountry": "KE"
        }
      }
    })} />

    <!-- Theme Color -->
    <meta name="theme-color" content="#00d4a4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

  </head>
  <body class="bg-canvas text-ink antialiased min-h-screen flex flex-col">
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-primary focus:text-on-primary focus:px-4 focus:py-2 focus:rounded-lg">
      Skip to main content
    </a>

    <slot />

    <!-- Floating particles container -->
    <div id="particles" class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true"></div>

    <!-- Floating bubbles -->
    <div class="bubble" style="width:12px;height:12px;left:5%;background:var(--color-accent);animation-delay:0s;animation-duration:9s"></div>
    <div class="bubble" style="width:8px;height:8px;left:15%;background:var(--color-accent-warm);animation-delay:2s;animation-duration:7s"></div>
    <div class="bubble" style="width:16px;height:16px;left:30%;background:var(--color-accent-soft);animation-delay:4s;animation-duration:11s"></div>
    <div class="bubble" style="width:6px;height:6px;left:45%;background:var(--color-accent);animation-delay:1s;animation-duration:8s"></div>
    <div class="bubble" style="width:14px;height:14px;left:55%;background:var(--color-accent-warm);animation-delay:3s;animation-duration:10s"></div>
    <div class="bubble" style="width:10px;height:10px;left:65%;background:var(--color-accent-soft);animation-delay:5s;animation-duration:7s"></div>
    <div class="bubble" style="width:7px;height:7px;left:75%;background:var(--color-accent);animation-delay:0s;animation-duration:9s"></div>
    <div class="bubble" style="width:18px;height:18px;left:85%;background:var(--color-accent-warm);animation-delay:2s;animation-duration:12s"></div>
    <div class="bubble" style="width:9px;height:9px;left:92%;background:var(--color-accent-soft);animation-delay:4s;animation-duration:8s"></div>
    <div class="bubble" style="width:11px;height:11px;left:35%;background:var(--color-accent);animation-delay:6s;animation-duration:10s"></div>

    <script>
      // Scroll reveal — subtle fade-up when elements enter viewport
      const srObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-4');
            entry.target.style.opacity = '1';
            srObserver.unobserve(entry.target);
          }
        });
      }, { rootMargin: '80px', threshold: 0.05 });
      document.querySelectorAll('.scroll-reveal').forEach(el => {
        el.style.opacity = '0';
        srObserver.observe(el);
      });
      const srMo = new MutationObserver(() => {
        document.querySelectorAll('.scroll-reveal:not(.animate-in)').forEach(el => {
          el.style.opacity = '0';
          srObserver.observe(el);
        });
      });
      srMo.observe(document.body, { childList: true, subtree: true });
    </script>

    <script is:inline>
      (function() {
        var container = document.createElement('div');
        container.className = 'fixed inset-0 pointer-events-none z-0 overflow-hidden';
        container.id = 'particles';
        container.setAttribute('aria-hidden', 'true');
        document.body.prepend(container);
        for (var i = 0; i < 15; i++) {
          var dot = document.createElement('div');
          dot.className = 'absolute w-1 h-1 rounded-full';
          dot.style.cssText = 'background:' + (i % 3 === 0 ? '#00d4a4' : i % 3 === 1 ? '#f59e0b' : '#7cebcb') + ';left:' + Math.random() * 100 + '%;top:' + (70 + Math.random() * 30) + '%;animation:float-up ' + (3 + Math.random() * 4) + 's ease-out ' + (Math.random() * 5) + 's infinite;opacity:' + (0.2 + Math.random() * 0.3);
          container.appendChild(dot);
        }
      })();
    </script>
  </body>
</html>
