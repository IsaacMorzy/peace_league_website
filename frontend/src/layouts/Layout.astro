---
import '../styles/global.css';
import Libredesk from '../components/Libredesk.astro';


interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Peace League Africa transforms conflict into hope across East Africa and the Great Lakes region. Through peace education in 45+ schools, youth mentorship across 12 countries, and community reconciliation programs, we are building lasting peace in communities divided by war and poverty. Donate, volunteer, or partner with us.',
  image = '/og-image.png',
  noIndex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://peaceleagueafrica.com');
const pageTitle = `${title} | Peace League Africa`;
---

<!doctype html>
<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Anti-FOUC: apply dark class before render -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Fonts (system font stack — no downloads needed) -->
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />

    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || 'https://peaceleagueafrica.com')} />
    <meta property="og:site_name" content="Peace League Africa" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site || 'https://peaceleagueafrica.com')} />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Peace League Africa",
      "description": description,
      "url": "https://peaceleagueafrica.com",
      "logo": "https://peaceleagueafrica.com/favicon.svg",
      "sameAs": [
        "https://twitter.com/peaceleagueafrica",
        "https://facebook.com/peaceleagueafrica",
        "https://linkedin.com/company/peaceleagueafrica"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@peaceleagueafrica.com",
        "telephone": "+1-555-123-4567",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Nairobi",
          "addressCountry": "KE"
        }
      }
    })} />

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Peace League Africa",
      "url": "https://peaceleagueafrica.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://peaceleagueafrica.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Theme Color -->
    <meta name="theme-color" content="#00d4a4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

    <!-- Speculation Rules (desktop only, skip on save-data) -->
    <script is:inline>
      (function() {
        if (window.matchMedia('(max-width: 768px)').matches) return;
        if (navigator.connection && navigator.connection.saveData) return;
        const spec = {
          prerender: [{
            where: { href_matches: '/*' },
            eagerness: 'moderate'
          }]
        };
        const el = document.createElement('script');
        el.type = 'speculationrules';
        el.textContent = JSON.stringify(spec);
        document.head.appendChild(el);
      })();
    </script>

  </head>
  <body class="bg-canvas text-ink antialiased min-h-screen flex flex-col overflow-x-hidden" data-js-listeners>
    <!-- Cursor glow ring -->
    <div id="cursor-glow" aria-hidden="true"></div>

    <!-- Scroll progress bar -->
    <div id="scroll-progress-bar" aria-hidden="true"></div>

    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="skip-nav" id="skip-nav">
      Skip to main content
    </a>

    <!-- ── URGENCY / MATCHING BANNER ── -->
    <div id="urgency-banner" class="hidden md:block" role="banner">
      <span class="banner-text">
        &#x2728; Your gift goes further &mdash; all donations are being matched 2× until midnight. Double your impact now. &#x2728;
      </span>
    </div>

    <slot />

    <!-- Subtle ambient vignette (keeps the depth without AI-aesthetic orbs) -->
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,_theme(colors.ink/0.03)_0%,_transparent_60%)]"></div>

    <!-- ═════════════════════════════════════════════════════
         HYPNOTIC MEDITATIVE AMBIENT EFFECTS
         Slow-spinning mandala · Breathing light · Rising hearts
         Floating embers · Gentle wave — all across every page
         ═════════════════════════════════════════════════════ -->

    <!-- Sacred Geometry Mandala (background, barely visible, slow rotation) -->
    <div class="meditative-mandala" aria-hidden="true"></div>

    <!-- Breathing overlay (gentle radial pulse like peaceful breath) -->
    <div class="meditative-breath" aria-hidden="true"></div>

    <!-- Subtle horizontal wave (like light on still water) -->
    <div class="meditative-wave" aria-hidden="true"></div>

    <!-- Floating decorative elements (across all pages) -->
    <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true" style="contain:layout style paint;">
      <div class="floating-bubble" style="width:14px;height:14px;left:12%;animation-delay:0s;"></div>
      <div class="floating-bubble" style="width:10px;height:10px;left:68%;animation-delay:8s;"></div>
      <div class="floating-dot" style="width:8px;height:8px;left:35%;animation-delay:4s;"></div>
      <div class="floating-dot" style="width:6px;height:6px;left:82%;animation-delay:12s;"></div>
    </div>

    <!-- ── HYPNOTIC FLOATING HEARTS (two colors: warm amber + cool teal) ──
         They emerge from the bottom of the viewport and float all the way
         to the top with a gentle swaying motion — like leaves on a breeze.
         Each heart has its own size, lateral position, timing, and duration
         creating an organic, ever-changing constellation of love rising. -->
    <div aria-hidden="true" style="position:fixed;inset:0;pointer-events:none;z-index:9995;contain:layout style paint;">
      <span class="hypnotic-heart hypnotic-heart--warm" style="left:8%;font-size:0.55rem;--heart-dur:38s;animation-delay:0s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--cool" style="left:22%;font-size:0.6rem;--heart-dur:48s;animation-delay:4s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--warm" style="left:45%;font-size:0.5rem;--heart-dur:42s;animation-delay:8s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--cool" style="left:65%;font-size:0.55rem;--heart-dur:40s;animation-delay:2s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--warm" style="left:80%;font-size:0.45rem;--heart-dur:50s;animation-delay:12s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--cool" style="left:92%;font-size:0.5rem;--heart-dur:44s;animation-delay:6s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--pale" style="left:35%;font-size:0.35rem;--heart-dur:58s;animation-delay:16s;">&#x2764;</span>
      <span class="hypnotic-heart hypnotic-heart--pale" style="left:72%;font-size:0.3rem;--heart-dur:60s;animation-delay:20s;">&#x2764;</span>
    </div>

    <!-- ── HYPNOTIC FLOATING PARTICLES (glowing embers) ──
         Tiny gold, teal, and white specks that drift upward
         like fireflies in a meditation garden. -->
    <div aria-hidden="true" style="position:fixed;inset:0;pointer-events:none;z-index:9994;contain:layout style paint;">
      <span class="hypnotic-particle hypnotic-particle--gold" style="left:15%;width:4px;height:4px;--particle-dur:28s;animation-delay:0s;"></span>
      <span class="hypnotic-particle hypnotic-particle--teal" style="left:55%;width:4px;height:4px;--particle-dur:32s;animation-delay:6s;"></span>
      <span class="hypnotic-particle hypnotic-particle--gold" style="left:78%;width:3px;height:3px;--particle-dur:26s;animation-delay:12s;"></span>
      <span class="hypnotic-particle hypnotic-particle--teal" style="left:38%;width:3px;height:3px;--particle-dur:34s;animation-delay:18s;"></span>
    </div>

    <!-- ── STICKY DONATE BUTTON ── -->
    <a href="/donate" id="sticky-donate-btn" class="btn-text-contrast inline-flex items-center gap-2 px-4 py-2.5 bg-accent rounded-full text-xs font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" aria-label="Donate now">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      <span>Donate</span>
    </a>

    <!-- ── LIVE DONATION TOAST ── -->
    <div id="donation-toast" aria-live="polite">
      <div class="toast-avatar">
        <span id="toast-initials">AK</span>
      </div>
      <div class="toast-text">
        <strong id="toast-name">Someone</strong>
        <span id="toast-action">just donated</span>
        <strong id="toast-amount">$50</strong>
        <span id="toast-location"></span>
      </div>
      <svg class="toast-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
    </div>

    <!-- Newsletter Popup (exit-intent) -->
    <div id="newsletter-popup" class="fixed inset-0 z-[9998] hidden items-center justify-center p-4" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
      <div class="bg-canvas rounded-3xl border border-hairline shadow-2xl max-w-md w-full p-8 relative overflow-hidden">
        <button id="newsletter-close" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-surface flex items-center justify-center text-steel hover:text-ink transition-colors" aria-label="Close">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-accent/10 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-ink mb-2">Stay in the Loop</h3>
          <p class="text-sm text-steel mb-6">Get monthly updates on our peace-building work, impact stories, and ways to help.</p>
          <form id="newsletter-popup-form" class="flex gap-2">
            <input type="email" placeholder="your@email.com" required class="flex-1 px-4 py-3 rounded-xl border border-hairline bg-canvas text-ink text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20" />
            <button type="submit" class="px-6 py-3 bg-accent text-white font-semibold rounded-xl hover:bg-accent-deep transition-colors text-sm">Subscribe</button>
          </form>
          <p class="text-xs text-steel mt-3">No spam. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>

    <!-- Newsletter Popup Script -->
    <script>
      (function() {
        var popup = document.getElementById('newsletter-popup');
        var closeBtn = document.getElementById('newsletter-close');
        var form = document.getElementById('newsletter-popup-form');
        
        if (!popup) return;
        
        // Don't show if already dismissed or subscribed
        if (localStorage.getItem('pleague-newsletter-dismissed') || localStorage.getItem('pleague-newsletter-subscribed')) return;
        
        // Exit intent detection
        document.addEventListener('mouseout', function(e) {
          if (e.clientY <= 0 && !sessionStorage.getItem('newsletter-shown')) {
            sessionStorage.setItem('newsletter-shown', '1');
            setTimeout(function() {
              popup.classList.remove('hidden');
              popup.classList.add('flex');
            }, 500);
          }
        });
        
        // Also show after 60 seconds on page
        setTimeout(function() {
          if (!sessionStorage.getItem('newsletter-shown') && !localStorage.getItem('pleague-newsletter-dismissed')) {
            sessionStorage.setItem('newsletter-shown', '1');
            popup.classList.remove('hidden');
            popup.classList.add('flex');
          }
        }, 60000);
        
        // Close button
        if (closeBtn) {
          closeBtn.addEventListener('click', function() {
            popup.classList.add('hidden');
            popup.classList.remove('flex');
            localStorage.setItem('pleague-newsletter-dismissed', '1');
          });
        }
        
        // Click outside to close
        popup.addEventListener('click', function(e) {
          if (e.target === popup) {
            popup.classList.add('hidden');
            popup.classList.remove('flex');
            localStorage.setItem('pleague-newsletter-dismissed', '1');
          }
        });
        
        // Form submit
        if (form) {
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            var email = form.querySelector('input[type=email]').value;
            if (email) {
              localStorage.setItem('pleague-newsletter-subscribed', '1');
              popup.innerHTML = '<div class="text-center p-8"><div class="w-16 h-16 mx-auto rounded-full bg-accent/10 flex items-center justify-center mb-4"><svg class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div><h3 class="text-xl font-bold text-ink mb-2">You\'re In!</h3><p class="text-sm text-steel">Check your inbox for a welcome message.</p></div>';
              setTimeout(function() {
                popup.classList.add('hidden');
                popup.classList.remove('flex');
              }, 3000);
            }
          });
        }
      })();
    </script>

    <script>
      // Scroll reveal — guarded: only query DOM lazily and observe existing elements
      const revealTargets = document.querySelectorAll('.scroll-reveal');
      if (revealTargets.length) {
        const srObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-4');
              entry.target.style.opacity = '1';
              srObserver.unobserve(entry.target);
            }
          });
        }, { rootMargin: '80px', threshold: 0.05 });

        revealTargets.forEach(el => {
          el.style.opacity = '0';
          srObserver.observe(el);
        });

        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            const srMo = new MutationObserver(() => {
              document.querySelectorAll('.scroll-reveal:not(.animate-in)').forEach(el => {
                el.style.opacity = '0';
                srObserver.observe(el);
              });
            });
            srMo.observe(document.body, { childList: true, subtree: true });
          }, { timeout: 2000 });
        }
      }

      // ── TREND 1: 3D TILT CARDS ──
      const tiltCards = document.querySelectorAll('.tilt-card');
      if (tiltCards.length && window.matchMedia('(pointer: fine)').matches) {
        tiltCards.forEach(card => {
          const sheen = card.querySelector('.tilt-sheen');
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = ((y - centerY) / centerY) * -6;
            const rotateY = ((x - centerX) / centerX) * 6;
            card.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02,1.02,1.02)`;
            if (sheen) {
              sheen.style.setProperty('--sheen-x', `${(x / rect.width) * 100}%`);
              sheen.style.setProperty('--sheen-y', `${(y / rect.height) * 100}%`);
            }
          });
          card.addEventListener('mouseleave', () => {
            card.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)';
          });
        });
      }

      // ── TREND 2: ENHANCED SCROLL REVEALS ──
      // Handle .img-reveal, .reveal-scale, .reveal-scale, .img-reveal-left
      if ('IntersectionObserver' in window) {
        const scrollObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              scrollObserver.unobserve(entry.target);
            }
          });
        }, { rootMargin: '60px', threshold: 0.1 });

        document.querySelectorAll('.img-reveal, .reveal-scale, .img-reveal-left, .stat-number').forEach(el => {
          scrollObserver.observe(el);
        });

        // Also set up mutation observer for dynamically added elements
        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            const mo = new MutationObserver(() => {
              document.querySelectorAll('.img-reveal:not(.revealed), .reveal-scale:not(.revealed), .img-reveal-left:not(.revealed), .stat-number:not(.revealed)').forEach(el => {
                scrollObserver.observe(el);
              });
            });
            mo.observe(document.body, { childList: true, subtree: true });
          }, { timeout: 2000 });
        }
      }

      // ── TREND 5: HERO MOUSE DEPTH PARALLAX ──
      const heroSection = document.getElementById('hero-section');
      if (heroSection && window.matchMedia('(pointer: fine)').matches) {
        const heroLayers = heroSection.querySelectorAll('.hero-depth-layer');
        const speeds = [0.02, 0.04, 0.06, 0.01]; // L0→L3
        let heroCenterX = window.innerWidth / 2;
        let heroCenterY = window.innerHeight / 2;
        let mouseX = heroCenterX;
        let mouseY = heroCenterY;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        }, { passive: true });

        function animateHeroDepth() {
          const dx = (mouseX - heroCenterX) / heroCenterX;
          const dy = (mouseY - heroCenterY) / heroCenterY;
          heroLayers.forEach((layer, i) => {
            const s = speeds[i] || 0.02;
            layer.style.transform = `translate(${dx * s * 40}px, ${dy * s * 40}px)`;
          });
          requestAnimationFrame(animateHeroDepth);
        }
        animateHeroDepth();

        window.addEventListener('resize', () => {
          heroCenterX = window.innerWidth / 2;
          heroCenterY = window.innerHeight / 2;
        }, { passive: true });
      }

      // ── MOUSE-RESPONSIVE PARTICLES ──
      // Gently attract floating particles toward cursor
      if (heroSection && window.matchMedia('(pointer: fine)').matches) {
        const particles = heroSection.querySelectorAll('.animate-particle, .animate-particle--fast, .animate-particle--glow');
        if (particles.length) {
          let pMouseX = window.innerWidth / 2;
          let pMouseY = window.innerHeight / 2;

          document.addEventListener('mousemove', (e) => {
            pMouseX = e.clientX;
            pMouseY = e.clientY;
          }, { passive: true });

          // Store original positions
          const origPositions = [];
          particles.forEach((p, i) => {
            const rect = p.getBoundingClientRect();
            origPositions[i] = {
              x: rect.left + rect.width / 2,
              y: rect.top + rect.height / 2,
            };
          });

          // Subtle attraction - move particles slightly toward cursor
          function animateParticles() {
            particles.forEach((p, i) => {
              if (!origPositions[i]) return;
              const rect = p.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              const dx = (pMouseX - cx) * 0.0005;
              const dy = (pMouseY - cy) * 0.0005;
              // Clamp to tiny movement
              const moveX = Math.max(-3, Math.min(3, dx));
              const moveY = Math.max(-3, Math.min(3, dy));
              // Use margin to avoid conflicting with keyframe transform
              p.style.marginLeft = `${moveX}px`;
              p.style.marginTop = `${moveY}px`;
            });
            requestAnimationFrame(animateParticles);
          }
          animateParticles();
        }
      }

      // ── MAGNETIC BUTTONS ──
      const magneticBtns = document.querySelectorAll('.magnetic-btn');
      if (magneticBtns.length && window.matchMedia('(pointer: fine)').matches) {
        magneticBtns.forEach(btn => {
          const strength = parseFloat(btn.dataset.magnetStrength) || 0.3;
          btn.addEventListener('mousemove', (e) => {
            const rect = btn.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            btn.style.transform = `translate(${x * strength * 0.4}px, ${y * strength * 0.4}px) scale(1.03)`;
          });
          btn.addEventListener('mouseleave', () => {
            btn.style.transform = 'translate(0, 0) scale(1)';
          });
        });
      }

      // Cursor glow effect
      const cursorGlow = document.getElementById('cursor-glow');
      if (cursorGlow && window.matchMedia('(pointer: fine)').matches) {
        let glowX = window.innerWidth / 2, glowY = window.innerHeight / 2;
        let currentX = glowX, currentY = glowY;

        document.addEventListener('mousemove', (e) => {
          glowX = e.clientX;
          glowY = e.clientY;
        }, { passive: true });

        function animateGlow() {
          currentX += (glowX - currentX) * 0.08;
          currentY += (glowY - currentY) * 0.08;
          cursorGlow.style.transform = `translate(${currentX - 150}px, ${currentY - 150}px)`;
          requestAnimationFrame(animateGlow);
        }
        animateGlow();
      }

      // Scroll progress bar
      const progressBar = document.getElementById('scroll-progress-bar');
      if (progressBar) {
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
              const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
              const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
              progressBar.style.width = Math.min(progress, 100) + '%';
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }

      // Defer parallax init until idle — scoped to #hero-section
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => {
          const heroSection = document.querySelector('#hero-section');
          if (!heroSection) return;

          let parallaxTicking = false;
          window.addEventListener('scroll', () => {
            if (!parallaxTicking) {
              requestAnimationFrame(() => {
                const speed = 0.15;
                const y = heroSection.getBoundingClientRect().top;
                const shapes = heroSection.querySelectorAll('.parallax-bg-shape');
                const dots = heroSection.querySelectorAll('.parallax-dot-grid');
                shapes.forEach(s => { s.style.transform = `translateY(${y * speed}px)`; });
                dots.forEach(d => { d.style.transform = `translateY(${y * speed * 0.5}px)`; });
                parallaxTicking = false;
              });
              parallaxTicking = true;
            }
          }, { passive: true });
        });
      }

      // ── STICKY DONATE BUTTON ──
      const stickyBtn = document.getElementById('sticky-donate-btn');
      if (stickyBtn) {
        let lastScrollY = window.scrollY;
        let tickingSticky = false;

        window.addEventListener('scroll', () => {
          if (!tickingSticky) {
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              const docHeight = document.documentElement.scrollHeight;
              const winHeight = window.innerHeight;
              const scrolledToBottom = (scrollY + winHeight) >= (docHeight - 200);

              // Show after scrolling past 600px
              if (scrollY > 600 && !scrolledToBottom) {
                stickyBtn.classList.add('visible');
              } else {
                stickyBtn.classList.remove('visible');
              }

              // Move up when near footer
              if (scrolledToBottom) {
                stickyBtn.classList.add('hide-on-footer');
              } else {
                stickyBtn.classList.remove('hide-on-footer');
              }

              tickingSticky = false;
            });
            tickingSticky = true;
          }
        }, { passive: true });
      }

      // ── LIVE DONATION & VOLUNTEER TOASTS ──
      const toast = document.getElementById('donation-toast');
      if (toast) {
        const people = [
          { name: 'Amara K.', initials: 'AK' }, { name: 'James M.', initials: 'JM' },
          { name: 'Sarah W.', initials: 'SW' }, { name: 'David O.', initials: 'DO' },
          { name: 'Grace N.', initials: 'GN' }, { name: 'Peter K.', initials: 'PK' },
          { name: 'Makena T.', initials: 'MT' }, { name: 'Kwame A.', initials: 'KA' },
          { name: 'Fatima Z.', initials: 'FZ' }, { name: 'Emeka O.', initials: 'EO' },
          { name: 'Amina S.', initials: 'AS' }, { name: 'Joseph M.', initials: 'JM' },
          { name: 'Nadia A.', initials: 'NA' }, { name: 'Tendai M.', initials: 'TM' },
          { name: 'Zuri K.', initials: 'ZK' }, { name: 'Chidi N.', initials: 'CN' },
          { name: 'Nyokabi W.', initials: 'NW' }, { name: 'Olu S.', initials: 'OS' },
          { name: 'Thandiwe B.', initials: 'TB' }, { name: 'Kofi A.', initials: 'KA' },
          { name: 'Adaeze O.', initials: 'AO' }, { name: 'Musa D.', initials: 'MD' },
        ];
        const locations = [' from Nairobi', ' from London', ' from Lagos', ' from Kampala',
          ' from Accra', ' from Kigali', ' from Dar es Salaam', ' from Addis Ababa',
          ' from Cape Town', ' from Johannesburg', ' from Mombasa', ' from Kisumu',
          ' from Abuja', ' from Dakar', '', '', '', ''];
        const donationActions = [
          { text: 'just donated', icon: 'donate' },
          { text: 'became a monthly donor', icon: 'donate' },
          { text: 'funded a clean water well', icon: 'donate' },
          { text: 'sponsored a child\'s education', icon: 'donate' },
        ];
        const volunteerActions = [
          { text: 'signed up to volunteer', icon: 'volunteer' },
          { text: 'joined as a peace educator', icon: 'volunteer' },
          { text: 'registered for community outreach', icon: 'volunteer' },
          { text: 'committed to weekly mentoring', icon: 'volunteer' },
        ];
        const amounts = ['$25', '$50', '$75', '$100', '$150', '$200', '$500', '$1,000'];

        let toastTimeout = null;
        let toastVisible = false;

        function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

        function generateToastData() {
          const person = pick(people);
          const isVolunteer = Math.random() < 0.35; // 35% volunteer actions
          const amount = isVolunteer ? '' : pick(amounts);
          const location = pick(locations);
          return {
            initials: person.initials,
            name: person.name,
            amount: amount,
            location: location,
            action: pick(isVolunteer ? volunteerActions : donationActions).text,
            isVolunteer: isVolunteer,
            showAmount: !isVolunteer,
            showLocation: !!location
          };
        }

        function showToast() {
          const d = generateToastData();
          document.getElementById('toast-initials').textContent = d.initials;
          document.getElementById('toast-name').textContent = d.name;
          document.getElementById('toast-amount').textContent = d.amount;
          document.getElementById('toast-location').textContent = d.location;
          document.getElementById('toast-action').textContent = d.action;
          // Swap icon based on action type
          var icon = toast.querySelector('.toast-icon');
          if (icon) {
            icon.setAttribute('stroke', 'currentColor');
            icon.innerHTML = d.isVolunteer
              ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>'
              : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>';
          }

          // Hide amount element if volunteer action
          var amtEl = document.getElementById('toast-amount');
          if (amtEl) {
            if (d.isVolunteer) {
              amtEl.style.display = 'none';
            } else {
              amtEl.style.display = 'inline';
            }
          }

          // Show/hide location dot
          var locEl = document.getElementById('toast-location');
          if (locEl) {
            locEl.style.display = d.showLocation ? 'inline' : 'none';
          }

          toast.classList.remove('visible');
          void toast.offsetWidth;
          toast.classList.add('visible');
          toastVisible = true;

          clearTimeout(toastTimeout);
          toastTimeout = setTimeout(() => {
            toast.classList.remove('visible');
            toastVisible = false;
            // Schedule next: 20–50 seconds from now
            setTimeout(showToast, 20000 + Math.random() * 30000);
          }, 4500 + Math.random() * 1500);
        }

        // First toast after 5–15 seconds (random per visitor)
        setTimeout(showToast, 5000 + Math.random() * 10000);
      }

    </script>

    <!-- ══════════════════════════════════════
         WOW FACTOR: Magnetic hover + Parallax + Gradient Borders
         ══════════════════════════════════════ -->
    <script>
      // ── 1. Magnetic Hover on CTA buttons ──
      document.querySelectorAll('[data-magnetic]').forEach(btn => {
        btn.addEventListener('mousemove', e => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          const dist = Math.sqrt(x * x + y * y);
          const maxDist = 120;
          const strength = Math.min(dist / maxDist, 1);
          btn.style.transform = `translate3d(${x * 0.2 * strength}px, ${y * 0.2 * strength}px, 0)`;
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.transform = 'translate3d(0, 0, 0)';
          btn.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
          setTimeout(() => { btn.style.transition = ''; }, 400);
        });
      });

      // ── 2. Hero Parallax ──
      const heroParallax = () => {
        const hero = document.querySelector('[data-hero-parallax]');
        if (!hero) return;
        const img = hero.querySelector('img');
        if (!img) return;
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const rect = hero.getBoundingClientRect();
              if (rect.bottom > 0 && rect.top < window.innerHeight) {
                const speed = 0.15;
                const y = rect.top * speed;
                img.style.transform = `translate3d(0, ${y}px, 0) scale(1.05)`;
              }
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      };
      heroParallax();

      // ── 3. Animated Gradient Border on cards with [data-gradient-border] ──
      const gradientCards = document.querySelectorAll('[data-gradient-border]');
      gradientCards.forEach(card => {
        const border = document.createElement('div');
        border.className = 'pointer-events-none absolute inset-0 rounded-[inherit] opacity-0 group-hover:opacity-100 transition-opacity duration-500';
        border.style.cssText = 'border: 1.5px solid transparent; background: linear-gradient(135deg, #00d4a4, #7cebcb, #f59e0b, #00d4a4) border-box; -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; background-size: 300% 300%; animation: gradient-shift 4s ease infinite; z-index: 1;';
        card.style.position = 'relative';
        card.appendChild(border);
      });

      // ── 4. Enhanced Scroll-Reveal (stagger + direction variants) ──
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            const delay = el.dataset.revealDelay || 0;
            const direction = el.dataset.reveal || 'up';
            setTimeout(() => {
              el.classList.add('revealed');
              if (direction === 'left') {
                el.style.transform = 'translateX(0)';
                el.style.opacity = '1';
              } else if (direction === 'right') {
                el.style.transform = 'translateX(0)';
                el.style.opacity = '1';
              } else if (direction === 'scale') {
                el.style.transform = 'scale(1)';
                el.style.opacity = '1';
              } else {
                el.style.transform = 'translateY(0)';
                el.style.opacity = '1';
              }
            }, delay);
            revealObserver.unobserve(el);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-reveal]').forEach(el => {
        const direction = el.dataset.reveal || 'up';
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)';
        if (direction === 'left') {
          el.style.transform = 'translateX(-30px)';
        } else if (direction === 'right') {
          el.style.transform = 'translateX(30px)';
        } else if (direction === 'scale') {
          el.style.transform = 'scale(0.85)';
        } else {
          el.style.transform = 'translateY(30px)';
        }
        revealObserver.observe(el);
      });

      // ── 5. Theme Toggle Rotation Animation ──
      document.querySelectorAll('[id^="theme-toggle"]').forEach(btn => {
        btn.addEventListener('click', function(e) {
          const icon = this.querySelector('svg:not(.hidden)');
          if (icon) {
            icon.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
            icon.style.transform = 'rotate(360deg)';
            setTimeout(() => { icon.style.transform = ''; icon.style.transition = ''; }, 500);
          }
        });
      });
    </script>

