---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy" description="Peace League Africa Privacy Policy. How we collect, use, and protect your personal information.">
  <Navigation />
  
  <main id="main-content">
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
      <!-- Ambient orbs -->
      <div class="orb-float orb-float--1" style="top:-100px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-80px;left:-80px;" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.10] tracking-tight">Privacy Policy</h1>
        <p class="mt-4 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-150 text-lg text-white/70">Last updated: January 2026</p>
      </div>
      <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <!-- Doves flying (natural swooping arcs) -->
        <span class="animate-dove-drift" style="left:18%;bottom:-20%;animation-delay:0.5s;font-size:1.125rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow" style="left:55%;bottom:-25%;animation-delay:2s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift" style="left:82%;bottom:-15%;animation-delay:3.5s;font-size:1rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <!-- Hearts pulsing -->
        <!-- Sparkle particles -->
        <span class="animate-particle" style="left:10%;bottom:5%;width:4px;height:4px;border-radius:50%;background:var(--color-accent);animation-delay:1s;"></span>
        <span class="animate-particle--fast" style="left:25%;bottom:10%;width:3px;height:3px;border-radius:50%;background:var(--color-accent-soft);animation-delay:0.3s;"></span>
        <span class="animate-particle" style="left:40%;bottom:8%;width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.4);animation-delay:2s;"></span>
        <span class="animate-particle--glow" style="left:60%;bottom:0;color:var(--color-accent);animation-delay:1.5s;font-size:1.2rem;">&#x2726;</span>
        <span class="animate-particle--fast" style="left:75%;bottom:15%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:2.5s;"></span>
        <span class="animate-particle" style="left:90%;bottom:5%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
      </div>
    </section>

    <section class="py-10 lg:py-14 bg-surface">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="scroll-reveal bg-canvas/80 backdrop-blur-xl rounded-2xl border border-hairline p-8 md:p-10 shadow-[0_8px_32px_rgba(0,0,0,0.06)] prose prose-sm max-w-none text-steel">
          <h2 class="text-2xl font-bold text-ink mt-0">1. Information We Collect</h2>
          <p>We collect personal information you voluntarily provide when you donate, volunteer, subscribe to our newsletter, or contact us. This may include your name, email address, phone number, billing information, and any messages you send us.</p>

          <h2 class="text-2xl font-bold text-ink">2. How We Use Your Information</h2>
          <p>We use your information to process donations, communicate about our programs, send receipts and impact updates, respond to inquiries, and improve our services. We never sell your personal data to third parties.</p>

          <h2 class="text-2xl font-bold text-ink">3. Payment Processing</h2>
          <p>Donation payments are processed securely through third-party payment providers. We do not store full credit card numbers or M-Pesa credentials on our servers. Payment data is handled directly by our payment partners in compliance with PCI security standards.</p>

          <h2 class="text-2xl font-bold text-ink">4. Data Retention</h2>
          <p>We retain your personal information only as long as necessary to fulfill the purposes described in this policy, or as required by law. Donation records are retained for financial reporting and tax purposes.</p>

          <h2 class="text-2xl font-bold text-ink">5. Your Rights</h2>
          <p>You have the right to access, correct, or request deletion of your personal data. To exercise these rights, please <a href="/contact" class="text-accent-link hover:text-accent-deep underline">contact us</a>. We will respond within 30 days.</p>

          <h2 class="text-2xl font-bold text-ink">6. Cookies</h2>
          <p>Our website uses minimal cookies for essential functionality and analytics. We do not use tracking cookies for advertising. You can disable cookies in your browser settings.</p>

          <h2 class="text-2xl font-bold text-ink">7. Changes to This Policy</h2>
          <p>We may update this policy periodically. Changes will be posted on this page with an updated revision date.</p>

          <h2 class="text-2xl font-bold text-ink">8. Contact Us</h2>
          <p>If you have questions about this privacy policy, please <a href="/contact" class="text-accent-link hover:text-accent-deep underline">contact us</a> at info@peaceleagueafrica.org.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
