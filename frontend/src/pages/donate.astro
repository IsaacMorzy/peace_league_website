---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Donate">
  <Navigation />
  
  <main>
    <section class="bg-gradient-to-br from-green-800 via-green-700 to-green-600 text-white py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold">Support Our Mission</h1>
        <p class="mt-4 text-xl text-green-100">Your contribution makes a real difference</p>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Make a Donation</h2>
          <p class="text-gray-600 mb-8">
            Every donation helps us continue our work across Africa. You can donate directly 
            through our secure payment system or contact us for other donation options.
          </p>
          
          <form id="donation-form" class="space-y-6">
            <div>
              <label for="donor_name" class="block text-sm font-medium text-gray-700 mb-2">Full Name *</label>
              <input type="text" id="donor_name" name="donor_name" required 
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" />
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
                <input type="email" id="email" name="email" required 
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
                <input type="tel" id="phone" name="phone" 
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" />
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-3">Select Amount</label>
              <div class="grid grid-cols-3 gap-4">
                <button type="button" class="amount-btn p-4 border-2 border-gray-300 rounded-lg hover:border-green-600 hover:bg-green-50 font-semibold text-gray-700 transition-colors" data-amount="25">
                  $25
                </button>
                <button type="button" class="amount-btn p-4 border-2 border-gray-300 rounded-lg hover:border-green-600 hover:bg-green-50 font-semibold text-gray-700 transition-colors" data-amount="50">
                  $50
                </button>
                <button type="button" class="amount-btn p-4 border-2 border-gray-300 rounded-lg hover:border-green-600 hover:bg-green-50 font-semibold text-gray-700 transition-colors" data-amount="100">
                  $100
                </button>
              </div>
            </div>
            
            <div>
              <label for="amount" class="block text-sm font-medium text-gray-700 mb-2">Or enter custom amount ($) *</label>
              <input type="number" id="amount" name="amount" min="1" step="0.01" required placeholder="Enter amount"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" />
            </div>
            
            <div>
              <label for="payment_method" class="block text-sm font-medium text-gray-700 mb-2">Payment Method *</label>
              <select id="payment_method" name="payment_method" required 
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                <option value="">Select payment method</option>
                <option value="Credit Card">Credit Card</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="PayPal">PayPal</option>
                <option value="Mobile Money">Mobile Money</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message (Optional)</label>
              <textarea id="message" name="message" rows="2" placeholder="Leave a message with your donation"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"></textarea>
            </div>
            
            <div class="flex items-center">
              <input type="checkbox" id="anonymous" name="anonymous" value="1" class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500" />
              <label for="anonymous" class="ml-2 text-sm text-gray-600">Make this donation anonymous</label>
            </div>
            
            <div id="form-message" class="hidden"></div>
            
            <button type="submit" id="submit-btn"
              class="w-full bg-green-700 text-white py-4 rounded-lg font-semibold hover:bg-green-800 transition-colors disabled:bg-gray-400 disabled:cursor-not-allowed">
              Donate Now
            </button>
          </form>
          
          <p class="mt-6 text-sm text-gray-500 text-center">
            All donations are tax-deductible. You will receive a receipt via email.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { submitDonation } from '../lib/api.js';

  const form = document.getElementById('donation-form');
  const messageDiv = document.getElementById('form-message');
  const submitBtn = document.getElementById('submit-btn');
  const amountInputs = document.querySelectorAll('.amount-btn');
  const amountField = document.getElementById('amount');

  amountInputs.forEach(btn => {
    btn.addEventListener('click', () => {
      const amount = btn.dataset.amount;
      amountField.value = amount;
      
      amountInputs.forEach(b => {
        b.classList.remove('border-green-600', 'bg-green-50', 'text-green-800');
        b.classList.add('border-gray-300', 'text-gray-700');
      });
      btn.classList.remove('border-gray-300', 'text-gray-700');
      btn.classList.add('border-green-600', 'bg-green-50', 'text-green-800');
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.anonymous = data.anonymous === '1' ? 1 : 0;
    data.currency = 'USD';
    
    messageDiv.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Processing...';
    
    try {
      const response = await submitDonation(data);
      
      if (response.status === 'success') {
        messageDiv.className = 'p-4 bg-green-100 text-green-800 rounded-lg';
        messageDiv.textContent = 'Thank you! Your donation has been recorded. You will receive a confirmation email shortly.';
        form.reset();
        amountInputs.forEach(b => {
          b.classList.remove('border-green-600', 'bg-green-50', 'text-green-800');
          b.classList.add('border-gray-300', 'text-gray-700');
        });
      } else {
        throw new Error(response.message || 'Failed to process donation');
      }
    } catch (error) {
      messageDiv.className = 'p-4 bg-red-100 text-red-800 rounded-lg';
      messageDiv.textContent = 'Error: ' + error.message + '. Please try again.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Donate Now';
      messageDiv.classList.remove('hidden');
    }
  });
</script>