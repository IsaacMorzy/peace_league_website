---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Donate">
  <Navigation />
  
  <main>
    <section class="hero-pattern bg-hero-bg text-white py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 text-5xl font-semibold leading-[1.10] tracking-tight">Give. Restore. Rebuild.</h1>
        <p class="mt-4 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-150 text-lg text-on-dark-muted">$50 can train a peace teacher. $25 can provide clean water for a family. Every dollar rebuilds a community.</p>
      </div>
    </section>

    <section class="py-16 bg-gradient-to-b from-surface to-canvas">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="flex items-center gap-2 mb-8 justify-center animate-in fade-in slide-in-from-bottom-4 duration-700">
          <div class="flex items-center gap-2">
            <div class="progress-step-circle active">1</div>
            <span class="progress-step-label active">Details</span>
          </div>
          <div class="progress-step-line active"></div>
          <div class="flex items-center gap-2">
            <div class="progress-step-circle">2</div>
            <span class="progress-step-label">Submit</span>
          </div>
          <div class="progress-step-line"></div>
          <div class="flex items-center gap-2">
            <div class="progress-step-circle">3</div>
            <span class="progress-step-label">Done</span>
          </div>
        </div>

        <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 bg-canvas/80 backdrop-blur-xl rounded-lg border border-hairline p-6 md:p-8 shadow-[0_8px_32px_rgba(0,0,0,0.06)]">
          <h2 class="text-2xl font-bold text-ink mb-4">Donate to Peace League Africa</h2>
          <p class="text-steel mb-6 text-sm">
            Your gift — whatever the size — goes directly to peace-building programs across East Africa. 
            Choose an amount below and join the movement to restore hope, one community at a time.
          </p>
          
          <form id="donation-form" class="space-y-5">
            <div>
              <label for="donor_name" class="block text-sm font-medium text-ink mb-1.5">Full Name *</label>
              <input type="text" id="donor_name" name="donor_name" required 
                class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-[16px] text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required 
                  class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-[16px] text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-ink mb-1.5">Phone</label>
                <input type="tel" id="phone" name="phone" 
                  class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-[16px] text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-ink mb-2">Select Amount</label>
              <div class="grid grid-cols-3 gap-3">
                <button type="button" class="amount-btn py-3 px-4 border border-hairline rounded-lg font-medium text-ink text-sm" data-amount="10">$10</button>
                <button type="button" class="amount-btn py-3 px-4 border border-hairline rounded-lg font-medium text-ink text-sm" data-amount="25">$25</button>
                <button type="button" class="amount-btn py-3 px-4 border border-hairline rounded-lg font-medium text-ink text-sm" data-amount="50">$50</button>
                <button type="button" class="amount-btn py-3 px-4 border border-hairline rounded-lg font-medium text-ink text-sm" data-amount="100">$100</button>
                <button type="button" class="amount-btn py-3 px-4 border border-hairline rounded-lg font-medium text-ink text-sm" data-amount="250">$250</button>
                <button type="button" class="amount-btn py-3 px-4 border border-hairline rounded-lg font-medium text-ink text-sm" data-amount="500">$500</button>
              </div>
            </div>
            
            <div>
              <label for="amount" class="block text-sm font-medium text-ink mb-1.5">Or enter custom amount ($) *</label>
              <input type="number" id="amount" name="amount" min="1" step="0.01" required placeholder="e.g. 50"
                class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-[16px] text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
            </div>
            
            <div>
              <label for="payment_method" class="block text-sm font-medium text-ink mb-1.5">Payment Method *</label>
              <select id="payment_method" name="payment_method" required 
                class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-[16px] text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none">
                <option value="">Select payment method</option>
                <option value="Credit Card">Credit Card</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="PayPal">PayPal</option>
                <option value="Mobile Money">Mobile Money</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message (Optional)</label>
              <textarea id="message" name="message" rows="2" placeholder="Tell us what inspires you to give..."
                class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-[16px] text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none"></textarea>
            </div>
            
            <div class="flex items-center">
              <input type="checkbox" id="anonymous" name="anonymous" value="1" class="w-4 h-4 text-accent border-hairline rounded focus:ring-accent" />
              <label for="anonymous" class="ml-2 text-sm text-steel">Make this donation anonymous</label>
            </div>
            
            <div class="rounded-full bg-gradient-to-r from-accent via-accent-warm to-accent p-[2px]">
              <button type="submit" id="submit-btn"
                class="submit-btn w-full bg-primary text-on-dark py-[10px] rounded-full text-sm font-medium leading-[1.30] hover:bg-charcoal transition-colors disabled:bg-hairline disabled:text-muted disabled:cursor-not-allowed inline-flex items-center justify-center gap-2">
                Complete My Donation
              </button>
            </div>
          </form>
          
          <p class="mt-6 text-sm text-stone text-center">
            All donations are tax-deductible. You will receive a receipt and a story of impact via email.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { submitDonation } from '../lib/api.js';

  const form = document.getElementById('donation-form');
  const submitBtn = document.getElementById('submit-btn');
  const amountInputs = document.querySelectorAll('.amount-btn');
  const amountField = document.getElementById('amount');
  const originalBtnHtml = submitBtn.innerHTML;

  amountInputs.forEach(btn => {
    btn.addEventListener('click', () => {
      const amount = btn.dataset.amount;
      amountField.value = amount;

      amountInputs.forEach(b => {
        b.classList.remove('selected');
        b.innerHTML = '$' + b.dataset.amount;
      });
      btn.classList.add('selected');
      btn.innerHTML = '\u2713 $' + amount;
      btn.style.animation = 'scale-pulse 0.3s ease';
      setTimeout(() => { btn.style.animation = ''; }, 300);
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.anonymous = data.anonymous === '1' ? 1 : 0;
    data.currency = 'USD';

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner"></span> Processing...';

    try {
      const response = await submitDonation(data);

      if (response.status === 'success') {
        window.showToast('Thank you! Your donation has been received and will go directly to peace-building programs. Watch your inbox for a confirmation and the story of the life you have touched.', 'success');
        submitBtn.innerHTML = '<span class="success-checkmark">\u2713</span> Done!';
        window.createConfetti(submitBtn);
        form.reset();
        amountInputs.forEach(b => {
          b.classList.remove('selected');
          b.innerHTML = '$' + b.dataset.amount;
        });
        setTimeout(() => {
          submitBtn.innerHTML = originalBtnHtml;
          submitBtn.disabled = false;
        }, 2000);
      } else {
        throw new Error(response.message || 'Failed to process donation');
      }
    } catch (error) {
      window.showToast('Error: ' + error.message + '. Please try again.', 'error');
      submitBtn.innerHTML = originalBtnHtml;
      submitBtn.disabled = false;
    }
  });
</script>
