---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Donate" description="Support peace-building across Africa. Your tax-deductible donation funds peace education, clean water, healthcare, and youth programs in 12 countries. Donate now.">
  <Navigation />
  
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "Donate", "item": "https://peaceleagueafrica.org/donate" }
      ]
    })} />
    <section class="hero-gradient hero-pattern text-white py-10 lg:py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.10] tracking-tight">Your Gift Rebuilds Communities</h1>
        <p class="mt-4 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-150 text-lg text-white/70 max-w-2xl">$50 trains a peace teacher. $25 provides clean water for a family. $500 launches a youth mentorship program. Every dollar goes to peace-building across 12 African countries.</p>
      <div class="parallax-layer" aria-hidden="true">
        <div class="parallax-bg-shape w-[300px] h-[300px] -top-[50px] -right-[80px] bg-[radial-gradient(circle,rgba(0,212,164,0.3)_0%,transparent_70%)]"></div>
        <div class="parallax-bg-shape w-[200px] h-[200px] -bottom-[40px] -left-[60px] bg-[radial-gradient(circle,rgba(245,158,11,0.2)_0%,transparent_70%)]"></div>
      </div>
      </div>
    </section>

    <section class="py-10 lg:py-14 bg-surface">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="section-divider mb-6"></div>

        <h2 class="sr-only">Donation Form</h2>

        <div class="step-indicator flex items-center justify-center gap-0 mb-10 animate-in fade-in slide-in-from-bottom-4 duration-700" role="progressbar" aria-valuenow="1" aria-valuemin="1" aria-valuemax="3" aria-label="Donation progress">
          <div class="step-item active" data-step="1">
            <div class="step-marker">
              <svg class="step-check hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span class="step-number">1</span>
            </div>
            <span class="step-label">Details</span>
          </div>
          <div class="step-connector" data-step="1"></div>
          <div class="step-item" data-step="2">
            <div class="step-marker">
              <svg class="step-check hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span class="step-number">2</span>
            </div>
            <span class="step-label">Pay</span>
          </div>
          <div class="step-connector" data-step="2"></div>
          <div class="step-item" data-step="3">
            <div class="step-marker">
              <svg class="step-check hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span class="step-number">3</span>
            </div>
            <span class="step-label">Done</span>
          </div>
        </div>

        <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 bg-canvas/80 backdrop-blur-xl rounded-2xl border border-hairline p-6 md:p-8 shadow-[0_8px_32px_rgba(0,0,0,0.08)] relative overflow-hidden">

          <div id="form-skeleton" class="space-y-5">
            <div class="skeleton-shimmer h-7 w-48 rounded-md"></div>
            <div class="skeleton-shimmer h-4 w-full rounded-md"></div>
            <div class="skeleton-shimmer h-11 w-full rounded-md"></div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="skeleton-shimmer h-11 rounded-md"></div>
              <div class="skeleton-shimmer h-11 rounded-md"></div>
            </div>
            <div class="skeleton-shimmer h-11 w-full rounded-md"></div>
            <div class="skeleton-shimmer h-11 w-full rounded-md"></div>
            <div class="skeleton-shimmer h-14 w-full rounded-full"></div>
          </div>

          <form id="donation-form" class="space-y-5 hidden" novalidate>
          <div id="form-error" class="bg-error-bg text-error p-3 rounded-md text-sm mb-4 hidden" role="alert"></div>
          <div id="form-success" class="bg-success-bg text-success p-3 rounded-md text-sm mb-4 hidden" role="alert"></div>

            <div class="relative">
              <label for="donor_name" class="block text-sm font-medium text-ink mb-1.5">Full Name *</label>
              <div class="relative">
                <input type="text" id="donor_name" name="donor_name" required autocomplete="name"
                  class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
                <svg class="field-check hidden absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <p id="donor_name-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter your full name.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="relative">
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email *</label>
                <div class="relative">
                  <input type="email" id="email" name="email" required autocomplete="email"
                    class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
                  <svg class="field-check hidden absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <p id="email-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter a valid email address.</p>
              </div>
              <div class="relative">
                <label for="phone" class="block text-sm font-medium text-ink mb-1.5">Phone <span id="phone-required-label" class="text-red-500 hidden">*</span></label>
                <div class="relative">
                  <input type="tel" id="phone" name="phone" autocomplete="tel"
                    class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
                  <svg class="field-check hidden absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <p id="phone-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Phone number is required for M-Pesa payments.</p>
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-ink mb-3">Select Amount</label>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="10">
                  <span>$10</span>
                  <span class="amount-hint absolute -top-8 left-1/2 -translate-x-1/2 bg-ink text-on-dark text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Clears landmines</span>
                </button>
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="25">
                  <span>$25</span>
                  <span class="amount-hint absolute -top-8 left-1/2 -translate-x-1/2 bg-ink text-on-dark text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Clean water for a family</span>
                </button>
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="50">
                  <span>$50</span>
                  <span class="amount-hint absolute -top-8 left-1/2 -translate-x-1/2 bg-ink text-on-dark text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Trains a peace teacher</span>
                </button>
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="100">
                  <span>$100</span>
                  <span class="amount-hint absolute -top-8 left-1/2 -translate-x-1/2 bg-ink text-on-dark text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">School supplies for 20 kids</span>
                </button>
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="250">
                  <span>$250</span>
                  <span class="amount-hint absolute -top-8 left-1/2 -translate-x-1/2 bg-ink text-on-dark text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Community health clinic</span>
                </button>
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="500">
                  <span>$500</span>
                  <span class="amount-hint absolute -top-8 left-1/2 -translate-x-1/2 bg-ink text-on-dark text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Launches youth mentorship</span>
                </button>
                <button type="button" class="amount-btn group relative py-3 px-4 border border-hairline rounded-full font-medium text-ink text-sm min-h-[44px] transition-all duration-200" data-amount="custom">
                  <span>Custom</span>
                </button>
              </div>
            </div>
            
            <div class="relative">
              <label for="amount" class="block text-sm font-medium text-ink mb-1.5">Or enter custom amount *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-steel text-base pointer-events-none">$</span>
                <input type="number" id="amount" name="amount" min="1" step="0.01" required placeholder="50.00"
                  class="input-focus-ring w-full pl-8 pr-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none" />
              </div>
              <p id="amount-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter a valid donation amount.</p>
            </div>
            
            <div class="relative">
              <label for="payment_method" class="block text-sm font-medium text-ink mb-1.5">Payment Method *</label>
              <select id="payment_method" name="payment_method" required 
                class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none">
                <option value="">Select payment method</option>
                <option value="Credit Card">Credit Card</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="PayPal">PayPal</option>
                <option value="Mobile Money">Mobile Money (M-Pesa)</option>
              </select>
              <p id="payment_method-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please select a payment method.</p>
            </div>

            <div class="relative">
              <label for="cause" class="block text-sm font-medium text-ink mb-1.5">Campaign (Optional)</label>
              <select id="cause" name="cause" class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none">
                <option value="">Select a campaign (optional)</option>
                <!-- Populated via JavaScript -->
              </select>
              <p id="cause-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please select a campaign.</p>
            </div>
            
            <div class="relative">
              <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message <span class="text-steel font-normal">(Optional)</span></label>
              <textarea id="message" name="message" rows="2" placeholder="What inspires you to give today?"
                class="input-focus-ring w-full px-3 py-[10px] border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none"></textarea>
            </div>
            
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="checkbox" id="anonymous" name="anonymous" value="1" class="mt-0.5 w-4 h-4 text-accent border-hairline rounded focus:ring-accent" />
              <span class="text-sm text-steel group-hover:text-ink transition-colors">Keep my donation anonymous — I trust Peace League with the recognition.</span>
            </label>

            <div class="flex flex-wrap gap-2 justify-center pt-1">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-surface text-xs text-steel border border-hairline transition-colors duration-200 hover:border-accent hover:text-accent">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0110 0v4"></path></svg>
                SSL Secured
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-surface text-xs text-steel border border-hairline transition-colors duration-200 hover:border-accent hover:text-accent">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"></path></svg>
                Tax Deductible
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-surface text-xs text-steel border border-hairline transition-colors duration-200 hover:border-accent hover:text-accent">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
                100% Transparent
              </span>
            </div>
            
            <div class="btn-pulse-glow rounded-full bg-gradient-to-r from-accent via-accent-warm to-accent p-[2px] shadow-lg shadow-accent/20">
              <button type="submit" id="submit-btn"
                class="submit-btn w-full bg-primary text-on-dark py-[10px] rounded-full text-sm font-medium leading-[1.30] hover:bg-charcoal transition-all duration-200 disabled:bg-hairline disabled:text-muted disabled:cursor-not-allowed disabled:shadow-none disabled:scale-100 inline-flex items-center justify-center gap-2">
                <span id="submit-btn-text">Complete My Gift</span>
                <svg id="submit-btn-arrow" class="w-4 h-4 transition-transform group-hover/submit:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle>
                  <path d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" fill="currentColor" class="opacity-75"></path>
                </svg>
              </button>
            </div>
          </form>
          
          <div id="mpesa-waiting" class="hidden text-center py-6">
            <div class="max-w-xs mx-auto">
              <div class="mb-6 flex justify-center">
                <svg class="w-32 h-auto" viewBox="0 0 120 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="10" y="5" width="100" height="190" rx="16" fill="var(--color-surface)" stroke="var(--color-hairline)" stroke-width="2"/>
                  <rect x="40" y="10" width="40" height="4" rx="2" fill="var(--color-hairline)"/>
                  <rect x="25" y="40" width="70" height="8" rx="2" fill="var(--color-accent)" opacity="0.15"/>
                  <rect x="25" y="55" width="50" height="6" rx="2" fill="var(--color-hairline)"/>
                  <rect x="25" y="85" width="70" height="40" rx="6" fill="var(--color-accent)" opacity="0.08"/>
                  <text x="60" y="108" text-anchor="middle" font-size="9" fill="var(--color-accent)" font-weight="700">M-PESA</text>
                  <rect x="25" y="135" width="70" height="6" rx="3" fill="var(--color-accent)" opacity="0.6"/>
                  <rect x="25" y="148" width="40" height="6" rx="3" fill="var(--color-hairline)"/>
                  <rect x="45" y="175" width="30" height="3" rx="1.5" fill="var(--color-hairline)"/>
                  <rect class="mpesa-screen-pulse" x="25" y="40" width="70" height="8" rx="2" fill="var(--color-accent)" opacity="0.15"/>
                </svg>
              </div>

              <div class="relative mb-5">
                <svg class="w-20 h-20 mx-auto -rotate-90" viewBox="0 0 72 72">
                  <circle cx="36" cy="36" r="30" fill="none" stroke="var(--color-hairline)" stroke-width="5"/>
                  <circle id="mpesa-timer-ring" cx="36" cy="36" r="30" fill="none" stroke="var(--color-accent)" stroke-width="5" stroke-linecap="round" stroke-dasharray="188.5" stroke-dashoffset="0" class="animate-glow transition-all duration-500 ease-linear"/>
                </svg>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-8 h-8 text-accent animate-float-slow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                </div>
              </div>

              <h3 class="text-lg font-semibold text-ink mb-2">Check Your Phone</h3>
              <p class="text-steel text-sm mb-1">An M-Pesa prompt has been sent to <span id="mpesa-display-phone" class="font-medium text-ink">your phone</span>.</p>
              <p class="text-steel text-sm mb-4">Enter your M-Pesa PIN to complete your gift.</p>
              
              <p id="mpesa-timer-text" class="text-xs text-steel mb-1">Waiting for confirmation</p>
              <div class="w-full bg-hairline rounded-full h-1.5 mb-4 max-w-xs mx-auto overflow-hidden">
                <div id="mpesa-progress-bar" class="bg-accent h-full rounded-full transition-all duration-1000 ease-linear"></div>
              </div>
              
              <p id="mpesa-retry" class="hidden mt-2">
                <button type="button" id="mpesa-retry-btn" class="inline-flex items-center gap-1.5 text-accent hover:text-accent-deep text-sm font-medium transition-colors min-h-[44px] px-4">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 102.13-9.36L1 10"></path></svg>
                  Didn't receive the prompt? Try again.
                </button>
              </p>
            </div>
          </div>

          <div id="mpesa-success" class="hidden text-center py-8">
            <div class="mb-4 flex justify-center">
              <div class="w-20 h-20 rounded-full bg-success-bg flex items-center justify-center animate-fade-in-scale">
                <svg class="w-10 h-10 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              </div>
            </div>
            <h3 class="text-2xl font-bold text-ink mb-1 animate-slide-up">Thank You!</h3>
            <p class="text-accent font-semibold text-lg mb-3 animate-fade-in-scale" id="mpesa-success-amount">$50</p>
            <p id="mpesa-receipt-info" class="text-steel text-sm mb-5">Your generous gift is already at work building peace.</p>
            
            <div id="mpesa-impact-message" class="animate-in fade-in slide-in-from-bottom-4 zoom-in-95 duration-500 delay-300 bg-surface rounded-xl p-4 mb-5 text-sm text-steel text-left max-w-sm mx-auto border border-hairline"></div>

            <div class="flex items-center justify-center gap-3">
              <a id="share-twitter" href="#" target="_blank" rel="noopener noreferrer" class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-500 inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent transition-colors min-h-[44px]" aria-label="Share on X">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Share
              </a>
              <a id="share-facebook" href="#" target="_blank" rel="noopener noreferrer" class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-700 inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent transition-colors min-h-[44px]" aria-label="Share on Facebook">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Share
              </a>
            </div>
          </div>

          <p class="mt-6 text-sm text-steel text-center">
            All donations are tax-deductible. You will receive a receipt and a story of impact via email.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
   import { submitDonation, donationStatus } from '../lib/api.js';
   import confetti from 'canvas-confetti';
   
   // Fetch active causes on page load
   document.addEventListener('DOMContentLoaded', async () => {
     try {
       const response = await fetch(`${import.meta.env.VITE_API_BASE_URL}/api/method/peace_league_website.plw_portal.doctype.cause.cause.get_active_causes`);
       const result = await response.json();
       
       if (result.status === 'success' && result.data) {
         const causeSelect = document.getElementById('cause');
         result.data.forEach(cause => {
           const option = document.createElement('option');
           option.value = cause.name;
           option.textContent = cause.title;
           causeSelect.appendChild(option);
         });
       }
     } catch (error) {
       console.error('Error fetching causes:', error);
     }
   });
   
   const form = document.getElementById('donation-form');
   const skeleton = document.getElementById('form-skeleton');
   const submitBtn = document.getElementById('submit-btn');
   const submitBtnText = document.getElementById('submit-btn-text');
   const submitBtnArrow = document.getElementById('submit-btn-arrow');
   const submitSpinner = document.getElementById('submit-spinner');
   const amountInputs = document.querySelectorAll('.amount-btn');
   const amountField = document.getElementById('amount');
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const PHONE_RE = /^\+?\d{7,15}$/;
  const mpesaWaiting = document.getElementById('mpesa-waiting');
  const mpesaSuccess = document.getElementById('mpesa-success');
  const mpesaPollStatus = document.getElementById('mpesa-poll-status');
  const mpesaRetry = document.getElementById('mpesa-retry');
  const mpesaReceiptInfo = document.getElementById('mpesa-receipt-info');
  const phoneRequiredLabel = document.getElementById('phone-required-label');
  const mpesaTimerRing = document.getElementById('mpesa-timer-ring');
  const mpesaTimerText = document.getElementById('mpesa-timer-text');
  const mpesaProgressBar = document.getElementById('mpesa-progress-bar');
  const mpesaDisplayPhone = document.getElementById('mpesa-display-phone');
  const mpesaSuccessAmount = document.getElementById('mpesa-success-amount');
  const mpesaImpactMessage = document.getElementById('mpesa-impact-message');

  const stepItems = document.querySelectorAll('.step-item');
  const stepConnectors = document.querySelectorAll('.step-connector');
  const stepIndicator = document.querySelector('.step-indicator');

  const fieldChecks = {
    donor_name: document.querySelector('#donor_name + .field-check'),
    email: document.querySelector('#email + .field-check'),
    phone: document.querySelector('#phone + .field-check'),
    amount: document.querySelector('#amount + .field-check'),
  };

  function goToStep(step) {
    stepItems.forEach((item, i) => {
      const idx = i + 1;
      item.classList.toggle('active', idx <= step);
      item.classList.toggle('completed', idx < step);
      const marker = item.querySelector('.step-marker');
      const check = item.querySelector('.step-check');
      const num = item.querySelector('.step-number');
      if (idx < step) {
        check.classList.remove('hidden');
        num.classList.add('hidden');
      } else {
        check.classList.add('hidden');
        num.classList.remove('hidden');
      }
    });
    stepConnectors.forEach((conn, i) => {
      const idx = i + 1;
      conn.classList.toggle('active', idx < step);
    });
    if (stepIndicator) {
      stepIndicator.setAttribute('aria-valuenow', String(step));
    }
  }

  function showFieldCheck(id) {
    const el = fieldChecks[id];
    if (el) el.classList.remove('hidden');
  }
  function hideFieldCheck(id) {
    const el = fieldChecks[id];
    if (el) el.classList.add('hidden');
  }

  function showFieldError(id) {
    const field = document.getElementById(id);
    const errEl = document.getElementById(id + '-error');
    if (field) field.setAttribute('aria-invalid', 'true');
    if (errEl) errEl.classList.remove('hidden');
    hideFieldCheck(id);
  }

  function clearFieldError(id) {
    const field = document.getElementById(id);
    const errEl = document.getElementById(id + '-error');
    if (field) field.removeAttribute('aria-invalid');
    if (errEl) errEl.classList.add('hidden');
  }

  function clearAllErrors() {
    formError.classList.add('hidden');
    formError.textContent = '';
    formSuccess.classList.add('hidden');
    formSuccess.textContent = '';
    ['donor_name', 'email', 'amount', 'payment_method', 'phone'].forEach(id => {
      clearFieldError(id);
      hideFieldCheck(id);
    });
  }

  function updatePhoneRequirement() {
    const method = document.getElementById('payment_method').value;
    const isMpesa = method === 'Mobile Money';
    document.getElementById('phone').required = isMpesa;
    if (phoneRequiredLabel) {
      phoneRequiredLabel.classList.toggle('hidden', !isMpesa);
    }
  }

  document.getElementById('payment_method').addEventListener('change', () => {
    clearFieldError('payment_method');
    updatePhoneRequirement();
  });

  amountInputs.forEach(btn => {
    btn.addEventListener('click', () => {
      const amount = btn.dataset.amount;
      clearFieldError('amount');

      amountInputs.forEach(b => {
        b.classList.remove('selected');
        const span = b.querySelector('span:first-child');
        if (b.dataset.amount === 'custom') {
          if (span) span.textContent = 'Custom';
        } else {
          if (span) span.textContent = '$' + b.dataset.amount;
        }
      });

      if (amount === 'custom') {
        amountField.value = '';
        amountField.focus();
      } else {
        amountField.value = amount;
        btn.classList.add('selected');
        const span = btn.querySelector('span:first-child');
        if (span) span.textContent = '\u2713 $' + amount;
      }
    });
  });

  function validateField(id) {
    const field = document.getElementById(id);
    if (!field) return true;
    const val = field.value.trim();
    let valid = true;

    clearFieldError(id);
    hideFieldCheck(id);

    if (id === 'donor_name') {
      if (!val) valid = false;
    } else if (id === 'email') {
      if (!val || !EMAIL_RE.test(val)) valid = false;
    } else if (id === 'phone') {
      const method = document.getElementById('payment_method').value;
      if (method === 'Mobile Money') {
        if (!val || !PHONE_RE.test(val)) valid = false;
      }
    } else if (id === 'amount') {
      const num = parseFloat(val);
      if (!num || num <= 0) valid = false;
    }

    if (valid) {
      if (val) showFieldCheck(id);
    } else {
      showFieldError(id);
    }
    return valid || !val;
  }

  amountField.addEventListener('blur', () => validateField('amount'));
  document.getElementById('donor_name').addEventListener('blur', () => validateField('donor_name'));
  document.getElementById('email').addEventListener('blur', () => validateField('email'));
  document.getElementById('phone').addEventListener('blur', () => validateField('phone'));

  amountField.addEventListener('input', () => { clearFieldError('amount'); hideFieldCheck('amount'); });
  document.getElementById('donor_name').addEventListener('input', () => { clearFieldError('donor_name'); hideFieldCheck('donor_name'); });
  document.getElementById('email').addEventListener('input', () => { clearFieldError('email'); hideFieldCheck('email'); });
  document.getElementById('phone').addEventListener('input', () => { clearFieldError('phone'); hideFieldCheck('phone'); });

  function validate() {
    let valid = true;
    clearAllErrors();
    const errors = [];

    const name = document.getElementById('donor_name').value.trim();
    if (!name) {
      showFieldError('donor_name');
      errors.push('Please enter your full name.');
      valid = false;
    } else {
      showFieldCheck('donor_name');
    }

    const email = document.getElementById('email').value.trim();
    if (!email) {
      showFieldError('email');
      document.getElementById('email-error').textContent = 'Please enter your email address.';
      errors.push('Please enter your email address.');
      valid = false;
    } else if (!EMAIL_RE.test(email)) {
      showFieldError('email');
      document.getElementById('email-error').textContent = 'Please enter a valid email address.';
      errors.push('Please enter a valid email address.');
      valid = false;
    } else {
      showFieldCheck('email');
    }

    const amount = parseFloat(amountField.value);
    if (!amount || amount <= 0) {
      showFieldError('amount');
      errors.push('Please enter a valid donation amount.');
      valid = false;
    } else {
      showFieldCheck('amount');
    }

    const paymentMethod = document.getElementById('payment_method').value;
    if (!paymentMethod) {
      showFieldError('payment_method');
      errors.push('Please select a payment method.');
      valid = false;
    }

    if (paymentMethod === 'Mobile Money') {
      const phone = document.getElementById('phone').value.trim();
      if (!phone) {
        showFieldError('phone');
        errors.push('Phone number is required for M-Pesa payments.');
        valid = false;
      } else if (!PHONE_RE.test(phone)) {
        showFieldError('phone');
        document.getElementById('phone-error').textContent = 'Please enter a valid phone number (e.g. 254712345678).';
        errors.push('Please enter a valid phone number.');
        valid = false;
      } else {
        showFieldCheck('phone');
      }
    }

    if (!valid) {
      formError.textContent = errors.join(' ');
      formError.classList.remove('hidden');
      formError.setAttribute('tabindex', '-1');
      formError.focus();
    }

    return valid;
  }

  function showMpesaForm(show) {
    form.classList.toggle('hidden', show);
    mpesaWaiting.classList.toggle('hidden', !show);
    if (show) goToStep(2);
  }

  function showMpesaSuccess(amount, receipt, phone) {
    mpesaWaiting.classList.add('hidden');
    mpesaSuccess.classList.remove('hidden');
    goToStep(3);
    confetti({ particleCount: 150, spread: 90, origin: { y: 0.6 } });
    setTimeout(() => confetti({ particleCount: 80, spread: 120, origin: { y: 0.5 } }), 300);

    if (amount) {
      mpesaSuccessAmount.textContent = '$' + (parseFloat(amount).toFixed(2));
    }

    if (receipt) {
      mpesaReceiptInfo.textContent = `M-Pesa Receipt: ${receipt}. Thank you for your generous gift!`;
    } else {
      mpesaReceiptInfo.textContent = 'Thank you for your generous gift! A receipt will be sent to your email.';
    }

    const amt = parseFloat(amount) || 50;
    let impactText = '';
    if (amt >= 500) {
      impactText = 'Your gift of $' + amt.toFixed(2) + ' can launch an entire youth mentorship program — reaching dozens of young leaders with peace education, leadership training, and community service projects. You are building the next generation of peacebuilders.';
    } else if (amt >= 100) {
      impactText = 'Your gift of $' + amt.toFixed(2) + ' can provide school supplies for 20 children, giving them the tools they need to learn, grow, and build a peaceful future for their communities.';
    } else if (amt >= 50) {
      impactText = 'Your gift of $' + amt.toFixed(2) + ' can train a peace teacher who will go on to educate hundreds of students in conflict resolution, empathy, and non-violent communication.';
    } else if (amt >= 25) {
      impactText = 'Your gift of $' + amt.toFixed(2) + ' can provide clean water for a family, reducing waterborne disease and giving children more time to attend school.';
    } else {
      impactText = 'Every dollar counts. Your gift of $' + amt.toFixed(2) + ' goes directly to peace-building programs across 12 African countries. You are making a real difference.';
    }
    mpesaImpactMessage.textContent = impactText;

    const shareUrl = 'https://peaceleagueafrica.org/donate';
    document.getElementById('share-twitter').href = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent('I just donated to Peace League Africa! Join me in building peace across Africa. ' + shareUrl);
    document.getElementById('share-facebook').href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(shareUrl);


  }

  function showMpesaError(msg) {
    mpesaWaiting.classList.add('hidden');
    form.classList.remove('hidden');
    goToStep(1);
    formError.textContent = msg + '. Please try again.';
    formError.classList.remove('hidden');
    submitBtnText.textContent = 'Complete My Gift';
    submitBtnArrow.classList.remove('hidden');
    submitSpinner.classList.add('hidden');
    submitBtn.disabled = false;
  }

  async function pollMpesaStatus(checkoutRequestId, phone) {
    let attempts = 0;
    const maxAttempts = 40;
    const totalDuration = maxAttempts * 3000;
    const circumference = 188.5;

    while (attempts < maxAttempts) {
      attempts++;
      const elapsed = attempts * 3000;
      const pct = Math.min((elapsed / totalDuration) * 100, 99);
      const offset = circumference - (circumference * pct / 100);

      mpesaTimerRing.style.strokeDashoffset = offset;
      mpesaProgressBar.style.width = pct + '%';

      if (pct < 50) {
        mpesaTimerText.textContent = 'Waiting for payment confirmation...';
      } else if (pct < 80) {
        mpesaTimerText.textContent = 'Still waiting... check your phone';
      } else {
        mpesaTimerText.textContent = 'Almost there!';
      }

      try {
        const result = await donationStatus(checkoutRequestId);
        if (result.status === 'success' && result.data) {
          if (result.data.paid) {
            mpesaTimerRing.style.strokeDashoffset = '0';
            mpesaProgressBar.style.width = '100%';
            showMpesaSuccess(result.data.amount || amountField.value, result.data.receipt, phone);
            return;
          }
          if (result.data.status === 'Failed') {
            showMpesaError('Payment was declined');
            return;
          }
        }
      } catch (e) {
      }

      await new Promise(r => setTimeout(r, 3000));
    }

    showMpesaError('Payment confirmation timed out. Check your M-Pesa messages for the receipt.');
  }

  setTimeout(() => {
    skeleton.classList.add('hidden');
    form.classList.remove('hidden');
  }, 600);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!validate()) return;

    updatePhoneRequirement();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.anonymous = data.anonymous === '1' ? 1 : 0;
    data.currency = 'USD';
    data.payment_method = data.payment_method === 'Mobile Money' ? 'MPesa' : data.payment_method;

    submitBtn.disabled = true;
    submitBtnText.textContent = 'Processing...';
    submitBtnArrow.classList.add('hidden');
    submitSpinner.classList.remove('hidden');

    try {
      const response = await submitDonation(data);

      if (response.status === 'success') {
        if (response.data && response.data.mpesa_pending) {
          const phone = document.getElementById('phone').value.trim();
          const masked = phone.length > 4 ? '****' + phone.slice(-4) : phone;
          mpesaDisplayPhone.textContent = masked;
          showMpesaForm(true);
          pollMpesaStatus(response.data.checkout_request_id, phone);
        } else {
          formSuccess.textContent = 'Thank you! Your donation has been received. Watch your inbox for confirmation.';
          formSuccess.classList.remove('hidden');
          setTimeout(() => { formSuccess.classList.add('hidden'); }, 8000);
          submitBtnText.textContent = '\u2713 Done!';
          submitBtnArrow.classList.add('hidden');
          submitSpinner.classList.add('hidden');

          form.reset();
          amountInputs.forEach(b => {
            b.classList.remove('selected');
            const span = b.querySelector('span:first-child');
            if (span) span.textContent = '$' + b.dataset.amount;
          });
          goToStep(3);
          setTimeout(() => {
            submitBtnText.textContent = 'Complete My Gift';
            submitBtnArrow.classList.remove('hidden');
            submitBtn.disabled = false;
            goToStep(1);
          }, 2500);
        }
      } else {
        throw new Error(response.message || 'Failed to process donation');
      }
    } catch (error) {
      formError.textContent = 'Error: ' + error.message + '. Please try again.';
      formError.classList.remove('hidden');
      submitBtnText.textContent = 'Complete My Gift';
      submitBtnArrow.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
      submitBtn.disabled = false;
    }
  });
</script>