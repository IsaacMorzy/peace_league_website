---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const categories = ['All', 'Education', 'Health', 'Events', 'Community'];

const galleryImages = [
  { src: 'photo-1497633762265-9d179a990aa6', alt: 'Students in a peace education classroom', category: 'Education', desc: 'Students engaging with our peace curriculum in a classroom in Nairobi, learning conflict resolution and empathy skills.' },
  { src: 'photo-1559027615-cd4628902d4a', alt: 'Youth leadership workshop participants', category: 'Education', desc: 'Young leaders from across East Africa participate in an intensive workshop on civic engagement and public speaking.' },
  { src: 'photo-1571019613454-1cb2f99b2d8b', alt: 'Community health outreach workers', category: 'Health', desc: 'Our mobile clinic team provides free health screenings and nutrition counseling to rural communities.' },
  { src: 'photo-1534430480872-3498386e7856', alt: 'Clean water well inauguration ceremony', category: 'Community', desc: 'Celebrating the inauguration of our 50th clean water well, providing safe drinking water to thousands.' },
  { src: 'photo-1540575467063-178a50c2df87', alt: 'Annual gala fundraising event', category: 'Events', desc: 'Our annual gala brings together supporters, partners, and beneficiaries for an evening of inspiration.' },
  { src: 'photo-1507003211169-0a1dd7228f2d', alt: 'Youth peace club gathering', category: 'Community', desc: 'Peace club members meet weekly to organize community service projects and peace-building activities.' },
  { src: 'photo-1543269865-cbf427effbad', alt: 'Community dialogue session', category: 'Events', desc: 'Community members gather for an open dialogue on reconciliation and building trust across divides.' },
  { src: 'photo-1488521787991-ed7bbaae773c', alt: 'School supplies distribution', category: 'Education', desc: 'Distributing school supplies to children in underserved communities to support access to education.' },
  { src: 'photo-1488521787991-ed7bbaae773c', alt: 'Women empowerment workshop', category: 'Community', desc: 'Women entrepreneurs gather for a workshop on financial literacy, leadership, and business skills.' },
];
---

<Layout title="Gallery" description="Browse Peace League Africa's photo gallery featuring peace education, community health, clean water, and youth empowerment moments from across Africa.">
  <Navigation />

  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "Gallery", "item": "https://peaceleagueafrica.org/gallery" }
      ]
    })} />
    <section class="hero-gradient text-white py-4 lg:py-8 hero-pattern">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight">Our Gallery</h1>
          <p class="mt-4 text-lg text-white/80 max-w-2xl">From a child's first day at school to a community's first clean water well — see the faces and places behind 10 years of peace-building across Africa.</p>
        </div>
        <div class="parallax-layer" aria-hidden="true">
          <div class="parallax-bg-shape" style="width:300px;height:300px;top:-50px;right:-80px;background:radial-gradient(circle, rgba(0,212,164,0.3) 0%, transparent 70%);"></div>
          <div class="parallax-bg-shape" style="width:200px;height:200px;bottom:-40px;left:-60px;background:radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);"></div>
        </div>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-2 mb-12 justify-center" id="gallery-filters">
          {categories.map((cat, idx) => (
            <button data-category={cat.toLowerCase()} aria-pressed={idx === 0 ? 'true' : 'false'} class={`gallery-filter px-5 py-2 text-sm rounded-full border transition-all duration-300 cursor-pointer hover:-translate-y-0.5 min-h-[44px] ${idx === 0 ? 'bg-primary text-on-primary border-primary' : 'bg-canvas text-steel border-hairline hover:border-accent hover:text-accent'}`}>
              {cat}
            </button>
          ))}
        </div>

        <div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4" id="gallery-grid">
          {galleryImages.map((img, idx) => (
            <div class="gallery-item scroll-reveal animate-in fade-in slide-in-from-bottom-4 break-inside-avoid rounded-2xl overflow-hidden border border-hairline transition-all duration-300 hover:-translate-y-1 hover:shadow-lg group cursor-pointer" data-category={img.category.toLowerCase()} style={`animation-delay: ${idx * 50}ms`}>
              <div class="relative overflow-hidden img-zoom">
                <img src={`https://images.unsplash.com/${img.src}?w=600&q=85&auto=format&fit=crop`} alt={img.alt} class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-108" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
                  <p class="text-white text-sm p-4 font-medium">{img.desc}</p>
                </div>
              </div>
              <div class="p-4 bg-canvas">
                <span class="text-xs font-medium text-accent uppercase tracking-wider">{img.category}</span>
                <p class="text-sm text-ink mt-1">{img.alt}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Follow Us</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Follow our journey across 12 countries — daily stories of hope, resilience, and peace-building from the field.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">Twitter / X</h3>
            <p class="text-sm text-steel mb-4">Daily updates and stories from the field.</p>
            <a href="https://twitter.com/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent hover:text-accent-deep transition-colors">@PeaceLeagueAfrica</a>
          </div>
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg" style="animation-delay: 50ms">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 4.948C.014 8.316 0 8.754 0 12c0 3.259.014 3.668.072 4.948.2 2.248 2.628 4.676 4.98 4.676 1.266.057 1.645.069 4.85.069 3.259 0 3.668-.014 4.848-.072 2.248-.2 4.676-2.628 4.676-4.98-.072-3.259-.072-3.668-.072-4.948 0-3.246-.2-4.678-4.676-4.978C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">Instagram</h3>
            <p class="text-sm text-steel mb-4">Visual stories of impact and hope.</p>
            <a href="https://instagram.com/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent hover:text-accent-deep transition-colors">@peaceleagueafrica</a>
          </div>
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg" style="animation-delay: 100ms">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">LinkedIn</h3>
            <p class="text-sm text-steel mb-4">Professional updates and partnerships.</p>
            <a href="https://linkedin.com/company/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent hover:text-accent-deep transition-colors">Peace League Africa</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 hero-gradient text-white hero-pattern">
      <div class="max-w-3xl mx-auto text-center px-4">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px]">Share Your Photos</h2>
        <p class="scroll-reveal mt-4 text-lg text-white/80 mb-8">Your peace-building moments deserve to be seen. Tag us and use <span class="text-accent font-semibold">#PeaceBuiltHere</span> to be featured across our channels.</p>
        <div class="scroll-reveal flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-3 bg-white text-primary font-medium text-sm rounded-full hover:bg-white/90 transition-colors shadow-lg">
            Follow on Instagram
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const filterBtns = document.querySelectorAll('.gallery-filter');
    const items = document.querySelectorAll('.gallery-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.className = 'gallery-filter px-5 py-2 text-sm rounded-full border transition-all duration-300 cursor-pointer bg-canvas text-steel border-hairline hover:border-accent hover:text-accent';
          b.setAttribute('aria-pressed', 'false');
        });
        btn.className = 'gallery-filter px-5 py-2 text-sm rounded-full border transition-all duration-300 cursor-pointer bg-primary text-on-primary border-primary';
        btn.setAttribute('aria-pressed', 'true');

        const cat = btn.dataset.category;
        items.forEach(item => {
          if (cat === 'all' || item.dataset.category === cat) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  </script>
</Layout>
