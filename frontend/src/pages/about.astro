---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us">
  <Navigation />
  
  <main>
    <section class="bg-hero-bg text-white py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-5xl font-semibold leading-[1.10] tracking-tight">About Peace League Africa</h1>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-steel leading-relaxed space-y-4">
          <h2 class="scroll-reveal text-3xl font-semibold text-ink leading-[1.20] tracking-tight">Our Mission</h2>
          <p>
            Peace League Africa exists because conflict steals futures — and peace can restore them. 
            We work alongside communities in East Africa and the Great Lakes region to replace 
            division with dialogue, poverty with opportunity, and despair with hope.
          </p>
          
          <h2 class="scroll-reveal text-3xl font-semibold text-ink leading-[1.20] tracking-tight">Our History</h2>
          <p>
            What began in 2015 as a single peace workshop in a Nairobi community hall has grown into 
            a movement spanning 12 African countries. Today, our programs reach more than 50,000 
            people annually — from conflict-resolution classrooms in Kampala to reconciliation 
            dialogues in Kigali and clean-water initiatives in rural Kenya.
          </p>
          
          <h2 class="scroll-reveal text-3xl font-semibold text-ink leading-[1.20] tracking-tight">Our Values</h2>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Compassion:</strong> Every child, every mother, every elder we serve deserves to be seen, heard, and valued — not as a beneficiary, but as family.</li>
            <li><strong>Integrity:</strong> 95% of donations go directly to programs. Our books are open, our decisions are transparent, and our promises are kept.</li>
            <li><strong>Innovation:</strong> From mobile-money giving platforms to community radio peace programs, we meet challenges with African creativity — not imported templates.</li>
            <li><strong>Sustainability:</strong> We don't just build wells; we train local water committees. We don't just teach peace; we train teachers to carry the work forward.</li>
            <li><strong>Inclusivity:</strong> Whether you are a farmer in Goma, a student in Nairobi, or a donor in London — if you believe in peace, you belong here.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-3xl font-semibold text-ink text-center mb-12 leading-[1.20] tracking-tight">Our Chapters</h2>
        <div id="chapters-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="space-y-2">
              <div class="skeleton-shimmer h-5 w-40"></div>
              <div class="skeleton-shimmer h-3 w-24"></div>
              <div class="skeleton-shimmer h-3 w-full"></div>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="space-y-2">
              <div class="skeleton-shimmer h-5 w-40"></div>
              <div class="skeleton-shimmer h-3 w-24"></div>
              <div class="skeleton-shimmer h-3 w-full"></div>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="space-y-2">
              <div class="skeleton-shimmer h-5 w-40"></div>
              <div class="skeleton-shimmer h-3 w-24"></div>
              <div class="skeleton-shimmer h-3 w-full"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-3xl font-semibold text-ink text-center mb-4 leading-[1.20] tracking-tight">Why Peace League Africa</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Four reasons our partners trust us to deliver lasting change in some of Africa's most challenging communities.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 delay-0 bg-surface rounded-lg p-8 border border-hairline text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30" style="view-transition-name: why-1;">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">Proven Impact</h3>
            <p class="mt-3 text-steel text-sm leading-relaxed">Over a decade of measurable results across 12 African countries, with 95% of donations going directly to program delivery.</p>
          </div>
          <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 delay-100 bg-surface rounded-lg p-8 border border-hairline text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30" style="view-transition-name: why-2;">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">Community-Led Approach</h3>
            <p class="mt-3 text-steel text-sm leading-relaxed">We work hand-in-hand with local leaders to design programs that respect cultural context and empower communities to lead their own development.</p>
          </div>
          <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200 bg-surface rounded-lg p-8 border border-hairline text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30" style="view-transition-name: why-3;">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">Transparent & Accountable</h3>
            <p class="mt-3 text-steel text-sm leading-relaxed">Full financial transparency with annual audited reports, real-time project tracking, and direct communication with the communities you support.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';

    async function fetchChapters() {
      try {
        const response = await fetch(`${API_BASE_URL}/api/method/peace_league_website.api.get_chapters`);
        if (!response.ok) return;
        const json = await response.json();
        const data = json.message || json;
        if (data.status === 'success' && data.data && data.data.length > 0) {
          const container = document.getElementById('chapters-list');
          container.innerHTML = data.data.map((chapter, idx) => `
            <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
              <h3 class="text-lg font-semibold text-accent-deep">${chapter.introduction || ''}</h3>
              ${chapter.region ? `<p class="mt-1 text-sm text-stone">${chapter.region}</p>` : ''}
              ${chapter.address ? `<p class="mt-2 text-steel text-sm line-clamp-2">${chapter.address}</p>` : ''}
            </div>
          `).join('');
          // AOS removed
        }
      } catch (e) {
        console.log('API not available, using static content');
      }
    }
    fetchChapters();
  </script>
</Layout>
