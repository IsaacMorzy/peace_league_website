---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';


const milestones = [
  { year: '2015', title: 'First Peace Workshop', desc: 'A single peace workshop in a Nairobi community hall — 47 people, one room, and a vision that would change thousands of lives.' },
  { year: '2017', title: 'Expansion to Uganda', desc: 'Our first cross-border program launched in Kampala, training teachers in conflict resolution techniques for post-conflict classrooms.' },
  { year: '2018', title: 'Clean Water Initiative', desc: 'Began drilling wells in Turkana, Kenya, reaching 12 remote communities with clean water access for the first time.' },
  { year: '2019', title: 'Youth Leadership Program', desc: 'Launched regional youth peace summits bringing together 500 young leaders from 8 countries for dialogue and action planning.' },
  { year: '2020', title: 'COVID-19 Response', desc: 'Pivoted to deliver emergency food aid and health education across 5 countries, reaching 20,000+ families during the pandemic.' },
  { year: '2021', title: '12-Country Reach', desc: 'Expanded operations to all 12 countries across East Africa and the Great Lakes region. 50+ staff and 1,000+ volunteers strong.' },
  { year: '2023', title: '50,000 Lives Impacted', desc: 'Crossed the milestone of 50,000 lives directly impacted through peace education, healthcare, water, and youth programs.' },
  { year: '2025', title: 'Peace Built Here', desc: 'Launched the Peace League Africa digital platform, connecting donors directly with communities and bringing transparency to every dollar.' },
];
---

<Layout title="About Us" description="Peace League Africa is a peace-building organization transforming conflict into hope across 12 African countries. Learn about our mission, history, values, and impact.">
  <Navigation />
  
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "About Us", "item": "https://peaceleagueafrica.org/about" }
      ]
    })} />
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
      <!-- Ambient orbs -->
      <div class="orb-float orb-float--1" style="top:-100px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-80px;left:-80px;" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.10] tracking-tight">About Peace League Africa</h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl">From a single peace workshop in 2015 to a movement spanning 12 countries — we replace division with dialogue, poverty with opportunity, and despair with hope.</p>
      </div>
      <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <!-- Doves flying (natural swooping arcs) -->
        <span class="animate-dove-drift" style="left:18%;bottom:-20%;animation-delay:0.5s;font-size:1.125rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow" style="left:55%;bottom:-25%;animation-delay:2s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift" style="left:82%;bottom:-15%;animation-delay:3.5s;font-size:1rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <!-- Hearts pulsing -->
        <!-- Sparkle particles -->
        <span class="animate-particle" style="left:10%;bottom:5%;width:4px;height:4px;border-radius:50%;background:var(--color-accent);animation-delay:1s;"></span>
        <span class="animate-particle--fast" style="left:25%;bottom:10%;width:3px;height:3px;border-radius:50%;background:var(--color-accent-soft);animation-delay:0.3s;"></span>
        <span class="animate-particle" style="left:40%;bottom:8%;width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.4);animation-delay:2s;"></span>
        <span class="animate-particle--glow" style="left:60%;bottom:0;color:var(--color-accent);animation-delay:1.5s;font-size:1.2rem;">&#x2726;</span>
        <span class="animate-particle--fast" style="left:75%;bottom:15%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:2.5s;"></span>
        <span class="animate-particle" style="left:90%;bottom:5%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-16">
          <div>
            <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink">Our Mission</h2>
            <p class="mt-4 text-steel leading-relaxed">
              Peace League Africa exists because conflict steals futures — and peace can restore them. 
              We work alongside communities in East Africa and the Great Lakes region to replace 
              division with dialogue, poverty with opportunity, and despair with hope.
            </p>
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-3 bg-white/60 rounded-xl p-4 border border-hairline transition-transform transition-shadow duration-300 hover:-translate-y-0.5 hover:shadow-sm">
                <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-sm text-ink">Dialogue &amp; Mediation</h3>
                  <p class="text-xs text-steel mt-0.5 leading-relaxed">Trained mediators facilitate community dialogues that resolve conflicts before they escalate — 87% of mediated disputes reach lasting agreements.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 bg-white/60 rounded-xl p-4 border border-hairline transition-transform transition-shadow duration-300 hover:-translate-y-0.5 hover:shadow-sm">
                <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-sm text-ink">Community Empowerment</h3>
                  <p class="text-xs text-steel mt-0.5 leading-relaxed">We train local leaders and equip communities with the tools, resources, and ownership to sustain their own peace-building long after we leave.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 bg-white/60 rounded-xl p-4 border border-hairline transition-transform transition-shadow duration-300 hover:-translate-y-0.5 hover:shadow-sm">
                <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-sm text-ink">Sustainable Development</h3>
                  <p class="text-xs text-steel mt-0.5 leading-relaxed">Clean water wells, school construction, and livelihood programs address the root causes of conflict — poverty, inequality, and lack of opportunity.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="scroll-reveal relative">
            <img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=600&q=80&auto=format&fit=crop" alt="Peace League Africa community gathering" class="rounded-lg w-full h-auto object-cover shadow-lg" loading="lazy" />
            <div class="absolute -bottom-3 -right-3 w-full h-full border-2 border-accent/20 rounded-lg -z-10"></div>
          </div>
        </div>

        <div class="max-w-4xl mx-auto space-y-4 mb-16">
          <div class="section-divider ml-0 mb-6"></div>
          <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink">Our History</h2>
          <p class="text-steel leading-relaxed">
            What began in 2015 as a single peace workshop in a Nairobi community hall has grown into 
            a movement spanning 12 African countries. Today, our programs reach more than 50,000 
            people annually — from conflict-resolution classrooms in Kampala to reconciliation 
            dialogues in Kigali and clean-water initiatives in rural Kenya.
          </p>
        </div>

        <div class="max-w-5xl mx-auto">
          <div class="section-divider mb-6"></div>
          <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Our Values</h2>
          <div class="cascade-grid grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            <div class="cascade-item scroll-reveal bg-surface rounded-2xl p-6 border border-hairline transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center mb-3">
                <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              </div>
              <h3 class="font-semibold text-ink">Compassion</h3>
              <p class="text-steel text-sm mt-1 leading-relaxed">Every child, every mother, every elder we serve deserves to be seen, heard, and valued — not as a beneficiary, but as family.</p>
            </div>
            <div class="cascade-item scroll-reveal bg-surface rounded-2xl p-6 border border-hairline transition-all duration-300 hover:-translate-y-1 hover:shadow-md" style="animation-delay: 50ms">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center mb-3">
                <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <h3 class="font-semibold text-ink">Integrity</h3>
              <p class="text-steel text-sm mt-1 leading-relaxed">95% of donations go directly to programs. Our books are open, our decisions are transparent, and our promises are kept.</p>
            </div>
            <div class="cascade-item scroll-reveal bg-surface rounded-2xl p-6 border border-hairline transition-all duration-300 hover:-translate-y-1 hover:shadow-md" style="animation-delay: 100ms">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center mb-3">
                <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </div>
              <h3 class="font-semibold text-ink">Innovation</h3>
              <p class="text-steel text-sm mt-1 leading-relaxed">From mobile-money giving platforms to community radio peace programs, we meet challenges with African creativity — not imported templates.</p>
            </div>
            <div class="cascade-item scroll-reveal bg-surface rounded-2xl p-6 border border-hairline transition-all duration-300 hover:-translate-y-1 hover:shadow-md" style="animation-delay: 150ms">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center mb-3">
                <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </div>
              <h3 class="font-semibold text-ink">Sustainability</h3>
              <p class="text-steel text-sm mt-1 leading-relaxed">We do not just build wells; we train local water committees. We do not just teach peace; we train teachers to carry the work forward.</p>
            </div>
            <div class="cascade-item scroll-reveal bg-surface rounded-2xl p-6 border border-hairline transition-all duration-300 hover:-translate-y-1 hover:shadow-md md:col-span-2 max-w-md mx-auto w-full" style="animation-delay: 200ms">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center mb-3">
                <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              </div>
              <h3 class="font-semibold text-ink">Inclusivity</h3>
              <p class="text-steel text-sm mt-1 leading-relaxed">Whether you are a farmer in Goma, a student in Nairobi, or a donor in London — if you believe in peace, you belong here.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 lg:py-16 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="section-divider mb-6"></div>
        <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Our Chapters</h2>
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-start">
          <div class="lg:col-span-3">
            <div id="chapters-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-canvas rounded-2xl border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="space-y-2">
                  <div class="skeleton-shimmer h-5 w-40"></div>
                  <div class="skeleton-shimmer h-3 w-24"></div>
                  <div class="skeleton-shimmer h-3 w-full"></div>
                </div>
              </div>
              <div class="bg-canvas rounded-2xl border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="space-y-2">
                  <div class="skeleton-shimmer h-5 w-40"></div>
                  <div class="skeleton-shimmer h-3 w-24"></div>
                  <div class="skeleton-shimmer h-3 w-full"></div>
                </div>
              </div>
              <div class="bg-canvas rounded-2xl border border-hairline p-6 border-l-4 border-l-accent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="space-y-2">
                  <div class="skeleton-shimmer h-5 w-40"></div>
                  <div class="skeleton-shimmer h-3 w-24"></div>
                  <div class="skeleton-shimmer h-3 w-full"></div>
                </div>
              </div>
            </div>
            <p id="chapters-error" role="status" class="mt-4 text-sm text-accent-warm-link hidden">Unable to load chapters right now. Showing saved content.</p>
          </div>
          <div class="lg:col-span-1 hidden lg:block">
            <div class="sticky top-24">
              <svg viewBox="0 0 200 200" fill="none" stroke="currentColor" class="w-full h-auto text-accent ring-glow-svg">
                <defs>
                  <filter id="ring-glow">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feMerge>
                      <feMergeNode in="blur" />
                      <feMergeNode in="SourceGraphic" />
                    </feMerge>
                  </filter>
                </defs>
                <circle cx="100" cy="100" r="85" stroke-width="1" stroke-dasharray="4 4" opacity="0.35" filter="url(#ring-glow)"/>
                <circle cx="100" cy="100" r="65" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.4"/>
                <circle cx="100" cy="100" r="45" stroke-width="0.8" stroke-dasharray="2 2" opacity="0.6"/>
                <g opacity="0.3">
                  <line x1="100" y1="15" x2="100" y2="185" stroke-width="0.5"/>
                  <line x1="15" y1="100" x2="185" y2="100" stroke-width="0.5"/>
                  <line x1="40" y1="40" x2="160" y2="160" stroke-width="0.5"/>
                  <line x1="160" y1="40" x2="40" y2="160" stroke-width="0.5"/>
                </g>
                <circle cx="100" cy="100" r="10" fill="currentColor" opacity="0.8"/>
                <circle cx="100" cy="18" r="5" fill="currentColor" opacity="0.5"/>
                <circle cx="182" cy="100" r="5" fill="currentColor" opacity="0.5"/>
                <circle cx="100" cy="182" r="5" fill="currentColor" opacity="0.5"/>
                <circle cx="18" cy="100" r="5" fill="currentColor" opacity="0.5"/>
                <circle cx="62" cy="62" r="3.5" fill="currentColor" opacity="0.35"/>
                <circle cx="138" cy="62" r="3.5" fill="currentColor" opacity="0.35"/>
                <circle cx="62" cy="138" r="3.5" fill="currentColor" opacity="0.35"/>
                <circle cx="138" cy="138" r="3.5" fill="currentColor" opacity="0.35"/>
                <circle cx="145" cy="40" r="3" fill="currentColor" opacity="0.25"/>
                <circle cx="55" cy="40" r="3" fill="currentColor" opacity="0.25"/>
                <circle cx="40" cy="145" r="3" fill="currentColor" opacity="0.25"/>
                <circle cx="160" cy="145" r="3" fill="currentColor" opacity="0.25"/>
              </svg>
              <p class="text-center text-xs text-steel mt-3">Connected across 12 countries</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 lg:py-16 bg-gradient-to-br from-accent/5 via-canvas to-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <div class="section-divider mb-6"></div>
          <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Our Impact by the Numbers</h2>
          <p class="scroll-reveal text-lg text-steel text-center max-w-2xl mx-auto mb-12">Real results across every program we run.</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
          <div class="scroll-reveal text-center">
            <div class="big-stat-value text-4xl md:text-5xl font-bold text-accent-glow" data-count-target="12" data-count-suffix="">0</div>
            <div class="mt-2 text-ink font-semibold">Countries</div>
            <p class="mt-1 text-xs text-steel">Across East &amp; Central Africa</p>
          </div>
          <div class="scroll-reveal text-center" style="animation-delay: 100ms">
            <div class="big-stat-value text-4xl md:text-5xl font-bold text-accent-glow" data-count-target="500" data-count-suffix="+">0+</div>
            <div class="mt-2 text-ink font-semibold">Communities</div>
            <p class="mt-1 text-xs text-steel">Served and growing</p>
          </div>
          <div class="scroll-reveal text-center" style="animation-delay: 200ms">
            <div class="big-stat-value text-4xl md:text-5xl font-bold text-accent-glow" data-count-target="50000" data-count-suffix="+">0+</div>
            <div class="mt-2 text-ink font-semibold">Lives Impacted</div>
            <p class="mt-1 text-xs text-steel">Through programs and outreach</p>
          </div>
          <div class="scroll-reveal text-center" style="animation-delay: 300ms">
            <div class="big-stat-value text-4xl md:text-5xl font-bold text-accent-glow" data-count-target="1200" data-count-suffix="+">0+</div>
            <div class="mt-2 text-ink font-semibold">Volunteers</div>
            <p class="mt-1 text-xs text-steel">Active across all programs</p>
          </div>
          <div class="scroll-reveal text-center" style="animation-delay: 400ms">
            <div class="big-stat-value text-4xl md:text-5xl font-bold text-accent-glow" data-count-prefix="$" data-count-target="500000" data-count-suffix="+">$0+</div>
            <div class="mt-2 text-ink font-semibold">Funds Raised</div>
            <p class="mt-1 text-xs text-steel">For community-driven programs</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 lg:py-16 bg-surface overflow-hidden">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="section-divider mb-6"></div>
        <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Our Journey</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-16">From a single room in Nairobi to 12 countries — every milestone brought us closer to a more peaceful Africa.</p>
        <div class="relative">
