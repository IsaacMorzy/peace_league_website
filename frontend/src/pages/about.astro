---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us">
  <Navigation />
  
  <main>
    <section class="bg-hero-bg text-white py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-5xl font-semibold leading-[1.10] tracking-tight" data-aos="fade-down">About Peace League Africa</h1>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-steel leading-relaxed space-y-4">
          <h2 class="text-3xl font-semibold text-ink leading-[1.20] tracking-tight" data-aos="fade-up">Our Mission</h2>
          <p data-aos="fade-up" data-aos-delay="100">
            Peace League Africa is dedicated to fostering peace, understanding, and sustainable 
            development across the African continent. We believe that through education, 
            community engagement, and compassion, we can create lasting positive change.
          </p>
          
          <h2 class="text-3xl font-semibold text-ink leading-[1.20] tracking-tight" data-aos="fade-up">Our History</h2>
          <p data-aos="fade-up" data-aos-delay="100">
            Founded with a vision of unity, Peace League Africa has grown from a small 
            grassroots movement into a continental force for good. Our programs span multiple 
            countries and touch the lives of thousands each year.
          </p>
          
          <h2 class="text-3xl font-semibold text-ink leading-[1.20] tracking-tight" data-aos="fade-up">Our Values</h2>
          <ul class="list-disc pl-5 space-y-1" data-aos="fade-up" data-aos-delay="100">
            <li><strong>Compassion:</strong> We lead with empathy in all our interactions</li>
            <li><strong>Integrity:</strong> We operate with transparency and accountability</li>
            <li><strong>Innovation:</strong> We seek creative solutions to complex challenges</li>
            <li><strong>Sustainability:</strong> We build programs that last</li>
            <li><strong>Inclusivity:</strong> We welcome all who share our vision</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-semibold text-ink text-center mb-12 leading-[1.20] tracking-tight" data-aos="fade-up">Our Chapters</h2>
        <div id="chapters-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent" data-aos="fade-up" data-aos-delay="0">
            <h3 class="text-lg font-semibold text-accent-deep">Nairobi Chapter</h3>
            <p class="mt-1 text-sm text-stone">Kenya</p>
            <p class="mt-2 text-steel text-sm line-clamp-2">Leading community initiatives in Kenya's capital city.</p>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent" data-aos="fade-up" data-aos-delay="100">
            <h3 class="text-lg font-semibold text-accent-deep">Lagos Chapter</h3>
            <p class="mt-1 text-sm text-stone">Nigeria</p>
            <p class="mt-2 text-steel text-sm line-clamp-2">Empowering communities in Nigeria's largest city.</p>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent" data-aos="fade-up" data-aos-delay="200">
            <h3 class="text-lg font-semibold text-accent-deep">Johannesburg Chapter</h3>
            <p class="mt-1 text-sm text-stone">South Africa</p>
            <p class="mt-2 text-steel text-sm line-clamp-2">Driving change in South Africa's economic hub.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';
    
    async function fetchChapters() {
      try {
        const response = await fetch(`${API_BASE_URL}/api/method/peace_league_website.api.get_chapters`);
        if (!response.ok) return;
        const data = await response.json();
        if (data.status === 'success' && data.data && data.data.length > 0) {
          const container = document.getElementById('chapters-list');
          container.innerHTML = data.data.map((chapter, idx) => `
            <div class="bg-canvas rounded-lg border border-hairline p-6 border-l-4 border-l-accent" data-aos="fade-up" data-aos-delay="${idx * 100}">
              <h3 class="text-lg font-semibold text-accent-deep">${chapter.introduction || ''}</h3>
              ${chapter.region ? `<p class="mt-1 text-sm text-stone">${chapter.region}</p>` : ''}
              ${chapter.address ? `<p class="mt-2 text-steel text-sm line-clamp-2">${chapter.address}</p>` : ''}
            </div>
          `).join('');
        }
      } catch (e) {
        console.log('API not available, using static content');
      }
    }
    fetchChapters();
  </script>
</Layout>
