---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import posts from '../../lib/blog-data.json';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// ── Parse table of contents from HTML content ──
const headingRegex = /<h(?<level>[23])\s*[^>]*?id="(?<id>[^"]*)"[^>]*>(?<text>.*?)<\/h\1>/gs;
const tocFallback = /<h(?<level>[23])[^>]*>(?<text>.*?)<\/h\1>/gs;

// First try with IDs, then fallback
let tocEntries = [];
let match;
const idRegex = /<h(?<level>[23])\s*[^>]*?id="([^"]*)"[^>]*>(.*?)<\/h\1>/gs;

while ((match = idRegex.exec(post.content)) !== null) {
  tocEntries.push({
    level: parseInt(match[1]),
    id: match[2],
    text: match[3].replace(/<[^>]*>/g, ''),
  });
}

// Fallback: no IDs found, generate from text
if (tocEntries.length === 0) {
  const fallbackRegex = /<h(?<level>[23])[^>]*>(?<text>.*?)<\/h\1>/gs;
  while ((match = fallbackRegex.exec(post.content)) !== null) {
    const text = match.groups.text.replace(/<[^>]*>/g, '');
    const id = text
      .toLowerCase()
      .replace(/<[^>]*>/g, '')
      .replace(/&[^;]+;/g, '')
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .trim();
    tocEntries.push({ level: parseInt(match.groups.level), id, text });
  }
}

const hasToc = tocEntries.length >= 2;

const relatedPosts = posts
  .filter((p) => p.category === post.category && p.slug !== post.slug)
  .slice(0, 3);
---

<Layout title={post.title} description={post.description} image={post.image}>
  <Navigation />

  <main id="main-content">
    <!-- ── HERO: Image-As-Background ── -->
    <section class="relative pt-20 pb-12 md:pb-16 overflow-hidden">
      <div class="absolute inset-0">
        <img src={post.image} alt="" class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/60 to-black/90"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/40 via-transparent to-black/20"></div>
      </div>
      <div class="absolute inset-0 pointer-events-none opacity-20" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.5'/%3E%3C/svg%3E&quot;); background-size: 256px 256px;"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 md:pt-20">
        <div>
          <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-white/60 hover:text-white transition-colors mb-6 group">
            <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Back to all articles
          </a>
          <div class="flex flex-wrap items-center gap-3 text-xs font-medium text-white/70 mb-4">
            <span class="px-3 py-1 bg-white/15 backdrop-blur-sm rounded-full text-white font-semibold border border-white/10">{post.category}</span>
            <span class="w-1 h-1 rounded-full bg-white/20"></span>
            <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            <span class="w-1 h-1 rounded-full bg-white/20"></span>
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {post.readTime}
            </span>
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.05] tracking-tight max-w-4xl">
            {post.title}
          </h1>
          {post.description && (
            <p class="mt-4 text-lg text-white/70 max-w-2xl leading-relaxed">{post.description}</p>
          )}
          <div class="flex items-center gap-4 mt-8 pt-6 border-t border-white/10">
            <div class="w-11 h-11 rounded-full bg-white/15 flex items-center justify-center text-white font-bold text-sm backdrop-blur-sm border border-white/10">
              {post.author.split(' ').map(n => n[0]).join('').slice(0, 2)}
            </div>
            <div>
              <p class="text-white font-semibold text-sm">{post.author}</p>
              <p class="text-white/50 text-xs">{post.authorRole}</p>
            </div>
            <div class="ml-auto flex items-center gap-2">
              <button id="tts-btn" class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-semibold text-white/80 bg-white/10 backdrop-blur-sm rounded-full border border-white/10 hover:bg-white/20 hover:text-white transition-all duration-300 active:scale-[0.97]" aria-label="Listen to this article">
                <svg id="tts-icon-play" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <svg id="tts-icon-pause" class="w-3.5 h-3.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span id="tts-label">Listen</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── READING PROGRESS BAR ── -->
    <div id="reading-progress" class="fixed top-0 left-0 w-full h-[3px] z-[999] pointer-events-none">
      <div id="reading-bar" class="h-full bg-gradient-to-r from-accent via-accent-soft to-accent-warm transition-all duration-100 ease-out" style="width: 0%"></div>
    </div>

    <!-- ── FLOATING SHARE BAR (desktop) ── -->
    <div id="share-bar" class="hidden xl:flex fixed left-[max(0px,calc(50%-720px))] top-1/2 -translate-y-1/2 z-40 flex-col items-center gap-3 transition-all duration-500" style="margin-left: -60px;">
      <span class="text-[10px] font-semibold text-muted uppercase tracking-[0.2em] mb-4">Share</span>
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(`https://peaceleagueafrica.org/blog/${post.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-canvas border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white hover:border-accent transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md" aria-label="Share on X">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://peaceleagueafrica.org/blog/${post.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-canvas border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white hover:border-accent transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md" aria-label="Share on Facebook">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://peaceleagueafrica.org/blog/${post.slug}`)}&title=${encodeURIComponent(post.title)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-canvas border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white hover:border-accent transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md" aria-label="Share on LinkedIn">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <button id="copy-link-btn" class="w-9 h-9 rounded-full bg-canvas border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white hover:border-accent transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md cursor-pointer" aria-label="Copy link">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
      </button>
    </div>

    <!-- ── ARTICLE LAYOUT (with optional TOC) ── -->
    <section class="py-10 md:py-14" id="article-section">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="flex gap-10 lg:gap-14 xl:gap-16">
          <!-- ── TABLE OF CONTENTS (left sidebar, desktop) ── -->
          {hasToc && (
            <aside id="toc-column" class="hidden lg:block w-[220px] xl:w-[260px] shrink-0">
              <div id="toc-sticky" class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
                <nav class="border-l-2 border-hairline pl-5 py-2">
                  <p class="text-[11px] font-bold text-muted uppercase tracking-[0.15em] mb-4">On this page</p>
                  <ul class="space-y-1.5">
                    {tocEntries.map((entry, i) => (
                      <li style={`padding-left: ${(entry.level - 2) * 12}px`}>
                        <a
                          href={`#${entry.id}`}
                          class="toc-link block text-sm leading-snug py-1 text-muted hover:text-accent transition-colors duration-200 border-l-2 -ml-[21px] pl-4 border-transparent hover:border-accent/50"
                          data-toc-id={entry.id}
                        >
                          {entry.level === 3 ? (
                            <span class="text-xs font-normal">{entry.text}</span>
                          ) : (
                            <span class="text-sm font-medium text-ink/70 hover:text-ink">{entry.text}</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
                <!-- Progress indicator -->
                <div class="mt-6 ml-5">
                  <div class="text-[11px] font-bold text-muted uppercase tracking-[0.15em] mb-2">Reading</div>
                  <div class="w-full h-1.5 bg-surface rounded-full overflow-hidden">
                    <div id="toc-progress" class="h-full bg-accent rounded-full transition-all duration-150" style="width: 0%"></div>
                  </div>
                  <p id="toc-percent" class="text-xs text-muted mt-1">0%</p>
                </div>
              </div>
            </aside>
          )}

          <!-- ── MAIN ARTICLE ── -->
          <div class={`min-w-0 flex-1 ${hasToc ? '' : 'max-w-3xl mx-auto'}`}>
            <article set:html={post.content} class="article-content"></article>

            <!-- ── BOTTOM METADATA ── -->
            <div class="mt-14 pt-8 border-t border-hairline flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div class="flex items-center gap-2">
                <span class="text-xs font-semibold text-muted uppercase tracking-wider">Topic:</span>
                <span class="px-3 py-1 text-xs font-semibold bg-accent/10 text-accent rounded-full">{post.category}</span>
              </div>
              <div class="flex items-center gap-2 text-xs text-muted">
                <span>Published {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span class="w-1 h-1 rounded-full bg-hairline"></span>
                <span>{post.readTime}</span>
              </div>
            </div>

            <!-- ── MOBILE SHARE (below article) ── -->
            <div class="mt-8 pt-6 border-t border-hairline lg:hidden">
              <span class="text-xs font-semibold text-muted uppercase tracking-wider block mb-3">Share this article</span>
              <div class="flex items-center gap-2.5">
                <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(`https://peaceleagueafrica.org/blog/${post.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-surface border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white transition-colors" aria-label="Share on X">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://peaceleagueafrica.org/blog/${post.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-surface border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white transition-colors" aria-label="Share on Facebook">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://peaceleagueafrica.org/blog/${post.slug}`)}&title=${encodeURIComponent(post.title)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-surface border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white transition-colors" aria-label="Share on LinkedIn">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <button id="copy-link-mobile" class="w-9 h-9 rounded-full bg-surface border border-hairline flex items-center justify-center text-steel hover:bg-accent hover:text-white transition-colors cursor-pointer" aria-label="Copy link">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                </button>
              </div>
            </div>

            <!-- ── MOBILE TOC ── -->
            {hasToc && (
              <div class="mt-8 pt-6 border-t border-hairline lg:hidden">
                <details class="group">
                  <summary class="flex items-center gap-2 text-sm font-bold text-ink cursor-pointer list-none">
                    <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                    On this page
                    <svg class="w-4 h-4 ml-auto transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <ul class="mt-3 space-y-1.5 pl-2">
                    {tocEntries.map((entry) => (
                      <li style={`padding-left: ${(entry.level - 2) * 12}px`}>
                        <a href={`#${entry.id}`} class="block text-sm text-steel hover:text-accent py-1 transition-colors">
                          {entry.level === 3 ? <span class="text-xs">{entry.text}</span> : <span>{entry.text}</span>}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- ── AUTHOR SECTION ── -->
    <section class="py-12 bg-surface border-y border-hairline">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-start gap-5">
          <div class="w-16 h-16 rounded-full bg-accent/15 flex items-center justify-center text-accent font-bold text-xl shrink-0 ring-2 ring-accent/10">
            {post.author.split(' ').map(n => n[0]).join('').slice(0, 2)}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-1">
              <h3 class="text-lg font-bold text-ink">{post.author}</h3>
              <span class="text-xs text-muted bg-canvas px-2.5 py-0.5 rounded-full border border-hairline">{post.authorRole}</span>
            </div>
            <p class="text-sm text-steel leading-relaxed">Peace League Africa correspondent with years of experience covering peace-building, community development, and humanitarian efforts across the African continent.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── RELATED POSTS ── -->
    {relatedPosts.length > 0 && (
      <section class="py-14 md:py-18">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mb-8">
            <span class="inline-flex items-center gap-2 text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-2">
              <span class="w-6 h-px bg-accent"></span> Continue Reading
            </span>
            <h2 class="text-2xl md:text-3xl font-bold text-ink leading-tight">More in {post.category}</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            {relatedPosts.slice(0, 3).map((rp) => (
              <a href={`/blog/${rp.slug}`} class="group relative bg-canvas rounded-2xl border border-hairline overflow-hidden transition-all duration-500 hover:-translate-y-1.5 hover:shadow-xl hover:border-accent/25">
                <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-accent/0 to-transparent group-hover:via-accent/60 transition-all duration-700"></div>
                <div class="relative overflow-hidden aspect-[16/9]">
                  <img src={rp.image} alt={rp.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                  <span class="absolute top-3 left-3 px-2.5 py-1 text-[11px] font-bold bg-white/90 text-ink rounded-full shadow-lg backdrop-blur-sm border border-white/20">{rp.category}</span>
                </div>
                <div class="p-5">
                  <div class="flex items-center gap-2 text-xs text-steel mb-2.5">
                    <span>{new Date(rp.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                    <span class="w-1 h-1 rounded-full bg-hairline"></span>
                    <span>{rp.readTime}</span>
                  </div>
                  <h3 class="text-base font-bold text-ink leading-snug line-clamp-2 group-hover:text-accent transition-colors duration-300">{rp.title}</h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── NEWSLETTER ── -->
    <section class="py-16 md:py-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-accent/[0.03] via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-2xl mx-auto text-center px-4 relative">
        <span class="inline-flex items-center gap-2 text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-3">
          <span class="w-6 h-px bg-accent"></span> Stay Inspired
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight mb-3">Never Miss a Story</h2>
        <p class="text-base text-steel max-w-lg mx-auto mb-8 leading-relaxed">Subscribe to our newsletter and get stories of hope and impact delivered to your inbox every month.</p>
