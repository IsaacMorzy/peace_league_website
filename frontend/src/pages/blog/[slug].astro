          <input type="email" name="email" placeholder="Your email address" required aria-label="Email for newsletter" class="flex-1 px-4 py-3 text-sm bg-canvas border border-hairline rounded-xl text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all" />
          <button type="submit" class="px-7 py-3 text-sm font-semibold bg-primary text-on-primary rounded-xl hover:bg-charcoal transition-all duration-300 shadow-md whitespace-nowrap active:scale-[0.98] cursor-pointer">Subscribe</button>
