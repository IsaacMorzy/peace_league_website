<script>
  // ── READING PROGRESS ──
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    const bar = document.getElementById('reading-bar');
    if (bar) bar.style.width = Math.min(progress, 100) + '%';

    // TOC progress indicator
    const tocProgress = document.getElementById('toc-progress');
    const tocPercent = document.getElementById('toc-percent');
    if (tocProgress) tocProgress.style.width = Math.min(progress, 100) + '%';
    if (tocPercent) tocPercent.textContent = Math.round(progress) + '%';
  }, { passive: true });

  // ── SCROLLSPY: Highlight current TOC section ──
  const tocLinks = document.querySelectorAll('.toc-link');
  if (tocLinks.length > 0) {
    const headings = [...tocLinks].map(link => {
      const id = link.getAttribute('data-toc-id');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach(link => {
            const isActive = link.getAttribute('data-toc-id') === id;
            link.classList.toggle('active', isActive);
          });
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    headings.forEach(h => observer.observe(h));
  }

  // ── BACK TO TOP ──
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── COPY LINK ──
  function setupCopy(btnId) {
    document.getElementById(btnId)?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const btn = document.getElementById(btnId);
        const original = btn.innerHTML;
        btn.innerHTML = '<svg class="w-3.5 h-3.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        btn.style.borderColor = 'var(--color-accent)';
        setTimeout(() => { btn.innerHTML = original; btn.style.borderColor = ''; }, 2000);
      } catch { /* ignore */ }
    });
  }
  setupCopy('copy-link-btn');
  setupCopy('copy-link-mobile');

  // ── SHARE BAR FADE ──
  const shareBar = document.getElementById('share-bar');
  if (shareBar) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          shareBar.classList.toggle('opacity-0', scrollY < 400);
          shareBar.classList.toggle('pointer-events-none', scrollY < 400);
          shareBar.classList.toggle('opacity-100', scrollY >= 400);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
    shareBar.classList.add('opacity-0', 'pointer-events-none');
  }
</script>

<script>
  // ── TEXT-TO-SPEECH (Listen button) ──
  var ttsBtn = document.getElementById('tts-btn');
  if (ttsBtn && 'speechSynthesis' in window) {
    var ttsPlay = document.getElementById('tts-icon-play');
    var ttsPause = document.getElementById('tts-icon-pause');
    var ttsLabel = document.getElementById('tts-label');

    if (ttsPlay && ttsPause && ttsLabel) {
      ttsBtn.addEventListener('click', function ttsToggle() {
        if (window.speechSynthesis.speaking) {
          if (window.speechSynthesis.paused) {
            window.speechSynthesis.resume();
            ttsPlay.classList.add('hidden');
            ttsPause.classList.remove('hidden');
            ttsLabel.textContent = 'Pause';
          } else {
            window.speechSynthesis.pause();
            ttsPlay.classList.remove('hidden');
            ttsPause.classList.add('hidden');
            ttsLabel.textContent = 'Resume';
          }
          return;
        }

        // Extract article text
        var art = document.querySelector('.article-content');
        if (!art) return;
        var clone = art.cloneNode(true);
        clone.querySelectorAll('pre, code, img, svg, [style]').forEach(function(el) { el.remove(); });
        var text = (clone.textContent || '').replace(/\s+/g, ' ').trim();
        if (!text) return;

        window.speechSynthesis.cancel();

        var utter = new SpeechSynthesisUtterance(text);
        utter.rate = 0.92;
        utter.pitch = 1;
        utter.volume = 1;

        utter.onstart = function() {
          ttsPlay.classList.add('hidden');
          ttsPause.classList.remove('hidden');
          ttsLabel.textContent = 'Pause';
        };
        utter.onend = function() {
          ttsPlay.classList.remove('hidden');
          ttsPause.classList.add('hidden');
          ttsLabel.textContent = 'Listen';
        };
        utter.onerror = function(e) {
          if (e.error !== 'canceled' && e.error !== 'interrupted') {
            ttsPlay.classList.remove('hidden');
            ttsPause.classList.add('hidden');
            ttsLabel.textContent = 'Listen';
          }
        };

        window.speechSynthesis.speak(utter);
      });
    }
  }
</script>
