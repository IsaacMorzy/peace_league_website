---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Fundraise for Peace League Africa" description="Start a fundraiser to support peacebuilding across Africa.">
  <Navigation />

  <main id="main-content">
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Fundraise for Peace</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        Rally your community to support peacebuilding initiatives across Africa.
      </p>
    </div>
    <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);filter:blur(40px);"></span>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Coming Soon</h2>
      <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
        Our peer-to-peer fundraising platform is under development. In the meantime, you can
        make a direct donation or reach out to learn about other ways to support Peace League Africa.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/donate"
          class="inline-flex items-center px-6 py-3 bg-emerald-600 text-white rounded-lg font-semibold hover:bg-emerald-700 transition-colors"
        >
          Donate Now
        </a>
        <a
          href="/volunteer"
          class="inline-flex items-center px-6 py-3 border-2 border-emerald-600 text-emerald-600 rounded-lg font-semibold hover:bg-emerald-50 transition-colors"
        >
          Volunteer With Us
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 border-2 border-gray-300 text-gray-700 rounded-lg font-semibold hover:bg-gray-50 transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>
