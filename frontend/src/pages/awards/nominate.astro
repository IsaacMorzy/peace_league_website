---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Nominate for Awards" description="Nominate an individual or organization for a Peace League Africa Award. Submission deadline: December 5, 2026 at 00:00 EAT.">
  <Navigation />

  <main id="main-content" class="min-h-screen">
    <!-- Header -->
    <section class="bg-accent/10 py-12 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-heading-2 text-ink mb-4">Submit a Nomination</h1>
        <p class="text-body-md text-steel mb-6">
          Nominate a person or organization for a Peace League Africa Award. Deadline: December 5, 2026.
        </p>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full text-sm text-ink border border-hairline">
          <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Nominations close: <strong class="ml-1">December 5, 2026 at 00:00 EAT</strong>
        </div>
      </div>
    </section>

    <!-- Form -->
    <section class="py-section px-4 sm:px-6 lg:px-8 bg-canvas">
      <div class="max-w-3xl mx-auto">
        <form id="nomination-form" class="space-y-8" enctype="multipart/form-data">
          <!-- Nominee Information -->
          <div class="card-base p-6">
            <h2 class="text-heading-4 text-ink mb-6 pb-4 border-b border-hairline">Nominee Details</h2>

            <div class="space-y-6">
              <div>
                <label for="nominee-name" class="block text-body-sm font-semibold text-ink mb-2">
                  Nominee Name <span class="text-brand-error">*</span>
                </label>
                <input
                  type="text"
                  id="nominee-name"
                  name="nominee_name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
                  placeholder="Full name of the nominee"
                />
              </div>

              <div>
                <label for="category" class="block text-body-sm font-semibold text-ink mb-2">
                  Award Category <span class="text-brand-error">*</span>
                </label>
                <select
                  id="category"
                  name="category"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
                >
                  <option value="">Select a category...</option>
                </select>
                <p class="mt-2 text-sm text-steel" id="category-loading-text">Loading categories…</p>
              </div>

              <div>
                <label for="nominee-email" class="block text-body-sm font-semibold text-ink mb-2">
                  Nominee Email
                </label>
                <input
                  type="email"
                  id="nominee-email"
                  name="nominee_email"
                  class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
                  placeholder="contact@example.org"
                />
                <p class="mt-2 text-sm text-steel">Optional. Used only to notify if they win.</p>
              </div>

              <div>
                <label for="nominee-phone" class="block text-body-sm font-semibold text-ink mb-2">
                  Phone Number
                </label>
                <input
                  type="tel"
                  id="nominee-phone"
                  name="nominee_phone"
                  class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
                  placeholder="+254 XXX XXX XXX"
                />
                <p class="mt-2 text-sm text-steel">Optional.</p>
              </div>

              <div>
                <label for="nominee-photo" class="block text-body-sm font-semibold text-ink mb-2">
                  Photo of Nominee <span class="text-brand-error">*</span>
                </label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-hairline border-dashed rounded-lg hover:border-accent transition-colors">
                  <div class="space-y-1 text-center">
                    <svg class="mx-auto h-12 w-12 text-steel" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                      <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <div class="flex text-sm text-steel justify-center">
                      <label for="nominee-photo" class="relative cursor-pointer bg-canvas rounded-md font-medium text-accent hover:text-accent-deep focus-within:outline-none">
                        <span>Upload a file</span>
                        <input id="nominee-photo" name="photo" type="file" accept="image/*" required class="sr-only" />
                      </label>
                      <p class="pl-1">or drag and drop</p>
                    </div>
                    <p class="text-xs text-steel">PNG, JPG, GIF up to 5MB</p>
                  </div>
                </div>
              </div>

              <div>
                <label for="description" class="block text-body-sm font-semibold text-ink mb-2">
                  Description / Justification <span class="text-brand-error">*</span>
                </label>
                <textarea
                  id="description"
                  name="description"
                  rows="4"
                  required
                  maxlength="500"
                  class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all resize-none"
                  placeholder="Explain why this nominee deserves this award. What have they accomplished? How have they contributed to peace, community, or their field? (Max 500 characters)"
                ></textarea>
                <div class="mt-1 text-right text-sm text-steel">
                  <span id="char-count">0</span>/500
                </div>
              </div>
            </div>
          </div>

          <!-- Nominator Information (Optional) -->
          <div class="card-base p-6">
            <h2 class="text-heading-4 text-ink mb-6 pb-4 border-b border-hairline">Your Information (Optional)</h2>
            <p class="text-body-sm text-steel mb-6">
              We'd love to know who's submitting this nomination, but it's not required. Leave blank to remain anonymous.
            </p>

            <div class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="nominator-name" class="block text-body-sm font-semibold text-ink mb-2">
                    Your Name
                  </label>
                  <input
                    type="text"
                    id="nominator-name"
                    name="nominator_name"
                    class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
                    placeholder="Your full name"
                  />
                </div>

                <div>
                  <label for="nominator-email" class="block text-body-sm font-semibold text-ink mb-2">
                    Your Email
                  </label>
                  <input
                    type="email"
                    id="nominator-email"
                    name="nominator_email"
                    class="w-full px-4 py-3 rounded-lg border border-hairline bg-canvas text-ink focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
                    placeholder="your@email.com"
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Terms -->
          <div class="card-base p-6">
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <input type="checkbox" id="terms" name="terms" required class="mt-1" />
                <label for="terms" class="text-body-sm text-ink">
                  I confirm that this nomination is made in good faith and the information provided is accurate to the best of my knowledge. <span class="text-brand-error">*</span>
                </label>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="public-consent" name="public_consent" required class="mt-1" />
                <label for="public-consent" class="text-body-sm text-ink">
                  I understand that this nomination will be publicly visible on the website immediately upon submission. <span class="text-brand-error">*</span>
                </label>
              </div>

              <div id="recaptcha-container" class="flex justify-center py-4">
                <div class="text-sm text-steel border border-hairline rounded p-4 bg-surface">
                  reCAPTCHA verification required (to be integrated)
                </div>
              </div>
            </div>
          </div>

          <!-- Submit -->
          <div class="flex justify-between items-center pt-4">
            <p class="text-sm text-steel">* Required fields</p>
            <button type="submit" class="btn btn-primary btn-large px-8">Submit Nomination</button>
          </div>
        </form>

        <!-- Success Message (hidden by default) -->
        <div id="success-message" class="hidden mt-8 p-6 bg-accent/10 border border-accent rounded-xl text-center">
          <div class="text-5xl mb-4">🎉</div>
          <h3 class="text-heading-5 text-ink mb-2">Nomination Submitted</h3>
          <p class="text-body-md text-steel mb-6">
            Your nomination has been received and will appear on the site shortly.
          </p>
          <a href="/awards" class="btn btn-primary">Back to Awards</a>
        </div>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="py-10 bg-surface border-t border-hairline">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm text-steel mb-4">Explore more</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/awards" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">All Categories</a>
          <a href="/awards/results" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Results</a>
          <a href="/donate" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Donate</a>
          <a href="/events" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Events</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { getAwardCategories, submitNomination } from '../../lib/api.js';

  // Load categories into the dropdown
  async function loadCategories() {
    try {
      const res = await getAwardCategories();
      if (res.status !== 'success' || !res.data) throw new Error('API error');

      const select = document.getElementById('category');
      const loadingText = document.getElementById('category-loading-text');

      res.data.forEach(cat => {
        const opt = document.createElement('option');
        opt.value = cat.slug;
        opt.textContent = cat.category_name;
        select.appendChild(opt);
      });
      loadingText.textContent = `${res.data.length} categories available.`;
      loadingText.classList.add('text-steel');
    } catch (err) {
      console.error('Category load error:', err);
      document.getElementById('category-loading-text').textContent =
        'Unable to load categories. Please refresh the page.';
      document.getElementById('category-loading-text').classList.add('text-brand-error');
    }
  }

  // Character count
  const descEl = document.getElementById('description');
  const charCount = document.getElementById('char-count');
  if (descEl && charCount) {
    descEl.addEventListener('input', () => {
      charCount.textContent = descEl.value.length;
    });
  }

  // Form submission
  document.getElementById('nomination-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(e.target);
    const submitBtn = e.target.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    try {
      const res = await submitNomination(formData);
      if (res.status === 'success') {
        document.getElementById('nomination-form').classList.add('hidden');
        document.getElementById('success-message').classList.remove('hidden');
      } else {
        alert('Submission failed: ' + (res.message || 'Please try again.'));
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Nomination';
      }
    } catch (err) {
      console.error('Nomination error:', err);
      alert('Network error. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Nomination';
    }
  });

  loadCategories();
</script>
