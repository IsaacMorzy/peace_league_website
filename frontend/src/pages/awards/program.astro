---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Programme — Peace League Awards 2026" description="Full ceremony programme for the Peace League Africa Awards Gala 2026 at August 7th Memorial Park, Nairobi on December 17, 2026. Schedule, speakers, venue details, and ticket info.">
  <Navigation />

  <main id="main-content" class="min-h-screen">
    <!-- Hero -->
    <section class="relative hero-gradient text-on-dark py-section-lg px-4 sm:px-6 lg:px-8 overflow-hidden">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="relative max-w-7xl mx-auto text-center z-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/20 rounded-full text-accent-soft font-semibold text-sm mb-6 backdrop-blur-sm">
          🏆 Awards Gala 2026
        </div>
        <h1 class="text-heading-1 text-on-dark mb-4">Ceremony Programme</h1>
        <p class="text-body-md text-on-dark-muted max-w-2xl mx-auto mb-8">
          December 17, 2026 · August 7th Memorial Park, Nairobi · 10:00 AM – 3:00 PM EAT
        </p>

        <!-- Micro countdown bar -->
        <div class="inline-flex items-center gap-4 sm:gap-6 bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3 border border-white/10">
          <div class="text-center">
            <span class="block text-xl font-bold text-on-dark" id="prog-cd-days">--</span>
            <span class="text-[10px] text-on-dark-muted uppercase tracking-wider">Days</span>
          </div>
          <div class="text-center">
            <span class="block text-xl font-bold text-on-dark" id="prog-cd-hours">--</span>
            <span class="text-[10px] text-on-dark-muted uppercase tracking-wider">Hrs</span>
          </div>
          <div class="text-center">
            <span class="block text-xl font-bold text-on-dark" id="prog-cd-mins">--</span>
            <span class="text-[10px] text-on-dark-muted uppercase tracking-wider">Min</span>
          </div>
          <div class="text-center">
            <span class="block text-xl font-bold text-on-dark" id="prog-cd-secs">--</span>
            <span class="text-[10px] text-on-dark-muted uppercase tracking-wider">Sec</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Nav -->
    <section class="bg-surface border-b border-hairline sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex overflow-x-auto gap-0 -mb-px" aria-label="Programme sections">
          <a href="#schedule" class="shrink-0 px-5 py-3 text-sm font-medium text-accent border-b-2 border-accent transition-colors">Schedule</a>
          <a href="#speakers" class="shrink-0 px-5 py-3 text-sm font-medium text-steel hover:text-ink border-b-2 border-transparent hover:border-accent/30 transition-colors">Speakers</a>
          <a href="#venue" class="shrink-0 px-5 py-3 text-sm font-medium text-steel hover:text-ink border-b-2 border-transparent hover:border-accent/30 transition-colors">Venue</a>
          <a href="#tickets" class="shrink-0 px-5 py-3 text-sm font-medium text-steel hover:text-ink border-b-2 border-transparent hover:border-accent/30 transition-colors">Tickets</a>
          <a href="#about-awards" class="shrink-0 px-5 py-3 text-sm font-medium text-steel hover:text-ink border-b-2 border-transparent hover:border-accent/30 transition-colors">About the Awards</a>
        </nav>
      </div>
    </section>

    <!-- Full Schedule -->
    <section id="schedule" class="py-section px-4 sm:px-6 lg:px-8 bg-canvas">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12" data-reveal>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">Ceremony Schedule</span>
          <h2 class="text-heading-2 text-ink mb-4">December 17, 2026</h2>
          <p class="text-body-md text-steel max-w-xl mx-auto">A day of honour, remembrance, and celebration — from registration through to the closing address.</p>
        </div>

        <!-- Timeline -->
        <div class="relative" data-reveal>
          <div class="absolute left-[23px] top-3 bottom-3 w-0.5 bg-gradient-to-b from-accent via-accent/50 to-transparent" aria-hidden="true"></div>
          <div class="space-y-0">
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent border-2 border-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">08:00 – 09:00</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Arrival, Registration &amp; Welcome Coffee</h3>
                <p class="text-sm text-steel mt-1">Guests arrive, register at the welcome desk, and enjoy coffee and light refreshments. Name badges and programmes distributed.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent/10 border-2 border-accent/30 flex items-center justify-center shrink-0">
                  <span class="text-sm font-bold text-accent">09</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">09:00 – 10:00</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Pre-Ceremony Gathering &amp; Exhibition</h3>
                <p class="text-sm text-steel mt-1">Networking session with exhibition stands showcasing peacebuilding initiatives from across 12 African countries. Meet the nominees and learn about their work.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent border-2 border-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
                  <span class="text-sm font-bold text-primary">10</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">10:00 – 10:15</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Opening Ceremony</h3>
                <p class="text-sm text-steel mt-1">National Anthem. Welcome Address by Dr. James Nderitu, Executive Director of Peace League Africa. Opening remarks on the significance of the venue and the awards.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent/10 border-2 border-accent/30 flex items-center justify-center shrink-0">
                  <span class="text-sm font-bold text-amber-500">🎤</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-amber-500 uppercase tracking-wider">10:15 – 10:45</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Keynote Address</h3>
                <p class="text-sm text-steel mt-1"><strong class="text-ink">H.E. Fatuma Mohamed</strong>, Cabinet Secretary, Ministry of Interior &amp; Coordination — Kenya. A powerful address on the state of peacebuilding in Africa and the critical role of community-led initiatives.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent border-2 border-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
                  <span class="text-sm font-bold text-primary">11</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">10:45 – 11:30</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Award Session 1: Peace Advocacy &amp; Humanitarian Service</h3>
                <p class="text-sm text-steel mt-1">Presentation of awards recognising individuals and organizations that have demonstrated exceptional commitment to peace advocacy, conflict resolution, and humanitarian service across Africa.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent/10 border-2 border-accent/30 flex items-center justify-center shrink-0">
                  <span class="text-sm font-bold text-amber-500">🎵</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-amber-500 uppercase tracking-wider">11:30 – 11:45</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Cultural Interlude</h3>
                <p class="text-sm text-steel mt-1">A vibrant showcase of African music, dance, and spoken word — celebrating the rich cultural heritage of the communities we serve. Featuring artists from Kenya, Uganda, and Rwanda.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent border-2 border-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
                  <span class="text-sm font-bold text-primary">12</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">11:45 – 12:30</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Award Session 2: Youth Leadership &amp; Community Development</h3>
                <p class="text-sm text-steel mt-1">Honouring young leaders and community organisers who are driving change from the ground up. Categories include youth peace ambassadors, community development champions, and grassroots innovators.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent/10 border-2 border-accent/30 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">12:30 – 13:30</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Lunch Break &amp; Networking</h3>
                <p class="text-sm text-steel mt-1">A catered lunch with opportunities to network with fellow peacebuilders, nominees, and distinguished guests. Dietary requirements accommodated (halal, vegetarian, gluten-free).</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent border-2 border-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
                  <span class="text-sm font-bold text-accent">🏆</span>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">13:30 – 14:15</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Award Session 3: Special Recognitions &amp; Lifetime Achievement</h3>
                <p class="text-sm text-steel mt-1">The most anticipated session of the day. Special recognitions for extraordinary contributions, including the Lifetime Achievement Award honouring a peacebuilder whose work has transformed communities across generations.</p>
              </div>
            </div>
            <div class="flex gap-5 pb-8 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent/10 border-2 border-accent/30 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">14:15 – 14:45</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Closing Remarks &amp; Call to Action</h3>
                <p class="text-sm text-steel mt-1">A unifying address from Amb. Olusegun Akinlade, African Union Special Envoy for Conflict Resolution. A call to action for all attendees to continue building peace in their communities.</p>
              </div>
            </div>
            <div class="flex gap-5 relative">
              <div class="relative z-10">
                <div class="w-11 h-11 rounded-full bg-accent border-2 border-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/20">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-xs font-bold text-accent uppercase tracking-wider">14:45 – 15:00</p>
                <h3 class="text-lg font-bold text-ink mt-0.5">Group Photo &amp; Media Interviews</h3>
                <p class="text-sm text-steel mt-1">All award winners, nominees, and distinguished guests gather for the official group photograph. Media interviews with winners. Event concludes.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-12 text-center">
          <a href="/awards/tickets" class="btn btn-accent btn-large cta-hover-glow">
            🎟️ Get Your Tickets
          </a>
        </div>
      </div>
    </section>

    <!-- Speakers -->
    <section id="speakers" class="py-section px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12" data-reveal>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">Distinguished Speakers</span>
          <h2 class="text-heading-2 text-ink mb-4">Our Keynote Speakers</h2>
          <p class="text-body-md text-steel max-w-xl mx-auto">Esteemed leaders and peacebuilders who will address the gathering and present the awards.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-reveal>
          <!-- Speaker 1 -->
          <div class="card-base p-5 text-center scroll-reveal">
            <div class="w-24 h-24 rounded-full mx-auto mb-4 bg-hairline overflow-hidden">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&q=80&fit=crop&crop=face" alt="Dr. James Nderitu" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="text-heading-5 text-ink mb-1">Dr. James Nderitu</h3>
            <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Opening Address</p>
            <p class="text-sm text-steel">Executive Director, Peace League Africa. A leading voice in African peacebuilding with over 20 years of experience in conflict resolution across the Great Lakes region.</p>
          </div>
          <!-- Speaker 2 -->
          <div class="card-base p-5 text-center scroll-reveal">
            <div class="w-24 h-24 rounded-full mx-auto mb-4 bg-hairline overflow-hidden">
              <img src="https://images.unsplash.com/photo-1531123897727-8f129e1688ce?w=120&q=80&fit=crop&crop=face" alt="H.E. Fatuma Mohamed" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="text-heading-5 text-ink mb-1">H.E. Fatuma Mohamed</h3>
            <p class="text-xs font-semibold text-amber-500 uppercase tracking-wider mb-2">Keynote Speaker</p>
            <p class="text-sm text-steel">Cabinet Secretary, Ministry of Interior &amp; Coordination — Kenya. Champion of community policing and peace initiatives across Kenya's 47 counties.</p>
          </div>
          <!-- Speaker 3 -->
          <div class="card-base p-5 text-center scroll-reveal">
            <div class="w-24 h-24 rounded-full mx-auto mb-4 bg-hairline overflow-hidden">
              <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?w=120&q=80&fit=crop&crop=face" alt="Amb. Olusegun Akinlade" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="text-heading-5 text-ink mb-1">Amb. Olusegun Akinlade</h3>
            <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Closing Address</p>
            <p class="text-sm text-steel">African Union Special Envoy for Conflict Resolution. Former Nigerian Ambassador to the UN, with decades of diplomatic experience in peace mediation.</p>
          </div>
          <!-- Speaker 4 -->
          <div class="card-base p-5 text-center scroll-reveal">
            <div class="w-24 h-24 rounded-full mx-auto mb-4 bg-hairline overflow-hidden">
              <img src="https://images.unsplash.com/photo-1583394838336-acd977736f90?w=120&q=80&fit=crop&crop=face" alt="Mama Esperance Mukamana" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="text-heading-5 text-ink mb-1">Mama Esperance Mukamana</h3>
            <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Special Guest</p>
            <p class="text-sm text-steel">Founder, Women Peacebuilders Network — Rwanda. Survivor-led peacebuilding advocate. Recipient of the 2024 African Peace Prize for grassroots reconciliation work.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Venue -->
    <section id="venue" class="py-section px-4 sm:px-6 lg:px-8 bg-canvas">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12" data-reveal>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">The Venue</span>
          <h2 class="text-heading-2 text-ink mb-4">August 7th Memorial Park</h2>
          <p class="text-body-md text-steel max-w-2xl mx-auto">A place of remembrance, resilience, and the enduring power of peace — chosen deliberately as the setting for this historic ceremony.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start" data-reveal>
          <div class="rounded-2xl overflow-hidden shadow-lg">
            <img src="/images/events/peace-league-awards-gala-2026.jpg" alt="August 7th Memorial Park, Nairobi" class="w-full h-72 sm:h-96 object-cover" loading="lazy" />
          </div>
          <div class="space-y-4">
            <div class="bg-surface rounded-xl p-5 border border-hairline">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-ink">Location</h3>
                  <p class="text-sm text-steel">Junction of Haile Selassie Avenue &amp; Moi Avenue, Nairobi City Centre (next to Cooperative Bank)</p>
                </div>
              </div>
            </div>
            <div class="bg-surface rounded-xl p-5 border border-hairline">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-ink">Why This Venue</h3>
                  <p class="text-sm text-steel">The August 7th Memorial Park stands on the site of the 1998 US Embassy bombing, a tragedy that claimed 218 lives. By hosting our awards here, we honour those lost while celebrating the peacebuilders who choose hope over hate, dialogue over division.</p>
                </div>
              </div>
            </div>
            <div class="bg-surface rounded-xl p-5 border border-hairline">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-ink">Park Features</h3>
                  <p class="text-sm text-steel">The Memorial Wall with 218 names, indigenous Kenyan plants, the Yin-Yang fountain, the 'Mind, Body &amp; Spirit' sculpture from original debris, and riverbed rock walkways — every element tells a story of resilience.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tickets -->
    <section id="tickets" class="py-section px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10" data-reveal>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">Secure Your Seat</span>
          <h2 class="text-heading-2 text-ink mb-4">Ticket Tiers</h2>
          <p class="text-body-md text-steel max-w-xl mx-auto">Choose the experience that suits you. All proceeds support Peace League Africa's peacebuilding programs.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start" data-reveal>
          <!-- Early Bird - Sold Out -->
          <div class="card-base p-6 flex flex-col gap-4 relative overflow-hidden opacity-75">
            <div class="absolute -top-4 right-4 bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full">Save 29%</div>
            <div>
              <h3 class="text-heading-5 text-ink">Early Bird</h3>
              <p class="text-sm text-steel mt-1">Early bird pricing for early supporters.</p>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold text-ink">KES 2,500</span>
              <span class="text-sm text-muted line-through">3,500</span>
            </div>
            <ul class="space-y-2 text-sm text-steel flex-1">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Gala Dinner</li>
