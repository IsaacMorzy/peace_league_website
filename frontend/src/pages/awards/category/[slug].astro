---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import categories from '../../../../../peace_league_website/fixtures/award_categories.json';

// Pre-render a page for each known category slug from the fixtures file.
// Each page is a shell that fetches live data from the Frappe API client-side.
export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { slug: cat.slug },
  }));
}

const { slug } = Astro.params;
---

<Layout title="Award Category | Awards" description={`Vote for nominees in this Peace League Africa Award category.`}>
  <Navigation />

  <main id="main-content" class="min-h-screen">
    <!-- Breadcrumb -->
    <nav class="bg-surface py-3 px-4 sm:px-6 lg:px-8 text-sm text-steel">
      <div class="max-w-7xl mx-auto">
        <a href="/awards" class="hover:text-accent">Awards</a>
        <span class="mx-2">/</span>
        <span class="text-ink" id="breadcrumb-name">Category</span>
      </div>
    </nav>

    <!-- Category Header -->
    <section class="bg-canvas py-8 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl">
          <h1 class="text-heading-2 text-ink mb-4" id="category-name">Loading…</h1>
          <p class="text-body-md text-steel" id="category-description"></p>
          <div class="mt-4 text-sm text-steel">
            Voting closes: <strong class="text-ink">December 5, 2026 at 00:00 EAT</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- Nominees Grid -->
    <section class="py-section px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="mb-6 flex justify-between items-center">
          <h2 class="text-heading-4 text-ink">Nominees (<span id="nominee-count">0</span>)</h2>
          <div class="text-sm text-steel">
            Voting is open to everyone • One vote per category
          </div>
        </div>

        <div id="nominees-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="col-span-full text-center text-steel py-12" id="nominees-loading">Loading nominees…</div>
        </div>
        <div id="nominees-empty" class="hidden col-span-full text-center text-steel py-12">
          No nominees have been submitted for this category yet.
          <div class="mt-4">
            <a href="/awards/nominate" class="btn btn-primary">Submit a Nomination</a>
          </div>
        </div>
        <div id="nominees-error" class="hidden col-span-full text-center text-brand-error py-12">
          Unable to load this category. Please check the URL or go back to <a href="/awards" class="text-accent underline">all categories</a>.
        </div>
      </div>
    </section>

    <!-- Vote confirmation modal — Preline overlay -->
    <div id="hs-vote-modal" class="hs-overlay hidden fixed inset-0 z-[80] size-full" role="dialog" tabindex="-1" aria-labelledby="vote-modal-title">
      <div class="mt-0 opacity-0 ease-out transition-all size-full">
        <div class="flex justify-center items-center min-h-full p-4">
          <div class="scale-95 opacity-0 ease-out transition-all max-w-md w-full">
            <div class="bg-canvas rounded-2xl p-6 shadow-2xl border border-hairline">
              <div class="flex justify-between items-start mb-4" id="vote-modal-header">
                <h3 class="text-heading-5 text-ink" id="vote-modal-title">Vote Confirmed</h3>
                <button type="button" class="size-8 inline-flex justify-center items-center gap-x-2 rounded-full border border-transparent bg-surface text-steel hover:bg-hairline focus:outline-hidden focus:bg-hairline" aria-label="Close" data-hs-overlay="#hs-vote-modal">
                  <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
              </div>
              <p class="text-body-md text-steel mb-6" id="vote-modal-message">Your vote has been recorded. Thank you for participating.</p>
              <button type="button" class="btn btn-accent w-full" data-hs-overlay="#hs-vote-modal">Continue Browsing</button>
            </div>
          </div>
        </div>
      </div>
      <div class="hs-overlay-open:opacity-100 opacity-0 fixed inset-0 bg-black/50 backdrop-blur-sm z-[-1]" data-hs-overlay="#hs-vote-modal"></div>
    </div>

    <!-- Cross-links -->
    <section class="py-10 bg-surface border-t border-hairline">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm text-steel mb-4">Explore more</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/awards" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">All Categories</a>
          <a href="/awards/nominate" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Nominate</a>
          <a href="/awards/results" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Results</a>
          <a href="/donate" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Donate</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<!-- Pass server-side slug to client script via data attribute -->
<div id="category-data" data-slug={slug} class="hidden"></div>

<script>
  import { getAwardCategory, castVote } from '../../../lib/api.js';

  const CATEGORY_SLUG = document.getElementById('category-data').dataset.slug;

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str || '';
    return div.innerHTML.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function showModal(title, message) {
    document.getElementById('vote-modal-title').textContent = title;
    document.getElementById('vote-modal-message').textContent = message;
    // Open Preline overlay
    const modal = document.getElementById('hs-vote-modal');
    if (modal && window.HSOverlay) {
      window.HSOverlay.open(modal);
    } else if (modal) {
      // ponytail: fallback if Preline JS not loaded yet
      modal.classList.remove('hidden');
    }
  }
  window.closeVoteModal = () => {
    const modal = document.getElementById('hs-vote-modal');
    if (modal && window.HSOverlay) {
      window.HSOverlay.close(modal);
    } else if (modal) {
      modal.classList.add('hidden');
    }
  };

  async function loadCategory() {
    try {
      const res = await getAwardCategory(CATEGORY_SLUG);
      if (res.status !== 'success') {
        throw new Error(res.message || 'Category not found');
      }
      const { category, nominees } = res.data;

      // Populate header
      document.getElementById('category-name').textContent = category.category_name;
      document.getElementById('breadcrumb-name').textContent = category.category_name;
      document.getElementById('category-description').textContent = category.description || '';
      document.title = `${category.category_name} | Awards`;

      document.getElementById('nominees-loading').classList.add('hidden');

      if (!nominees || !nominees.length) {
        document.getElementById('nominees-empty').classList.remove('hidden');
        return;
      }

      document.getElementById('nominee-count').textContent = nominees.length;

      const grid = document.getElementById('nominees-grid');
      grid.innerHTML = nominees.map(n => `
        <div class="card-base p-6" id="nominee-${escapeHtml(n.name)}">
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              ${n.photo_url
                ? `<img src="${escapeHtml(n.photo_url)}" alt="${escapeHtml(n.nominee_name)}" class="w-24 h-24 object-cover rounded-lg bg-surface" />`
                : `<div class="w-24 h-24 rounded-lg bg-hairline flex items-center justify-center text-steel text-xs">No photo</div>`}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-start">
                <div>
                  <h3 class="text-heading-5 text-ink mb-1">${escapeHtml(n.nominee_name)}</h3>
                </div>
                <div class="text-right">
                  <div class="text-2xl font-bold text-ink vote-count" data-votes="${n.votes}">${n.votes.toLocaleString()}</div>
                  <div class="text-xs text-steel uppercase tracking-wide">Votes</div>
                </div>
              </div>
              <!-- Preline Accordion for nominee description -->
              <div class="hs-accordion-group my-4" data-hs-accordion-always-open>
                <div class="hs-accordion" id="hs-accordion-${escapeHtml(n.name)}">
                  <div id="hs-accordion-body-${escapeHtml(n.name)}" class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300" role="region">
                    <p class="text-body-sm text-steel">${escapeHtml(n.description)}</p>
                  </div>
                  ${n.description && n.description.length > 150 ? `
                    <p class="text-body-sm text-steel line-clamp-3 accordion-preview" id="accordion-preview-${escapeHtml(n.name)}">${escapeHtml(n.description)}</p>
                    <button type="button" class="hs-accordion-toggle inline-flex items-center gap-x-1 text-xs font-medium text-accent hover:text-accent-deep mt-2 transition-colors" aria-controls="hs-accordion-body-${escapeHtml(n.name)}">
                      <span class="accordion-text-more">Read more</span>
                      <span class="hidden accordion-text-less">Show less</span>
                      <svg class="size-3 transition-transform accordion-chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/></svg>
                    </button>
                  ` : `
                    <p class="text-body-sm text-steel">${escapeHtml(n.description)}</p>
                  `}
                </div>
              </div>
              <div class="mt-auto">
                <button
                  class="btn btn-primary vote-btn"
                  data-nominee-id="${escapeHtml(n.name)}"
                  data-category-slug="${escapeHtml(CATEGORY_SLUG)}"
                >
                  Vote for this nominee
                </button>
              </div>
            </div>
          </div>
        </div>
      `).join('');

      // Wire vote buttons
      grid.querySelectorAll('.vote-btn').forEach(btn => {
        btn.addEventListener('click', () => handleVote(btn));
      });
    } catch (err) {
      console.error('Category load error:', err);
      document.getElementById('nominees-loading').classList.add('hidden');
      document.getElementById('nominees-error').classList.remove('hidden');
    }
  }

  async function handleVote(button) {
    const nomineeId = button.dataset.nomineeId;
    const categorySlug = button.dataset.categorySlug;

    button.disabled = true;
    button.textContent = 'Submitting…';

    try {
      const res = await castVote(nomineeId, categorySlug);
      if (res.status === 'success') {
        // Increment vote count in the UI
        const card = button.closest('[id^="nominee-"]');
        const voteEl = card.querySelector('.vote-count');
        const current = parseInt(voteEl.dataset.votes, 10) || 0;
        voteEl.dataset.votes = current + 1;
        voteEl.textContent = (current + 1).toLocaleString();

        // Replace button with confirmation
        const votedEl = document.createElement('div');
        votedEl.className = 'text-sm text-green-600 font-medium flex items-center gap-2';
        votedEl.innerHTML = '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> You voted for this nominee';
        button.replaceWith(votedEl);

        showModal('Vote Confirmed', res.message || 'Your vote has been recorded. Thank you for participating.');
      } else {
        showModal('Vote Failed', res.message || 'Failed to cast vote. Please try again.');
        button.disabled = false;
        button.textContent = 'Vote for this nominee';
      }
    } catch (err) {
      console.error('Vote error:', err);
      showModal('Error', 'Network error. Please try again.');
      button.disabled = false;
      button.textContent = 'Vote for this nominee';
    }
  }

  loadCategory();
</script>

<style>
  /* ponytail: accordion toggle states without Preline plugin variants */
  .hs-accordion-toggle[aria-expanded="true"] .accordion-chevron { transform: rotate(180deg); }
  .hs-accordion-toggle[aria-expanded="true"] .accordion-text-more { display: none; }
  .hs-accordion-toggle[aria-expanded="true"] .accordion-text-less { display: inline; }
  .hs-accordion-toggle .accordion-text-less { display: none; }
  .hs-accordion-toggle[aria-expanded="true"] ~ .accordion-preview { display: none; }
</style>
