---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Peace League Awards 2026" description="Browse categories, vote for nominees, and celebrate excellence in peace-building across Africa. Awards announced December 5, 2026.">
  <Navigation />

  <main id="main-content" class="min-h-screen">
    <!-- Hero with gradient + countdown -->
    <section class="relative hero-gradient text-on-dark py-section-lg px-4 sm:px-6 lg:px-8 overflow-hidden">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="absolute inset-0 hero-pattern-overlay"></div>
      <div class="relative max-w-7xl mx-auto text-center z-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/20 rounded-full text-accent-soft font-semibold text-sm mb-6 backdrop-blur-sm">
          <span>🏆</span> 2026 Awards
        </div>
        <h1 class="text-heading-1 text-on-dark mb-6 max-w-4xl mx-auto">
          Peace League Africa Awards
        </h1>
        <p class="text-body-md text-on-dark-muted mb-8 max-w-2xl mx-auto">
          Celebrating the champions of peace-building, community service, and leadership
          across East Africa and the Great Lakes region.
        </p>

        <!-- Countdown -->
        <div class="flex justify-center gap-4 sm:gap-6 mb-10" id="countdown" aria-live="polite" aria-label="Countdown to awards ceremony">
          <div class="glass rounded-2xl px-4 sm:px-6 py-4 min-w-[80px] sm:min-w-[100px]">
            <div class="text-3xl sm:text-4xl font-bold text-on-dark" id="countdown-days">—</div>
            <div class="text-xs text-on-dark-muted uppercase tracking-wider mt-1">Days</div>
          </div>
          <div class="glass rounded-2xl px-4 sm:px-6 py-4 min-w-[80px] sm:min-w-[100px]">
            <div class="text-3xl sm:text-4xl font-bold text-on-dark" id="countdown-hours">—</div>
            <div class="text-xs text-on-dark-muted uppercase tracking-wider mt-1">Hours</div>
          </div>
          <div class="glass rounded-2xl px-4 sm:px-6 py-4 min-w-[80px] sm:min-w-[100px]">
            <div class="text-3xl sm:text-4xl font-bold text-on-dark" id="countdown-minutes">—</div>
            <div class="text-xs text-on-dark-muted uppercase tracking-wider mt-1">Minutes</div>
          </div>
          <div class="glass rounded-2xl px-4 sm:px-6 py-4 min-w-[80px] sm:min-w-[100px]">
            <div class="text-3xl sm:text-4xl font-bold text-on-dark" id="countdown-seconds">—</div>
            <div class="text-xs text-on-dark-muted uppercase tracking-wider mt-1">Seconds</div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap justify-center gap-4">
          <a href="#categories" class="btn btn-accent btn-large btn-pulse-glow">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/></svg>
            View Nominees
          </a>
          <a href="/awards/nominate" class="btn btn-large bg-white/10 text-on-dark border border-white/20 hover:bg-white/20 hover:border-white/30">
            Nominate Someone
          </a>
          <a href="/awards/program" class="btn btn-large inline-flex items-center gap-2 border-2 border-accent/40 text-accent-soft hover:bg-accent/10 transition-all">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            View Full Programme
          </a>
        </div>

        <!-- Event details -->
        <div class="flex flex-wrap justify-center gap-6 mt-10 text-sm text-on-dark-muted">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            17 Dec 2026
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            August 7th Memorial Park (next to Cooperative Bank), Nairobi
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            10:00 AM EAT
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-canvas py-8 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div class="stat-card-glass rounded-xl p-4 relative">
            <div class="text-3xl font-bold text-accent" id="stat-categories">—</div>
            <div class="text-sm text-steel mt-1">Award Categories</div>
            <!-- ponytail: css tooltip instead of broken hs-tooltip-shown: variants -->
            <div class="group/tip inline-block absolute top-2 right-2">
              <button type="button" class="size-5 inline-flex justify-center items-center rounded-full text-steel hover:text-ink transition-colors" aria-label="What are award categories?">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </button>
              <span class="invisible group-hover/tip:visible opacity-0 group-hover/tip:opacity-100 transition-opacity absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 bg-charcoal text-on-dark text-xs rounded-lg py-2 px-3 z-10 pointer-events-none shadow-lg" role="tooltip">Total active award categories across peace-building, leadership, and community service themes.</span>
            </div>
          </div>
          <div class="stat-card-glass rounded-xl p-4 relative">
            <div class="text-3xl font-bold text-accent" id="stat-nominees">—</div>
            <div class="text-sm text-steel mt-1">Nominees</div>
            <div class="group/tip inline-block absolute top-2 right-2">
              <button type="button" class="size-5 inline-flex justify-center items-center rounded-full text-steel hover:text-ink transition-colors" aria-label="What are nominees?">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </button>
              <span class="invisible group-hover/tip:visible opacity-0 group-hover/tip:opacity-100 transition-opacity absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 bg-charcoal text-on-dark text-xs rounded-lg py-2 px-3 z-10 pointer-events-none shadow-lg" role="tooltip">Individuals and organizations nominated for their outstanding contributions.</span>
            </div>
          </div>
          <div class="stat-card-glass rounded-xl p-4 relative">
            <div class="text-3xl font-bold text-accent" id="stat-votes">—</div>
            <div class="text-sm text-steel mt-1">Votes Cast</div>
            <div class="group/tip inline-block absolute top-2 right-2">
              <button type="button" class="size-5 inline-flex justify-center items-center rounded-full text-steel hover:text-ink transition-colors" aria-label="What are votes?">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </button>
              <span class="invisible group-hover/tip:visible opacity-0 group-hover/tip:opacity-100 transition-opacity absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 bg-charcoal text-on-dark text-xs rounded-lg py-2 px-3 z-10 pointer-events-none shadow-lg" role="tooltip">Total public votes cast across all categories. Anyone can vote once per category.</span>
            </div>
          </div>
          <div class="stat-card-glass rounded-xl p-4 relative">
            <div class="text-3xl font-bold text-accent" id="stat-ceremony-countdown-days">—</div>
            <div class="text-sm text-steel mt-1">Days to Ceremony</div>
            <div class="group/tip inline-block absolute top-2 right-2">
              <button type="button" class="size-5 inline-flex justify-center items-center rounded-full text-steel hover:text-ink transition-colors" aria-label="What is the gala?">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </button>
              <span class="invisible group-hover/tip:visible opacity-0 group-hover/tip:opacity-100 transition-opacity absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 bg-charcoal text-on-dark text-xs rounded-lg py-2 px-3 z-10 pointer-events-none shadow-lg" role="tooltip">The Peace League Africa Awards Gala — December 17, 2026 at August 7th Memorial Park, Nairobi.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Dismissible Alert (Preline) -->
    <div id="voting-alert" class="bg-accent/10 border-b border-accent/20" role="alert">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2 text-sm text-ink">
          <span>⏳</span>
          <span>Voting closes <strong>December 5, 2026</strong>. Every vote counts — cast yours today!</span>
        </div>
        <div class="flex items-center gap-3">
          <a href="#categories" class="text-xs font-semibold text-accent hover:text-accent-deep transition-colors">Vote now →</a>
          <button type="button" class="size-6 inline-flex justify-center items-center rounded-full text-steel hover:text-ink hover:bg-hairline transition-colors" data-hs-remove-element="#voting-alert" aria-label="Dismiss">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Categories Grid -->
    <section id="categories" class="py-section px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8 flex flex-col sm:flex-row justify-between sm:items-end gap-4">
          <div>
            <h2 class="text-heading-3 text-ink">Award Categories</h2>
            <p class="text-body-sm text-steel mt-2">Browse all categories and cast your vote</p>
          </div>
          <div class="flex gap-2">
            <input type="search" id="category-search" placeholder="Search categories…" class="input-focus-ring px-4 py-2.5 rounded-full border border-hairline bg-canvas text-ink text-sm w-full sm:w-56" />
            <!-- Preline Dropdown for sort -->
            <div class="hs-dropdown relative inline-flex">
              <button type="button" class="hs-dropdown-toggle input-focus-ring px-4 py-2.5 rounded-full border border-hairline bg-canvas text-ink text-sm flex items-center gap-1.5 hover:border-accent/40 transition-colors">
                Sort
                <svg class="size-3.5 text-steel transition-transform group-data-[hs-dropdown-open]:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/></svg>
              </button>
              <div class="hs-dropdown-menu hidden transition-[opacity,margin] duration-200 opacity-0 absolute right-0 top-full mt-2 min-w-48 bg-canvas rounded-xl border border-hairline shadow-lg z-20 p-1.5" role="menu">
                <button type="button" class="sort-option flex w-full items-center gap-x-3 py-2 px-3 rounded-lg text-sm text-steel hover:bg-surface hover:text-ink transition-colors" data-sort="name">
                  <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                  Name (A–Z)
                </button>
                <button type="button" class="sort-option flex w-full items-center gap-x-3 py-2 px-3 rounded-lg text-sm text-steel hover:bg-surface hover:text-ink transition-colors" data-sort="nominees">
                  <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Most Nominees
                </button>
                <button type="button" class="sort-option flex w-full items-center gap-x-3 py-2 px-3 rounded-lg text-sm text-steel hover:bg-surface hover:text-ink transition-colors" data-sort="index">
                  <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h10a2 2 0 012 2v1m-6 14h6m-3-5h3m-3-10h3"/></svg>
                  Default Order
                </button>
              </div>
            </div>
          </div>
        </div>
        <div id="categories-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <div class="col-span-full text-center text-steel py-12" id="categories-loading">Loading categories…</div>
        </div>
        <div id="categories-empty" class="hidden col-span-full text-center text-steel py-12">
          <div class="text-4xl mb-4">🔍</div>
          <p>No categories found matching your search.</p>
        </div>
        <div id="categories-error" class="hidden col-span-full text-center text-brand-error py-12">
          Unable to load categories. Please refresh the page.
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-section px-4 sm:px-6 lg:px-8 bg-canvas">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-heading-3 text-ink mb-4">How It Works</h2>
          <p class="text-body-md text-steel max-w-xl mx-auto">Three simple steps to participate in the Peace League Awards</p>
        </div>
        <ol class="grid grid-cols-1 md:grid-cols-3 gap-8 list-none">
          <li class="text-center scroll-reveal">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-accent">01</span>
            </div>
            <h3 class="text-heading-5 text-ink mb-2">Browse Nominees</h3>
            <p class="text-body-sm text-steel">Explore categories and discover the champions of peace-building across Africa.</p>
          </li>
          <li class="text-center scroll-reveal">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-accent">02</span>
            </div>
            <h3 class="text-heading-5 text-ink mb-2">Cast Your Vote</h3>
            <p class="text-body-sm text-steel">Vote for your favourite nominees. One vote per category. It's free and open to everyone.</p>
          </li>
          <li class="text-center scroll-reveal">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-accent">03</span>
            </div>
            <h3 class="text-heading-5 text-ink mb-2">Celebrate</h3>
            <p class="text-body-sm text-steel">Join us on December 17, 2026 at August 7th Memorial Park, Nairobi for the gala awards ceremony.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- Tickets / Pricing -->
    <section class="py-section px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/10 rounded-full text-accent-deep font-semibold text-sm mb-4">
            🎟️ Secure Your Seat
          </div>
          <h2 class="text-heading-3 text-ink mb-4">Attend the Gala</h2>
          <p class="text-body-md text-steel max-w-xl mx-auto">
            Join us on December 17, 2026 at August 7th Memorial Park, Nairobi for an unforgettable day of recognition.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
          <!-- Early Bird -->
          <div class="card-base p-6 flex flex-col gap-4 scroll-reveal relative overflow-hidden">
            <div class="absolute -top-4 right-4 bg-accent text-primary text-xs font-bold px-3 py-1 rounded-full">Save 29%</div>
            <div>
              <h3 class="text-heading-5 text-ink">Early Bird Standard Seat</h3>
              <p class="text-sm text-steel mt-1">Limited early bird offer before August 31.</p>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-ink">KES 2,500</span>
              <span class="text-sm text-muted line-through">3,500</span>
            </div>
            <ul class="space-y-2 text-sm text-steel flex-1">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Gala Dinner
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Event Programme
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Full Gala Access
              </li>
            </ul>
            <button class="btn w-full" disabled aria-disabled="true">Sold Out</button>
            <p class="text-xs text-steel text-center -mt-2">100 tickets — all claimed</p>
          </div>
          <!-- Standard -->
          <div class="card-base p-6 flex flex-col gap-4 scroll-reveal">
            <div>
              <h3 class="text-heading-5 text-ink">Standard Seat</h3>
              <p class="text-sm text-steel mt-1">Standard single seat at the gala.</p>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-ink">KES 3,500</span>
            </div>
            <ul class="space-y-2 text-sm text-steel flex-1">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Gala Dinner
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Event Programme
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Full Gala Access
              </li>
            </ul>
            <button class="btn w-full" disabled aria-disabled="true">Sold Out</button>
          </div>
          <!-- Premium -->
          <div class="card-base p-6 flex flex-col gap-4 scroll-reveal border-accent/40 ring-1 ring-accent/20 relative">
            <div class="absolute -top-3 left-4 bg-accent text-[#0a0a0a] text-xs font-bold px-3 py-1 rounded-full">POPULAR</div>
            <div>
              <h3 class="text-heading-5 text-ink">Premium Seat</h3>
              <p class="text-sm text-steel mt-1">Priority placement and exclusive networking.</p>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-ink">KES 6,500</span>
            </div>
            <ul class="space-y-2 text-sm text-steel flex-1">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Gala Dinner
              </li>
              <li class="flex items-start gap-2">
