---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

// Placeholder data - will come from Frappe API
const categories = [
  { slug: 'peace-ambassador', name: 'Peace Ambassador for Fighting Radicalism and Terrorism', description: 'Recognizing individuals who have made exceptional contributions to countering violent extremism and promoting peaceful coexistence.', icon: '🕊️' },
  { slug: 'lifetime-diplomacy', name: 'Lifetime Achievement Award in Diplomacy and Governance', description: 'Honoring a distinguished career in diplomacy and public service that has advanced peace and good governance.', icon: '🏛️' },
  // ... 60 more categories (in real implementation, fetch from API)
];
---

<Layout title="Awards" description="Browse and vote for the Peace League Africa Awards categories. Recognize excellence in peace-building, community service, leadership, and more across East Africa and the Great Lakes region.">
  <Navigation />

  <main id="main-content" class="min-h-screen">
    <!-- Page Header -->
    <section class="bg-surface py-section-sm px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl">
          <h1 class="text-heading-2 text-ink mb-4">Peace League Awards</h1>
          <p class="text-body-md text-steel mb-6">
            Celebrate the champions of peace across East Africa and the Great Lakes region. Browse 62 award categories, nominate outstanding individuals and organizations, and cast your vote for the 2026 winners.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/awards/nominate" class="btn btn-primary">Nominate Someone</a>
            <a href="/awards" class="btn btn-secondary">Vote Now</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-canvas py-6 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-2xl font-bold text-accent">62</div>
            <div class="text-sm text-steel">Award Categories</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent" id="nominee-count">~500</div>
            <div class="text-sm text-steel">Nominees</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent" id="vote-count">12,000+</div>
            <div class="text-sm text-steel">Votes Cast</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent">5 Dec 2026</div>
            <div class="text-sm text-steel">Announcement</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Grid -->
    <section class="py-section px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8 flex justify-between items-end">
          <h2 class="text-heading-3 text-ink">Award Categories</h2>
          <div class="flex gap-2">
            <!-- Search & Filter could be added later -->
          </div>
        </div>

        <div id="categories-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <!-- Categories will be loaded via JS -->
          <div class="col-span-full text-center text-steel py-12">Loading categories…</div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="bg-accent/10 py-section">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-heading-3 text-ink mb-4">Know an deserving champion?</h2>
        <p class="text-body-md text-steel mb-6 max-w-2xl mx-auto">
          Anyone can nominate. Recognize individuals and organizations making a difference in peace, governance, community service, and more across Africa.
        </p>
        <a href="/awards/nominate" class="btn btn-primary btn-large">Submit a Nomination</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Custom award category card styling */
  .card-award-category {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-award-category:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }
</style>
