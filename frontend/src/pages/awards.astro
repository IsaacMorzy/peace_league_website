---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Awards" description="Browse and vote for the Peace League Africa Awards categories. Recognize excellence in peace-building, community service, leadership, and more across East Africa and the Great Lakes region.">
  <Navigation />

  <main id="main-content" class="min-h-screen">
    <!-- Page Header -->
    <section class="bg-surface py-section-sm px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl">
          <h1 class="text-heading-2 text-ink mb-4">Peace League Awards</h1>
          <p class="text-body-md text-steel mb-6">
            Browse categories, nominate, and vote. Awards announced December 5, 2026.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/awards/nominate" class="btn btn-primary">Nominate Someone</a>
            <a href="/awards" class="btn btn-secondary">Vote Now</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-canvas py-6 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-2xl font-bold text-accent" id="stat-categories">—</div>
            <div class="text-sm text-steel">Award Categories</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent" id="stat-nominees">—</div>
            <div class="text-sm text-steel">Nominees</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent" id="stat-votes">—</div>
            <div class="text-sm text-steel">Votes Cast</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent">5 Dec 2026</div>
            <div class="text-sm text-steel">Announcement</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Grid -->
    <section class="py-section px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8 flex justify-between items-end">
          <h2 class="text-heading-3 text-ink">Award Categories</h2>
          <div class="flex gap-2">
            <input
              type="search"
              id="category-search"
              placeholder="Search categories…"
              class="px-4 py-2 rounded-lg border border-hairline bg-canvas text-ink text-sm focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
            />
          </div>
        </div>

        <div id="categories-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <div class="col-span-full text-center text-steel py-12" id="categories-loading">Loading categories…</div>
        </div>
        <div id="categories-empty" class="hidden col-span-full text-center text-steel py-12">
          No categories found.
        </div>
        <div id="categories-error" class="hidden col-span-full text-center text-brand-error py-12">
          Unable to load categories. Please refresh the page.
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="bg-accent/10 py-section">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-heading-3 text-ink mb-4">Nominate someone</h2>
        <p class="text-body-md text-steel mb-6 max-w-2xl mx-auto">
          Anyone can submit a nomination. No fee, no membership required.
        </p>
        <a href="/awards/nominate" class="btn btn-primary btn-large">Submit a Nomination</a>
      </div>
  </section>

  <!-- Cross-links -->
  <section class="py-10 bg-canvas border-t border-hairline">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-steel mb-4">You might also be interested in</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/causes" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Our Causes</a>
        <a href="/donate" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Donate</a>
        <a href="/events" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Events</a>
        <a href="/testimonials" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Testimonials</a>
      </div>
    </div>
  </section>
</main>

  <Footer />
</Layout>

<script>
  import { getAwardCategories } from '../lib/api.js';

  let allCategories = [];

  async function loadCategories() {
    try {
      const res = await getAwardCategories();
      if (res.status !== 'success' || !res.data) {
        throw new Error(res.message || 'API error');
      }
      allCategories = res.data;
      document.getElementById('stat-categories').textContent = allCategories.length;
      renderCategories(allCategories);
    } catch (err) {
      console.error('Awards load error:', err);
      document.getElementById('categories-loading').classList.add('hidden');
      document.getElementById('categories-error').classList.remove('hidden');
    }
  }

  function renderCategories(cats) {
    const grid = document.getElementById('categories-grid');
    const loading = document.getElementById('categories-loading');
    const empty = document.getElementById('categories-empty');
    const error = document.getElementById('categories-error');

    loading.classList.add('hidden');
    error.classList.add('hidden');

    if (!cats.length) {
      empty.classList.remove('hidden');
      return;
    }
    empty.classList.add('hidden');

    grid.innerHTML = cats.map(cat => `
      <a href="/awards/category/${encodeURIComponent(cat.slug)}" class="card-award-category card-base p-6 block hover:border-accent/30 transition-all duration-200">
        <h3 class="text-heading-5 text-ink mb-2 line-clamp-2">${escapeHtml(cat.category_name)}</h3>
        <p class="text-body-sm text-steel line-clamp-3">${escapeHtml(cat.description || '')}</p>
        <div class="mt-4 text-sm font-medium text-accent">View nominees →</div>
      </a>
    `).join('');
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // Search filter
  const searchEl = document.getElementById('category-search');
  if (searchEl) {
    searchEl.addEventListener('input', () => {
      const q = searchEl.value.toLowerCase().trim();
      const filtered = q
        ? allCategories.filter(c =>
            c.category_name.toLowerCase().includes(q) ||
            (c.description || '').toLowerCase().includes(q))
        : allCategories;
      renderCategories(filtered);
    });
  }

  loadCategories();
</script>

<style>
  .card-award-category {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-award-category:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }
</style>
