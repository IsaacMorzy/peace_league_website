<script>
  import { getAwardCategories } from '../lib/api.js';

  let allCategories = [];

  // Countdown timer
  const TARGET_DATE = new Date('2026-12-17T10:00:00+03:00');

  function updateCountdown() {
    const now = new Date();
    const diff = TARGET_DATE - now;
    if (diff <= 0) {
      ['days','hours','minutes','seconds'].forEach(id => {
        const el = document.getElementById('countdown-' + id);
        if (el) el.textContent = '00';
      });
      return;
    }
    document.getElementById('countdown-days').textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
    document.getElementById('countdown-hours').textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
    document.getElementById('countdown-minutes').textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
    document.getElementById('countdown-seconds').textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // Ceremony days remaining (static, updated on load)
  const ceremonyDate = new Date('2026-12-17T10:00:00+03:00');
  const ceremonyDaysEl = document.getElementById('stat-ceremony-countdown-days');
  if (ceremonyDaysEl) {
    const diff = ceremonyDate - new Date();
    ceremonyDaysEl.textContent = diff > 0 ? Math.ceil(diff / 86400000).toLocaleString() : '0';
  }

  // Animated count-up
  function animateCount(el, target, duration = 1200) {
    const start = 0;
    const startTime = performance.now();
    function tick(now) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(start + (target - start) * eased).toLocaleString();
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  async function loadCategories() {
    try {
      const res = await getAwardCategories();
      if (res.status !== 'success' || !res.data) throw new Error(res.message || 'API error');
      allCategories = res.data;
      animateCount(document.getElementById('stat-categories'), allCategories.length);
      renderCategories(allCategories);
    } catch (err) {
      console.error('Awards load error:', err);
      document.getElementById('categories-loading').classList.add('hidden');
      document.getElementById('categories-error').classList.remove('hidden');
    }
  }

  function renderCategories(cats) {
    const grid = document.getElementById('categories-grid');
    const loading = document.getElementById('categories-loading');
    const empty = document.getElementById('categories-empty');
    const error = document.getElementById('categories-error');
    loading.classList.add('hidden');
    error.classList.add('hidden');
    if (!cats.length) { empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');

    grid.innerHTML = cats.map((cat, i) => `
      <a href="/awards/category/${encodeURIComponent(cat.slug)}"
         class="card-shadow-shift card-base p-6 flex flex-col gap-3 group">
        <div class="flex items-start justify-between">
          <span class="text-xs font-bold text-accent bg-accent/10 px-2.5 py-1 rounded-full">${String(i + 1).padStart(2, '0')}</span>
          <span class="text-xs text-steel bg-surface px-2.5 py-1 rounded-full">${cat.nominee_count || 0} nominee${cat.nominee_count !== 1 ? 's' : ''}</span>
        </div>
        <h3 class="text-heading-5 text-ink line-clamp-2 group-hover:text-accent-deep transition-colors">${escapeHtml(cat.category_name)}</h3>
        <p class="text-body-sm text-steel line-clamp-2 flex-1">${escapeHtml(cat.description || 'No description available.')}</p>
        <div class="flex items-center justify-between pt-2 border-t border-hairline mt-auto">
          <span class="text-sm font-medium text-accent">View nominees →</span>
        </div>
      </a>
    `).join('');
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML.replace(/\"/g, '&quot;').replace(/'/g, '&#39;');
  }

  document.getElementById('category-search')?.addEventListener('input', () => {
    const q = document.getElementById('category-search').value.toLowerCase().trim();
    renderCategories(q ? allCategories.filter(c => c.category_name.toLowerCase().includes(q) || (c.description || '').toLowerCase().includes(q)) : allCategories);
  });

  // Preline dropdown sort handlers
  document.querySelectorAll('.sort-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const sort = btn.dataset.sort;
      let sorted = [...allCategories];
      if (sort === 'name') sorted.sort((a, b) => a.category_name.localeCompare(b.category_name));
      else if (sort === 'nominees') sorted.sort((a, b) => (b.nominee_count || 0) - (a.nominee_count || 0));
      // 'index' keeps original order
      renderCategories(sorted);
      const dropdown = document.querySelector('.hs-dropdown');
      if (dropdown && window.HSDropdown) {
        const toggle = dropdown.querySelector('.hs-dropdown-toggle');
        const instance = window.HSDropdown.getInstance(toggle);
        if (instance) instance.close();
      }
    });
  });

  loadCategories();
</script>

