  <Footer />

  <script>
    // ── Hero Countdown ──
    const heroTimer = document.getElementById('hero-countdown');
    const heroDate = heroTimer ? new Date(heroTimer.dataset.targetDate).getTime() : 0;
    const hDays = document.getElementById('hero-days');
    const hHours = document.getElementById('hero-hours');
    const hMins = document.getElementById('hero-mins');
    const hSecs = document.getElementById('hero-secs');

    if (hDays) {
      function updateHeroCountdown() {
        if (!heroDate) return;
        const now = new Date().getTime();
        const diff = heroDate - now;
        if (diff <= 0) {
          hDays.textContent = '00'; hHours.textContent = '00';
          hMins.textContent = '00'; hSecs.textContent = '00';
          return;
        }
        hDays.textContent = String(Math.floor(diff / (1000 * 60 * 60 * 24))).padStart(2, '0');
        hHours.textContent = String(Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))).padStart(2, '0');
        hMins.textContent = String(Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))).padStart(2, '0');
        hSecs.textContent = String(Math.floor((diff % (1000 * 60)) / 1000)).padStart(2, '0');
        requestAnimationFrame(updateHeroCountdown);
      }
      requestAnimationFrame(updateHeroCountdown);
    }

    // ── Map Share Buttons ──
    document.getElementById('share-map-btn')?.addEventListener('click', function() {
      if (navigator.share) {
        navigator.share({
          title: 'Peace League Africa Events',
          text: 'Check out Peace League Africa\'s peace-building events across Africa!',
          url: 'https://peaceleagueafrica.org/events'
        }).catch(() => {});
      } else {
        // Fallback: copy link and notify
        navigator.clipboard.writeText('https://peaceleagueafrica.org/events').then(() => {
          var btn = document.getElementById('share-map-btn');
          var orig = btn.innerHTML;
          btn.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Link Copied!';
          setTimeout(function() { btn.innerHTML = orig; }, 2500);
        });
      }
    });

    document.getElementById('copy-link-btn')?.addEventListener('click', function() {
      navigator.clipboard.writeText('https://peaceleagueafrica.org/events').then(function() {
        var span = document.getElementById('copy-link-text');
        if (span) {
          span.textContent = 'Copied!';
          setTimeout(function() { span.textContent = 'Copy Link'; }, 2500);
        }
      });
    });

    // ── Filter Buttons ──
    const filterBtns = document.querySelectorAll('.filter-btn');
    const upcoming = document.getElementById('events-upcoming');
    const past = document.getElementById('events-past');
    const emptyEl = document.getElementById('events-empty');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.className = 'filter-btn px-5 py-2.5 text-sm font-semibold bg-canvas text-steel border border-hairline rounded-full hover:border-accent hover:text-accent hover:shadow-md transition-all duration-300 cursor-pointer';
          b.setAttribute('aria-pressed', 'false');
        });
        btn.className = 'filter-btn px-5 py-2.5 text-sm font-semibold bg-primary text-on-primary rounded-full transition-all duration-300 cursor-pointer shadow-lg shadow-accent/15';
        btn.setAttribute('aria-pressed', 'true');

        const filter = btn.dataset.filter;
        if (filter === 'all') {
          upcoming.classList.remove('hidden'); past.classList.remove('hidden'); emptyEl.classList.add('hidden');
        } else if (filter === 'upcoming') {
          upcoming.classList.remove('hidden'); past.classList.add('hidden'); emptyEl.classList.add('hidden');
        } else {
          upcoming.classList.add('hidden'); past.classList.remove('hidden'); emptyEl.classList.add('hidden');
        }
      });
    });

    // ── View Toggle (Grid / List) ──
    const gridView = document.getElementById('events-grid-view');
    const listView = document.getElementById('events-list-view');
    const viewGridBtn = document.getElementById('view-grid');
    const viewListBtn = document.getElementById('view-list');

    if (viewGridBtn && viewListBtn) {
      viewGridBtn.addEventListener('click', () => {
        gridView.classList.remove('hidden'); listView.classList.add('hidden');
        viewGridBtn.className = 'view-toggle px-3 py-2 rounded-lg bg-accent/10 text-accent transition-all cursor-pointer';
        viewListBtn.className = 'view-toggle px-3 py-2 rounded-lg bg-canvas text-steel border border-hairline transition-all cursor-pointer';
      });
      viewListBtn.addEventListener('click', () => {
        gridView.classList.add('hidden'); listView.classList.remove('hidden');
        viewListBtn.className = 'view-toggle px-3 py-2 rounded-lg bg-accent/10 text-accent transition-all cursor-pointer';
        viewGridBtn.className = 'view-toggle px-3 py-2 rounded-lg bg-canvas text-steel border border-hairline transition-all cursor-pointer';
      });
    }

    // ── Scroll Reveal (complementing Layout.astro's system) ──
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const delay = el.dataset.revealDelay || 0;
          setTimeout(() => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0) translateX(0) scale(1)';
          }, delay);
          revealObserver.unobserve(el);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('[data-reveal]').forEach(el => {
      const dir = el.dataset.reveal || 'up';
      el.style.opacity = '0';
      el.style.transition = 'opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)';
      if (dir === 'left') el.style.transform = 'translateX(-30px)';
      else if (dir === 'right') el.style.transform = 'translateX(30px)';
      else if (dir === 'scale') el.style.transform = 'scale(0.85)';
      else el.style.transform = 'translateY(30px)';
      revealObserver.observe(el);
    });

    // ── Tilt Cards ──
    const tiltCards = document.querySelectorAll('.tilt-card');
    if (tiltCards.length && window.matchMedia('(pointer: fine)').matches) {
      tiltCards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((y - centerY) / centerY) * -4;
          const rotateY = ((x - centerX) / centerX) * 4;
          card.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02,1.02,1.02)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)';
        });
      });
    }
  </script>

