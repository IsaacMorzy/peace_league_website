---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const upcomingEvents = [
  { day: '15', month: 'Jun', title: 'Peace Education Summit', location: 'Nairobi, Kenya', desc: 'Bringing together educators, community leaders, and policymakers to advance peace curriculum across East African schools.', image: 'photo-1524178232363-1fb2b075b655' },
  { day: '22', month: 'Jul', title: 'Youth Leadership Workshop', location: 'Kampala, Uganda', desc: 'A three-day intensive workshop empowering young leaders with conflict resolution, public speaking, and civic engagement skills.', image: 'photo-1571019613454-1cb2f99b2d8b' },
  { day: '08', month: 'Aug', title: 'Community Health Fair', location: 'Kigali, Rwanda', desc: 'Free health screenings, nutrition counseling, and wellness education for underserved communities in the Great Lakes region.', image: 'photo-1511795409834-ef04bbd61622' },
  { day: '19', month: 'Sep', title: 'Annual Gala & Fundraiser', location: 'Nairobi, Kenya', desc: 'Our flagship fundraising event featuring guest speakers, beneficiary stories, and a celebration of peace-building achievements.', image: 'photo-1540575467063-178a50c2df87' },
  { day: '05', month: 'Oct', title: 'Water Well Inauguration', location: 'Turkana, Kenya', desc: 'Join us as we commission our 50th clean water well, providing safe drinking water to over 5,000 community members.', image: 'photo-1534430480872-3498386e7856' },
  { day: '14', month: 'Nov', title: 'Interfaith Dialogue Forum', location: 'Addis Ababa, Ethiopia', desc: 'Religious and community leaders gather to foster mutual understanding and build bridges across faith traditions.', image: 'photo-1529156069898-49953e39b3ac' },
];

const pastEvents = [
  { day: '02', month: 'Apr', title: 'Peace Run 2026', location: 'Nairobi, Kenya', desc: 'Hundreds of runners came together to promote peace and raise funds for community programs across the city.' },
  { day: '18', month: 'Mar', title: 'Women in Peacebuilding', location: 'Kampala, Uganda', desc: 'A landmark conference celebrating the role of women in conflict resolution and community reconciliation.' },
  { day: '10', month: 'Feb', title: 'Clean Water Awareness Day', location: 'Kisumu, Kenya', desc: 'Community members gathered to learn about water conservation and celebrate the completion of three new wells.' },
];
---

<Layout title="Events" description="Join Peace League Africa for peace-building events, community gatherings, and fundraisers across East Africa. Upcoming workshops, health fairs, and more.">
  <Navigation />

  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "Events", "item": "https://peaceleagueafrica.org/events" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EventSeries",
      "name": "Peace League Africa Events",
      "description": "Peace-building events, community gatherings, and fundraising initiatives across Africa and beyond.",
      "event": upcomingEvents.map(e => ({
        "@type": "Event",
        "name": e.title,
        "description": e.desc,
        "location": { "@type": "Place", "name": e.location },
        "startDate": "2026-" + ({
          "Jun": "06", "Jul": "07", "Aug": "08", "Sep": "09", "Oct": "10", "Nov": "11"
        }[e.month] || "06") + "-" + e.day
      }))
    })} />
    <section class="hero-gradient text-white py-4 lg:py-8 hero-pattern">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight">Our Events</h1>
          <p class="mt-4 text-lg text-white/80 max-w-2xl">From peace summits in Nairobi to health fairs in Kampala — find an event near you and be part of the change across 12 countries.</p>
        </div>
        <div class="parallax-layer" aria-hidden="true">
          <div class="parallax-bg-shape" style="width:300px;height:300px;top:-50px;right:-80px;background:radial-gradient(circle, rgba(0,212,164,0.3) 0%, transparent 70%);"></div>
          <div class="parallax-bg-shape" style="width:200px;height:200px;bottom:-40px;left:-60px;background:radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);"></div>
        </div>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-3 mb-12" id="event-filters">
          <button data-filter="all" aria-pressed="true" class="filter-btn px-5 py-2 text-sm font-medium bg-primary text-on-primary rounded-full transition-all duration-300 cursor-pointer min-h-[44px]">All Events</button>
          <button data-filter="upcoming" aria-pressed="false" class="filter-btn px-5 py-2 text-sm font-medium bg-canvas text-steel border border-hairline rounded-full hover:border-accent hover:text-accent transition-all duration-300 cursor-pointer min-h-[44px]">Upcoming</button>
          <button data-filter="past" aria-pressed="false" class="filter-btn px-5 py-2 text-sm font-medium bg-canvas text-steel border border-hairline rounded-full hover:border-accent hover:text-accent transition-all duration-300 cursor-pointer min-h-[44px]">Past</button>
        </div>

        <div id="events-empty" class="hidden text-center py-16">
          <svg class="w-16 h-16 mx-auto text-muted mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <p class="text-lg font-semibold text-ink">No events found</p>
          <p class="text-sm text-steel mt-1">Check back soon for upcoming events.</p>
        </div>

        <div id="events-upcoming">
          <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Upcoming Events</h2>
          <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Mark your calendar. Bring your passion. Be part of building lasting peace across East Africa.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {upcomingEvents.map((event, idx) => (
              <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 bg-canvas rounded-2xl border border-hairline overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-lg group" style={`animation-delay: ${idx * 80}ms`}>
                <div class="relative overflow-hidden img-zoom">
                  <img src={`https://images.unsplash.com/${event.image}?w=600&q=80&auto=format&fit=crop`} alt={event.title} class="w-full h-52 object-cover transition-transform duration-700 group-hover:scale-108" loading="lazy" />
                  <div class="absolute top-4 left-4 bg-accent text-on-dark text-center rounded-lg px-3 py-2 leading-tight shadow-lg">
                    <span class="block text-xl font-bold leading-none">{event.day}</span>
                    <span class="block text-xs font-semibold mt-0.5 uppercase">{event.month}</span>
                  </div>
                </div>
                <div class="p-6">
                  <div class="flex items-center gap-1.5 text-xs text-steel mb-2">
                    <svg class="w-3.5 h-3.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span>{event.location}</span>
                  </div>
                  <h3 class="text-lg font-semibold text-ink mb-2">{event.title}</h3>
                  <p class="text-sm text-steel leading-relaxed mb-4">{event.desc}</p>
                  <a href="/contact" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-deep transition-colors py-2">
                    Register Now
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div id="events-past" class="hidden">
          <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-12">Past Events</h2>
          <div class="max-w-3xl mx-auto space-y-4">
            {pastEvents.map((event, idx) => (
              <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 flex items-center gap-6 bg-canvas rounded-2xl border border-hairline p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-md" style={`animation-delay: ${idx * 80}ms`}>
                <div class="shrink-0 w-14 h-14 bg-surface rounded-lg flex flex-col items-center justify-center text-center">
                  <span class="text-lg font-bold text-accent leading-none">{event.day}</span>
                  <span class="text-xs font-semibold text-steel uppercase mt-0.5">{event.month}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-ink">{event.title}</h3>
                  <p class="text-xs text-steel mt-0.5">{event.location}</p>
                  <p class="text-sm text-steel/70 mt-1 leading-relaxed">{event.desc}</p>
                </div>
                <span class="text-xs text-steel bg-surface px-3 py-1 rounded-full shrink-0">Completed</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 hero-gradient text-white hero-pattern">
      <div class="max-w-3xl mx-auto text-center px-4">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px]">Stay Updated</h2>
        <p class="scroll-reveal mt-4 text-lg text-white/80 mb-8">Never miss a chance to build peace. Get notified about upcoming events, workshops, and volunteer opportunities in your region.</p>
        <form class="scroll-reveal max-w-md mx-auto flex flex-col sm:flex-row gap-3">
          <input type="email" placeholder="Your email address" aria-label="Email address" class="w-full sm:flex-1 min-w-0 px-4 py-2.5 text-sm bg-white/10 border border-white/20 rounded-md text-white placeholder:text-white/50 outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all" />
          <button type="submit" class="w-full sm:w-auto px-5 py-2.5 text-sm font-medium bg-accent text-on-dark rounded-full hover:bg-accent-deep transition-colors whitespace-nowrap cursor-pointer">
            Get Event Updates
          </button>
        </form>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const upcoming = document.getElementById('events-upcoming');
    const past = document.getElementById('events-past');
    const empty = document.getElementById('events-empty');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.className = 'filter-btn px-5 py-2 text-sm font-medium bg-canvas text-steel border border-hairline rounded-full hover:border-accent hover:text-accent transition-all duration-300 cursor-pointer';
          b.setAttribute('aria-pressed', 'false');
        });
        btn.className = 'filter-btn px-5 py-2 text-sm font-medium bg-primary text-on-primary rounded-full transition-all duration-300 cursor-pointer';
        btn.setAttribute('aria-pressed', 'true');
        const filter = btn.dataset.filter;
        if (filter === 'all') {
          upcoming.classList.remove('hidden');
          past.classList.remove('hidden');
          empty.classList.add('hidden');
        } else if (filter === 'upcoming') {
          upcoming.classList.remove('hidden');
          past.classList.add('hidden');
          empty.classList.add('hidden');
        } else {
          upcoming.classList.add('hidden');
          past.classList.remove('hidden');
          empty.classList.add('hidden');
        }
      });
    });
  </script>
</Layout>
