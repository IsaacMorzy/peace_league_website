---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import events from '../lib/events-data.json';
import EventMap from '../components/EventMap.astro';

const upcomingEvents = events.filter(e => e.status === "upcoming");
const pastEvents = events.filter(e => e.status === "past");
const featuredEvents = events.filter(e => e.featured && e.status === "upcoming");

const monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const featuredEventsWithDate = featuredEvents.map(e => {
  const monthIndex = monthNames.indexOf(e.month);
  const d = new Date(parseInt(e.year), monthIndex, parseInt(e.day));
  return { ...e, dateObj: d };
});
const nextEvent = featuredEventsWithDate.sort((a, b) => a.dateObj - b.dateObj)[0] || upcomingEvents[0];

const monthMap = { "Jan":"01","Feb":"02","Mar":"03","Apr":"04","May":"05","Jun":"06","Jul":"07","Aug":"08","Sep":"09","Oct":"10","Nov":"11","Dec":"12" };
const nextIsoDate = nextEvent ? `${nextEvent.year}-${monthMap[nextEvent.month]}-${nextEvent.day.padStart(2,"0")}` : "2026-12-31";
const nextStartTime = nextEvent?.startTime || "09:00";

// Serialized events for the interactive map
const mapEventsJson = JSON.stringify({
  events: [...upcomingEvents, ...pastEvents].map(e => ({
    title: e.title,
    slug: e.slug,
    location: e.location,
    lat: e.lat,
    lng: e.lng,
    day: e.day,
    month: e.month,
    type: e.type,
    image: e.image,
    status: e.status,
    capacity: e.capacity,
    registered: e.registered,
  })),
});
---

<Layout title="Events" description="Join Peace League Africa for peace-building events, community gatherings, and fundraisers across East Africa. Upcoming workshops, health fairs, and more.">
  <Navigation />

  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "Events", "item": "https://peaceleagueafrica.org/events" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EventSeries",
      "name": "Peace League Africa Events",
      "description": "Peace-building events, community gatherings, and fundraising initiatives across Africa.",
      "event": upcomingEvents.map(e => ({
        "@type": "Event",
        "name": e.title,
        "description": e.description,
        "location": { "@type": "Place", "name": e.location },
        "startDate": `${e.year}-${monthMap[e.month]}-${e.day.padStart(2,"0")}`
      }))
    })} />

    <!-- ════════════════════════════════════════════════════════
         SPLIT HERO — Left: title + next event countdown
                     Right: animated mosaic of event images
         ════════════════════════════════════════════════════════ -->
    <section class="relative hero-inner grain-overlay overflow-hidden min-h-[70vh] flex items-center">
      <div class="orb-float orb-float--1" style="top:-120px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-100px;left:-80px;" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-28">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Left: Content -->
          <div data-reveal="left">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-xs sm:text-sm font-medium text-accent-soft border border-white/10 mb-6">
              <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
              {upcomingEvents.length} Events Across 6 Countries
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold leading-[1.02] tracking-[-2px] text-white mb-6">
              Gather.<br/>
              <span class="bg-gradient-to-r from-accent via-accent-soft to-accent bg-clip-text text-transparent">Build Peace.</span>
            </h1>

            <p class="text-lg sm:text-xl text-white/70 max-w-xl leading-relaxed mb-10">
              From summits in Nairobi to health fairs in Kigali — every event is a doorway into the movement. Find yours.
            </p>

            <!-- Next event countdown (if upcoming) -->
            {nextEvent && (
              <div class="bg-white/5 backdrop-blur-xl rounded-2xl p-5 border border-white/10 inline-block">
                <p class="text-xs text-white/50 uppercase tracking-widest font-semibold mb-3">Next Event</p>
                <p class="text-white font-semibold mb-3">{nextEvent.title} &middot; {nextEvent.location}</p>
                <div class="flex gap-4" id="hero-countdown" data-target-date={`${nextIsoDate}T${nextStartTime}:00`}>
                  <div class="text-center">
                    <span class="block text-3xl font-bold text-white tabular-nums" id="hero-days">--</span>
                    <span class="text-[10px] text-white/40 uppercase tracking-wider">days</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-3xl font-bold text-white tabular-nums" id="hero-hours">--</span>
                    <span class="text-[10px] text-white/40 uppercase tracking-wider">hrs</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-3xl font-bold text-white tabular-nums" id="hero-mins">--</span>
                    <span class="text-[10px] text-white/40 uppercase tracking-wider">min</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-3xl font-bold text-white tabular-nums" id="hero-secs">--</span>
                    <span class="text-[10px] text-white/40 uppercase tracking-wider">sec</span>
                  </div>
                </div>
              </div>
            )}

            <div class="flex flex-wrap gap-4 mt-8" data-magnetic-container>
              <a href="#events-grid" class="magnetic-btn group inline-flex items-center gap-2 px-6 py-3 bg-accent btn-text-contrast font-semibold rounded-full shadow-xl shadow-accent/25 hover:shadow-2xl hover:shadow-accent/40 hover:bg-accent-deep transition-all btn-ripple" data-magnet-strength="0.35">
                Explore Events
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              </a>
              <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/25 text-white font-semibold rounded-full hover:bg-white/10 transition-all btn-ripple">
                Host an Event
              </a>
            </div>
          </div>

          <!-- Right: Image mosaic -->
          <div data-reveal="right" class="hidden lg:block">
            <div class="grid grid-cols-2 gap-3">
              {featuredEvents.slice(0,4).map((e, i) => {
                const sizes = [
                  "row-span-2 h-full",
                  "h-40",
                  "h-40",
                  "h-40"
                ];
                return (
                  <div class={`relative rounded-2xl overflow-hidden shadow-lg ${i === 0 ? 'row-span-2' : ''}`} style={`height:${i === 0 ? '100%' : 'auto'}`}>
                    <img src={`https://images.unsplash.com/${e.image}?w=400&q=75&auto=format&fit=crop`} alt={e.title} class="w-full h-full object-cover transition-transform duration-700 hover:scale-110" loading={i < 2 ? "eager" : "lazy"} />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
                    <div class="absolute bottom-3 left-3 right-3">
                      <span class="text-xs font-semibold text-white/90 block truncate">{e.title}</span>
                      <span class="text-[10px] text-white/60">{e.month} {e.day}, {e.year}</span>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         BENTO GRID — Featured events in organic layout
         ════════════════════════════════════════════════════════ -->
    <section class="py-20 lg:py-28 bg-surface" id="events-grid">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section header -->
        <div class="text-center mb-16" data-reveal="up">
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">2026 Calendar</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-ink tracking-tight mb-4">Where Peace Happens</h2>
          <p class="text-lg text-steel max-w-2xl mx-auto">Mark your calendar. Bring your passion. Every event plants a seed of hope across 12 nations.</p>
        </div>

        <!-- Filter bar -->
        <div class="flex flex-wrap gap-3 mb-12 justify-center" data-reveal="up">
          <button data-filter="all" aria-pressed="true" class="filter-btn px-5 py-2.5 text-sm font-semibold bg-primary text-on-primary rounded-full transition-all duration-300 cursor-pointer shadow-lg shadow-accent/15">All Events</button>
          <button data-filter="upcoming" aria-pressed="false" class="filter-btn px-5 py-2.5 text-sm font-semibold bg-canvas text-steel border border-hairline rounded-full hover:border-accent hover:text-accent hover:shadow-md transition-all duration-300 cursor-pointer">Upcoming</button>
          <button data-filter="past" aria-pressed="false" class="filter-btn px-5 py-2.5 text-sm font-semibold bg-canvas text-steel border border-hairline rounded-full hover:border-accent hover:text-accent hover:shadow-md transition-all duration-300 cursor-pointer">Past Events</button>
          <div class="w-px h-8 bg-hairline self-center"></div>
          <div class="flex gap-2">
            <button id="view-grid" aria-pressed="true" class="view-toggle px-3 py-2 rounded-lg bg-accent/10 text-accent transition-all cursor-pointer" title="Grid view">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            </button>
            <button id="view-list" aria-pressed="false" class="view-toggle px-3 py-2 rounded-lg bg-canvas text-steel border border-hairline transition-all cursor-pointer" title="List view">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
            </button>
          </div>
        </div>

        <!-- Empty state -->
        <div id="events-empty" class="hidden text-center py-20">
          <div class="w-20 h-20 mx-auto rounded-2xl bg-accent/5 flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-accent/40" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <p class="text-xl font-semibold text-ink">No events found</p>
          <p class="text-sm text-steel mt-2 max-w-md mx-auto">Check back soon — we're always adding new opportunities to gather and build peace.</p>
        </div>

        <!-- Upcoming Events -->
        <div id="events-upcoming">
          <div class="flex items-center gap-4 mb-10" data-reveal="up">
            <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-ink tracking-tight">Upcoming Events</h2>
              <p class="text-sm text-steel">{upcomingEvents.length} events on the horizon</p>
            </div>
          </div>

          <!-- Grid view -->
          <div id="events-grid-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {upcomingEvents.map((event, idx) => (
              <a href={`/events/${event.slug}`}
                class="group relative bg-canvas rounded-2xl border border-hairline overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:border-accent/20 block tilt-card"
                style={`animation-delay: ${idx * 60}ms`} data-reveal="up">

                <!-- Image with date badge -->
                <div class="relative overflow-hidden aspect-[16/10]">
                  <img src={`https://images.unsplash.com/${event.image}?w=600&q=75&auto=format&fit=crop`}
                    alt={event.title} class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:rotate-[2deg]" loading={idx < 3 ? "eager" : "lazy"} />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-md text-center rounded-xl px-3 py-2 leading-tight shadow-lg">
                    <span class="block text-xl font-bold text-ink leading-none">{event.day}</span>
                    <span class="block text-xs font-semibold text-accent mt-0.5 uppercase">{event.month}</span>
                  </div>
                  <div class="absolute top-4 right-4">
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-accent/90 btn-text-contrast backdrop-blur-sm">
                      {event.type}
                    </span>
                  </div>
                </div>

                <!-- Content -->
                <div class="p-5">
                  <!-- Location -->
                  <div class="flex items-center gap-1.5 text-xs text-steel mb-2">
                    <svg class="w-3.5 h-3.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span>{event.location}</span>
                    <span class="mx-1">&middot;</span>
                    <span>{event.startTime}</span>
                  </div>

                  <!-- Title -->
                  <h3 class="text-base font-bold text-ink mb-2 leading-snug group-hover:text-accent transition-colors">
                    {event.title}
                  </h3>

                  <!-- Description -->
                  <p class="text-sm text-steel leading-relaxed line-clamp-2 mb-4">{event.description}</p>

                  <!-- Tags + CTA -->
                  <div class="flex items-center justify-between">
                    <div class="flex gap-1.5 flex-wrap">
                      {event.tags.slice(0,2).map(tag => (
                        <span class="px-2 py-0.5 rounded-md text-[10px] font-medium bg-surface text-steel border border-hairline">{tag}</span>
                      ))}
                    </div>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-accent opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
                      Details
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </span>
                  </div>

                  <!-- Capacity bar -->
                  {event.capacity > 0 && (
                    <div class="mt-4 pt-3 border-t border-hairline">
                      <div class="flex justify-between text-xs mb-1.5">
                        <span class="text-steel">{event.registered} registered</span>
                        <span class="font-semibold" class:list={event.registered / event.capacity > 0.8 ? "text-brand-warn" : "text-accent"}>
                          {Math.round((event.registered / event.capacity) * 100)}%
                        </span>
                      </div>
                      <div class="h-1.5 bg-surface rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-1000"
                          style={`width:${Math.round((event.registered / event.capacity) * 100)}%`}
                          class:list={event.registered / event.capacity > 0.8 ? "bg-brand-warn" : "bg-accent"}>
                        </div>
                      </div>
                    </div>
                  )}
                </div>

                <!-- Gradient hover border effect -->
                <div class="pointer-events-none absolute inset-0 rounded-[inherit] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                  style="border: 1.5px solid transparent; background: linear-gradient(135deg, #00d4a4, #7cebcb, #f59e0b, #00d4a4) border-box; -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; background-size: 300% 300%; animation: gradient-shift 4s ease infinite;">
                </div>
              </a>
            ))}
          </div>

          <!-- List view (hidden by default) -->
          <div id="events-list-view" class="hidden space-y-4">
            {upcomingEvents.map((event, idx) => (
              <a href={`/events/${event.slug}`}
                class="group flex items-center gap-5 bg-canvas rounded-2xl border border-hairline p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/20"
                style={`animation-delay: ${idx * 60}ms`} data-reveal="up">
                <div class="shrink-0 w-16 h-16 bg-surface rounded-xl flex flex-col items-center justify-center text-center border border-hairline group-hover:border-accent/30 transition-colors">
                  <span class="text-xl font-bold text-accent leading-none">{event.day}</span>
                  <span class="text-xs font-semibold text-steel uppercase mt-0.5">{event.month}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 text-xs text-steel mb-1">
                    <span>{event.location}</span>
                    <span>&middot;</span>
                    <span>{event.startTime}</span>
                    <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-accent/10 text-accent">{event.type}</span>
                  </div>
                  <h3 class="font-bold text-ink group-hover:text-accent transition-colors">{event.title}</h3>
                  <p class="text-sm text-steel/70 mt-0.5 line-clamp-1">{event.description}</p>
                </div>
                <div class="shrink-0">
                  <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
                    View
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Past Events -->
        <div id="events-past" class="hidden mt-20">
          <div class="flex items-center gap-4 mb-10" data-reveal="up">
            <div class="w-10 h-10 rounded-xl bg-stone/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-stone" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-ink tracking-tight">Past Events</h2>
              <p class="text-sm text-steel">{pastEvents.length} moments that shaped our journey</p>
            </div>
          </div>

          <!-- Timeline layout for past events -->
          <div class="relative" data-reveal="up">
            <div class="absolute left-[31px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent/30 via-accent/10 to-transparent"></div>
            <div class="space-y-6">
              {pastEvents.map((event, idx) => (
                <a href={`/events/${event.slug}`}
                  class="group relative flex gap-6 bg-canvas rounded-2xl border border-hairline p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg ml-0"
                  style={`animation-delay: ${idx * 80}ms`} data-reveal="up">
                  <div class="relative z-10">
                    <div class="w-14 h-14 rounded-xl bg-surface border-2 border-accent/20 flex flex-col items-center justify-center shrink-0 group-hover:border-accent/50 transition-colors">
                      <span class="text-lg font-bold text-accent leading-none">{event.day}</span>
                      <span class="text-xs font-semibold text-steel uppercase mt-0.5">{event.month}</span>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 text-xs text-steel mb-1">
                      <span>{event.location}</span>
                      <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-surface text-steel border border-hairline">{event.type}</span>
                    </div>
                    <h3 class="font-bold text-ink group-hover:text-accent transition-colors">{event.title}</h3>
                    <p class="text-sm text-steel/70 mt-1 leading-relaxed line-clamp-2">{event.description}</p>
                    <div class="flex items-center gap-3 mt-3">
                      <span class="inline-flex items-center gap-1 text-xs font-semibold text-accent opacity-0 group-hover:opacity-100 transition-all">
                        Read recap
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                      </span>
                      <span class="text-xs text-steel/50">&middot;</span>
                      <span class="text-xs text-steel/50">{event.year}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         INTERACTIVE MAP — All event locations across Africa
         ════════════════════════════════════════════════════════ -->
    <section class="py-20 lg:py-28 bg-canvas">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-reveal="up">
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">Where We Gather</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-ink tracking-tight mb-4">Events Across Africa</h2>
          <p class="text-lg text-steel max-w-2xl mx-auto">From Nairobi to Addis Ababa — peace-building events are happening across the continent. Click a marker to learn more.</p>
        </div>

        <EventMap eventsJson={mapEventsJson} showLegend={true} showShareButton={false} />

        <!-- Social share bar below map -->
        <div class="flex flex-wrap items-center justify-center gap-3 mt-6" data-reveal="up">
          <span class="text-xs font-semibold text-steel uppercase tracking-wider mr-1">Share this map:</span>
