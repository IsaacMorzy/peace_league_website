---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Service" description="Peace League Africa Terms of Service. Read our terms governing donations, volunteering, and use of our website.">
  <Navigation />
  
  <main id="main-content">
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
      <!-- Ambient orbs -->
      <div class="orb-float orb-float--1" style="top:-100px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-80px;left:-80px;" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.10] tracking-tight">Terms of Service</h1>
        <p class="mt-4 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-150 text-lg text-white/70">Last updated: January 2026</p>
      </div>
      <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);filter:blur(40px);"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <!-- Doves flying (natural swooping arcs) -->
        <span class="animate-dove-drift" style="left:18%;bottom:-20%;animation-delay:0.5s;font-size:1.125rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow" style="left:55%;bottom:-25%;animation-delay:2s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift" style="left:82%;bottom:-15%;animation-delay:3.5s;font-size:1rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <!-- Hearts pulsing -->
        <!-- Sparkle particles -->
        <span class="animate-particle" style="left:10%;bottom:5%;width:4px;height:4px;border-radius:50%;background:var(--color-accent);animation-delay:1s;"></span>
        <span class="animate-particle--fast" style="left:25%;bottom:10%;width:3px;height:3px;border-radius:50%;background:var(--color-accent-soft);animation-delay:0.3s;"></span>
        <span class="animate-particle" style="left:40%;bottom:8%;width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.4);animation-delay:2s;"></span>
        <span class="animate-particle--glow" style="left:60%;bottom:0;color:var(--color-accent);animation-delay:1.5s;font-size:1.2rem;">&#x2726;</span>
        <span class="animate-particle--fast" style="left:75%;bottom:15%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:2.5s;"></span>
        <span class="animate-particle" style="left:90%;bottom:5%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
      </div>
    </section>

    <section class="py-10 lg:py-14 bg-surface">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="scroll-reveal bg-canvas/80 backdrop-blur-xl rounded-2xl border border-hairline p-8 md:p-10 shadow-[0_8px_32px_rgba(0,0,0,0.06)] prose prose-sm max-w-none text-steel">
          <h2 class="text-2xl font-bold text-ink mt-0">1. Acceptance of Terms</h2>
          <p>By accessing or using the Peace League Africa website, you agree to be bound by these Terms of Service. If you do not agree, please do not use our services.</p>

          <h2 class="text-2xl font-bold text-ink">2. Donations</h2>
          <p>All donations are voluntary and non-refundable. Peace League Africa is committed to using donor funds responsibly in accordance with our mission. Donations are tax-deductible where applicable by law. A receipt will be provided for every donation.</p>

          <h2 class="text-2xl font-bold text-ink">3. Volunteering</h2>
          <p>Volunteer applications are subject to review. Submitting an application does not guarantee placement. Peace League Africa reserves the right to decline volunteers who do not meet program requirements.</p>

          <h2 class="text-2xl font-bold text-ink">4. Privacy</h2>
          <p>Your privacy matters to us. We collect and use personal information only as described in our <a href="/privacy" class="text-accent hover:text-accent-deep underline">Privacy Policy</a>. We do not sell or share your data with third parties for marketing purposes.</p>

          <h2 class="text-2xl font-bold text-ink">5. Intellectual Property</h2>
          <p>All content on this website — including text, images, logos, and designs — is the property of Peace League Africa unless otherwise credited. You may not reproduce, distribute, or modify our content without written permission.</p>

          <h2 class="text-2xl font-bold text-ink">6. Limitation of Liability</h2>
          <p>Peace League Africa shall not be liable for any indirect, incidental, or consequential damages arising from your use of this website or our services.</p>

          <h2 class="text-2xl font-bold text-ink">7. Changes to Terms</h2>
          <p>We may update these terms at any time. Changes will be posted on this page with an updated revision date. Continued use of our services after changes constitutes acceptance of the new terms.</p>

          <h2 class="text-2xl font-bold text-ink">8. Contact</h2>
          <p>For questions about these terms, please <a href="/contact" class="text-accent hover:text-accent-deep underline">contact us</a>.</p>
        </div>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="py-10 bg-surface border-t border-hairline">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm text-steel mb-4">You might also be interested in</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/privacy" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Privacy Policy</a>
          <a href="/faq" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">FAQ</a>
          <a href="/contact" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Contact</a>
          <a href="/about" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">About Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
