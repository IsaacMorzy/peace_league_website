---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---
const partnerUrl = new URL("/partner", Astro.url).href;
const orgLogoUrl = new URL("/logo.png", Astro.url).href;

<Layout title="Partner With Us" description="Partner with Peace League Africa. Corporate, NGO, foundation, and community partnerships that build lasting peace across 12 African countries. Start the conversation.">
  <Navigation />

  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.com" },
        { "@type": "ListItem", "position": 2, "name": "Partner With Us", "item": "https://peaceleagueafrica.com/partner" }
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Peace League Africa",
      "url": Astro.url.origin,
      "logo": orgLogoUrl,
      "sameAs": [
        "https://twitter.com/peaceleagueafrica",
        "https://facebook.com/peaceleagueafrica",
        "https://linkedin.com/company/peaceleagueafrica"
      ],
      "knowsAbout": [
        "Peace education",
        "Conflict resolution",
        "Youth mentorship",
        "Clean water access",
        "Community health"
      ],
      "areaServed": [
        { "@type": "Country", "name": "Kenya" },
        { "@type": "Country", "name": "Uganda" },
        { "@type": "Country", "name": "Rwanda" },
        { "@type": "Country", "name": "Ethiopia" },
        { "@type": "Country", "name": "South Sudan" }
      ],
      "potentialAction": {
        "@type": "ContactAction",
        "target": { "@type": "EntryPoint", "urlTemplate": partnerUrl" }
      }
    })} />
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
      <!-- Ambient orbs -->
      <div class="orb-float orb-float--1" style="top:-100px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-80px;left:-80px;" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight">Partner With Us</h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl">Together, we can build peace across Africa. Join a growing network of organizations committed to lasting change.</p>
      </div>
      <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);filter:blur(40px);"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <!-- Doves flying (natural swooping arcs) -->
        <span class="animate-dove-drift" style="left:18%;bottom:-20%;animation-delay:0.5s;font-size:1.125rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow" style="left:55%;bottom:-25%;animation-delay:2s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift" style="left:82%;bottom:-15%;animation-delay:3.5s;font-size:1rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <!-- Hearts pulsing -->
        <!-- Sparkle particles -->
        <span class="animate-particle" style="left:10%;bottom:5%;width:4px;height:4px;border-radius:50%;background:var(--color-accent);animation-delay:1s;"></span>
        <span class="animate-particle--fast" style="left:25%;bottom:10%;width:3px;height:3px;border-radius:50%;background:var(--color-accent-soft);animation-delay:0.3s;"></span>
        <span class="animate-particle" style="left:40%;bottom:8%;width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.4);animation-delay:2s;"></span>
        <span class="animate-particle--glow" style="left:60%;bottom:0;color:var(--color-accent);animation-delay:1.5s;font-size:1.2rem;">&#x2726;</span>
        <span class="animate-particle--fast" style="left:75%;bottom:15%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:2.5s;"></span>
        <span class="animate-particle" style="left:90%;bottom:5%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Why Partner With Us</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Three reasons organizations choose to partner with Peace League Africa.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="scroll-reveal bg-surface rounded-2xl p-6 border border-hairline text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">Proven Impact</h3>
            <p class="mt-3 text-steel text-sm leading-relaxed">A decade of measurable results across 12 countries with transparent reporting and audited financials.</p>
          </div>
          <div class="scroll-reveal bg-surface rounded-2xl p-6 border border-hairline text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg" style="animation-delay: 80ms">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">Community Access</h3>
            <p class="mt-3 text-steel text-sm leading-relaxed">Deep relationships with local leaders, schools, and health centers in communities where we are trusted.</p>
          </div>
          <div class="scroll-reveal bg-surface rounded-2xl p-6 border border-hairline text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg" style="animation-delay: 160ms">
            <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">Integrity & Trust</h3>
            <p class="mt-3 text-steel text-sm leading-relaxed">Full transparency, ethical operations, and a track record of delivering on every commitment we make.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Partnership Types</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Find the partnership model that works best for your organization.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:border-accent/30">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">Corporate</h3>
            <p class="text-sm text-steel leading-relaxed">Sponsor programs, engage employees through volunteering, or match donations. We work with businesses of all sizes.</p>
          </div>
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:border-accent/30" style="animation-delay: 50ms">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1M15 11l-3 3m0 0l-3-3m3 3V8"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">NGO</h3>
            <p class="text-sm text-steel leading-relaxed">Collaborate on joint programs, share resources, and amplify impact through aligned missions and shared expertise.</p>
          </div>
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:border-accent/30" style="animation-delay: 100ms">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">Foundation</h3>
            <p class="text-sm text-steel leading-relaxed">Grant-making partnerships that fund scalable, sustainable programs with clear metrics and regular impact reporting.</p>
          </div>
          <div class="scroll-reveal bg-canvas rounded-2xl border border-hairline p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:border-accent/30" style="animation-delay: 150ms">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">Community</h3>
            <p class="text-sm text-steel leading-relaxed">Grassroots organizations, schools, and community groups partnering on local peace-building and development projects.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 border-y border-hairline">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Current Partners</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-10">Trusted by leading organizations working towards peace and development across Africa.</p>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
          <div class="flex flex-col items-center justify-center p-6 bg-canvas rounded-2xl border border-hairline hover:border-accent/30 hover:-translate-y-1 transition-all duration-300 group">
            <div class="h-14 flex items-center justify-center mb-3 grayscale group-hover:grayscale-0 transition-all duration-300">
              <img src="/logo-unicef.svg" alt="UNICEF" class="h-12 w-auto object-contain" loading="lazy" />
            </div>
            <span class="text-sm font-semibold text-steel group-hover:text-ink transition-colors">UNICEF</span>
            <span class="text-xs text-steel mt-0.5">Partner since 2020</span>
          </div>
          <div class="flex flex-col items-center justify-center p-6 bg-canvas rounded-2xl border border-hairline hover:border-accent/30 hover:-translate-y-1 transition-all duration-300 group">
            <div class="h-14 flex items-center justify-center mb-3 grayscale group-hover:grayscale-0 transition-all duration-300">
              <img src="/logo-who.svg" alt="World Health Organization" class="h-12 w-auto object-contain" loading="lazy" />
            </div>
            <span class="text-sm font-semibold text-steel group-hover:text-ink transition-colors">WHO</span>
            <span class="text-xs text-steel mt-0.5">Partner since 2021</span>
          </div>
          <div class="flex flex-col items-center justify-center p-6 bg-canvas rounded-2xl border border-hairline hover:border-accent-warm/30 hover:-translate-y-1 transition-all duration-300 group">
            <div class="h-14 flex items-center justify-center mb-3 grayscale group-hover:grayscale-0 transition-all duration-300">
              <img src="/logo-red-cross.svg" alt="Red Cross" class="h-12 w-auto object-contain" loading="lazy" />
            </div>
            <span class="text-sm font-semibold text-steel group-hover:text-ink transition-colors">Red Cross</span>
            <span class="text-xs text-steel mt-0.5">Partner since 2019</span>
          </div>
          <div class="flex flex-col items-center justify-center p-6 bg-canvas rounded-2xl border border-hairline hover:border-accent/30 hover:-translate-y-1 transition-all duration-300 group">
            <div class="h-14 flex items-center justify-center mb-3 grayscale group-hover:grayscale-0 transition-all duration-300">
              <img src="/logo-amref.png" alt="AMREF" class="h-12 w-auto object-contain" loading="lazy" />
            </div>
            <span class="text-sm font-semibold text-steel group-hover:text-ink transition-colors">AMREF</span>
            <span class="text-xs text-steel mt-0.5">Partner since 2020</span>
          </div>
          <div class="flex flex-col items-center justify-center p-6 bg-canvas rounded-2xl border border-hairline hover:border-accent-soft/30 hover:-translate-y-1 transition-all duration-300 group">
            <div class="h-14 flex items-center justify-center mb-3 grayscale group-hover:grayscale-0 transition-all duration-300">
              <img src="/logo-save-children.svg" alt="Save the Children" class="h-12 w-auto object-contain" loading="lazy" />
            </div>
            <span class="text-sm font-semibold text-steel group-hover:text-ink transition-colors">Save the Children</span>
            <span class="text-xs text-steel mt-0.5">Partner since 2018</span>
          </div>
          <div class="flex flex-col items-center justify-center p-6 bg-canvas rounded-2xl border border-hairline hover:border-accent-warm/30 hover:-translate-y-1 transition-all duration-300 group">
            <div class="h-14 flex items-center justify-center mb-3 grayscale group-hover:grayscale-0 transition-all duration-300">
              <img src="/logo-african-union.svg" alt="African Union" class="h-12 w-auto object-contain" loading="lazy" />
            </div>
            <span class="text-sm font-semibold text-steel group-hover:text-ink transition-colors">African Union</span>
            <span class="text-xs text-steel mt-0.5">Partner since 2022</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Start the Conversation</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Tell us about your organization and how you would like to partner. We will get back to you within 48 hours.</p>
        <form class="scroll-reveal space-y-6" id="partner-form" method="POST" action="/api/method/peace_league_website.api.submit_partner_form" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium text-ink mb-1.5">Full Name <span class="text-brand-error">*</span></label>
            <input type="text" id="name" name="name" required class="w-full px-3 py-2.5 text-sm bg-canvas border border-hairline rounded-md text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all input-focus-ring" placeholder="Your name" />
            <p class="text-xs text-brand-error mt-1 hidden" data-error="name">Please enter your full name.</p>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email Address <span class="text-brand-error">*</span></label>
            <input type="email" id="email" name="email" required class="w-full px-3 py-2.5 text-sm bg-canvas border border-hairline rounded-md text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all input-focus-ring" placeholder="you@organization.org" />
            <p class="text-xs text-brand-error mt-1 hidden" data-error="email">Please enter a valid email address.</p>
          </div>
          <div>
            <label for="organization" class="block text-sm font-medium text-ink mb-1.5">Organization <span class="text-brand-error">*</span></label>
            <input type="text" id="organization" name="organization" required class="w-full px-3 py-2.5 text-sm bg-canvas border border-hairline rounded-md text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all input-focus-ring" placeholder="Your organization" />
            <p class="text-xs text-brand-error mt-1 hidden" data-error="organization">Please enter your organization name.</p>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message <span class="text-brand-error">*</span></label>
            <textarea id="message" name="message" rows="5" required class="w-full px-3 py-2.5 text-sm bg-canvas border border-hairline rounded-md text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all input-focus-ring resize-y" placeholder="Tell us about your partnership interests and how we can work together..."></textarea>
            <p class="text-xs text-brand-error mt-1 hidden" data-error="message">Please enter a message.</p>
          </div>
          <button type="submit" id="partner-submit" class="w-full px-8 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-all duration-300 shadow-sm cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed min-h-[44px]">
            Start the Conversation
          </button>
          <p id="partner-success" class="text-sm text-success bg-success-bg px-4 py-3 rounded-lg text-center hidden">
            Thank you! Your inquiry has been submitted. We will get back to you within 48 hours.
          </p>
        </form>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const form = document.getElementById('partner-form');
    const submitBtn = document.getElementById('partner-submit');
    const successMsg = document.getElementById('partner-success');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        let valid = true;

        form.querySelectorAll('[required]').forEach(input => {
          const error = form.querySelector(`[data-error="${input.name}"]`);
          if (!input.value.trim()) {
            valid = false;
            input.classList.add('border-brand-error');
            if (error) error.classList.remove('hidden');
          } else if (input.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
            valid = false;
            input.classList.add('border-brand-error');
            if (error) {
              error.textContent = 'Please enter a valid email address.';
              error.classList.remove('hidden');
            }
          } else {
            input.classList.remove('border-brand-error');
            if (error) error.classList.add('hidden');
          }
        });

        if (!valid) return;

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' }
          });
          if (res.ok || res.status === 417) {
            form.reset();
            successMsg.classList.remove('hidden');
            setTimeout(() => successMsg.classList.add('hidden'), 6000);
          }
        } catch (err) {
          successMsg.textContent = 'Something went wrong. Please try again or email us directly.';
          successMsg.classList.remove('hidden');
          successMsg.className = 'text-sm text-brand-error bg-error-bg px-4 py-3 rounded-lg text-center';
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Inquiry';
        }
      });
    }
  </script>
</Layout>
