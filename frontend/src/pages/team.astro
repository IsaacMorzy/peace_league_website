---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const teamMembers = [
  { name: 'Amina Osei', role: 'Executive Director', bio: 'Over 15 years of experience in peace-building and community development across East Africa. Former UN peace mediator and founder of the Nairobi Peace Initiative.', avatar: 'Amina+Osei' },
  { name: 'Joseph Kiprop', role: 'Programs Director', bio: 'Leads all field operations across 12 countries. Background in international development and conflict resolution from the University of Nairobi.', avatar: 'Joseph+Kiprop' },
  { name: 'Grace Mukamana', role: 'Finance & Operations', bio: 'Ensures 95% of donations reach programs. Certified public accountant with deep expertise in NGO financial management.', avatar: 'Grace+Mukamana' },
  { name: 'Dr. Samuel Tadesse', role: 'Health Programs Lead', bio: 'Medical doctor and public health specialist coordinating our community health and nutrition initiatives across the region.', avatar: 'Samuel+Tadesse' },
  { name: 'Nkechi Okonkwo', role: 'Communications Lead', bio: 'Storyteller and media strategist amplifying the voices of peace-builders across Africa through digital and traditional media.', avatar: 'Nkechi+Okonkwo' },
  { name: 'Pierre Habimana', role: 'Field Coordinator', bio: 'On-the-ground coordinator for reconciliation programs in the Great Lakes region, with over a decade of grassroots peace-building experience.', avatar: 'Pierre+Habimana' },
];

const boardMembers = [
  { name: 'Dr. Elizabeth Wanjiku', role: 'Board Chair', bio: 'Professor of Peace Studies, University of Nairobi. Former Minister of Justice and Constitutional Affairs.' },
  { name: 'Michael Odhiambo', role: 'Vice Chair', bio: 'CEO of East Africa Development Trust. 25 years in social enterprise and impact investment.' },
  { name: 'Fatima Hassan', role: 'Treasurer', bio: 'Partner at KPMG Kenya. Specializes in nonprofit audit and financial governance.' },
];
---

<Layout title="Our Team" description="Meet the dedicated team behind Peace League Africa. Our leadership and board are committed to building lasting peace across 12 African countries.">
  <Navigation />

  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "Our Team", "item": "https://peaceleagueafrica.org/team" }
      ]
    })} />
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
      <!-- Ambient orbs -->
      <div class="orb-float orb-float--1" style="top:-100px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-80px;left:-80px;" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight">Our Team</h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl">Six passionate leaders, decades of combined experience, one relentless mission: turning conflict into lasting peace across 12 African countries.</p>
      </div>
      <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);filter:blur(40px);"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <!-- Doves flying (natural swooping arcs) -->
        <span class="animate-dove-drift" style="left:18%;bottom:-20%;animation-delay:0.5s;font-size:1.125rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow" style="left:55%;bottom:-25%;animation-delay:2s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift" style="left:82%;bottom:-15%;animation-delay:3.5s;font-size:1rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <!-- Hearts pulsing -->
        <!-- Sparkle particles -->
        <span class="animate-particle" style="left:10%;bottom:5%;width:4px;height:4px;border-radius:50%;background:var(--color-accent);animation-delay:1s;"></span>
        <span class="animate-particle--fast" style="left:25%;bottom:10%;width:3px;height:3px;border-radius:50%;background:var(--color-accent-soft);animation-delay:0.3s;"></span>
        <span class="animate-particle" style="left:40%;bottom:8%;width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.4);animation-delay:2s;"></span>
        <span class="animate-particle--glow" style="left:60%;bottom:0;color:var(--color-accent);animation-delay:1.5s;font-size:1.2rem;">&#x2726;</span>
        <span class="animate-particle--fast" style="left:75%;bottom:15%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:2.5s;"></span>
        <span class="animate-particle" style="left:90%;bottom:5%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Leadership Team</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Experienced professionals united by a single purpose: building a more peaceful Africa for every child, every family, every community.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {teamMembers.map((member, idx) => (
            <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 bg-canvas rounded-2xl border border-hairline p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg group" style={`animation-delay: ${idx * 80}ms`}>
              <div class="relative inline-block">
                <img src={`https://ui-avatars.com/api/?name=${member.avatar}&background=00d4a4&color=0a0a0a&size=128&bold=true`} alt={member.name} class="w-24 h-24 rounded-full mx-auto mb-4 ring-2 ring-accent/20 group-hover:ring-accent/40 transition-all" loading="lazy" />
                <span class="absolute bottom-4 right-0 w-4 h-4 bg-accent border-2 border-canvas rounded-full"></span>
              </div>
              <h3 class="text-lg font-semibold text-ink">{member.name}</h3>
              <p class="text-sm text-accent font-medium mb-3">{member.role}</p>
              <p class="text-sm text-steel leading-relaxed">{member.bio}</p>
              <div class="flex justify-center gap-3 mt-4 pt-4 border-t border-hairline">
                <a href="https://twitter.com/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="w-8 h-8 min-w-[44px] min-h-[44px] flex items-center justify-center text-steel hover:text-accent bg-surface rounded-full hover:bg-accent/10 transition-all" aria-label={`${member.name} Twitter`}>
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href="https://linkedin.com/company/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="w-8 h-8 min-w-[44px] min-h-[44px] flex items-center justify-center text-steel hover:text-accent bg-surface rounded-full hover:bg-accent/10 transition-all" aria-label={`${member.name} LinkedIn`}>
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="mailto:info@peaceleagueafrica.com" class="w-8 h-8 min-w-[44px] min-h-[44px] flex items-center justify-center text-steel hover:text-accent bg-surface rounded-full hover:bg-accent/10 transition-all" aria-label={`${member.name} Email`}>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative">
          <div class="absolute inset-0 bg-accent/5 rounded-2xl"></div>
          <div class="relative px-6 py-10 md:px-12 md:py-14">
            <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Board of Directors</h2>
            <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Guiding our strategic direction with wisdom and experience.</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
              {boardMembers.map((member, idx) => (
                <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 bg-canvas rounded-2xl border-2 border-accent-warm/20 p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:border-accent-warm/40" style={`animation-delay: ${idx * 100}ms`}>
                  <div class="relative inline-block">
                    <img src={`https://ui-avatars.com/api/?name=${member.name.split(' ').join('+')}&background=f59e0b&color=0a0a0a&size=96&bold=true`} alt={member.name} class="w-20 h-20 rounded-full mx-auto mb-4 ring-2 ring-accent-warm/30" loading="lazy" />
                    <span class="absolute -top-1 -right-1 w-5 h-5 bg-accent-warm rounded-full flex items-center justify-center">
                      <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    </span>
                  </div>
                  <h3 class="text-lg font-semibold text-ink">{member.name}</h3>
                  <p class="text-sm text-accent-warm-link font-medium mb-2">{member.role}</p>
                  <p class="text-sm text-steel leading-relaxed">{member.bio}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 hero-gradient text-white hero-pattern">
      <div class="max-w-3xl mx-auto text-center px-4">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px]">Join Our Team</h2>
        <p class="scroll-reveal mt-4 text-lg text-white/80 mb-8">Your next chapter starts here. Join a team that turns passion into purpose across 12 countries and 500+ communities.</p>
        <div class="scroll-reveal flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/careers" class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-3 bg-white text-primary font-medium text-sm rounded-full hover:bg-white/90 transition-colors shadow-lg">
            View Openings
          </a>
          <a href="/volunteer" class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-3 border border-white/30 text-white font-medium text-sm rounded-full hover:bg-white/15 hover:border-white/50 transition-all duration-300">
            Volunteer With Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
