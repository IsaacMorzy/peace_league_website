---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import posts from '../lib/blog-data.json';
import causes from '../lib/causes-data.json';
import events from '../lib/events-data.json';

const sortedPosts = [...posts].sort((a, b) => new Date(b.date) - new Date(a.date));
const latestPosts = sortedPosts.slice(0, 3);

const upcomingEvents = events.filter(e => e.status === "upcoming");
const monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const upcomingWithDate = upcomingEvents.map(e => {
  const monthIndex = monthNames.indexOf(e.month);
  const d = new Date(parseInt(e.year), monthIndex, parseInt(e.day));
  return { ...e, dateObj: d };
});
const nextEvent = upcomingWithDate.sort((a, b) => a.dateObj - b.dateObj)[0];
const monthMap = { "Jan":"01","Feb":"02","Mar":"03","Apr":"04","May":"05","Jun":"06","Jul":"07","Aug":"08","Sep":"09","Oct":"10","Nov":"11","Dec":"12" };
const nextIsoDate = nextEvent ? `${nextEvent.year}-${monthMap[nextEvent.month]}-${nextEvent.day.padStart(2,"0")}` : "2026-12-31";
const nextStartTime = nextEvent?.startTime || "09:00";
---

<Layout title="Home" description="Peace League Africa builds peace across 12 African countries through education, healthcare, clean water, and youth programs. 1,200+ volunteers active.">
  <Navigation />

  <main id="main-content">
    <section id="hero-section" data-hero-parallax class="relative text-white hero-gradient overflow-hidden flex items-center grain-overlay min-h-[70vh] md:min-h-[80vh]">
      <!-- ── DEPTH LAYER 0: Orbs (farthest, slowest) ── -->
      <div class="hero-depth-layer hero-depth-0 hidden sm:block" aria-hidden="true">
        <div class="orb-float orb-float--1" style="top:-150px;right:-100px;"></div>
        <div class="orb-float orb-float--2" style="bottom:-100px;left:-100px;"></div>
        <div class="orb-float orb-float--3" style="top:40%;left:50%;"></div>
      </div>

      <!-- ── DEPTH LAYER 1: Dots + Geometric shapes ── -->
      <div class="hero-depth-layer hero-depth-1" aria-hidden="true">
        <div class="absolute inset-0 opacity-[0.04] bg-[image:radial-gradient(circle_at_center,white_1px,transparent_1px)] bg-[size:32px_32px]"></div>
        <!-- Desktop shapes -->
        <span class="float-shape float-shape--a absolute hidden sm:block" style="width:300px;height:300px;top:5%;left:0;background:radial-gradient(circle,rgba(0,212,164,0.12),transparent 70%);border-radius:50%;"></span>
        <span class="float-shape float-shape--b absolute hidden sm:block" style="width:180px;height:180px;top:20%;right:5%;background:radial-gradient(circle,rgba(245,158,11,0.08),transparent 70%);border-radius:50%;"></span>
        <span class="float-shape--diamond float-shape--a absolute hidden sm:block" style="width:100px;height:100px;bottom:25%;left:8%;border:2px solid rgba(0,212,164,0.1);background:transparent;border-radius:0;transform:rotate(45deg);"></span>
        <!-- Mobile-friendly smaller shapes -->
        <span class="float-shape float-shape--a absolute sm:hidden" style="width:120px;height:120px;top:10%;right:-20px;background:radial-gradient(circle,rgba(0,212,164,0.10),transparent 70%);border-radius:50%;"></span>
        <span class="float-shape float-shape--b absolute sm:hidden" style="width:80px;height:80px;bottom:30%;left:-20px;background:radial-gradient(circle,rgba(245,158,11,0.06),transparent 70%);border-radius:50%;"></span>
        <!-- Large blur always -->
        <span class="float-shape float-shape--c absolute" style="width:400px;height:400px;bottom:-20%;right:-10%;background:radial-gradient(circle,rgba(0,212,164,0.05),transparent 70%);filter:blur(60px);border-radius:50%;"></span>
      </div>

      <!-- ── DEPTH LAYER 2: Doves + Particles (mid-speed) ── -->
      <div class="hero-depth-layer hero-depth-2" aria-hidden="true">
        <!-- Doves: hide on mobile, fewer on tablet -->
        <span class="animate-dove-drift hidden sm:block" style="left:15%;bottom:-20%;animation-delay:0s;font-size:1.5rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.3));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow hidden md:block" style="left:50%;bottom:-30%;animation-delay:2.5s;font-size:1.75rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.3));">&#x1F54A;</span>
        <span class="animate-dove-drift hidden sm:block" style="left:80%;bottom:-15%;animation-delay:4s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.3));">&#x1F54A;</span>
        <!-- Particles: fewer on mobile -->
        <span class="animate-particle hidden sm:block" style="left:8%;bottom:5%;width:5px;height:5px;border-radius:50%;background:var(--color-accent);animation-delay:0.5s;"></span>
        <span class="animate-particle--fast hidden sm:block" style="left:22%;bottom:10%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-soft);animation-delay:1.2s;"></span>
        <span class="animate-particle--glow" style="left:45%;bottom:2%;color:var(--color-accent);animation-delay:2s;font-size:1.5rem;">&#x2726;</span>
        <span class="animate-particle hidden sm:block" style="left:70%;bottom:15%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
        <span class="animate-particle--fast" style="left:85%;bottom:8%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:3s;"></span>
      </div>

      <!-- ── DEPTH LAYER 3: Overlay gradients (nearest) ── -->
      <div class="hero-depth-layer hero-depth-3" aria-hidden="true">
        <div class="absolute inset-0 bg-gradient-to-t from-hero-bg/60 via-transparent to-hero-bg/20"></div>
        <div class="absolute bottom-0 left-0 right-0 h-24 sm:h-32 bg-gradient-to-t from-hero-bg to-transparent"></div>
      </div>

      <!-- ── SWEEPING LIGHT BEAM (hope ray) ── -->
      <div class="light-beam" aria-hidden="true"></div>

      <!-- ── PEACE RINGS (expanding ripples) ── -->
      <div class="peace-ring hidden md:block" aria-hidden="true"></div>
      <div class="peace-ring hidden md:block" aria-hidden="true"></div>
      <div class="peace-ring hidden md:block" aria-hidden="true"></div>

      <!-- ── HERO CONTENT (foreground) ── -->
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-20 lg:py-28 z-10 w-full">
        <div class="max-w-3xl">
          <!-- Badge - faster entrance on mobile -->
          <div class="hero-badge mb-4 sm:mb-6" style="animation-delay: 0.1s;">
            <span class="inline-flex items-center gap-2 px-3 sm:px-4 py-1 sm:py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-xs sm:text-sm font-medium text-accent-soft border border-white/10">
              <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-accent animate-pulse"></span>
              12 Countries &middot; 500 Communities &middot; One Mission
            </span>
          </div>

          <!-- Headline with word reveal - faster on mobile, larger on mobile -->
          <h1 class="text-[clamp(2rem,10vw,3rem)] sm:text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-[1.05] sm:leading-[1.02] tracking-[-1.5px] sm:tracking-[-3px] text-white" style="perspective: 800px;">
            <span class="hero-word" style="animation-delay: 0.2s;">Turning</span>
            <span class="hero-word" style="animation-delay: 0.28s;">Conflict</span>
            <br class="hidden sm:block"/>
            <span class="hero-word" style="animation-delay: 0.35s;">Into</span>
            <span class="hero-word hero-word--accent" style="animation-delay: 0.42s;">Lasting</span>
            <br/>
            <span class="hero-word" style="animation-delay: 0.5s;">Peace</span>
          </h1>

          <p class="hero-social mt-4 sm:mt-8 text-sm sm:text-lg lg:text-xl leading-relaxed text-white/70 max-w-2xl font-light" style="animation-delay: 0.6s;">
            From the classrooms of Nairobi to the refugee camps of South Sudan &mdash; we are an unstoppable movement of 1,200+ volunteers rebuilding communities torn apart by war, drought, and displacement.
          </p>

          <!-- CTA Buttons - more compact on mobile -->
          <div class="hero-social mt-6 sm:mt-12 flex flex-col sm:flex-row gap-3 sm:gap-6" style="animation-delay: 0.7s;">
            <a href="/donate" class="btn btn-accent btn-large btn-ripple group w-full sm:w-auto shadow-xl shadow-accent/25 hover:shadow-2xl hover:shadow-accent/40 btn-pulse-glow" data-magnet-strength="0.4">
              Give Today
              <svg class="ml-2 w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/causes" class="btn btn-large btn-ripple w-full sm:w-auto border-2 border-white/25 text-white hover:bg-white/10 hover:border-white/50" data-magnet-strength="0.25">
              Explore Our Causes
            </a>
          </div>

          <!-- Social Proof - compact grid on mobile -->
          <div class="hero-social mt-8 sm:mt-16 flex flex-wrap items-center gap-x-6 gap-y-2 sm:gap-12 text-white/60" style="animation-delay: 0.8s;">
            <div class="flex -space-x-3 stat-badge-float">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=48&h=48&fit=crop&crop=face&q=80" alt="" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full border-2 border-hero-bg" loading="lazy" />
              <img src="https://images.unsplash.com/photo-1531123897727-8f129e1688ce?w=48&h=48&fit=crop&crop=face&q=80" alt="" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full border-2 border-hero-bg" loading="lazy" />
              <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?w=48&h=48&fit=crop&crop=face&q=80" alt="" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full border-2 border-hero-bg" loading="lazy" />
              <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full border-2 border-hero-bg bg-accent/20 flex items-center justify-center text-[10px] sm:text-xs font-semibold text-accent-soft">1.2k+</div>
            </div>
            <div class="hidden sm:block w-px h-8 bg-white/10"></div>
            <p class="text-xs sm:text-base stat-badge-float" style="animation-delay: -1.5s;"><span class="text-white font-semibold">95%</span> of donations fund programs</p>
            <div class="hidden sm:block w-px h-8 bg-white/10"></div>
            <p class="text-xs sm:text-base stat-badge-float" style="animation-delay: -3s;"><span class="text-white font-semibold">45+</span> school programs</p>
          </div>
        </div>
      </div>

      <!-- Scroll indicator - hidden on mobile -->
      <div class="hero-scroll-indicator hidden sm:flex" onclick="window.scrollBy({top: window.innerHeight * 0.8, behavior: 'smooth'})">
        <span>Scroll</span>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </div>
    </section>

    <section data-reveal class="py-8 lg:py-10 bg-gradient-to-br from-accent-soft/10 via-canvas to-accent-warm-soft/10 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-xl sm:text-2xl lg:text-3xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-3">Why Peace League Africa</h2>
        <div class="h-0.5 w-24 mx-auto mb-4 bg-gradient-to-r from-accent/60 via-accent-warm/60 to-accent/60"></div>
        <p class="scroll-reveal text-lg text-steel text-center max-w-2xl mx-auto mb-8">Four reasons to trust us with your support</p>
        
        <!-- Bento grid layout -->
        <div class="bento-grid md:bento-grid--4">
          <div class="scroll-reveal bento-card md:col-span-2 md:row-span-2 bg-gradient-to-br from-accent/10 via-canvas to-accent/5 border-accent/10" style="animation-delay: 0ms">
            <div class="w-14 h-14 rounded-2xl bg-accent/15 flex items-center justify-center mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="heading-md mb-3">Locally Led, African Owned</h3>
            <p class="text-body text-steel leading-relaxed max-w-md">We are not a foreign NGO. Peace League Africa is led by Africans, for Africans. Our teams live in the communities they serve, ensuring every program is culturally rooted and community-owned from day one.</p>
            <div class="mt-6 flex items-center gap-4 text-sm">
              <span class="inline-flex items-center gap-1.5 text-accent-link font-medium">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                12 Countries
              </span>
              <span class="inline-flex items-center gap-1.5 text-accent-link font-medium">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                500+ Communities
              </span>
            </div>
          </div>

          <div class="scroll-reveal bento-card bento-card--accent" style="animation-delay: 60ms">
            <div class="flex items-start gap-4">
              <div class="trust-donut shrink-0" style="width:80px;height:80px;">
                <div class="trust-donut-inner" style="inset:8px;">
                  <span class="trust-donut-value text-lg">95%</span>
                  <span class="trust-donut-label text-[9px]">to programs</span>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Radically Transparent</h3>
                <p class="text-sm text-white/80 leading-relaxed">We keep overhead under 5% so your donation goes where it matters most: on the ground. No bureaucracy, no bloat.</p>
              </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white/10 flex items-center gap-4">
              <span class="text-2xl font-bold">95%</span>
              <span class="text-white/60 text-sm">program funding</span>
              <span class="w-px h-6 bg-white/10"></span>
              <span class="text-2xl font-bold text-white/50">5%</span>
              <span class="text-white/40 text-sm">overhead</span>
            </div>
          </div>

          <div class="scroll-reveal bento-card bento-card--warm" style="animation-delay: 120ms">
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Pan-African Impact</h3>
            <p class="text-sm text-white/80 leading-relaxed">Operating in 12 countries, 500+ communities. Every program is hyper-local, designed by and for the community it serves.</p>
          </div>

          <div class="scroll-reveal bento-card bento-card--surface md:col-span-2" style="animation-delay: 180ms">
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 rounded-2xl bg-accent-warm/10 flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-accent-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </div>
              <div>
                <h3 class="heading-sm mb-2">Sustainable, Not Dependent</h3>
                <p class="text-body-sm text-steel leading-relaxed">Our 3-year handover model trains local leaders to run every program independently. We don't create dependency — we build self-sufficiency.</p>
                <a href="/about" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-link hover:text-accent-deep transition-colors">
                  Learn about our model
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section data-reveal class="py-6 lg:py-10 bg-surface overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="section-divider mb-6"></div>
        <h2 class="text-xl sm:text-2xl lg:text-3xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Our Impact in Numbers</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-8">Grassroots peacebuilding measured in lives changed, communities rebuilt, and futures restored.</p>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8 tilt-container">
          <div class="scroll-reveal tilt-card group relative bg-canvas rounded-2xl p-6 sm:p-8 border border-hairline text-center" style="animation-delay: 0ms; transform-style: preserve-3d;">
            <div class="absolute -top-3 -right-3 w-20 h-20 bg-accent/5 rounded-full blur-2xl"></div>
            <span class="big-stat-value text-4xl sm:text-5xl lg:text-6xl font-bold text-accent-glow block leading-none stat-number" data-count-target="45" data-count-suffix="+">0</span>
            <span class="block mt-2 text-sm text-steel font-medium">Schools</span>
            <p class="mt-3 text-xs text-steel leading-relaxed">Peace education programs in 8 countries equipping the next generation of leaders.</p>
            <div class="tilt-sheen"></div>
          </div>
          <div class="scroll-reveal tilt-card group relative bg-canvas rounded-2xl p-6 sm:p-8 border border-hairline text-center" style="animation-delay: 80ms; transform-style: preserve-3d;">
            <div class="absolute -top-3 -right-3 w-20 h-20 bg-accent-warm/5 rounded-full blur-2xl"></div>
            <span class="big-stat-value text-4xl sm:text-5xl lg:text-6xl font-bold text-accent-warm-glow block leading-none stat-number" data-count-target="12" data-count-suffix="">0</span>
            <span class="block mt-2 text-sm text-steel font-medium">Countries</span>
            <p class="mt-3 text-xs text-steel leading-relaxed">From Kenya to DRC, we operate where conflict is deepest and hope is scarcest.</p>
            <div class="tilt-sheen"></div>
          </div>
          <div class="scroll-reveal tilt-card group relative bg-canvas rounded-2xl p-6 sm:p-8 border border-hairline text-center" style="animation-delay: 150ms; transform-style: preserve-3d;">
            <div class="absolute -top-3 -right-3 w-20 h-20 bg-accent/5 rounded-full blur-2xl"></div>
            <span class="big-stat-value text-4xl sm:text-5xl lg:text-6xl font-bold text-accent-glow block leading-none stat-number" data-count-target="1200" data-count-suffix="+">0</span>
            <span class="block mt-2 text-sm text-steel font-medium">Volunteers</span>
            <p class="mt-3 text-xs text-steel leading-relaxed">Teachers, medics, engineers &mdash; everyday Africans building peace in their communities.</p>
            <div class="tilt-sheen"></div>
          </div>
          <div class="scroll-reveal tilt-card group relative bg-canvas rounded-2xl p-6 sm:p-8 border border-hairline text-center" style="animation-delay: 220ms; transform-style: preserve-3d;">
            <div class="absolute -top-3 -right-3 w-20 h-20 bg-accent-warm/5 rounded-full blur-2xl"></div>
            <span class="big-stat-value text-4xl sm:text-5xl lg:text-6xl font-bold text-accent-warm-glow block leading-none stat-number" data-count-target="95" data-count-suffix="%">0</span>
            <span class="block mt-2 text-sm text-steel font-medium">To Programs</span>
            <p class="mt-3 text-xs text-steel leading-relaxed">Every dollar donated goes directly to community-driven peacebuilding work.</p>
            <div class="tilt-sheen"></div>
          </div>
        </div>

        <!-- Donation Thermometer -->
        <div class="mt-12 max-w-2xl mx-auto" data-reveal>
          <div class="bg-canvas rounded-2xl border border-hairline p-6 sm:p-8">
            <div class="flex items-center justify-between mb-3">
              <div>
                <h3 class="text-lg font-bold text-ink">2026 Fundraising Goal</h3>
                <p class="text-sm text-steel">Help us reach $500,000 for peace programs</p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-accent">$347,500</span>
                <span class="text-sm text-steel block">of $500,000</span>
              </div>
            </div>
            <div class="relative h-6 bg-hairline rounded-full overflow-hidden">
              <div class="absolute inset-y-0 left-0 bg-gradient-to-r from-accent to-accent-soft rounded-full" style="width: 69%"></div>
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent animate-shimmer"></div>
            </div>
            <div class="flex items-center justify-between mt-3">
              <span class="text-xs text-steel">69% achieved</span>
              <span class="text-xs font-semibold text-accent">$152,500 to go</span>
            </div>
            <div class="mt-4 pt-4 border-t border-hairline">
              <p class="text-xs text-steel mb-2">Recent supporters:</p>
              <div class="flex items-center gap-2">
                <div class="flex -space-x-2">
                  <div class="w-7 h-7 rounded-full bg-gradient-to-br from-accent to-accent-soft flex items-center justify-center text-white text-[9px] font-bold border-2 border-canvas">AK</div>
                  <div class="w-7 h-7 rounded-full bg-gradient-to-br from-accent-warm to-amber-600 flex items-center justify-center text-white text-[9px] font-bold border-2 border-canvas">JM</div>
                  <div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white text-[9px] font-bold border-2 border-canvas">SO</div>
                </div>
                <span class="text-xs text-steel">Amara, James, Sarah & 42 others this week</span>
              </div>
            </div>
            <a href="/donate" class="mt-4 w-full inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent btn-text-contrast font-semibold rounded-full hover:bg-accent-deep transition-all shadow-lg shadow-accent/25">
              Contribute Now
