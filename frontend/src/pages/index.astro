        </div>
      </div>
    </section>

    <section class="py-16 bg-gradient-to-r from-accent/10 to-accent/5">
      <div class="max-w-2xl mx-auto text-center px-4">
                  <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Stay Connected</h2>
        <p class="scroll-reveal text-lg text-steel text-center max-w-2xl mx-auto mb-4">Get monthly stories of hope, impact reports, and ways to get involved &mdash; straight to your inbox.</p>
        <p class="text-sm text-steel text-center mb-10">No spam, ever. Unsubscribe anytime.</p>
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input type="email" placeholder="Enter your email" required aria-label="Email for newsletter" class="newsletter-input flex-1 px-3 py-[10px] bg-canvas border border-hairline rounded-md text-ink placeholder:text-stone text-sm focus:outline-none focus:ring-2 focus:ring-accent/30" />
          <button type="submit" class="px-6 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-colors whitespace-nowrap min-h-[44px]">
            Subscribe
