---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import posts from '../lib/blog-data.json';
import causes from '../lib/causes-data.json';
---

<Layout title="Home">
  <Navigation />
  
  <main id="main-content">
    <section id="hero-section" class="relative text-white hero-gradient overflow-hidden">
      <div class="absolute inset-0 bg-pattern opacity-[0.12] z-[1]"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#1a3d4a]/70 via-transparent to-[#1a3d4a]/30 z-[2]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-accent/10 via-transparent to-accent-warm/10 animate-gradient-overlay z-[2]"></div>
      <!-- Hero Image Carousel -->
      <div class="absolute inset-0 z-[1]">
        <div class="hero-carousel-slide hero-img-1"></div>
        <div class="hero-carousel-slide hero-img-2"></div>
        <div class="hero-carousel-slide hero-img-3"></div>
        <div class="hero-carousel-slide hero-img-4"></div>
        <div class="hero-carousel-slide hero-img-5"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 z-[3]">
        <div class="max-w-4xl">
          <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 animate-hold animate-fade-in-scale text-[44px] sm:text-[64px] lg:text-[84px] font-bold leading-[1.02] tracking-[-3px] text-white">
            A Peace Movement<br/>
            <span class="text-accent-soft">Across an Entire</span><br/>
            Continent
          </h1>
          <p class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200 animate-hold mt-8 text-xl sm:text-2xl leading-relaxed text-white/80 max-w-3xl font-light">
            From the classrooms of Nairobi to the refugee camps of South Sudan, from rural villages in Uganda to the bustling streets of Kinshasa &mdash; we are 12 countries, 500 communities, and one unstoppable mission: turning conflict into lasting peace, one community at a time.
          </p>
          <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-[400ms] animate-hold mt-12 flex flex-col sm:flex-row gap-4 sm:gap-6">
            <a href="/donate" class="inline-flex items-center justify-center w-full sm:w-auto px-10 py-4 bg-white text-primary font-semibold text-base rounded-full btn-pulse-glow shadow-xl shadow-white/20 hover:bg-white/90 hover:shadow-2xl hover:shadow-white/30 transition-all duration-300">
              Join the Movement
            </a>
            <a href="/causes" class="inline-flex items-center justify-center w-full sm:w-auto px-10 py-4 border-2 border-white/30 text-white font-semibold text-base rounded-full glass-dark hover:bg-white/15 hover:border-white/60 transition-all duration-300">
              Explore Our Work
            </a>
          </div>
        </div>
      </div>
    </section>



    <section class="py-16 bg-gradient-to-b from-canvas to-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Our Causes</h2>
        <div class="relative">
          <button id="causes-scroll-left" class="causes-scroll-btn flex absolute left-0 top-1/2 -translate-y-1/2 -ml-5 w-10 h-10 min-w-[44px] min-h-[44px] bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll causes left">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div id="causes-container" class="flex overflow-x-auto gap-6 pb-4 snap-x snap-mandatory scrollbar-thin scrollbar-track-transparent" style="-webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory;">
            {causes.slice(0, 10).map((cause, idx) => (
              <div class="flex-none w-[85vw] sm:w-[350px] snap-start bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-2 img-zoom" style={`animation-delay: ${idx * 150}ms`}>
                <div class="h-48 relative overflow-hidden">
                  <img src={cause.image} alt={cause.title} class="w-full h-full object-cover" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-14 h-14 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                  </div>
                </div>
                <div class="p-6">
                  <span class="badge-tag mb-3">{cause.category}</span>
                  <h3 class="text-xl font-semibold text-ink">{cause.title}</h3>
                  <p class="mt-2 text-steel line-clamp-3">{cause.description}</p>
                  <div class="mt-4">
                    <div class="flex justify-between text-sm mb-1.5">
                      <span class="font-medium text-ink">${cause.raised_amount.toLocaleString()}</span>
                      <span class="text-stone">${cause.goal_amount.toLocaleString()}</span>
                    </div>
                    <div class="w-full bg-hairline rounded-full h-2.5 progress-track">
                      <div class="bg-accent h-2.5 rounded-full progress-bar" data-progress-width={Math.min((cause.raised_amount / cause.goal_amount) * 100, 100)} style="width: 0"></div>
                    </div>
                    <p class="mt-1 text-xs text-stone">raised of ${cause.goal_amount.toLocaleString()} goal</p>
                  </div>
                  <a href={`/donate?cause=${encodeURIComponent(cause.name || '')}`} class="mt-4 inline-flex items-center justify-center w-full px-4 py-2.5 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors">
                    Donate Now
                  </a>
                </div>
              </div>
            ))}
          </div>
          <button id="causes-scroll-right" class="causes-scroll-btn flex absolute right-0 top-1/2 -translate-y-1/2 -mr-5 w-10 h-10 min-w-[44px] min-h-[44px] bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll causes right">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
        <div class="mt-8 text-center">
          <a href="/causes" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-colors min-h-[44px]">
            View All Causes
          </a>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Get Involved</h2>
          <p class="text-lg text-steel text-center max-w-2xl mx-auto mb-12">
            Your hands, your voice, your resources — every contribution builds peace. Join thousands of Africans already taking action.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/volunteer" class="inline-flex items-center justify-center w-full sm:w-auto px-6 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-colors">
              Volunteer With Us
            </a>
            <a href="/contact" class="inline-flex items-center justify-center w-full sm:w-auto px-6 py-3 border border-hairline text-ink font-medium text-sm rounded-full hover:bg-surface transition-colors">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">What People Say</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Real voices from the communities you have helped restore, rebuild, and reconcile.</p>
        <div class="relative">
          <button id="testimonial-scroll-left" class="causes-scroll-btn flex absolute left-0 top-1/2 -translate-y-1/2 -ml-5 w-10 h-10 min-w-[44px] min-h-[44px] bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll testimonials left">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div id="testimonial-container" class="flex overflow-x-auto gap-8 pb-4 snap-x snap-mandatory scrollbar-thin" style="-webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory;">
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-1;">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&crop=face&q=80" alt="Mama Sarah" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">Peace League Africa transformed our community. The peace education program reached over 500 children in our village.</p>
              <div>
                <p class="text-ink font-semibold">Mama Sarah</p>
                <p class="text-stone text-sm">Community Leader, Uganda</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-2;">
              <img src="https://images.unsplash.com/photo-1531123897727-8f129e1688ce?w=120&h=120&fit=crop&crop=face&q=80" alt="James K." class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">As a volunteer, I have seen firsthand how donations change lives. Every dollar goes directly to those who need it most.</p>
              <div>
                <p class="text-ink font-semibold">James K.</p>
                <p class="text-stone text-sm">Volunteer Coordinator</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-3;">
              <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=120&h=120&fit=crop&crop=face&q=80" alt="Esther M." class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">The clean water initiative saved our village. We no longer walk 10km for clean water.</p>
              <div>
                <p class="text-ink font-semibold">Esther M.</p>
                <p class="text-stone text-sm">Teacher, Kenya</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-4;">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face&q=80" alt="James Ochieng" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">When I joined the youth mentorship program, I was a lost teenager on the streets of Kisumu. Today, I mentor 50 young boys myself. Peace League Africa gave me a second chance.</p>
              <div>
                <p class="text-ink font-semibold">James Ochieng</p>
                <p class="text-stone text-sm">Teacher, Kenya</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-5;">
              <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=100&h=100&fit=crop&crop=face&q=80" alt="Grace Achieng" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">Our mobile clinic reaches villages that have never seen a doctor. I have delivered babies, treated malnutrition, and vaccinated thousands &mdash; all because Peace League Africa believed in bringing healthcare to the people.</p>
              <div>
                <p class="text-ink font-semibold">Grace Achieng</p>
                <p class="text-stone text-sm">Healthcare Worker, Tanzania</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-6;">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face&q=80" alt="Paul Mwangi" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">The sustainable agriculture training taught me to grow food year-round, even through dry seasons. My family no longer goes hungry, and I now train other farmers in my district.</p>
              <div>
                <p class="text-ink font-semibold">Paul Mwangi</p>
                <p class="text-stone text-sm">Farmer, Rwanda</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-7;">
              <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=100&h=100&fit=crop&crop=face&q=80" alt="Faith Kemunto" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">The scholarship program changed everything for me. I am the first girl in my village to attend university. I study peace and conflict resolution, and one day I will come back and serve my community.</p>
              <div>
                <p class="text-ink font-semibold">Faith Kemunto</p>
                <p class="text-stone text-sm">Student, Uganda</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-8;">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face&q=80" alt="David Ouma" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">After years of conflict, our community was broken. The reconciliation dialogues brought us together &mdash; people who had not spoken in years sat down, shared meals, and forgave each other. Peace is possible.</p>
              <div>
                <p class="text-ink font-semibold">David Ouma</p>
                <p class="text-stone text-sm">Community Elder, South Sudan</p>
              </div>
            </div>
            <div class="flex-none w-[85vw] sm:w-[370px] snap-start p-6 rounded-2xl border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-9;">
              <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=100&h=100&fit=crop&crop=face&q=80" alt="Sarah Wanjiku" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
              <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
              <p class="text-steel leading-relaxed mb-6 italic">With a small microloan from Peace League Africa, I started a tailoring business that now employs five women from my village. I am not just surviving &mdash; I am thriving, and lifting others as I rise.</p>
              <div>
                <p class="text-ink font-semibold">Sarah Wanjiku</p>
                <p class="text-stone text-sm">Small Business Owner, Kenya</p>
              </div>
            </div>
          </div>
          <button id="testimonial-scroll-right" class="causes-scroll-btn flex absolute right-0 top-1/2 -translate-y-1/2 -mr-5 w-10 h-10 min-w-[44px] min-h-[44px] bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll testimonials right">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
        <div class="mt-12 text-center">
          <p class="text-sm text-steel mb-4">Your voice matters. Share your experience with Peace League Africa.</p>
          <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-hairline text-ink font-medium text-sm rounded-full hover:bg-canvas hover:border-accent/30 transition-colors min-h-[44px]">
            Leave a Review
          </a>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl sm:text-3xl lg:text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Upcoming Events</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Come build peace with us. From workshops to health fairs, find an event near you.</p>
        <div class="relative">
