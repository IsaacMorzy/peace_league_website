---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Home">
  <Navigation />
  
  <main>
    <section id="hero-section" class="relative text-white hero-gradient overflow-hidden">
      <div class="absolute inset-0 bg-pattern opacity-[0.12] z-[1]"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#1a3d4a]/70 via-transparent to-[#1a3d4a]/30 z-[2]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-accent/10 via-transparent to-accent-warm/10 animate-gradient-overlay z-[2]"></div>
      <!-- Hero Image Carousel -->
      <div class="absolute inset-0 z-[1]">
        <div class="hero-carousel-slide hero-img-1"></div>
        <div class="hero-carousel-slide hero-img-2"></div>
        <div class="hero-carousel-slide hero-img-3"></div>
        <div class="hero-carousel-slide hero-img-4"></div>
        <div class="hero-carousel-slide hero-img-5"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20 z-[3]">
        <div class="max-w-3xl">
          <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 animate-hold animate-fade-in-scale text-[40px] sm:text-[56px] lg:text-[72px] font-semibold leading-[1.05] tracking-[-2px] text-white">
            12 Countries, <br/>
            <span class="text-accent-soft">500 Communities</span>, One Mission
          </h1>
          <p class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200 animate-hold mt-6 text-lg leading-relaxed text-white/80 max-w-2xl">
            Across East Africa, Peace League Africa transforms conflict into hope through education, 
            reconciliation, and community-driven development. Together, we are rebuilding what war divided.
          </p>
          <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-[400ms] animate-hold mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/donate" class="inline-flex items-center justify-center px-8 py-3 bg-white text-primary font-medium text-sm rounded-full btn-pulse-glow shadow-lg shadow-white/20 hover:bg-white/90 transition-colors">
              Donate Now
            </a>
            <a href="/causes" class="inline-flex items-center justify-center px-8 py-3 border border-white/30 text-white font-medium text-sm rounded-full glass hover:bg-white/15 hover:border-white/50 transition-all duration-300">
              Our Causes
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink">Our Impact</h2>
          <p class="mt-4 text-lg text-steel">
            From classrooms in Nairobi to villages in the Great Lakes region — real change, measured in lives transformed.
          </p>
        </div>
        <div id="stat-cards" class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="scroll-reveal bg-accent/5 p-6 rounded-lg border border-accent/20 text-center stat-card-glass backdrop-blur-sm">
            <svg class="w-8 h-8 mx-auto text-accent mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div id="stat-donations" class="stat-value text-4xl font-bold text-accent" data-count-target="0" data-count-prefix="$">$0</div>
            <div class="mt-2 text-steel">Total Donations Received</div>
          </div>
          <div class="scroll-reveal bg-canvas p-6 rounded-lg border border-hairline text-center stat-card-glass backdrop-blur-sm" style="animation-delay: 100ms">
            <svg class="w-8 h-8 mx-auto text-accent mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <div id="stat-volunteers" class="stat-value text-4xl font-bold text-accent" data-count-target="0">0</div>
            <div class="mt-2 text-steel">Active Volunteers</div>
          </div>
          <div class="scroll-reveal bg-surface p-6 rounded-lg border border-hairline text-center stat-card-glass backdrop-blur-sm" style="animation-delay: 200ms">
            <svg class="w-8 h-8 mx-auto text-accent mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <div id="stat-chapters" class="stat-value text-4xl font-bold text-accent" data-count-target="0" data-count-suffix="+">0+</div>
            <div class="mt-2 text-steel">Active Chapters</div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gradient-to-b from-canvas to-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-12">Our Causes</h2>
        <div class="relative">
          <button id="causes-scroll-left" class="causes-scroll-btn hidden lg:flex absolute left-0 top-1/2 -translate-y-1/2 -ml-5 w-10 h-10 bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll causes left">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div id="causes-container" class="flex overflow-x-auto gap-6 pb-4 snap-x snap-mandatory scrollbar-thin scrollbar-track-transparent" style="-webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory;">
            <div class="flex-none w-[350px] snap-start bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:shadow-lg hover:-translate-y-2 animate-in fade-in slide-in-from-bottom-4 duration-700 img-zoom" style="animation-delay: 0ms">
              <div class="h-48 relative overflow-hidden">
                <img src="https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=600&q=80&auto=format&fit=crop" alt="Peace Education" class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-14 h-14 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </div>
              </div>
              <div class="p-6">
                <span class="badge-tag mb-3">Education</span>
                <h3 class="text-xl font-semibold text-ink">Peace Education</h3>
                <p class="mt-2 text-steel line-clamp-3">Hands-on peace education workshops reaching 5,000+ students across 45 schools in Kenya and Uganda — teaching young Africans how to resolve conflict, listen deeply, and lead with empathy.</p>
                <div class="mt-4">
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium text-ink">$12,500</span>
                    <span class="text-stone">$50,000</span>
                  </div>
                  <div class="w-full bg-hairline rounded-full h-2.5 progress-track">
                    <div class="bg-accent h-2.5 rounded-full progress-bar" data-progress-width="25" style="width: 0"></div>
                  </div>
                  <p class="mt-1 text-xs text-stone">raised of $50,000 goal</p>
                </div>
                <a href="/donate?cause=peace-education" class="mt-4 inline-flex items-center justify-center w-full px-4 py-2.5 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors">
                  Donate Now
                </a>
              </div>
            </div>
            <div class="flex-none w-[350px] snap-start bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:shadow-lg hover:-translate-y-2 animate-in fade-in slide-in-from-bottom-4 duration-700 img-zoom" style="animation-delay: 150ms">
              <div class="h-48 relative overflow-hidden">
                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80&auto=format&fit=crop" alt="Youth Empowerment" class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-14 h-14 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
              </div>
              <div class="p-6">
                <span class="badge-tag mb-3">Youth</span>
                <h3 class="text-xl font-semibold text-ink">Youth Empowerment Initiative</h3>
                <p class="mt-2 text-steel line-clamp-3">A youth leadership pipeline that has mentored 800+ young Africans into community organizers, entrepreneurs, and peace ambassadors — across 12 communities in 5 countries.</p>
                <div class="mt-4">
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium text-ink">$8,200</span>
                    <span class="text-stone">$35,000</span>
                  </div>
                  <div class="w-full bg-hairline rounded-full h-2.5 progress-track">
                    <div class="bg-accent h-2.5 rounded-full progress-bar" data-progress-width="23" style="width: 0"></div>
                  </div>
                  <p class="mt-1 text-xs text-stone">raised of $35,000 goal</p>
                </div>
                <a href="/donate?cause=youth-empowerment" class="mt-4 inline-flex items-center justify-center w-full px-4 py-2.5 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors">
                  Donate Now
                </a>
              </div>
            </div>
            <div class="flex-none w-[350px] snap-start bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:shadow-lg hover:-translate-y-2 animate-in fade-in slide-in-from-bottom-4 duration-700 img-zoom" style="animation-delay: 300ms">
              <div class="h-48 relative overflow-hidden">
                <img src="https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&q=80&auto=format&fit=crop" alt="Community Reconciliation" class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-14 h-14 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
              </div>
              <div class="p-6">
                <span class="badge-tag mb-3">Community</span>
                <h3 class="text-xl font-semibold text-ink">Community Reconciliation</h3>
                <p class="mt-2 text-steel line-clamp-3">Healing the wounds of conflict through facilitated inter-community dialogues, trauma counseling, and grassroots peace-building across Rwanda, DRC, and Burundi.</p>
                <div class="mt-4">
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium text-ink">$15,000</span>
                    <span class="text-stone">$40,000</span>
                  </div>
                  <div class="w-full bg-hairline rounded-full h-2.5 progress-track">
                    <div class="bg-accent h-2.5 rounded-full progress-bar" data-progress-width="37" style="width: 0"></div>
                  </div>
                  <p class="mt-1 text-xs text-stone">raised of $40,000 goal</p>
                </div>
                <a href="/donate?cause=community-reconciliation" class="mt-4 inline-flex items-center justify-center w-full px-4 py-2.5 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors">
                  Donate Now
                </a>
              </div>
            </div>
          </div>
          <button id="causes-scroll-right" class="causes-scroll-btn hidden lg:flex absolute right-0 top-1/2 -translate-y-1/2 -mr-5 w-10 h-10 bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll causes right">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
        <div class="mt-8 text-center">
          <a href="/causes" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-colors">
            View All Causes
          </a>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink">Get Involved</h2>
          <p class="mt-4 text-lg text-steel">
            Your hands, your voice, your resources — every contribution builds peace. Join thousands of Africans already taking action.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/volunteer" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-colors">
              Volunteer With Us
            </a>
            <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-hairline text-ink font-medium text-sm rounded-full hover:bg-surface transition-colors">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">What People Say</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Real voices from the communities you have helped restore, rebuild, and reconcile.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 delay-0 p-6 rounded-lg border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-1;">
            <img src="https://images.unsplash.com/photo-1524502397800-3605f2cba3a5?w=120&h=120&fit=crop&crop=face&q=80" alt="Mama Sarah" class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
            <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
            <p class="text-steel leading-relaxed mb-6 italic">Peace League Africa transformed our community. The peace education program reached over 500 children in our village.</p>
            <div>
              <p class="text-ink font-semibold">Mama Sarah</p>
              <p class="text-stone text-sm">Community Leader, Uganda</p>
            </div>
          </div>
          <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 delay-100 p-6 rounded-lg border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-2;">
            <img src="https://images.unsplash.com/photo-1531123897727-8f129e1688ce?w=120&h=120&fit=crop&crop=face&q=80" alt="James K." class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
            <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
            <p class="text-steel leading-relaxed mb-6 italic">As a volunteer, I have seen firsthand how donations change lives. Every dollar goes directly to those who need it most.</p>
            <div>
              <p class="text-ink font-semibold">James K.</p>
              <p class="text-stone text-sm">Volunteer Coordinator</p>
            </div>
          </div>
          <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200 p-6 rounded-lg border border-hairline bg-canvas/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-accent/30 text-center" style="view-transition-name: testimonial-3;">
            <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=120&h=120&fit=crop&crop=face&q=80" alt="Esther M." class="w-16 h-16 rounded-full mx-auto mb-4" loading="lazy" />
            <svg class="w-8 h-8 text-accent/40 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C2.433 6.068.87 8.789.87 11H4.87v10H0z"/></svg>
            <p class="text-steel leading-relaxed mb-6 italic">The clean water initiative saved our village. We no longer walk 10km for clean water.</p>
            <div>
              <p class="text-ink font-semibold">Esther M.</p>
              <p class="text-stone text-sm">Teacher, Kenya</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Upcoming Events</h2>
        <p class="scroll-reveal text-center text-lg text-steel max-w-2xl mx-auto mb-12">Come build peace with us. From workshops to health fairs, find an event near you.</p>
        <div class="relative">
          <button id="events-scroll-left" class="causes-scroll-btn hidden lg:flex absolute left-0 top-1/2 -translate-y-1/2 -ml-5 w-10 h-10 bg-canvas border border-hairline rounded-full items-center justify-center shadow-md hover:shadow-lg z-10 cursor-pointer hover:border-accent/30" aria-label="Scroll events left">
            <svg class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div id="events-container" class="flex overflow-x-auto gap-6 pb-4 snap-x snap-mandatory scrollbar-thin" style="-webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory;">
            <div class="flex-none w-[340px] snap-start bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:shadow-lg hover:-translate-y-2 animate-in fade-in slide-in-from-bottom-4 duration-700 img-zoom" style="animation-delay: 0ms">
              <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80&auto=format&fit=crop" alt="Peace Education Workshop" class="w-full h-40 object-cover" loading="lazy" />
              <div class="p-5">
                <div class="flex items-center gap-2 text-xs text-steel mb-2">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <span>Jun 15, 2026</span>
                  <span class="text-hairline">|</span>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <span>Nairobi, Kenya</span>
                </div>
