  </main>

  <Footer />

  <script>
    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';

    function animateCounter(el, target, suffix, prefix) {
      const duration = 1500;
      const startTime = performance.now();
      function tick(now) {
        const p = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const current = Math.floor(eased * target);
        el.textContent = current === 0 && target === 0
          ? `${prefix}0${suffix}`
          : `${prefix}${current.toLocaleString()}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
          statObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.stat-value').forEach(el => statObserver.observe(el));

    const bigStatObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
          bigStatObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.big-stat-value').forEach(el => bigStatObserver.observe(el));

    function animateStats() {
      document.querySelectorAll('.stat-value').forEach(el => {
        const target = parseInt(el.dataset.countTarget, 10);
        if (target > 0) {
          el.textContent = `${el.dataset.countPrefix || ''}0${el.dataset.countSuffix || ''}`;
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
        }
      });
    }

    const progressObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const targetWidth = parseFloat(el.dataset.progressWidth) || 0;
          requestAnimationFrame(() => { el.style.width = targetWidth + '%'; });
          progressObserver.unobserve(el);
        }
      });
    }, { threshold: 0.3 });

    function observeProgressBars() {
      document.querySelectorAll('.progress-bar').forEach(el => progressObserver.observe(el));
    }

    observeProgressBars();

    // Causes carousel scroll buttons
    const causesContainer = document.getElementById('causes-container');
    const causesScrollLeft = document.getElementById('causes-scroll-left');
    const causesScrollRight = document.getElementById('causes-scroll-right');
    if (causesContainer && causesScrollLeft) {
      causesScrollLeft.addEventListener('click', function() { causesContainer.scrollBy({ left: -370, behavior: 'smooth' }); });
    }
    if (causesContainer && causesScrollRight) {
      causesScrollRight.addEventListener('click', function() { causesContainer.scrollBy({ left: 370, behavior: 'smooth' }); });
    }

    // Testimonials carousel scroll buttons
    const testimonialContainer = document.getElementById('testimonial-container');
    const testimonialScrollLeft = document.getElementById('testimonial-scroll-left');
    const testimonialScrollRight = document.getElementById('testimonial-scroll-right');
    if (testimonialContainer && testimonialScrollLeft) {
      testimonialScrollLeft.addEventListener('click', function() { testimonialContainer.scrollBy({ left: -390, behavior: 'smooth' }); });
    }
    if (testimonialContainer && testimonialScrollRight) {
      testimonialScrollRight.addEventListener('click', function() { testimonialContainer.scrollBy({ left: 390, behavior: 'smooth' }); });
    }

    // Events carousel scroll buttons
    const eventsContainer = document.getElementById('events-container');
    const eventsScrollLeft = document.getElementById('events-scroll-left');
    const eventsScrollRight = document.getElementById('events-scroll-right');
    if (eventsContainer && eventsScrollLeft) {
      eventsScrollLeft.addEventListener('click', function() { eventsContainer.scrollBy({ left: -370, behavior: 'smooth' }); });
    }
    if (eventsContainer && eventsScrollRight) {
      eventsScrollRight.addEventListener('click', function() { eventsContainer.scrollBy({ left: 370, behavior: 'smooth' }); });
    }

    // Blog carousel scroll buttons
    const blogContainer = document.getElementById('blog-container');
    const blogScrollLeft = document.getElementById('blog-scroll-left');
    const blogScrollRight = document.getElementById('blog-scroll-right');
    if (blogContainer && blogScrollLeft) {
      blogScrollLeft.addEventListener('click', function() { blogContainer.scrollBy({ left: -370, behavior: 'smooth' }); });
    }
    if (blogContainer && blogScrollRight) {
      blogScrollRight.addEventListener('click', function() { blogContainer.scrollBy({ left: 370, behavior: 'smooth' }); });
    }
  </script>
</Layout>
