          <input type="email" placeholder="Enter your email" required class="newsletter-input flex-1 px-3 py-[10px] bg-canvas border border-hairline rounded-md text-ink placeholder:text-stone text-sm focus:outline-none focus:ring-2 focus:ring-accent/30" />
