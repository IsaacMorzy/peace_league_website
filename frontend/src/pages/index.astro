        <div class="absolute bottom-4 md:bottom-8 left-1/2 -translate-x-1/2 z-10 flex gap-2 md:gap-3" role="tablist" aria-label="Slide indicators">
          {[0,1,2,3,4].map((i) => (
            <button class="carousel-dot w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-white/40 hover:bg-white/70 transition-all duration-300 cursor-pointer" role="tab" aria-selected={i === 0} aria-label={`Slide ${i + 1}`} data-carousel-dot={i}></button>
          ))}
        </div>
      </div>
    </section>

    <section class="relative w-full bg-gradient-to-r from-accent/10 via-accent-warm/10 to-accent/10 border-y border-hairline overflow-hidden" aria-label="Call to action">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-16 flex flex-col md:flex-row items-center justify-between gap-6 relative">
        <div class="floating-bubble-warm" style="width:60px;height:60px;bottom:-30px;left:5%;animation-delay:0s;animation-duration:20s"></div>
        <div class="floating-heart-warm" style="bottom:-20px;right:12%;font-size:24px;animation-delay:3s;animation-duration:25s">♥</div>
        <div class="text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-bold text-ink mb-2">Your donation creates lasting change</h2>
          <p class="text-sm md:text-base text-steel max-w-xl">Every contribution, whether $5 or $500, brings clean water, education, and peace to communities across Africa.</p>
        </div>
        <div class="flex items-center gap-4 shrink-0">
          <a href="/donate" class="btn-pulse-glow inline-flex items-center justify-center min-h-[48px] px-8 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-all duration-300 shadow-lg shadow-accent/20">
            Donate Now
          </a>
          <a href="/volunteer" class="inline-flex items-center justify-center min-h-[48px] px-8 py-3 border border-hairline text-ink font-medium text-sm rounded-full hover:bg-surface transition-all duration-300">
            Get Involved
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    (function(){
      var carousel = document.getElementById('carousel');
      if (!carousel) return;
      var slides = carousel.querySelectorAll('.carousel-slide');
      var dots = carousel.querySelectorAll('.carousel-dot');
      var prevBtn = carousel.querySelector('[data-carousel-prev]');
      var nextBtn = carousel.querySelector('[data-carousel-next]');
      var active = 0;
      var total = slides.length;
      var interval;
      var isPaused = false;

      function goTo(index) {
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        slides.forEach(function(s, i) {
          s.classList.toggle('opacity-0', i !== index);
        });
        dots.forEach(function(d, i) {
          d.classList.toggle('bg-white/70', i === index);
          d.classList.toggle('bg-white/40', i !== index);
          d.setAttribute('aria-selected', i === index);
        });
        active = index;
      }

      function next() { goTo(active + 1); }
      function prev() { goTo(active - 1); }

      function startAutoplay() {
        stopAutoplay();
        interval = setInterval(function(){
          if (!isPaused) next();
        }, 5000);
      }

      function stopAutoplay() {
        if (interval) { clearInterval(interval); interval = null; }
      }

      prevBtn.addEventListener('click', function(){ prev(); startAutoplay(); });
      nextBtn.addEventListener('click', function(){ next(); startAutoplay(); });

      dots.forEach(function(dot){
        dot.addEventListener('click', function(){
          goTo(parseInt(this.dataset.carouselDot));
          startAutoplay();
        });
      });

      carousel.addEventListener('mouseenter', function(){ isPaused = true; });
      carousel.addEventListener('mouseleave', function(){ isPaused = false; });

      goTo(0);
      startAutoplay();
    })();

    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';

    function animateCounter(el, target, suffix, prefix) {
      const duration = 1500;
      const startTime = performance.now();
      function tick(now) {
        const p = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const current = Math.floor(eased * target);
        el.textContent = current === 0 && target === 0
          ? `${prefix}0${suffix}`
          : `${prefix}${current.toLocaleString()}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const bigStatObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
          bigStatObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.big-stat-value').forEach(el => bigStatObserver.observe(el));

    const progressObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const targetWidth = parseFloat(el.dataset.progressWidth) || 0;
          requestAnimationFrame(() => { el.style.width = targetWidth + '%'; });
          progressObserver.unobserve(el);
        }
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('.progress-bar').forEach(el => progressObserver.observe(el));

    const donationObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          if (target > 0) {
            animateCounter(el, target, '', '$');
          }
          donationObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });
    document.querySelectorAll('.donation-amount').forEach(el => donationObserver.observe(el));

    // ── Homepage Countdown Timer for Next Event ──
    (function() {
      var cdEl = document.getElementById('home-countdown-timer');
      if (!cdEl) return;
      var eventDate = new Date(cdEl.dataset.targetDate).getTime();
      if (isNaN(eventDate)) return;
      var daysEl = document.getElementById('home-cd-days');
      var hoursEl = document.getElementById('home-cd-hours');
      var minsEl = document.getElementById('home-cd-mins');
      var secsEl = document.getElementById('home-cd-secs');
      function tick() {
        var now = new Date().getTime();
        var diff = eventDate - now;
        if (diff <= 0) {
          daysEl.textContent = '00';
          hoursEl.textContent = '00';
          minsEl.textContent = '00';
          secsEl.textContent = '00';
          return;
        }
        daysEl.textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
        hoursEl.textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
        minsEl.textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
        secsEl.textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
        requestAnimationFrame(tick);
      }
      tick();
    })();
  </script>
</Layout>