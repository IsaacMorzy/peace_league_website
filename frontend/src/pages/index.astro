  <Footer />

  <script>
    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';

    function animateCounter(el, target, suffix, prefix) {
      const duration = 1500;
      const startTime = performance.now();
      function tick(now) {
        const p = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const current = Math.floor(eased * target);
        el.textContent = current === 0 && target === 0
          ? `${prefix}0${suffix}`
          : `${prefix}${current.toLocaleString()}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
          statObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.stat-value').forEach(el => statObserver.observe(el));

    const bigStatObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
          bigStatObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.big-stat-value').forEach(el => bigStatObserver.observe(el));

    function animateStats() {
      document.querySelectorAll('.stat-value').forEach(el => {
        const target = parseInt(el.dataset.countTarget, 10);
        if (target > 0) {
          el.textContent = `${el.dataset.countPrefix || ''}0${el.dataset.countSuffix || ''}`;
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
        }
      });
    }

    const progressObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const targetWidth = parseFloat(el.dataset.progressWidth) || 0;
          requestAnimationFrame(() => { el.style.width = targetWidth + '%'; });
          progressObserver.unobserve(el);
        }
      });
    }, { threshold: 0.3 });

    function observeProgressBars() {
      document.querySelectorAll('.progress-bar').forEach(el => progressObserver.observe(el));
    }

    const CAUSE_IMAGES = {
      'peace-education': 'https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=600&q=80&auto=format&fit=crop',
      'peace education program': 'https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=600&q=80&auto=format&fit=crop',
      'youth-empowerment': 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80&auto=format&fit=crop',
      'youth empowerment initiative': 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80&auto=format&fit=crop',
      'community-reconciliation': 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&q=80&auto=format&fit=crop',
      'community reconciliation': 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&q=80&auto=format&fit=crop',
      'health': 'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600&q=80&auto=format&fit=crop',
      'healthcare outreach': 'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600&q=80&auto=format&fit=crop',
      'water': 'https://images.unsplash.com/photo-1534274988757-a28bf1a57c17?w=600&q=80&auto=format&fit=crop',
      'clean water access': 'https://images.unsplash.com/photo-1534274988757-a28bf1a57c17?w=600&q=80&auto=format&fit=crop',
      'agriculture': 'https://images.unsplash.com/photo-1500937386664-56d1dfef3854?w=600&q=80&auto=format&fit=crop',
      'sustainable agriculture': 'https://images.unsplash.com/photo-1500937386664-56d1dfef3854?w=600&q=80&auto=format&fit=crop',
      'training': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80&auto=format&fit=crop',
      'peace leader training': 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80&auto=format&fit=crop',
      'global peace summit 2026': 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&q=80&auto=format&fit=crop',
      'girls education initiative': 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=600&q=80&auto=format&fit=crop',
      'digital literacy for all': 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=600&q=80&auto=format&fit=crop',
      'emergency relief fund': 'https://images.unsplash.com/photo-1544027993-37dbfe43562a?w=600&q=80&auto=format&fit=crop',
      'women empowerment program': 'https://images.unsplash.com/photo-1524502397800-3605f2cba3a5?w=600&q=80&auto=format&fit=crop',
      'climate resilience initiative': 'https://images.unsplash.com/photo-1611273426858-450d8e3c9fce?w=600&q=80&auto=format&fit=crop',
      'orphanage support program': 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=600&q=80&auto=format&fit=crop',
      'sports for peace': 'https://images.unsplash.com/photo-1461896836934-bd45ba8fcf9b?w=600&q=80&auto=format&fit=crop',
      'default': 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=600&q=80&auto=format&fit=crop'
    };

    function getCauseImage(cause) {
      if (cause.image) return cause.image;
      const key = cause.name?.toLowerCase() || '';
      return CAUSE_IMAGES[key] || CAUSE_IMAGES['default'];
    }

    async function fetchHomepageData() {
      try {
        const response = await fetch(`${API_BASE_URL}/api/method/peace_league_website.api.get_homepage_data`);
        if (!response.ok) return;
        const json = await response.json();
        const data = json.message || json;
        if (data.status === 'success') {
          const { causes, chapters, stats } = data.data;

          if (stats) {
            document.getElementById('stat-donations').dataset.countTarget = stats.total_donations || 0;
            document.getElementById('stat-volunteers').dataset.countTarget = stats.total_volunteers || 0;
            document.getElementById('stat-chapters').dataset.countTarget = chapters?.length || 0;
            animateStats();
          }

          if (causes && causes.length > 0) {
            const container = document.getElementById('causes-container');
            container.innerHTML = causes.slice(0, 6).map((cause, idx) => {
              const causeImg = getCauseImage(cause);
              return `
              <div class="flex-none w-[350px] snap-start bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:shadow-lg hover:-translate-y-2 animate-in fade-in slide-in-from-bottom-4 duration-700 img-zoom" style="animation-delay: ${idx * 100}ms">
                <div class="h-48 relative overflow-hidden">
                  <img src="${causeImg}" alt="${cause.title || ''}" class="w-full h-full object-cover" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-14 h-14 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                  </div>
                </div>
                <div class="p-6">
                  <span class="badge-tag mb-3">${cause.category || 'Cause'}</span>
                  <h3 class="text-xl font-semibold text-ink">${cause.title || ''}</h3>
                  <p class="mt-2 text-steel line-clamp-3">${cause.description || ''}</p>
                  ${cause.raised_amount > 0 && cause.goal_amount > 0 ? `
                    <div class="mt-4">
                      <div class="flex justify-between text-sm mb-1.5">
                        <span class="font-medium text-ink">$${cause.raised_amount.toLocaleString()}</span>
                        <span class="text-stone">$${cause.goal_amount.toLocaleString()}</span>
                      </div>
                      <div class="w-full bg-hairline rounded-full h-2.5 progress-track">
                        <div class="bg-accent h-2.5 rounded-full progress-bar" data-progress-width="${Math.min((cause.raised_amount / cause.goal_amount) * 100, 100)}" style="width: 0"></div>
                      </div>
                      <p class="mt-1 text-xs text-stone">raised of $${cause.goal_amount.toLocaleString()} goal</p>
                    </div>
                  ` : ''}
                  <a href="/donate?cause=${encodeURIComponent(cause.name || '')}" class="mt-4 inline-flex items-center justify-center w-full px-4 py-2.5 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors">
                    Donate Now
                  </a>
                </div>
              </div>`;
            }).join('');
            observeProgressBars();
          }
        }
      } catch (e) {
        console.log('API not available, using static content');
      }
    }

    observeProgressBars();
    fetchHomepageData();

    // Events carousel scroll buttons
    const eventsContainer = document.getElementById('events-container');
    const eventsScrollLeft = document.getElementById('events-scroll-left');
    const eventsScrollRight = document.getElementById('events-scroll-right');
    if (eventsContainer && eventsScrollLeft) {
      eventsScrollLeft.addEventListener('click', function() { eventsContainer.scrollBy({ left: -370, behavior: 'smooth' }); });
    }
    if (eventsContainer && eventsScrollRight) {
      eventsScrollRight.addEventListener('click', function() { eventsContainer.scrollBy({ left: 370, behavior: 'smooth' }); });
    }
  </script>
</Layout>
