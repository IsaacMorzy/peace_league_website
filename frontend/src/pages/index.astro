  <script>
    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';

    function animateCounter(el, target, suffix, prefix) {
      const duration = 1500;
      const startTime = performance.now();
      function tick(now) {
        const p = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const current = Math.floor(eased * target);
        el.textContent = current === 0 && target === 0
          ? `${prefix}0${suffix}`
          : `${prefix}${current.toLocaleString()}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.countTarget, 10);
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
          statObserver.unobserve(el);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.stat-value').forEach(el => statObserver.observe(el));

    function animateStats() {
      document.querySelectorAll('.stat-value').forEach(el => {
        const target = parseInt(el.dataset.countTarget, 10);
        if (target > 0) {
          el.textContent = `${el.dataset.countPrefix || ''}0${el.dataset.countSuffix || ''}`;
          animateCounter(el, target, el.dataset.countSuffix || '', el.dataset.countPrefix || '');
        }
      });
    }

    const progressObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const targetWidth = parseFloat(el.dataset.progressWidth) || 0;
          requestAnimationFrame(() => { el.style.width = targetWidth + '%'; });
          progressObserver.unobserve(el);
        }
      });
    }, { threshold: 0.3 });

    function observeProgressBars() {
      document.querySelectorAll('.progress-bar').forEach(el => progressObserver.observe(el));
    }

    async function fetchHomepageData() {
      try {
        const response = await fetch(`${API_BASE_URL}/api/method/peace_league_website.api.get_homepage_data`);
        if (!response.ok) return;
        const json = await response.json();
        const data = json.message || json;
        if (data.status === 'success') {
          const { causes, chapters, stats } = data.data;

          if (stats) {
            document.getElementById('stat-donations').dataset.countTarget = stats.total_donations || 0;
            document.getElementById('stat-volunteers').dataset.countTarget = stats.total_volunteers || 0;
            document.getElementById('stat-chapters').dataset.countTarget = chapters?.length || 0;
            animateStats();
          }

          if (causes && causes.length > 0) {
            const container = document.getElementById('causes-container');
            container.innerHTML = causes.slice(0, 3).map((cause, idx) => `
              <div class="bg-canvas rounded-2xl overflow-hidden border border-hairline shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:shadow-lg hover:-translate-y-2 animate-in fade-in slide-in-from-bottom-4 duration-700" style="animation-delay: ${idx * 150}ms">
                ${cause.image
                  ? `<img src="${cause.image}" alt="${cause.title}" class="w-full h-48 object-cover"/>`
                  : `<div class="h-48 bg-gradient-to-br from-accent/20 to-accent/5 flex items-center justify-center">
                      <svg class="w-14 h-14 text-accent/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>`}
                <div class="p-6">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">${cause.category || 'Cause'}</span>
                  <h3 class="text-xl font-semibold text-ink">${cause.title || ''}</h3>
                  <p class="mt-2 text-steel line-clamp-3">${cause.description || ''}</p>
                  ${cause.raised_amount > 0 && cause.goal_amount > 0 ? `
                    <div class="mt-4">
                      <div class="flex justify-between text-sm mb-1.5">
                        <span class="font-medium text-ink">$${cause.raised_amount.toLocaleString()}</span>
                        <span class="text-stone">$${cause.goal_amount.toLocaleString()}</span>
                      </div>
                      <div class="w-full bg-hairline rounded-full h-2.5 progress-track">
                        <div class="bg-accent h-2.5 rounded-full progress-bar" data-progress-width="${Math.min((cause.raised_amount / cause.goal_amount) * 100, 100)}" style="width: 0"></div>
                      </div>
                      <p class="mt-1 text-xs text-stone">raised of $${cause.goal_amount.toLocaleString()} goal</p>
                    </div>
                  ` : ''}
                  <a href="/donate?cause=${encodeURIComponent(cause.name || '')}" class="mt-4 inline-flex items-center justify-center w-full px-4 py-2.5 bg-primary text-on-dark text-sm font-medium rounded-full hover:bg-charcoal transition-colors">
                    Donate Now
                  </a>
                </div>
              </div>
            `).join('');
            observeProgressBars();
          }
        }
      } catch (e) {
        console.log('API not available, static content shown');
      }
    }
    fetchHomepageData();
    setTimeout(observeProgressBars, 500);
  </script>
</Layout>
