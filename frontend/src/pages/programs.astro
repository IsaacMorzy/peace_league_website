---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Our Programs">
  <Navigation />
  
  <main>
    <section class="bg-[#1a3d4a] text-white py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-5xl font-semibold leading-[1.10] tracking-tight" data-aos="fade-down">Our Programs</h1>
        <p class="mt-4 text-lg text-on-dark-muted" data-aos="fade-down" data-aos-delay="100">Comprehensive initiatives creating lasting impact</p>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="programs-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="0">
            <div class="h-1 bg-accent"></div>
            <div class="p-6">
              <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">Education</span>
              <h3 class="text-xl font-semibold text-ink">Education for All</h3>
              <p class="mt-2 text-steel line-clamp-3">Providing quality education to underserved communities across Africa. Our programs focus on teacher training, school supplies, and digital learning resources.</p>
              <p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Status:</span> Active</p>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="100">
            <div class="h-1 bg-accent"></div>
            <div class="p-6">
              <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">Health</span>
              <h3 class="text-xl font-semibold text-ink">Healthcare Initiative</h3>
              <p class="mt-2 text-steel line-clamp-3">Bringing essential healthcare services to remote areas. We organize mobile clinics, health education workshops, and vaccination drives.</p>
              <p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Status:</span> Active</p>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="200">
            <div class="h-1 bg-accent"></div>
            <div class="p-6">
              <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">Water</span>
              <h3 class="text-xl font-semibold text-ink">Clean Water Project</h3>
              <p class="mt-2 text-steel line-clamp-3">Ensuring access to clean, safe drinking water for communities in need through well construction and water purification systems.</p>
              <p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Status:</span> Active</p>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="0">
            <div class="h-1 bg-accent"></div>
            <div class="p-6">
              <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">Food</span>
              <h3 class="text-xl font-semibold text-ink">Food Security Program</h3>
              <p class="mt-2 text-steel line-clamp-3">Combating hunger through sustainable agriculture training, community gardens, and emergency food distribution.</p>
              <p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Status:</span> Active</p>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="100">
            <div class="h-1 bg-accent"></div>
            <div class="p-6">
              <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">Youth</span>
              <h3 class="text-xl font-semibold text-ink">Youth Empowerment</h3>
              <p class="mt-2 text-steel line-clamp-3">Leadership training, mentorship programs, and entrepreneurship support for young people across the continent.</p>
              <p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Status:</span> Active</p>
            </div>
          </div>
          <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="200">
            <div class="h-1 bg-accent"></div>
            <div class="p-6">
              <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">Peace</span>
              <h3 class="text-xl font-semibold text-ink">Peace Building</h3>
              <p class="mt-2 text-steel line-clamp-3">Conflict resolution workshops, community dialogue sessions, and peace education in schools.</p>
              <p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Status:</span> Active</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const API_BASE_URL = window.ENV?.PUBLIC_API_URL || '';
    
    async function fetchPrograms() {
      try {
        const response = await fetch(`${API_BASE_URL}/api/method/peace_league_website.api.get_programs`);
        if (!response.ok) return;
        const data = await response.json();
        if (data.status === 'success' && data.data && data.data.length > 0) {
          const container = document.getElementById('programs-list');
          container.innerHTML = data.data.map((program, idx) => `
            <div class="bg-canvas rounded-lg border border-hairline overflow-hidden" data-aos="fade-up" data-aos-delay="${idx * 100}">
              <div class="h-1 bg-accent"></div>
              ${program.image ? `<img src="${program.image}" alt="${program.title}" class="w-full h-48 object-cover"/>` : ''}
              <div class="p-6">
                <span class="inline-flex items-center px-2 py-0.5 rounded-sm text-xs font-semibold mb-3" style="background-color: rgba(55,114,207,0.15); color: #3772cf;">${program.category || 'Program'}</span>
                <h3 class="text-xl font-semibold text-ink">${program.title || ''}</h3>
                <p class="mt-2 text-steel line-clamp-3">${program.description || ''}</p>
                ${program.start_date ? `<p class="mt-4 text-sm text-stone"><span class="font-medium text-ink">Starts:</span> ${new Date(program.start_date).toLocaleDateString()}</p>` : ''}
                ${program.raised_amount > 0 && program.goal_amount > 0 ? `
                  <div class="mt-4">
                    <div class="w-full bg-hairline rounded-full h-2">
                      <div class="bg-accent-deep h-2 rounded-full" style="width: ${Math.min((program.raised_amount / program.goal_amount) * 100, 100)}%"></div>
                    </div>
                    <p class="mt-2 text-sm text-stone">$${program.raised_amount.toLocaleString()} raised of $${program.goal_amount.toLocaleString()}</p>
                  </div>
                ` : ''}
                <a href="/donate?program=${encodeURIComponent(program.name || '')}" class="mt-4 inline-block text-accent-deep font-medium text-sm hover:text-accent">
                  Support this program →
                </a>
              </div>
            </div>
          `).join('');
        }
      } catch (e) {
        console.log('API not available, using static content');
      }
    }
    fetchPrograms();
  </script>
</Layout>
