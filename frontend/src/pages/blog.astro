---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import posts from '../lib/blog-data.json';

const categories = ['All', ...new Set(posts.map(p => p.category))];
const featured = posts[0];
const perPage = 6;
const totalPages = Math.ceil(posts.length / perPage);
const allPostsJson = JSON.stringify(posts);
---

<Layout title="Blog — Peace League Africa" description="Stories of hope, impact, and the people building peace across Africa. Read Peace League's latest news, field reports, and community voices from 12 African countries.">
  <Navigation />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero-gradient text-white py-24 lg:py-32 hero-pattern relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="scroll-reveal max-w-3xl">
          <span class="inline-block px-3 py-1 text-xs font-semibold bg-accent/20 text-accent-soft rounded-full mb-4 uppercase tracking-wider">Our Journal</span>
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.02] tracking-tight">Latest News & Stories</h1>
          <p class="mt-5 text-xl text-white/80 max-w-2xl leading-relaxed">Stories of hope, impact, and the people building peace across Africa.</p>
        </div>
        <div class="parallax-layer" aria-hidden="true">
          <div class="parallax-bg-shape" style="width:300px;height:300px;top:-50px;right:-80px;background:radial-gradient(circle, rgba(0,212,164,0.3) 0%, transparent 70%);"></div>
          <div class="parallax-bg-shape" style="width:200px;height:200px;bottom:-40px;left:-60px;background:radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);"></div>
        </div>
      </div>
    </section>

    <!-- Featured Post -->
    <section class="py-20 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="scroll-reveal">
          <h2 class="text-sm font-semibold text-accent uppercase tracking-[0.2em] mb-8 flex items-center gap-3">
            <span class="w-8 h-[2px] bg-accent rounded-full"></span>Featured Story
          </h2>
        </div>
        <a href={`/blog/${featured.slug}`} class="scroll-reveal block relative rounded-2xl overflow-hidden group shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
          <span class="absolute top-6 left-6 z-10 inline-block px-4 py-1.5 text-xs font-bold bg-warm text-white rounded-full uppercase tracking-wider shadow-lg">Featured</span>
          <img src={featured.image.replace('?w=800&q=80&auto=format&fit=crop', '?w=1400&q=80&auto=format&fit=crop')} alt={featured.title} class="w-full h-[460px] lg:h-[520px] object-cover transition-transform duration-700 group-hover:scale-105" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
            <span class="inline-block px-3 py-1 text-xs font-semibold bg-accent text-on-dark rounded-full mb-4">{featured.category}</span>
            <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold text-white mb-3 leading-tight max-w-3xl">{featured.title}</h2>
            <p class="text-white/70 text-sm md:text-base max-w-2xl mb-4 leading-relaxed">{featured.description.substring(0, 150)}...</p>
            <div class="flex items-center gap-4 text-sm text-white/60">
              <span>{new Date(featured.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span class="w-1 h-1 rounded-full bg-white/30"></span>
              <span>{featured.readTime}</span>
              <span class="w-1 h-1 rounded-full bg-white/30"></span>
              <span>{featured.author}</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Section Divider -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-divider"></div>
    </div>

    <!-- Blog Grid + Sidebar -->
    <section class="py-20 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="scroll-reveal flex flex-wrap gap-3 mb-12">
          {categories.map((cat, idx) => {
            const href = cat === 'All' ? '/blog' : `/blog?category=${cat.toLowerCase()}`;
            return (
              <a href={href} class={`px-5 py-2 text-sm rounded-full border transition-all duration-300 hover:-translate-y-0.5 min-h-[44px] inline-flex items-center ${idx === 0 ? 'bg-primary text-on-primary border-primary shadow-sm' : 'bg-canvas text-steel border-hairline hover:border-accent hover:text-accent hover:shadow-sm hover:bg-accent/5'}`}>
                {cat}
              </a>
            );
          })}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
          <!-- Main Grid -->
          <div class="lg:col-span-3">
            <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8" data-pages={totalPages}>
              {posts.map((post, idx) => (
                <article class="blog-card bg-canvas rounded-2xl border border-hairline overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:border-accent/30 hover:shadow-accent/5 group" data-page={Math.floor(idx / perPage) + 1} style="animation-delay: 0ms">
                  <div class="relative overflow-hidden h-48">
                    <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <span class="absolute top-4 left-4 px-3 py-1 text-xs font-semibold bg-accent/90 text-white rounded-full shadow-lg backdrop-blur-sm">{post.category}</span>
                  </div>
                  <div class="p-7">
                    <div class="flex items-center gap-3 text-xs text-steel mb-3">
                      <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                      <span class="w-1 h-1 rounded-full bg-hairline"></span>
                      <span>{post.readTime}</span>
                    </div>
                    <h3 class="text-lg font-semibold text-ink mb-3 leading-snug line-clamp-2 group-hover:text-accent transition-colors duration-300">{post.title}</h3>
                    <p class="text-sm text-steel leading-relaxed mb-5 line-clamp-3">{post.description}</p>
                    <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-deep transition-all duration-300 group/link">
                      Read Full Story
                      <svg class="w-4 h-4 transition-all duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </a>
                  </div>
                </article>
              ))}
            </div>

            <!-- Pagination -->
            <div id="pagination" class="mt-16 flex items-center justify-center gap-3" data-total={totalPages}>
              <button id="prev-btn" class="px-5 py-2.5 text-sm font-medium text-steel bg-canvas border border-hairline rounded-full hover:text-ink hover:border-accent hover:bg-accent/5 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed min-h-[44px]">
                <svg class="w-4 h-4 inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Previous
              </button>
              <div id="page-numbers" class="flex items-center gap-2">
                <button class="page-btn w-10 h-10 text-sm font-medium rounded-full transition-all duration-200 bg-primary text-on-primary shadow-md">1</button>
              </div>
              <button id="next-btn" class="px-5 py-2.5 text-sm font-medium text-steel bg-canvas border border-hairline rounded-full hover:text-ink hover:border-accent hover:bg-accent/5 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed min-h-[44px]">
                Next
                <svg class="w-4 h-4 inline-block ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-1 space-y-8">
            <div class="bg-canvas rounded-2xl border border-hairline p-6 hover:shadow-lg hover:border-accent/20 transition-all duration-300">
              <h3 class="text-sm font-semibold text-ink uppercase tracking-wider mb-5 flex items-center gap-2">
                <span class="w-1 h-4 bg-accent rounded-full"></span>Categories
              </h3>
              <div class="space-y-1">
                {categories.filter(c => c !== 'All').map((cat, idx) => (
                  <span class="flex items-center gap-2 px-3 py-2.5 text-sm text-steel rounded-lg hover:text-accent hover:bg-accent/5 transition-all duration-200 cursor-pointer group" style={`animation-delay: ${idx * 30}ms`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/40 group-hover:bg-accent transition-all duration-300 shrink-0 group-hover:scale-125"></span>
                    {cat}
                    <span class="ml-auto text-xs text-muted bg-surface px-2 py-0.5 rounded-full">({posts.filter(p => p.category === cat).length})</span>
                  </span>
                ))}
              </div>
            </div>

            <div class="bg-canvas rounded-2xl border border-hairline p-6 hover:shadow-lg hover:border-accent/20 transition-all duration-300">
              <h3 class="text-sm font-semibold text-ink uppercase tracking-wider mb-5 flex items-center gap-2">
                <span class="w-1 h-4 bg-accent rounded-full"></span>Recent Posts
              </h3>
              <div class="space-y-5">
                {posts.slice(0, 4).map((post, idx) => (
                  <a href={`/blog/${post.slug}`} class="group flex gap-3 transition-all duration-200 hover:-translate-x-0.5" style={`animation-delay: ${idx * 40}ms`}>
                    <img src={post.image} alt={post.title} class="w-14 h-14 rounded-xl object-cover shrink-0 transition-transform duration-300 group-hover:scale-110" loading="lazy" />
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-ink line-clamp-2 group-hover:text-accent transition-colors duration-200">{post.title}</p>
                      <p class="text-xs text-muted mt-1">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <div class="bg-gradient-to-br from-accent/20 via-accent/10 to-accent/0 rounded-2xl border border-accent/30 p-6 shadow-md relative overflow-hidden group hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
              <div class="absolute top-0 right-0 w-32 h-32 bg-accent/15 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
              <div class="absolute bottom-0 left-0 w-24 h-24 bg-accent-warm/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-2xl"></div>
              <h3 class="text-sm font-semibold text-ink mb-2 relative z-10">Stay Connected</h3>
              <p class="text-xs text-steel mb-5 relative z-10 leading-relaxed">Get our latest stories delivered to your inbox.</p>
              <div class="flex flex-col gap-2.5 relative z-10">
                <input type="email" placeholder="Your email address" aria-label="Email for newsletter" class="w-full px-3.5 py-2.5 text-sm bg-canvas border border-hairline rounded-lg text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all" />
                <button class="w-full px-4 py-2.5 text-sm font-medium bg-primary text-on-dark rounded-full hover:bg-charcoal transition-all duration-300 cursor-pointer min-h-[44px] hover:shadow-md active:scale-[0.98]">Get Updates</button>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="py-24 lg:py-28 bg-surface relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 25% 50%, var(--color-accent) 0%, transparent 50%), radial-gradient(circle at 75% 50%, var(--color-accent-warm) 0%, transparent 50%);"></div>
      <div class="max-w-3xl mx-auto text-center px-4 relative z-10">
        <div class="section-divider mb-8"></div>
        <h2 class="scroll-reveal text-4xl lg:text-5xl font-semibold leading-[1.15] tracking-[-0.5px] text-ink text-center mb-4">Have a Story to Share?</h2>
        <p class="scroll-reveal text-lg text-steel text-center max-w-2xl mx-auto mb-10 leading-relaxed">We love featuring voices from our community. Pitch us your peace-building story and inspire others across Africa.</p>
        <a href="/contact" class="scroll-reveal inline-flex items-center justify-center w-full sm:w-auto px-8 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-all duration-300 shadow-md hover:shadow-lg active:scale-[0.98]">
          Submit Your Story
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  (function() {
    const grid = document.getElementById('blog-grid');
    const totalPages = parseInt(grid?.getAttribute('data-pages') || '1');
    const cards = document.querySelectorAll('.blog-card');
    const pageNumbers = document.getElementById('page-numbers');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    let currentPage = 1;

    function showPage(page) {
      currentPage = page;
      cards.forEach(card => {
        card.style.display = parseInt(card.getAttribute('data-page')) === page ? 'block' : 'none';
      });
      prevBtn.disabled = page <= 1;
      nextBtn.disabled = page >= totalPages;
      renderPageNumbers();
    }

    function renderPageNumbers() {
      const pages = [];
      if (totalPages <= 5) {
        for (let i = 1; i <= totalPages; i++) pages.push(i);
      } else {
        pages.push(1);
        let start = Math.max(2, currentPage - 1);
        let end = Math.min(totalPages - 1, currentPage + 1);
        if (currentPage <= 2) { start = 2; end = Math.min(4, totalPages - 1); }
        if (currentPage >= totalPages - 1) { start = Math.max(totalPages - 3, 2); end = totalPages - 1; }
        if (start > 2) pages.push('...');
        for (let i = start; i <= end; i++) pages.push(i);
        if (end < totalPages - 1) pages.push('...');
        pages.push(totalPages);
      }

      pageNumbers.innerHTML = pages.map(p => {
        if (p === '...') return '<span class="w-6 text-center text-steel text-sm">...</span>';
        const active = p === currentPage;
        return `<button class="page-btn w-10 h-10 text-sm font-medium rounded-full transition-all duration-200 ${active ? 'bg-primary text-on-primary shadow-md' : 'text-steel bg-canvas border border-hairline hover:border-accent hover:text-accent'}">${p}</button>`;
      }).join('');

      pageNumbers.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', () => showPage(parseInt(btn.textContent)));
      });
    }

    prevBtn.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1); });
    nextBtn.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1); });

    showPage(1);
  })();
</script>
