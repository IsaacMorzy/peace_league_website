---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import posts from '../lib/blog-data.json';

const categories = ['All', ...new Set(posts.map(p => p.category))];
const featured = posts[0];
const perPage = 6;
const totalPages = Math.ceil(posts.length / perPage);
const page = 1;
const paginatedPosts = posts.slice(0, perPage);
const p = 1;
---

<Layout title="Blog — Peace League Africa" description="Stories of hope, impact, and the people building peace across Africa. Read Peace League's latest news, field reports, and community voices from 12 African countries.">
  <Navigation />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero-gradient text-white py-20 lg:py-28 hero-pattern relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="scroll-reveal">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.02] tracking-tight">Latest News & Stories</h1>
          <p class="mt-5 text-xl text-white/80 max-w-2xl">Stories of hope, impact, and the people building peace across Africa.</p>
        </div>
      </div>
    </section>

    <!-- Featured Post -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href={`/blog/${featured.slug}`} class="block relative rounded-2xl overflow-hidden group shadow-lg hover:shadow-2xl transition-all duration-500">
          <span class="absolute top-6 left-6 z-10 inline-block px-4 py-1.5 text-xs font-bold bg-warm text-white rounded-full uppercase tracking-wider shadow-lg">Featured</span>
          <img src={featured.image.replace('?w=800&q=80&auto=format&fit=crop', '?w=1400&q=80&auto=format&fit=crop')} alt={featured.title} class="w-full h-[420px] object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
            <span class="inline-block px-3 py-1 text-xs font-semibold bg-accent text-on-dark rounded-full mb-4">{featured.category}</span>
            <h2 class="text-2xl md:text-4xl font-bold text-white mb-3 leading-tight">{featured.title}</h2>
            <p class="text-white/70 text-sm md:text-base max-w-2xl mb-4">{featured.description.substring(0, 120)}...</p>
            <div class="flex items-center gap-4 text-sm text-white/60">
              <span>{new Date(featured.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span>&middot;</span>
              <span>{featured.readTime}</span>
              <span>&middot;</span>
              <span>{featured.author}</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Blog Grid + Sidebar -->
    <section class="pb-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-2 mb-10">
          {categories.map((cat, idx) => {
            const href = cat === 'All' ? '/blog' : `/blog?category=${cat.toLowerCase()}`;
            return (
              <a href={href} class={`px-4 py-2 text-sm rounded-full border transition-all duration-300 hover:-translate-y-0.5 min-h-[44px] inline-flex items-center ${idx === 0 ? 'bg-primary text-on-primary border-primary shadow-sm' : 'bg-canvas text-steel border-hairline hover:border-accent hover:text-accent hover:shadow-sm'}`}>
                {cat}
              </a>
            );
          })}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
          <!-- Main Grid -->
          <div class="lg:col-span-3">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 stagger-children">
              {paginatedPosts.map((post, idx) => (
                <article class="scroll-reveal-animate bg-canvas rounded-2xl border border-hairline overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:border-accent/30 hover:shadow-accent/5 group" style={`animation-delay: ${idx * 80}ms`}>
                  <div class="relative overflow-hidden h-52">
                    <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                    <span class="absolute top-4 left-4 px-3 py-1 text-xs font-semibold bg-accent text-on-dark rounded-full shadow-lg backdrop-blur-sm">{post.category}</span>
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3 text-xs text-steel mb-3">
                      <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                      <span class="w-1 h-1 rounded-full bg-hairline"></span>
                      <span>{post.readTime}</span>
                      <span class="w-1 h-1 rounded-full bg-hairline"></span>
                      <span>{post.author}</span>
                    </div>
                    <h3 class="text-lg font-semibold text-ink mb-2 leading-snug line-clamp-2">{post.title}</h3>
                    <p class="text-sm text-steel leading-relaxed mb-4 line-clamp-3">{post.description}</p>
                    <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-deep transition-colors group/link">
                      Read Article
                      <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </a>
                  </div>
                </article>
              ))}
            </div>

            <!-- Pagination -->
            <div class="mt-12 flex items-center justify-center gap-3">
              <button class="px-4 py-2 text-sm font-medium text-steel bg-canvas border border-hairline rounded-full hover:text-ink hover:border-accent transition-colors disabled:opacity-30 disabled:cursor-not-allowed min-h-[44px]" disabled={p <= 1}>
                <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Previous
              </button>
              {Array.from({ length: totalPages }, (_, i) => i + 1).map(pageNum => (
                <button class={`w-10 h-10 min-w-[44px] min-h-[44px] text-sm font-medium rounded-full transition-all duration-200 ${pageNum === p ? 'bg-primary text-on-primary shadow-md' : 'text-steel bg-canvas border border-hairline hover:border-accent hover:text-accent'}`}>
                  {pageNum}
                </button>
              ))}
              <button class="px-4 py-2 text-sm font-medium text-steel bg-canvas border border-hairline rounded-full hover:text-ink hover:border-accent transition-colors disabled:opacity-30 disabled:cursor-not-allowed min-h-[44px]" disabled={p >= totalPages}>
                Next
                <svg class="w-4 h-4 inline-block ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-1 space-y-8">
            <div class="bg-canvas rounded-2xl border border-hairline p-6 hover:shadow-md transition-shadow">
              <h3 class="text-sm font-semibold text-ink uppercase tracking-wider mb-4 flex items-center gap-2">
                <span class="w-1 h-4 bg-accent rounded-full"></span>Categories
              </h3>
              <div class="space-y-1">
                {categories.filter(c => c !== 'All').map((cat, idx) => (
                  <span class="flex items-center gap-2 px-3 py-2 text-sm text-steel rounded-lg hover:text-accent hover:bg-accent/5 transition-colors cursor-pointer group" style={`animation-delay: ${idx * 30}ms`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/60 group-hover:bg-accent transition-colors shrink-0"></span>
                    {cat}
                    <span class="ml-auto text-xs text-stone">({posts.filter(p => p.category === cat).length})</span>
                  </span>
                ))}
              </div>
            </div>

            <div class="bg-canvas rounded-2xl border border-hairline p-6 hover:shadow-md transition-shadow">
              <h3 class="text-sm font-semibold text-ink uppercase tracking-wider mb-4 flex items-center gap-2">
                <span class="w-1 h-4 bg-accent rounded-full"></span>Recent Posts
              </h3>
              <div class="space-y-4">
                {posts.slice(0, 4).map((post, idx) => (
                  <a href={`/blog/${post.slug}`} class="group flex gap-3 transition-all duration-200 hover:-translate-x-0.5" style={`animation-delay: ${idx * 40}ms`}>
                    <img src={post.image} alt={post.title} class="w-14 h-14 rounded-xl object-cover shrink-0 transition-transform duration-300 group-hover:scale-110" loading="lazy" />
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-ink truncate group-hover:text-accent transition-colors">{post.title}</p>
                      <p class="text-xs text-steel mt-1">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <div class="bg-gradient-to-br from-accent/15 via-accent/8 to-accent/0 rounded-2xl border border-accent/25 p-6 shadow-sm relative overflow-hidden">
              <div class="absolute top-0 right-0 w-24 h-24 bg-accent/10 rounded-full -translate-y-1/2 translate-x-1/2 blur-2xl"></div>
              <h3 class="text-sm font-semibold text-ink mb-2 relative z-10">Stay Connected</h3>
              <p class="text-xs text-steel mb-4 relative z-10">Get our latest stories delivered to your inbox.</p>
              <div class="flex flex-col gap-2 relative z-10">
                <input type="email" placeholder="Your email" aria-label="Email for newsletter" class="w-full px-3 py-2 text-sm bg-canvas border border-hairline rounded-lg text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all" />
                <button class="w-full px-4 py-2 text-sm font-medium bg-primary text-on-dark rounded-full hover:bg-charcoal transition-colors cursor-pointer min-h-[44px]">Subscribe</button>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="py-16 bg-surface">
      <div class="max-w-3xl mx-auto text-center px-4">
        <h2 class="scroll-reveal text-4xl font-semibold leading-[1.2] tracking-[-0.5px] text-ink text-center mb-4">Have a Story to Share?</h2>
        <p class="scroll-reveal text-lg text-steel text-center max-w-2xl mx-auto mb-12">We love featuring voices from our community. Pitch us your peace-building story.</p>
        <a href="/contact" class="scroll-reveal inline-flex items-center justify-center w-full sm:w-auto px-8 py-3 bg-primary text-on-dark font-medium text-sm rounded-full hover:bg-charcoal transition-colors shadow-md">
          Submit Your Story
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
