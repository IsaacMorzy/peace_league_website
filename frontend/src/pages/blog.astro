---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import posts from '../lib/blog-data.json';

const categories = ['All', ...new Set(posts.map(p => p.category))];
const featured = posts[0];
const perPage = 6;
const totalPages = Math.ceil(posts.length / perPage);
const allPostsJson = JSON.stringify(posts);
---

<Layout title="Blog — Peace League Africa" description="Stories of hope, impact, and the people building peace across Africa. Read Peace League's latest news, field reports, and community voices from 12 African countries.">
  <Navigation />

  <main id="main-content">
    <!-- ── MINIMAL HERO ── -->
    <section class="relative pt-28 pb-16 md:pb-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="max-w-3xl">
          <span class="inline-flex items-center gap-2 text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-4">
            <span class="w-6 h-px bg-accent"></span> Our Journal
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-ink leading-[1.05] tracking-tight">
            Latest News &amp; Stories
          </h1>
          <p class="mt-4 text-lg text-steel max-w-xl leading-relaxed">
            Stories of hope, impact, and the people building peace across Africa.
          </p>
        </div>
      </div>
    </section>

    <!-- ── FEATURED POST — IMMERSIVE HERO CARD ── -->
    <section class="pb-12 md:pb-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <a
          href={`/blog/${featured.slug}`}
          class="tilt-card group relative block rounded-3xl overflow-hidden bg-canvas border border-hairline shadow-sm hover:shadow-2xl transition-all duration-700 dark:bg-[#141416] dark:border-[#2a2a2c]"
          style="transform-style: preserve-3d;"
        >
          <div class="tilt-sheen absolute inset-0 pointer-events-none z-20" style="background: radial-gradient(circle at var(--sheen-x, 50%) var(--sheen-y, 50%), rgba(255,255,255,0.12) 0%, transparent 60%);"></div>
          <div class="grid md:grid-cols-2 gap-0 min-h-[420px]">
            <!-- Image side -->
            <div class="relative overflow-hidden h-64 md:h-auto">
              <img
                src={featured.image}
                alt={featured.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                loading="eager"
                fetchpriority="high"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/20 to-transparent md:bg-gradient-to-r md:from-black/50 md:via-black/10 md:to-transparent"></div>
              <div class="absolute top-4 left-4 md:hidden">
                <span class="px-3 py-1 text-xs font-bold bg-accent text-white rounded-full uppercase tracking-wider shadow-lg">Featured</span>
              </div>
            </div>
            <!-- Content side -->
            <div class="relative flex flex-col justify-center p-6 md:p-10 lg:p-12 bg-gradient-to-br from-canvas via-surface to-canvas dark:from-[#1a1a1c] dark:via-[#141416] dark:to-[#141416]">
              <span class="hidden md:inline-block px-3 py-1 text-xs font-bold bg-accent text-white rounded-full uppercase tracking-wider shadow-lg w-fit mb-5">Featured</span>
              <div class="flex flex-wrap items-center gap-3 text-xs text-steel mb-3">
                <span class="px-2.5 py-0.5 rounded-full bg-accent/10 text-accent font-semibold">{featured.category}</span>
                <span class="w-1 h-1 rounded-full bg-hairline"></span>
                <span>{new Date(featured.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span class="w-1 h-1 rounded-full bg-hairline"></span>
                <span>{featured.readTime}</span>
              </div>
              <h2 class="text-xl md:text-2xl lg:text-3xl font-bold text-ink leading-tight mb-3 group-hover:text-accent transition-colors duration-300 dark:text-[#e8e8ed] dark:group-hover:text-accent-soft">
                {featured.title}
              </h2>
              <p class="text-sm md:text-base text-steel leading-relaxed mb-6 line-clamp-3 dark:text-[#a1a1a6]">
                {featured.description}
              </p>
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-accent/15 flex items-center justify-center text-accent font-bold text-xs">
                  {featured.author.split(' ').map(n => n[0]).join('').slice(0, 2)}
                </div>
                <div class="text-sm">
                  <p class="font-medium text-ink dark:text-[#e8e8ed]">{featured.author}</p>
                  <p class="text-xs text-steel dark:text-[#8e8e92]">{featured.authorRole}</p>
                </div>
                <span class="ml-auto inline-flex items-center gap-1.5 text-sm font-semibold text-accent group-hover/link:gap-2.5 transition-all">
                  Read
                  <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- ── STICKY CATEGORY FILTER BAR ── -->
    <div class="sticky top-0 z-30 bg-canvas/80 backdrop-blur-xl border-b border-hairline py-3 dark:bg-[#0a0a0a]/90 dark:border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2 overflow-x-auto scrollbar-none pb-1" id="category-filter">
          {categories.map((cat, idx) => {
            const count = cat === 'All' ? posts.length : posts.filter(p => p.category === cat).length;
            return (
              <button
                data-category={cat.toLowerCase()}
                class={`filter-btn whitespace-nowrap px-4 py-1.5 text-sm font-medium rounded-full border transition-all duration-200 cursor-pointer ${
                  idx === 0
                    ? 'bg-primary text-on-primary border-primary shadow-sm dark:bg-white dark:text-[#0a0a0a] dark:border-white'
                    : 'bg-canvas text-steel border-hairline hover:border-accent hover:text-accent hover:bg-accent/5 dark:bg-[#1c1c1e] dark:text-[#c7c7cc] dark:border-[#2a2a2c] dark:hover:border-accent dark:hover:text-accent-soft dark:hover:bg-accent/5'
                }`}
              >
                {cat}
                <span class="ml-1.5 text-xs opacity-60">({count})</span>
              </button>
            );
          })}
        </div>
      </div>
    </div>

    <!-- ── BLOG GRID + SIDEBAR ── -->
    <section class="py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
          <!-- Main Grid -->
          <div class="lg:col-span-3">
            <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8" data-pages={totalPages}>
              {posts.map((post, idx) => (
                <article
                  class="blog-card group relative bg-canvas rounded-2xl border border-hairline overflow-hidden transition-all duration-500 hover:-translate-y-1.5 hover:shadow-xl hover:border-accent/25 dark:bg-[#141416] dark:border-[#2a2a2c] dark:hover:border-accent/30 dark:hover:shadow-2xl dark:hover:shadow-black/40"
                  data-page={Math.floor(idx / perPage) + 1}
                  data-category={post.category.toLowerCase()}
                  style="animation-delay: 0ms"
                >
                  <!-- Gradient border accent on hover -->
                  <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-accent/0 to-transparent group-hover:via-accent/60 transition-all duration-700"></div>

                  <div class="relative overflow-hidden aspect-[16/10]">
                    <img
                      src={post.image}
                      alt={post.title}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <span class="absolute top-3 left-3 px-2.5 py-1 text-[11px] font-bold bg-white/90 text-ink rounded-full shadow-lg backdrop-blur-sm border border-white/20 dark:bg-[#1c1c1e]/90 dark:text-[#e8e8ed] dark:border-white/10">
                      {post.category}
                    </span>
                  </div>
                  <div class="p-5 md:p-6">
                    <div class="flex items-center gap-2.5 text-xs text-steel mb-3">
                      <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                      <span class="w-1 h-1 rounded-full bg-hairline dark:bg-[#2a2a2c]"></span>
                      <span class="flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        {post.readTime}
                      </span>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-ink mb-2.5 leading-snug line-clamp-2 group-hover:text-accent transition-colors duration-300 dark:text-[#e8e8ed] dark:group-hover:text-accent-soft">
                      {post.title}
                    </h3>
                    <p class="text-sm text-steel leading-relaxed mb-4 line-clamp-2 dark:text-[#a1a1a6]">
                      {post.description}
                    </p>
                    <div class="flex items-center justify-between">
                      <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent group/link dark:text-accent-soft">
                        Read more
                        <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                      </span>
                      <span class="text-xs text-muted dark:text-[#6e6e72]">{post.author.split(' ')[0]}</span>
                    </div>
                  </div>
                  <a href={`/blog/${post.slug}`} class="absolute inset-0 z-10" aria-label={`Read ${post.title}`}></a>
                </article>
              ))}
            </div>

            <!-- ── LOAD MORE / PAGINATION ── -->
            <div class="mt-12 flex flex-col items-center gap-4">
              <button id="load-more" class="px-8 py-3 text-sm font-semibold text-ink bg-canvas border-2 border-hairline rounded-full hover:border-accent hover:text-accent hover:bg-accent/5 transition-all duration-300 shadow-sm hover:shadow-md active:scale-[0.98] cursor-pointer">
                Load more articles
              </button>
              <div id="pagination" class="hidden items-center gap-2" data-total={totalPages}>
                <button id="prev-btn" class="px-4 py-2 text-sm font-medium text-steel bg-canvas border border-hairline rounded-full hover:text-ink hover:border-accent hover:bg-accent/5 transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer">
                  <svg class="w-4 h-4 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <div id="page-numbers" class="flex items-center gap-1.5"></div>
                <button id="next-btn" class="px-4 py-2 text-sm font-medium text-steel bg-canvas border border-hairline rounded-full hover:text-ink hover:border-accent hover:bg-accent/5 transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer">
                  <svg class="w-4 h-4 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
              </div>
              <p id="grid-status" class="text-sm text-steel"></p>
            </div>
          </div>

          <!-- ── SIDEBAR ── -->
          <aside class="lg:col-span-1 space-y-6 lg:sticky lg:top-24 lg:self-start">
            <!-- About / Intro -->
            <div class="bg-gradient-to-br from-surface to-canvas rounded-2xl border border-hairline p-6">
              <div class="w-10 h-10 rounded-full bg-accent/15 flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
              <h3 class="text-sm font-bold text-ink mb-2">About This Blog</h3>
              <p class="text-xs text-steel leading-relaxed">Stories from the frontlines of peace-building across Africa. Field reports, community voices, and updates from Peace League's programs in 12 countries.</p>
            </div>

            <!-- Categories -->
            <div class="bg-canvas rounded-2xl border border-hairline p-6">
              <h3 class="text-xs font-bold text-ink uppercase tracking-wider mb-4 flex items-center gap-2">
                <span class="w-1 h-3 bg-accent rounded-full"></span>Categories
              </h3>
              <div class="space-y-0.5">
                {categories.filter(c => c !== 'All').map((cat) => (
                  <button
                    data-category={cat.toLowerCase()}
                    class="filter-btn w-full flex items-center gap-2.5 px-3 py-2 text-sm text-steel rounded-xl hover:text-accent hover:bg-accent/5 transition-all duration-200 cursor-pointer text-left dark:text-[#a1a1a6] dark:hover:text-accent-soft dark:hover:bg-accent/5"
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/30 shrink-0"></span>
                    {cat}
                    <span class="ml-auto text-xs text-muted bg-surface px-2 py-0.5 rounded-full">{posts.filter(p => p.category === cat).length}</span>
                  </button>
                ))}
              </div>
            </div>

            <!-- Recent Posts -->
            <div class="bg-canvas rounded-2xl border border-hairline p-6">
              <h3 class="text-xs font-bold text-ink uppercase tracking-wider mb-4 flex items-center gap-2">
                <span class="w-1 h-3 bg-accent rounded-full"></span>Recent
              </h3>
              <div class="space-y-4">
                {posts.slice(0, 4).map((post) => (
                  <a href={`/blog/${post.slug}`} class="group flex gap-3 items-start">
                    <div class="w-12 h-12 rounded-xl overflow-hidden shrink-0 bg-surface">
                      <img src={post.image} alt="" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" loading="lazy" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-semibold text-ink line-clamp-2 group-hover:text-accent transition-colors leading-snug">{post.title}</p>
                      <p class="text-xs text-muted mt-0.5">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <!-- Newsletter -->
            <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-accent/10 via-accent/5 to-canvas border border-accent/20 p-6">
              <div class="absolute top-0 right-0 w-24 h-24 bg-accent/10 rounded-full -translate-y-1/2 translate-x-1/2 blur-2xl"></div>
              <div class="relative z-10">
                <h3 class="text-sm font-bold text-ink mb-1">Stay in the loop</h3>
                <p class="text-xs text-steel mb-4 leading-relaxed">Get our latest stories delivered to your inbox — no spam, just impact.</p>
                <form class="flex flex-col gap-2.5" action="/api/subscribe" method="POST">
                  <input type="email" name="email" placeholder="you@email.com" required aria-label="Email for newsletter" class="w-full px-3.5 py-2.5 text-sm bg-canvas border border-hairline rounded-xl text-ink placeholder:text-muted outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all dark:bg-[#1c1c1e] dark:border-[#2a2a2c] dark:text-[#e8e8ed] dark:placeholder:text-[#6e6e72]" />
                  <button type="submit" class="w-full px-4 py-2.5 text-sm font-semibold bg-primary text-on-primary rounded-xl hover:bg-charcoal transition-all duration-300 cursor-pointer active:scale-[0.98] shadow-sm dark:bg-white dark:text-[#0a0a0a] dark:hover:bg-[#e5e5e5]">Subscribe</button>
                </form>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ── NEWSLETTER CTA ── -->
    <section class="py-20 md:py-24 bg-surface relative overflow-hidden dark:bg-[#141416]">
      <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent pointer-events-none dark:from-accent/[0.015]"></div>
      <div class="max-w-2xl mx-auto text-center px-4 relative">
        <span class="inline-flex items-center gap-2 text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-4 dark:text-accent-soft">
          <span class="w-6 h-px bg-accent dark:bg-accent-soft"></span> Get Involved
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight mb-3 dark:text-[#e8e8ed]">Have a Story to Share?</h2>
        <p class="text-base text-steel max-w-lg mx-auto mb-8 leading-relaxed dark:text-[#a1a1a6]">We love featuring voices from our community. Pitch us your peace-building story and inspire others across Africa.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3 bg-primary text-on-primary font-semibold text-sm rounded-full hover:bg-charcoal transition-all duration-300 shadow-md hover:shadow-lg active:scale-[0.98] dark:bg-white dark:text-[#0a0a0a] dark:hover:bg-[#e5e5e5]">
          Submit Your Story
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  (function() {
    const grid = document.getElementById('blog-grid');
    const cards = document.querySelectorAll('.blog-card');
    const loadMoreBtn = document.getElementById('load-more');
    const pagination = document.getElementById('pagination');
    const pageNumbers = document.getElementById('page-numbers');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const totalPages = parseInt(pagination?.getAttribute('data-total') || '1');
    const gridStatus = document.getElementById('grid-status');

    // ── CATEGORY FILTERING ──
    let activeCategory = 'all';

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;
        activeCategory = cat;

        // Update button styles
        document.querySelectorAll('.filter-btn').forEach(b => {
          const isActive = b.dataset.category === cat;
          // Top bar buttons
          if (b.parentElement?.id === 'category-filter' || b.closest('#category-filter')) {
            b.className = `filter-btn whitespace-nowrap px-4 py-1.5 text-sm font-medium rounded-full border transition-all duration-200 cursor-pointer ${
              isActive
                ? 'bg-primary text-on-primary border-primary shadow-sm dark:bg-white dark:text-[#0a0a0a] dark:border-white'
                : 'bg-canvas text-steel border-hairline hover:border-accent hover:text-accent hover:bg-accent/5 dark:bg-[#1c1c1e] dark:text-[#c7c7cc] dark:border-[#2a2a2c] dark:hover:border-accent dark:hover:text-accent-soft dark:hover:bg-accent/5'
            }`;
          }
          // Sidebar buttons
          if (b.closest('aside')) {
            if (isActive) {
              b.classList.add('text-accent', 'bg-accent/5');
              b.classList.remove('text-steel');
              b.querySelector('span:first-child')?.classList.replace('bg-accent/30', 'bg-accent');
            } else {
              b.classList.remove('text-accent', 'bg-accent/5');
              b.classList.add('text-steel');
              b.querySelector('span:first-child')?.classList.replace('bg-accent', 'bg-accent/30');
            }
          }
        });

        // Show/hide cards
        cards.forEach(card => {
          const cardCat = card.dataset.category;
          if (cat === 'all' || cardCat === cat) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });

        // Reset pagination
        currentPage = 1;
        const visibleCards = [...cards].filter(c => c.style.display !== 'none');
        gridStatus.textContent = `Showing ${visibleCards.length} article${visibleCards.length !== 1 ? 's' : ''}`;

        // Show load more or pagination
        if (visibleCards.length <= perPage) {
          loadMoreBtn.style.display = 'none';
          pagination.style.display = 'none';
          // Show all visible
          visibleCards.forEach(c => c.style.display = '');
        } else {
          loadMoreBtn.style.display = '';
          pagination.style.display = 'none';
          // Show first page only
          showFilteredPage(1);
        }
      });
    });

    // ── LOAD MORE / PAGINATION LOGIC ──
    let currentPage = 1;
    let usingLoadMore = true;

    function getVisibleCards() {
      return [...cards].filter(c => c.style.display !== 'none');
    }

    function showFilteredPage(page) {
      const visible = getVisibleCards();
      const perPageActual = perPage;
      const start = (page - 1) * perPageActual;
      const end = start + perPageActual;

      visible.forEach((c, i) => {
        c.style.display = (i >= start && i < end) ? '' : 'none';
      });

      const totalVisible = visible.length;
      const showing = Math.min(end, totalVisible);
      gridStatus.textContent = `Showing ${showing} of ${totalVisible} article${totalVisible !== 1 ? 's' : ''}`;

      if (end >= totalVisible) {
        loadMoreBtn.textContent = 'All articles loaded';
        loadMoreBtn.disabled = true;
        loadMoreBtn.classList.add('opacity-50', 'cursor-not-allowed');
        loadMoreBtn.classList.remove('hover:border-accent', 'hover:text-accent', 'hover:bg-accent/5', 'cursor-pointer');
      } else {
        loadMoreBtn.textContent = `Load more (${totalVisible - showing} remaining)`;
        loadMoreBtn.disabled = false;
        loadMoreBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        loadMoreBtn.classList.add('hover:border-accent', 'hover:text-accent', 'hover:bg-accent/5', 'cursor-pointer');
      }
    }

    loadMoreBtn?.addEventListener('click', () => {
      const visible = getVisibleCards();
      const currentlyShowing = [...cards].filter(c => c.style.display !== 'none' && c.style.display !== '').length;
      // Count how many are actually displayed (not hidden by filter)
      const filtered = visible;
      const shown = filtered.length;
      const nextPage = Math.ceil(shown / perPage) + 1;
      const end = nextPage * perPage;

      filtered.forEach((c, i) => {
        c.style.display = (i < end) ? '' : 'none';
      });

      const totalVisible = filtered.length;
      const showing = Math.min(end, totalVisible);
      gridStatus.textContent = `Showing ${showing} of ${totalVisible} article${totalVisible !== 1 ? 's' : ''}`;

      if (end >= totalVisible) {
        loadMoreBtn.textContent = 'All articles loaded';
        loadMoreBtn.disabled = true;
        loadMoreBtn.classList.add('opacity-50', 'cursor-not-allowed');
        loadMoreBtn.classList.remove('hover:border-accent', 'hover:text-accent', 'hover:bg-accent/5', 'cursor-pointer');
      } else {
        loadMoreBtn.textContent = `Load more (${totalVisible - showing} remaining)`;
      }
    });

    // ── 3D TILT ON FEATURED CARD ──
    const featuredCard = document.querySelector('.tilt-card');
    if (featuredCard && window.matchMedia('(pointer: fine)').matches) {
      const sheen = featuredCard.querySelector('.tilt-sheen');
      featuredCard.addEventListener('mousemove', (e) => {
        const rect = featuredCard.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -4;
        const rotateY = ((x - centerX) / centerX) * 4;
        featuredCard.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.01,1.01,1.01)`;
        if (sheen) {
          sheen.style.setProperty('--sheen-x', `${(x / rect.width) * 100}%`);
          sheen.style.setProperty('--sheen-y', `${(y / rect.height) * 100}%`);
          sheen.style.opacity = '1';
        }
      });
      featuredCard.addEventListener('mouseleave', () => {
        featuredCard.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)';
        if (sheen) sheen.style.opacity = '0';
      });
    }

    // ── INIT ──
    // Show initial status
    const initialVisible = getVisibleCards();
    const showing = Math.min(perPage, initialVisible.length);
    gridStatus.textContent = `Showing ${showing} of ${initialVisible.length} article${initialVisible.length !== 1 ? 's' : ''}`;

    if (initialVisible.length <= perPage) {
      loadMoreBtn.style.display = 'none';
    }
  })();
</script>

<style is:global>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { scrollbar-width: none; }
</style>
