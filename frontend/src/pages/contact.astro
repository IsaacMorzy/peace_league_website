---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import EventMap from '../components/EventMap.astro';

const hqJson = JSON.stringify({
  lat: -1.2830,
  lng: 36.8218,
  venue: 'Kenda House',
  address: 'Tom Mboya Street',
  location: 'Nairobi, Kenya',
});
---

<Layout title="Contact" description="Have a question about Peace League Africa? Get in touch with our team. We respond within 24 hours. Email, phone, and online contact form available.">
  <Navigation />
  
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peaceleagueafrica.org" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://peaceleagueafrica.org/contact" }
      ]
    })} />
    <section class="hero-inner grain-overlay text-white py-4 lg:py-8">
      <!-- Ambient orbs -->
      <div class="orb-float orb-float--1" style="top:-100px;right:-100px;" aria-hidden="true"></div>
      <div class="orb-float orb-float--2" style="bottom:-80px;left:-80px;" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h1 class="animate-in fade-in slide-in-from-bottom-4 duration-700 text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.10] tracking-tight">Let's Talk Peace</h1>
        <p class="mt-4 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-150 text-lg text-on-dark-muted">Have a question, an idea, or a story to share? We're listening.</p>
      </div>
      <div class="geometric-shapes" aria-hidden="true">
        <span class="float-shape float-shape--a" style="width:160px;height:160px;top:0;left:5%;background:radial-gradient(circle,rgba(0,212,164,0.2),transparent 70%);"></span>
        <span class="float-shape float-shape--b" style="width:100px;height:100px;top:10%;right:8%;background:radial-gradient(circle,rgba(245,158,11,0.15),transparent 70%);"></span>
        <span class="float-shape--diamond float-shape--a" style="width:70px;height:70px;bottom:25%;left:12%;border:2px solid rgba(0,212,164,0.15);background:transparent;"></span>
        <span class="float-shape float-shape--c" style="width:250px;height:250px;bottom:-15%;right:-5%;background:radial-gradient(circle,rgba(0,212,164,0.06),transparent 70%);filter:blur(40px);"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <!-- Doves flying (natural swooping arcs) -->
        <span class="animate-dove-drift" style="left:18%;bottom:-20%;animation-delay:0.5s;font-size:1.125rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift--slow" style="left:55%;bottom:-25%;animation-delay:2s;font-size:1.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <span class="animate-dove-drift" style="left:82%;bottom:-15%;animation-delay:3.5s;font-size:1rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));">&#x1F54A;</span>
        <!-- Hearts pulsing -->
        <!-- Sparkle particles -->
        <span class="animate-particle" style="left:10%;bottom:5%;width:4px;height:4px;border-radius:50%;background:var(--color-accent);animation-delay:1s;"></span>
        <span class="animate-particle--fast" style="left:25%;bottom:10%;width:3px;height:3px;border-radius:50%;background:var(--color-accent-soft);animation-delay:0.3s;"></span>
        <span class="animate-particle" style="left:40%;bottom:8%;width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.4);animation-delay:2s;"></span>
        <span class="animate-particle--glow" style="left:60%;bottom:0;color:var(--color-accent);animation-delay:1.5s;font-size:1.2rem;">&#x2726;</span>
        <span class="animate-particle--fast" style="left:75%;bottom:15%;width:4px;height:4px;border-radius:50%;background:var(--color-accent-warm);animation-delay:2.5s;"></span>
        <span class="animate-particle" style="left:90%;bottom:5%;width:3px;height:3px;border-radius:50%;background:white;animation-delay:0.8s;opacity:0.3;"></span>
      </div>
    </section>

    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="flex items-center gap-2 mb-8 justify-center animate-in fade-in slide-in-from-bottom-4 duration-700">
          <div class="flex items-center gap-2">
            <div class="progress-step-circle active">1</div>
            <span class="progress-step-label active">Details</span>
          </div>
          <div class="progress-step-line active"></div>
          <div class="flex items-center gap-2">
            <div class="progress-step-circle">2</div>
            <span class="progress-step-label">Submit</span>
          </div>
          <div class="progress-step-line"></div>
          <div class="flex items-center gap-2">
            <div class="progress-step-circle">3</div>
            <span class="progress-step-label">Done</span>
          </div>
        </div>

        <div class="scroll-reveal animate-in fade-in slide-in-from-bottom-4 duration-700 grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
          <div class="lg:col-span-3 bg-canvas/80 backdrop-blur-xl rounded-2xl border border-hairline p-6 md:p-6 shadow-[0_8px_32px_rgba(0,0,0,0.06)]">
            <h2 class="text-2xl font-bold text-ink mb-6">Send Us a Message</h2>
            
            <form id="contact-form" class="space-y-5" novalidate>
              <div id="form-error" class="bg-red-50 text-red-700 p-3 rounded-md text-sm mb-4 hidden" role="alert"></div>
              <div id="form-success" class="bg-green-50 text-green-700 p-3 rounded-md text-sm mb-4 hidden" role="alert"></div>
              
              <div>
                <label for="name" class="block text-sm font-medium text-ink mb-1.5">Name *</label>
                <input type="text" id="name" name="name" required 
                  class="input-focus-ring w-full px-3 py-2.5 border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent" />
                <p id="name-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter your name.</p>
              </div>
              
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required 
                  class="input-focus-ring w-full px-3 py-2.5 border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent" />
                <p id="email-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter a valid email address.</p>
              </div>
              
              <div>
                <label for="phone" class="block text-sm font-medium text-ink mb-1.5">Phone</label>
                <input type="tel" id="phone" name="phone" 
                  class="input-focus-ring w-full px-3 py-2.5 border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent" />
              </div>
              
              <div>
                <label for="subject" class="block text-sm font-medium text-ink mb-1.5">Subject *</label>
                <input type="text" id="subject" name="subject" required 
                  class="input-focus-ring w-full px-3 py-2.5 border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent" />
                <p id="subject-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter a subject.</p>
              </div>
              
              <div>
                <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message *</label>
                <textarea id="message" name="message" rows="5" required 
                  class="input-focus-ring w-full px-3 py-2.5 border border-hairline rounded-md text-base text-ink focus:border-accent focus:ring-1 focus:ring-accent"></textarea>
                <p id="message-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Please enter your message.</p>
              </div>
              
              <div class="rounded-full bg-gradient-to-r from-accent via-accent-warm to-accent p-0.5">
                <button type="submit" id="submit-btn"
                  class="submit-btn w-full bg-primary text-on-dark py-2.5 rounded-full text-sm font-medium leading-[1.30] hover:bg-charcoal transition-colors disabled:bg-hairline disabled:text-muted disabled:cursor-not-allowed inline-flex items-center justify-center gap-2">
                Send Message
              </button>
              </div>
            </form>
          </div>
          
          <div class="lg:col-span-2 space-y-6">
            <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200">
              <h2 class="text-2xl font-bold text-ink mb-6">Contact Information</h2>
              
              <div class="space-y-6">
                <div class="bg-surface rounded-2xl p-5 border border-hairline transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
                  <h3 class="font-semibold text-ink">Email</h3>
                  <p class="text-steel text-sm mt-1">info@peaceleagueafrica.org</p>
                </div>
                
                <div class="bg-surface rounded-2xl p-5 border border-hairline transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
                  <h3 class="font-semibold text-ink">Phone</h3>
                  <p class="text-steel text-sm mt-1">+1 (555) 123-4567</p>
                </div>
                
                <div class="bg-surface rounded-2xl p-5 border border-hairline transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
                  <h3 class="font-semibold text-ink">Address</h3>
                  <p class="text-steel text-sm mt-1">
                    123 Peace Avenue<br />
                    Nairobi, Kenya<br />
                    Africa
                  </p>
                </div>
                
                <div class="bg-surface rounded-2xl p-5 border border-hairline transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
                  <h3 class="font-semibold text-ink">Follow Us</h3>
                  <div class="flex gap-4 mt-3">
                    <a href="https://twitter.com/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-1.5 bg-accent/10 text-accent-deep text-sm font-medium rounded-full hover:bg-accent/20 transition-colors min-h-[44px]">Twitter</a>
                    <a href="https://facebook.com/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-1.5 bg-accent/10 text-accent-deep text-sm font-medium rounded-full hover:bg-accent/20 transition-colors min-h-[44px]">Facebook</a>
                    <a href="https://linkedin.com/company/peaceleagueafrica" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-1.5 bg-accent/10 text-accent-deep text-sm font-medium rounded-full hover:bg-accent/20 transition-colors min-h-[44px]">LinkedIn</a>
                  </div>
                </div>
              </div>
            </div>

            <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-300 bg-surface rounded-2xl border border-hairline p-6 text-center">
              <svg viewBox="0 0 200 140" fill="none" stroke="currentColor" class="w-full h-auto text-accent/60 max-w-[160px] mx-auto ring-glow-svg">
                <defs>
                  <filter id="ring-glow">
                    <feGaussianBlur stdDeviation="2.5" result="blur" />
                    <feMerge>
                      <feMergeNode in="blur" />
                      <feMergeNode in="SourceGraphic" />
                    </feMerge>
                  </filter>
                </defs>
                <circle cx="100" cy="70" r="55" stroke-width="1" stroke-dasharray="3 3" opacity="0.4" filter="url(#ring-glow)" class="animate-ring-glow"/>
                <circle cx="100" cy="70" r="38" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.5"/>
                <g opacity="0.25">
                  <line x1="100" y1="15" x2="100" y2="125" stroke-width="0.5"/>
                  <line x1="45" y1="70" x2="155" y2="70" stroke-width="0.5"/>
                  <line x1="61" y1="31" x2="139" y2="109" stroke-width="0.5"/>
                  <line x1="139" y1="31" x2="61" y2="109" stroke-width="0.5"/>
                </g>
                <circle cx="100" cy="70" r="5" fill="currentColor" opacity="0.8"/>
                <circle cx="100" cy="18" r="3.5" fill="currentColor" opacity="0.4"/>
                <circle cx="152" cy="70" r="3.5" fill="currentColor" opacity="0.4"/>
                <circle cx="100" cy="122" r="3.5" fill="currentColor" opacity="0.4"/>
                <circle cx="48" cy="70" r="3.5" fill="currentColor" opacity="0.4"/>
                <circle cx="68" cy="38" r="2.5" fill="currentColor" opacity="0.3"/>
                <circle cx="132" cy="38" r="2.5" fill="currentColor" opacity="0.3"/>
                <circle cx="68" cy="102" r="2.5" fill="currentColor" opacity="0.3"/>
                <circle cx="132" cy="102" r="2.5" fill="currentColor" opacity="0.3"/>
              </svg>
              <p class="text-xs text-steel mt-3">We respond within 24 hours</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         INTERACTIVE MAP — Peace League Africa HQ
         ════════════════════════════════════════════════════════ -->
    <section class="py-20 lg:py-28 bg-canvas">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-reveal="up">
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent uppercase tracking-wider mb-4">Find Us</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-ink tracking-tight mb-4">Visit Our Headquarters</h2>
          <p class="text-lg text-steel max-w-2xl mx-auto">We're based at Kenda House in Nairobi, Kenya — the heart of East Africa. Drop by, reach out, or find our field offices across the continent.</p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8 items-start">
          <!-- Map -->
          <div class="lg:col-span-2" data-reveal="left">
            <EventMap hqJson={hqJson} mode="hq" showLegend={false} showShareButton={true} />
          </div>

          <!-- Info cards -->
          <div class="space-y-4" data-reveal="right">
            <div class="bg-canvas rounded-2xl border border-hairline p-5 shadow-sm">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink text-sm">Head Office</h3>
                  <p class="text-sm text-steel mt-0.5">Kenda House, Tom Mboya Street<br/>Nairobi, Kenya<br/>East Africa</p>
                </div>
              </div>
            </div>

            <div class="bg-canvas rounded-2xl border border-hairline p-5 shadow-sm">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-accent-warm/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-accent-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink text-sm">Phone</h3>
                  <p class="text-sm text-steel mt-0.5">+254 712 345 678<br/>+1 (555) 123-4567</p>
                </div>
              </div>
            </div>

            <div class="bg-canvas rounded-2xl border border-hairline p-5 shadow-sm">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-ink text-sm">Email</h3>
                  <p class="text-sm text-steel mt-0.5">info@peaceleagueafrica.org<br/>hello@peaceleagueafrica.org</p>
                </div>
              </div>
            </div>

            <div class="bg-accent/5 rounded-2xl border border-accent/10 p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
                <span class="text-xs font-semibold text-accent uppercase tracking-wider">Field Offices</span>
              </div>
              <p class="text-sm text-steel leading-relaxed">We also have field offices in <strong class="text-ink">Kampala</strong>, <strong class="text-ink">Kigali</strong>, <strong class="text-ink">Addis Ababa</strong>, and <strong class="text-ink">Juba</strong>. Reach out to our main line to connect with any location.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="py-10 bg-surface border-t border-hairline">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm text-steel mb-4">You might also be interested in</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/faq" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">FAQ</a>
          <a href="/about" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">About Us</a>
          <a href="/team" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Our Team</a>
          <a href="/donate" class="inline-flex items-center px-5 py-2.5 rounded-full border border-hairline text-sm text-steel hover:text-ink hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">Donate</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { submitContact } from '../lib/api.js';

  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const originalBtnHtml = submitBtn.innerHTML;
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function showFieldError(id) {
    const field = document.getElementById(id);
    const errEl = document.getElementById(id + '-error');
    if (field) field.setAttribute('aria-invalid', 'true');
    if (errEl) errEl.classList.remove('hidden');
  }

  function clearFieldError(id) {
    const field = document.getElementById(id);
    const errEl = document.getElementById(id + '-error');
    if (field) field.removeAttribute('aria-invalid');
    if (errEl) errEl.classList.add('hidden');
  }

  function clearAllErrors() {
    formError.classList.add('hidden');
    formError.textContent = '';
    formSuccess.classList.add('hidden');
    formSuccess.textContent = '';
    ['name', 'email', 'subject', 'message'].forEach(clearFieldError);
  }

  ['name', 'email', 'subject', 'message'].forEach(id => {
    document.getElementById(id).addEventListener('input', () => clearFieldError(id));
  });

  function validate() {
    let valid = true;
    clearAllErrors();
    const errors = [];

    const name = document.getElementById('name').value.trim();
    if (!name) {
      showFieldError('name');
      errors.push('Please enter your name.');
      valid = false;
    }

    const email = document.getElementById('email').value.trim();
    if (!email) {
      showFieldError('email');
      document.getElementById('email-error').textContent = 'Please enter your email address.';
      errors.push('Please enter your email address.');
      valid = false;
    } else if (!EMAIL_RE.test(email)) {
      showFieldError('email');
      document.getElementById('email-error').textContent = 'Please enter a valid email address.';
      errors.push('Please enter a valid email address.');
      valid = false;
    }

    const subject = document.getElementById('subject').value.trim();
    if (!subject) {
      showFieldError('subject');
      errors.push('Please enter a subject.');
      valid = false;
    }

    const message = document.getElementById('message').value.trim();
    if (!message) {
      showFieldError('message');
      errors.push('Please enter your message.');
      valid = false;
    }

    if (!valid) {
      formError.textContent = errors.join(' ');
      formError.classList.remove('hidden');
      formError.setAttribute('tabindex', '-1');
      formError.focus();
    }

    return valid;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!validate()) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner"></span> Sending...';

    try {
      const response = await submitContact(data);

      if (response.status === 'success') {
        formSuccess.textContent = 'Thank you for reaching out! A member of our team will respond within 24 hours.';
        formSuccess.classList.remove('hidden');
        setTimeout(() => { formSuccess.classList.add('hidden'); }, 8000);
        submitBtn.innerHTML = '<span class="success-checkmark">\u2713</span> Sent!';
        window.createConfetti(submitBtn);
        form.reset();
        setTimeout(() => {
          submitBtn.innerHTML = originalBtnHtml;
          submitBtn.disabled = false;
        }, 2000);
      } else {
        throw new Error(response.message || 'Failed to send message');
      }
    } catch (error) {
      formError.textContent = 'Error: ' + error.message + '. Please try again.';
      formError.classList.remove('hidden');
      submitBtn.innerHTML = originalBtnHtml;
      submitBtn.disabled = false;
    }
  });
</script>


</Layout>
