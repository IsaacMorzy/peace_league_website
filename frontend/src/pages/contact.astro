---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact">
  <Navigation />
  
  <main>
    <section class="bg-[#1a3d4a] text-white py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-5xl font-semibold leading-[1.10] tracking-tight">Get in Touch</h1>
        <p class="mt-4 text-lg text-gray-300">We would love to hear from you</p>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Send us a message</h2>
            
            <form id="contact-form" class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-900 mb-1.5">Name *</label>
                <input type="text" id="name" name="name" required 
                  class="w-full px-3 py-[10px] border border-gray-200 rounded-md text-[16px] text-gray-900 focus:border-[#00d4a4] focus:ring-1 focus:ring-[#00d4a4] focus:outline-none" />
              </div>
              
              <div>
                <label for="email" class="block text-sm font-medium text-gray-900 mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required 
                  class="w-full px-3 py-[10px] border border-gray-200 rounded-md text-[16px] text-gray-900 focus:border-[#00d4a4] focus:ring-1 focus:ring-[#00d4a4] focus:outline-none" />
              </div>
              
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-900 mb-1.5">Phone</label>
                <input type="tel" id="phone" name="phone" 
                  class="w-full px-3 py-[10px] border border-gray-200 rounded-md text-[16px] text-gray-900 focus:border-[#00d4a4] focus:ring-1 focus:ring-[#00d4a4] focus:outline-none" />
              </div>
              
              <div>
                <label for="subject" class="block text-sm font-medium text-gray-900 mb-1.5">Subject *</label>
                <input type="text" id="subject" name="subject" required 
                  class="w-full px-3 py-[10px] border border-gray-200 rounded-md text-[16px] text-gray-900 focus:border-[#00d4a4] focus:ring-1 focus:ring-[#00d4a4] focus:outline-none" />
              </div>
              
              <div>
                <label for="message" class="block text-sm font-medium text-gray-900 mb-1.5">Message *</label>
                <textarea id="message" name="message" rows="5" required 
                  class="w-full px-3 py-[10px] border border-gray-200 rounded-md text-[16px] text-gray-900 focus:border-[#00d4a4] focus:ring-1 focus:ring-[#00d4a4] focus:outline-none"></textarea>
              </div>
              
              <div id="form-message" class="hidden"></div>
              
              <button type="submit" id="submit-btn"
                class="w-full bg-[#0a0a0a] text-white py-[10px] rounded-full text-sm font-medium leading-[1.30] hover:bg-[#1c1c1e] transition-colors disabled:bg-gray-200 disabled:text-gray-400 disabled:cursor-not-allowed">
                Send Message
              </button>
            </form>
          </div>
          
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Contact Information</h2>
            
            <div class="space-y-6">
              <div>
                <h3 class="font-semibold text-gray-900">Email</h3>
                <p class="text-gray-600 text-sm">info@peaceleagueafrica.org</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-900">Phone</h3>
                <p class="text-gray-600 text-sm">+1 (555) 123-4567</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-900">Address</h3>
                <p class="text-gray-600 text-sm">
                  123 Peace Avenue<br />
                  Nairobi, Kenya<br />
                  Africa
                </p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-900">Follow Us</h3>
                <div class="flex gap-4 mt-2">
                  <a href="#" class="text-[#00b48a] hover:text-[#00d4a4] text-sm font-medium">Twitter</a>
                  <a href="#" class="text-[#00b48a] hover:text-[#00d4a4] text-sm font-medium">Facebook</a>
                  <a href="#" class="text-[#00b48a] hover:text-[#00d4a4] text-sm font-medium">LinkedIn</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { submitContact } from '../lib/api.js';

  const form = document.getElementById('contact-form');
  const messageDiv = document.getElementById('form-message');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    messageDiv.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    
    try {
      const response = await submitContact(data);
      
      if (response.status === 'success') {
        messageDiv.className = 'p-4 bg-green-100 text-green-800 rounded-lg';
        messageDiv.textContent = 'Thank you for your message! We will get back to you soon.';
        form.reset();
      } else {
        throw new Error(response.message || 'Failed to send message');
      }
    } catch (error) {
      messageDiv.className = 'p-4 bg-red-100 text-red-800 rounded-lg';
      messageDiv.textContent = 'Error: ' + error.message + '. Please try again.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
      messageDiv.classList.remove('hidden');
    }
  });
</script>
